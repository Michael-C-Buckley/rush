{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "fmt",
    "description": "format plain text",
    "options": [
      {
        "short": "c",
        "inherit": false,
        "description": "center text line by line"
      },
      {
        "short": "m",
        "inherit": false,
        "description": "format mail header lines"
      },
      {
        "short": "n",
        "inherit": false,
        "description": "format lines beginning with a dot"
      },
      {
        "short": "p",
        "inherit": false,
        "description": "allow indented paragraphs"
      },
      {
        "short": "s",
        "inherit": false,
        "description": "collapse whitespace inside lines"
      },
      {
        "short": "d",
        "inherit": false,
        "value": {
          "name": "chars",
          "provider": {
            "values": [
              ".",
              "?",
              "!"
            ]
          }
        },
        "description": "set sentence-ending characters"
      },
      {
        "short": "l",
        "inherit": false,
        "value": {
          "name": "number",
          "provider": {
            "values": [
              "8"
            ]
          }
        },
        "description": "replace leading spaces with tabs"
      },
      {
        "short": "t",
        "inherit": false,
        "value": {
          "name": "number",
          "provider": {
            "values": [
              "8"
            ]
          }
        },
        "description": "set input tab width"
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "file",
          "description": "files to format",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
