{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "cut",
    "description": "cut selected portions of file lines",
    "options": [
      {
        "short": "b",
        "description": "select byte positions",
        "inherit": false,
        "value": {
          "name": "list",
          "description": "byte positions"
        },
        "exclusiveGroup": "cut.selection"
      },
      {
        "short": "c",
        "description": "select character positions",
        "inherit": false,
        "value": {
          "name": "list",
          "description": "character positions"
        },
        "exclusiveGroup": "cut.selection"
      },
      {
        "short": "f",
        "description": "select field positions",
        "inherit": false,
        "value": {
          "name": "list",
          "description": "field positions"
        },
        "exclusiveGroup": "cut.selection"
      },
      {
        "short": "n",
        "description": "do not split multi-byte characters",
        "inherit": false
      },
      {
        "short": "d",
        "description": "set the field delimiter",
        "inherit": false,
        "value": {
          "name": "delim",
          "description": "field delimiter",
          "required": false,
          "style": "optional"
        }
      },
      {
        "short": "s",
        "description": "suppress lines without delimiters",
        "inherit": false
      },
      {
        "short": "w",
        "description": "use whitespace as the delimiter",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "file",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
