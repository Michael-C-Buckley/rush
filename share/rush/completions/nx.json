          {
            "description": "show help",
            "inherit": false,
            "long": "help"
          },
          {
            "description": "show version",
            "inherit": false,
            "long": "version"
          }
        ]
      },
      {
        "name": "generate",
        "description": "runs a generator that creates and/or modifies files based on a generator from a collection",
