          "states": [
            {
              "name": "collection:generator",
              "index": 0,
              "provider": "nx.generators"
            }
          ]
        },
        "options": [
          {
            "description": "use default answers",
            "inherit": false,
            "long": "defaults"
          },
          {
            "description": "preview changes",
            "inherit": false,
            "long": "dryRun"
          },
          {
            "description": "force changes",
            "inherit": false,
            "long": "force"
          },
          {
            "description": "show help",
            "inherit": false,
            "long": "help"
          },
          {
