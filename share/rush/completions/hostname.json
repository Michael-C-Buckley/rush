{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "hostname",
    "description": "set or print the current host name",
    "options": [
      {
        "short": "f",
        "description": "include domain information",
        "inherit": false
      },
      {
        "short": "s",
        "description": "trim domain information",
        "inherit": false
      },
      {
        "short": "d",
        "description": "only print domain information",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "hostname",
          "description": "host name to set",
          "index": 0
        }
      ]
    }
  }
}
