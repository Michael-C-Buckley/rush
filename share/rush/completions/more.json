{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "more",
    "description": "page through text files",
    "options": [
      {
        "short": "d",
        "long": "silent",
        "description": "show prompts instead of ringing the bell",
        "inherit": false
      },
      {
        "short": "l",
        "long": "logical",
        "description": "do not pause after form feed lines",
        "inherit": false
      },
      {
        "short": "f",
        "long": "no-pause",
        "description": "count logical lines instead of screen lines",
        "inherit": false
      },
      {
        "short": "p",
        "long": "print-over",
        "description": "clear the screen before displaying text",
        "inherit": false
      },
      {
        "short": "c",
        "long": "clean-print",
        "description": "paint screens from the top",
        "inherit": false
      },
      {
        "short": "s",
        "long": "squeeze",
        "description": "squeeze multiple blank lines into one",
        "inherit": false
      },
      {
        "short": "u",
        "long": "plain",
        "description": "accept ignored compatibility option",
        "inherit": false
      },
      {
        "short": "n",
        "long": "lines",
        "description": "set lines per screenful",
        "inherit": false,
        "value": {
          "name": "count"
        }
      },
      {
        "long": "help",
        "description": "show help",
        "inherit": false
      },
      {
        "short": "V",
        "long": "version",
        "description": "show version information",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "file",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
