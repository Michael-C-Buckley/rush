{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "tee",
    "description": "duplicate standard input",
    "options": [
      {
        "short": "a",
        "description": "append to files",
        "inherit": false
      },
      {
        "short": "i",
        "description": "ignore SIGINT",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "file",
          "description": "output file",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
