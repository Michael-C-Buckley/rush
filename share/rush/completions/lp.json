{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "lp",
    "description": "print files",
    "options": [
      {
        "short": "E",
        "description": "force encryption when connecting to the server",
        "inherit": false
      },
      {
        "short": "U",
        "description": "specifies the username to use when connecting to the server",
        "inherit": false,
        "value": {
          "name": "Username"
        }
      },
      {
        "short": "c",
        "description": "this option is provided for backwards-compatibility only. On systems that support it, this option forces the print file to be copied to the spool directory befo",
        "inherit": false
      },
      {
        "short": "d",
        "description": "print files to the named printer",
        "inherit": false,
        "value": {
          "name": "Destination-printer-name"
        }
      },
      {
        "short": "h",
        "description": "chooses an alternate server",
        "inherit": false,
        "value": {
          "name": "hostname[:port]"
        }
      },
      {
        "short": "i",
        "description": "specifies an existing job to modify",
        "inherit": false,
        "value": {
          "name": "job-id"
        }
      },
      {
        "short": "m",
        "description": "sends an email when the job is completed",
        "inherit": false
      },
      {
        "short": "n",
        "description": "sets the number of copies to print",
        "inherit": false,
        "value": {
          "name": "copies"
        }
      },
      {
        "short": "q",
        "description": "sets the job priority from 1 (lowest) to 100 (highest). The default priority is 50",
        "inherit": false,
        "value": {
          "name": "priority",
          "provider": {
            "values": [
              "1",
              "2",
              "3",
              "4",
              "5",
