              "97",
              "98",
              "99",
              "100"
            ]
          }
        }
      },
      {
        "short": "s",
        "description": "do not report the resulting job IDs (silent mode)",
        "inherit": false
      },
      {
        "short": "t",
        "description": "sets the job name",
        "inherit": false,
        "value": {
          "name": "name"
        }
      },
      {
        "short": "H",
        "description": "specifies when the job should be printed. A value of immediate will print the file immediately, a value of hold will hold the job indefinitely, and a UTC time v",
        "inherit": false,
        "value": {
          "name": "when",
          "provider": {
            "values": [
              "hold",
              "immediate",
              "restart",
              "resume"
            ]
          }
        }
      },
      {
        "short": "P",
        "description": "specifies which pages to print in the document. The list can contain a list of numbers and ranges (#-#) separated by commas, e.g., \"1,3-5,16\". The page numbers",
        "inherit": false,
        "value": {
          "name": "pages"
        }
      },
      {
        "short": "o",
        "description": "sets one or more job options",
        "inherit": false,
        "value": {
          "name": "name=value"
        }
      },
      {
        "long": "help",
        "description": "show help",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "file",
          "description": "file to print",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
