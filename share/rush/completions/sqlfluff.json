{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "sqlfluff",
    "description": "lint and format SQL with SQLFluff",
    "options": [
      {
        "long": "version",
        "description": "show the version and exit",
        "inherit": true
      },
      {
        "long": "help",
        "short": "h",
        "description": "show help for sqlfluff",
        "inherit": true
      }
    ],
    "subcommands": [
      {
        "name": "lint",
        "description": "lint SQL files via passing a list of files or using stdin",
        "options": [
          {
            "long": "nocolor",
            "short": "n",
            "description": "no color - output will be without ANSI color codes",
            "inherit": false
          },
          {
            "long": "ignore",
            "short": "i",
            "description": "ignore particular families of errors so that they don\u2019t cause a failed run. -\u2013ignore behaves somewhat like noqa comments, except it applies globally",
            "inherit": false,
            "value": {
              "name": "error"
            }
          },
          {
            "long": "verbose",
            "short": "v",
            "description": "verbosity, how detailed should the output be. This is stackable, so -vv is more verbose than -v. For the most verbose option try -vvvv or -vvvvv",
            "inherit": false
          },
          {
            "long": "exclude-rules",
            "short": "e",
            "description": "exclude specific rules. This could either be the allowlist, or the general set if there is no specific allowlist",
            "inherit": false,
            "value": {
              "name": "exclude_rules"
            }
          },
          {
            "long": "rules",
            "short": "r",
            "description": "narrow the search to only specific rules",
            "inherit": false,
            "value": {
              "name": "rules"
            }
          },
          {
            "long": "templater",
            "short": "t",
            "description": "the templater to use (default=jinja)",
            "inherit": false,
            "value": {
              "name": "templater",
              "description": "name of templater to use, eg. raw",
              "provider": {
                "values": [
                  "raw",
                  "jinja",
                  "python",
                  "placeholders"
                ]
              }
            }
          },
          {
            "long": "dialect",
            "short": "d",
            "description": "the dialect of SQL to lint",
            "inherit": false,
            "value": {
              "name": "dialect",
              "description": "name of dialect, eg. ANSI",
              "provider": {
                "values": [
                  "ansi",
                  "bigquery",
                  "exasol",
                  "hive",
                  "mysql",
                  "oracle",
                  "postgres",
                  "redshift",
                  "snowflake",
                  "spark3",
                  "sqllite",
                  "teradata",
                  "tsql"
                ]
              }
            }
          },
          {
            "long": "format",
            "short": "f",
            "description": "what format to return the lint result in (default=human)",
            "inherit": false,
            "value": {
              "name": "format",
              "provider": {
                "values": [
                  "human",
                  "json",
                  "yaml",
                  "github-annotation",
                  "github-annotation-native"
                ]
              }
            }
          },
          {
            "long": "processes",
            "short": "p",
            "description": "the number of parallel processes to run. Positive numbers work as expected. Zero and negative numbers will work as number_of_cpus - number. e.g -1 means all cpu",
            "inherit": false,
            "value": {
              "name": "processes"
            }
          },
          {
            "long": "disable-noqa",
            "description": "set this flag to ignore inline noqa comments",
            "inherit": false
          },
          {
            "long": "bench",
            "description": "set this flag to engage the benchmarking tool output",
            "inherit": false
          },
          {
            "long": "logger",
            "description": "choose to limit the logging to one of the loggers",
            "inherit": false,
            "value": {
              "name": "logger",
              "description": "name of logger to limit to, eg. templater",
              "provider": {
                "values": [
                  "templater",
                  "lexer",
                  "parser",
                  "linter",
                  "rules"
                ]
              }
            }
          },
          {
            "long": "encoding",
            "description": "specify encoding to use when reading and writing files. Defaults to autodetect",
            "inherit": false,
            "value": {
              "name": "encoding"
            }
          },
          {
            "long": "ignore-local-config",
            "description": "ignore config files in default search path locations. This option allows the user to lint with the default config or can be used in conjunction with \u2013config to",
            "inherit": false
          },
          {
            "long": "config",
            "description": "include additional config file. By default the config is generated from the standard configuration files described in the documentation. This argument allows yo",
            "inherit": false,
            "value": {
              "name": "extra_config_path",
              "provider": "builtin.files"
            }
          },
          {
            "long": "write-output",
            "description": "optionally provide a filename to write the results to, mostly used in tandem with \u2013format. NB: Setting an output file re-enables normal stdout logging",
            "inherit": false,
            "value": {
              "name": "write_output",
              "provider": "builtin.files"
            }
          },
          {
            "long": "annotation-level",
            "description": "when format is set to github-annotation or github-annotation-native, default annotation level (default=notice). failure and error are equivalent",
            "inherit": false,
            "value": {
              "name": "annotation-level",
              "description": "level of annotation, eg. notice",
              "provider": {
                "values": [
                  "notice",
                  "warning",
                  "failure",
                  "error"
                ]
              }
            }
          },
          {
            "long": "disregard-sqlfluffignores",
            "description": "perform the operation regardless of .sqlfluffignore configurations",
            "inherit": false
          },
          {
            "long": "disable-progress-bar",
            "description": "disables progress bars",
            "inherit": false
          },
          {
            "long": "nofail",
            "description": "if set, the exit code will always be zero, regardless of violations found. This is potentially useful during rollout",
            "inherit": false
          },
          {
            "long": "help",
            "short": "h",
            "description": "show help for sqlfluff",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "value",
              "provider": "builtin.files",
              "index": 0,
              "repeatable": true
            }
          ]
        }
      },
