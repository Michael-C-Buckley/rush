            "inherit": false
          },
          {
            "long": "no-stack",
            "description": "do not stack the environment. Overrides 'auto_stack' setting",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "value",
              "index": 0,
              "provider": "conda.envs"
            }
          ]
        }
      },
      {
        "name": "deactivate",
        "description": "deactivate an environment"
