{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "pyenv",
    "description": "manage Python versions with pyenv",
    "options": [
      {
        "short": "h",
        "long": "help",
        "description": "output usage information",
        "inherit": false
      }
    ],
    "subcommands": [
      {
        "name": "commands",
        "description": "lists all available pyenv commands"
      },
      {
        "name": "local",
        "description": "sets a local application-specific Python version",
        "options": [
          {
            "long": "unset",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "python-version",
              "index": 0,
              "repeatable": true,
              "provider": "pyenv.installed-versions"
            }
          ]
        }
      },
      {
        "name": "global",
        "description": "sets the global version of Python to be used in all shells",
        "arguments": {
          "states": [
            {
              "name": "python-version",
              "index": 0,
              "provider": "pyenv.installed-versions"
            }
          ]
        }
      },
      {
        "name": "shell",
        "description": "sets a shell-specific Python version",
        "options": [
          {
            "long": "unset",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "python-version",
              "index": 0,
              "provider": "pyenv.installed-versions"
            }
          ]
        }
      },
      {
        "name": "install",
        "description": "install a Python version",
        "options": [
          {
            "short": "l",
            "long": "list",
            "description": "list all available versions",
            "inherit": false
          },
          {
            "short": "f",
            "long": "force",
            "description": "install even if the version appears to be installed already",
            "inherit": false
          },
          {
            "short": "s",
            "long": "skip-existing",
            "description": "skip the installation if the version appears to be installed already",
            "inherit": false
          },
          {
            "short": "k",
            "long": "keep",
            "description": "keep source tree in $PYENV_BUILD_ROOT after installation",
            "inherit": false
          },
          {
            "short": "v",
            "long": "verbose",
            "description": "verbose mode: print compilation status to stdout",
            "inherit": false
          },
          {
            "short": "p",
            "long": "patch",
            "description": "apply a patch from stdin before building",
            "inherit": false
          },
          {
            "short": "g",
            "long": "debug",
            "description": "build a debug version",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "python-version",
              "index": 0,
              "provider": "pyenv.installable-versions"
            }
          ]
        }
      },
      {
        "name": "uninstall",
        "description": "uninstall a Python version",
        "options": [
          {
            "short": "f",
            "long": "force",
            "description": "attempt to remove the specified version without prompting for confirmation",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "version",
              "index": 0,
              "provider": "pyenv.installed-versions"
            }
          ]
        }
      },
      {
        "name": "rehash",
        "description": "rebuild pyenv shims"
      },
      {
        "name": "version",
        "description": "displays the currently active Python version, along with information on how it was set"
      },
      {
        "name": "versions",
        "description": "lists all Python versions known to pyenv, and shows an asterisk next to the currently active version",
        "options": [
          {
            "long": "bare",
            "description": "print only the version names, one per line",
            "inherit": false
          },
          {
            "long": "skip-aliases",
            "description": "skip printing aliases",
            "inherit": false
          }
        ]
      },
      {
        "name": "which",
        "description": "displays the full path to the executable that pyenv will invoke when you run the given command",
        "arguments": {
          "states": [
            {
              "name": "command",
              "index": 0,
              "provider": "builtin.executables"
            }
          ]
        }
      },
      {
        "name": "whence",
        "description": "lists all Python versions with the given command installed",
        "arguments": {
          "states": [
            {
              "name": "command",
              "index": 0,
              "provider": "builtin.executables"
            }
          ]
        }
      }
    ],
    "providers": {
      "pyenv.installed-versions": {
        "function": "__rush_complete_pyenv_installed_versions"
      },
      "pyenv.installable-versions": {
        "function": "__rush_complete_pyenv_installable_versions"
      },
      "builtin.executables": {
        "builtin": "executables"
      }
    }
  }
}
