{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "meroxa",
    "description": "manage Meroxa resources",
    "options": [
      {
        "long": "api-url",
        "description": "aPI url",
        "inherit": true,
        "hidden": true,
        "value": {
          "name": "api-url"
        }
      },
      {
        "long": "cli-config-file",
        "description": "meroxa configuration file",
        "inherit": true,
        "value": {
          "name": "cli-config-file",
          "provider": "builtin.files"
        }
      },
      {
        "long": "debug",
        "description": "display any debugging information",
        "inherit": true
      },
      {
        "long": "json",
        "description": "output json",
        "inherit": true
      },
      {
        "long": "timeout",
        "description": "set the duration of the client timeout in seconds",
        "inherit": true,
        "value": {
          "name": "timeout"
        }
      },
      {
        "long": "help",
        "short": "h",
        "description": "display help",
        "inherit": true
      }
