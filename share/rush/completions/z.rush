__rush_complete_z_directories() {
    if [ "$rush_completion_options_terminated" = true ]; then
        rush_complete directories --append-slash
        return
    fi

    case $rush_completion_prefix in
        */*) rush_complete directories --append-slash ;;
        *)
            if [ "$rush_completion_argument_index" -eq 0 ]; then
                rush_complete directories --append-slash
            fi
            rush_complete history-directories
            ;;
    esac
}
