{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "supabase",
    "description": "manage Supabase projects",
    "options": [
      {
        "long": "debug",
        "description": "output debug logs",
        "inherit": true
      },
      {
        "long": "help",
        "short": "h",
        "description": "show help",
        "inherit": true
      }
    ],
    "subcommands": [
      {
        "name": "completion",
        "description": "generate shell completions",
        "subcommands": [
          {
            "name": "bash",
            "description": "generate bash completions",
            "options": [
              {
                "long": "no-descriptions",
                "description": "disable completion descriptions",
                "inherit": false
              }
            ]
          },
          {
            "name": "fish",
            "description": "generate fish completions",
            "options": [
              {
                "long": "no-descriptions",
                "description": "disable completion descriptions",
                "inherit": false
              }
            ]
          },
          {
            "name": "powershell",
            "description": "generate PowerShell completions",
            "options": [
              {
                "long": "no-descriptions",
                "description": "disable completion descriptions",
                "inherit": false
              }
            ]
          },
          {
            "name": "zsh",
            "description": "generate zsh completions",
            "options": [
              {
                "long": "no-descriptions",
                "description": "disable completion descriptions",
                "inherit": false
              }
            ]
          }
        ]
      },
      {
        "name": "db",
        "description": "manage local Postgres databases",
        "subcommands": [
          {
            "name": "branch",
            "description": "manage local database branches",
            "subcommands": [
              {
                "name": "create",
                "description": "create a branch"
              },
              {
                "name": "delete",
                "description": "delete a branch"
              },
              {
                "name": "list",
                "description": "list branches"
              },
              {
                "name": "switch",
                "description": "switch the active branch"
              }
            ]
          },
          {
            "name": "diff",
            "description": "diffs the local database for schema changes",
            "options": [
              {
                "long": "file",
                "short": "f",
                "description": "saves schema diff to a file",
                "inherit": false,
                "value": {
                  "name": "file",
                  "provider": "builtin.files"
                }
              },
              {
                "long": "schema",
                "short": "s",
                "description": "list of schema to include",
                "repeatable": true,
                "inherit": false,
                "value": {
                  "name": "schema"
                }
              },
              {
                "long": "use-migra",
                "description": "use migra to generate schema diff",
                "inherit": false
              }
            ]
          },
          {
            "name": "dump",
            "description": "dumps data or schemas from the remote database",
            "options": [
              {
                "long": "data-only",
                "description": "dumps only data records",
                "inherit": false
              },
              {
                "long": "db-url",
                "description": "dumps from the database specified by the connection string (must be percent-encoded)",
                "inherit": false,
                "value": {
                  "name": "string"
                }
              },
              {
                "long": "dry-run",
                "description": "prints the pg_dump script that would be executed",
                "inherit": false
              },
              {
                "long": "file",
                "short": "f",
                "description": "file path to save the dumped contents",
                "inherit": false,
                "value": {
                  "name": "string",
                  "provider": "builtin.files"
                }
              },
              {
                "short": "h",
                "long": "help",
                "description": "help for dump",
                "inherit": false
              },
              {
                "long": "keep-comments",
                "description": "keeps commented lines from pg_dump output",
                "inherit": false
              },
              {
                "long": "linked",
                "description": "dumps from the linked project. (default true)",
                "inherit": false
              },
              {
                "long": "local",
                "description": "dumps from the local database",
                "inherit": false
              },
              {
                "long": "password",
                "short": "p",
                "description": "set the remote database password",
                "inherit": false,
                "value": {
                  "name": "string"
                }
              },
              {
                "long": "role-only",
                "description": "dumps only cluster roles",
                "inherit": false
              },
              {
                "long": "schema",
                "short": "s",
                "description": "comma separated list of schema to include. (default all)",
                "inherit": false,
                "value": {
                  "name": "string"
                }
              },
              {
                "long": "use-copy",
                "description": "uses copy statements in place of inserts",
                "inherit": false
              }
            ]
          },
          {
            "name": "lint",
            "description": "checks local database for typing error",
            "options": [
              {
                "long": "level",
                "description": "error level to emit",
                "inherit": false,
                "value": {
                  "name": "level"
                }
              },
              {
                "long": "schema",
                "short": "s",
                "description": "list of schema to include",
                "repeatable": true,
                "inherit": false,
                "value": {
                  "name": "schema"
                }
              }
            ]
          },
          {
            "name": "pull",
            "description": "pull schema from the remote database"
          },
          {
            "name": "push",
            "description": "push new migrations to the remote database",
            "options": [
              {
                "long": "dry-run",
                "description": "print the migrations that would be applied, but don't actually apply them",
                "inherit": false
              },
              {
                "long": "password",
                "short": "p",
                "description": "set the remote database password",
                "inherit": false,
                "value": {
                  "name": "password"
                }
              }
            ]
          },
          {
            "name": "remote",
            "description": "manage remote databases",
            "options": [
              {
                "long": "password",
                "short": "p",
                "description": "set the remote database password",
                "inherit": true,
                "value": {
                  "name": "password"
                }
              }
            ],
            "subcommands": [
              {
                "name": "changes",
                "description": "show changes on the remote database"
              },
              {
                "name": "commit",
                "description": "commit remote changes as a new migration"
              }
            ]
          },
          {
            "name": "reset",
            "description": "resets the local database to current migrations"
          }
        ]
      },
      {
        "name": "functions",
        "description": "manage Edge functions",
        "subcommands": [
          {
            "name": "delete",
            "description": "delete a Function from Supabase",
            "options": [
              {
                "long": "project-ref",
                "description": "set the project ref",
                "inherit": false,
                "value": {
                  "name": "project-ref"
                }
              }
            ]
          },
          {
            "name": "deploy",
            "description": "deploy a Function to Supabase",
            "options": [
              {
                "long": "no-verify-jwt",
                "description": "disable JWT verification for the Function",
                "inherit": false
              },
              {
                "long": "project-ref",
                "description": "set the project ref",
                "inherit": false,
                "value": {
                  "name": "project-ref"
                }
              }
            ]
          },
          {
            "name": "new",
            "description": "create a new Function locally"
          },
          {
            "name": "serve",
            "description": "serve a Function locally",
            "options": [
              {
                "long": "env-file",
                "description": "set the function env file",
                "inherit": false,
                "value": {
                  "name": "env-file",
                  "provider": "builtin.files"
                }
              },
              {
                "long": "no-verify-jwt",
                "description": "disable JWT verification for the Function",
                "inherit": false
              }
            ]
          }
        ]
      },
      {
        "name": "gen",
        "description": "run code generation tools",
        "subcommands": [
          {
            "name": "types",
            "description": "generate types from Postgres schema",
            "subcommands": [
              {
                "name": "typescript",
                "description": "generate types for TypeScript",
                "options": [
                  {
                    "long": "db-url",
                    "description": "generate types from a database url",
                    "inherit": false,
                    "value": {
                      "name": "db-url"
                    }
                  },
                  {
                    "long": "local",
                    "description": "generate types from the local dev database",
                    "inherit": false
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "name": "init",
        "description": "initialize a local project"
      },
      {
        "name": "link",
        "description": "link to a Supabase project",
        "options": [
          {
            "long": "password",
            "short": "p",
            "description": "set the remote database password",
            "inherit": false,
            "value": {
              "name": "password"
            }
          },
          {
            "long": "project-ref",
            "description": "set the project ref",
            "inherit": false,
            "value": {
              "name": "project-ref"
            }
          }
        ]
      },
      {
        "name": "login",
        "description": "authenticate using an access token"
      },
      {
        "name": "migration",
        "description": "manage database migration scripts",
        "subcommands": [
          {
            "name": "list",
            "description": "list local and remote migrations",
            "options": [
              {
                "long": "password",
                "short": "p",
                "description": "set the remote database password",
                "inherit": false,
                "value": {
                  "name": "password"
                }
              },
              {
                "long": "local",
                "description": "lists migrations applied to the local database",
                "inherit": false
              },
              {
                "long": "linked",
                "description": "lists migrations applied to the linked project (default true)",
                "inherit": false
              },
              {
                "long": "db-url",
                "description": "database URL to connect to",
                "inherit": false,
                "value": {
                  "name": "string"
                }
              }
            ]
          },
          {
            "name": "new",
            "description": "create an empty migration script",
            "arguments": {
              "states": [
                {
                  "name": "migration-name",
                  "index": 0
                }
              ]
            }
          },
          {
            "name": "repair",
            "description": "repair the migration history table",
            "options": [
              {
                "long": "status",
                "description": "version status to update",
                "inherit": false,
                "value": {
                  "name": "status",
                  "provider": {
                    "values": [
                      {
                        "value": "applied"
                      },
                      {
                        "value": "reverted"
                      }
                    ]
                  }
                }
              },
              {
                "long": "password",
                "short": "p",
                "description": "set the remote database password",
                "inherit": false,
                "value": {
                  "name": "password"
                }
              },
              {
                "long": "local",
                "description": "repairs the migration history of the local database",
                "inherit": false
              },
              {
                "long": "linked",
                "description": "repairs the migration history of the linked project (default true)",
                "inherit": false
              },
              {
                "long": "db-url",
                "description": "database URL to connect to",
                "inherit": false,
                "value": {
                  "name": "string"
                }
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "version",
                  "index": 0
                }
              ]
            }
          },
          {
            "name": "squash",
            "description": "squash migrations to a single file",
            "options": [
              {
                "long": "password",
                "short": "p",
                "description": "set the remote database password",
                "inherit": false,
                "value": {
                  "name": "password"
                }
              },
              {
                "long": "local",
                "description": "squashes the migration history of the local database",
                "inherit": false
              },
              {
                "long": "version",
                "description": "squash up to the specified version",
                "inherit": false,
                "value": {
                  "name": "string"
                }
              },
              {
                "long": "linked",
                "description": "squashes the migration history of the linked project (default true)",
                "inherit": false
              },
              {
                "long": "db-url",
                "description": "database URL to connect to",
                "inherit": false,
                "value": {
                  "name": "string"
                }
              }
            ]
          },
          {
            "name": "up",
            "description": "apply pending migrations to local database"
          }
        ]
      },
      {
        "name": "orgs",
        "description": "manage Supabase organizations",
        "subcommands": [
          {
            "name": "list",
            "description": "list all organizations"
          }
        ]
      },
      {
        "name": "projects",
        "description": "manage Supabase projects",
        "subcommands": [
          {
            "name": "create",
            "description": "create a project on Supabase",
            "options": [
              {
                "long": "db-password",
                "description": "database password of the project",
                "inherit": false,
                "value": {
                  "name": "db-password"
                }
              },
              {
                "long": "interactive",
                "short": "i",
                "description": "enable interactive mode",
                "inherit": false
              },
              {
                "long": "org-id",
                "description": "organization ID to create the project in",
                "inherit": false,
                "value": {
                  "name": "org-id"
                }
              },
              {
                "long": "plan",
                "description": "select a plan that suits your needs",
                "inherit": false,
                "value": {
                  "name": "plan"
                }
              },
              {
                "long": "region",
                "description": "select a region close to you for the best performance",
                "inherit": false,
                "value": {
                  "name": "region"
                }
              }
            ]
          },
          {
            "name": "list",
            "description": "list all Supabase projects"
          }
        ]
      },
      {
        "name": "secrets",
        "description": "manage Supabase secrets",
        "subcommands": [
          {
            "name": "list",
            "description": "list all secrets on Supabase"
          },
          {
            "name": "set",
            "description": "set a secret(s) on Supabase",
            "options": [
              {
                "long": "env-file",
                "description": "read secrets from an env file",
                "inherit": false,
                "value": {
                  "name": "env-file",
                  "provider": "builtin.files"
                }
              }
            ]
          },
          {
            "name": "unset",
            "description": "unset a secret(s) on Supabase"
          }
        ]
      },
      {
        "name": "start",
        "description": "start containers for Supabase local development"
      },
      {
        "name": "status",
        "description": "show status of local Supabase containers"
      },
      {
        "name": "stop",
        "description": "stop all local Supabase containers"
      },
      {
        "name": "help",
        "description": "show command help",
        "subcommands": [
          {
            "name": "completion",
            "description": "generate shell completions",
            "subcommands": [
              {
                "name": "bash",
                "description": "generate bash completions"
              },
              {
                "name": "fish",
                "description": "generate fish completions"
              },
              {
                "name": "powershell",
                "description": "generate PowerShell completions"
              },
              {
                "name": "zsh",
                "description": "generate zsh completions"
              }
            ]
          },
          {
            "name": "db",
            "description": "manage local Postgres databases",
            "subcommands": [
              {
                "name": "branch",
                "description": "manage local database branches",
                "subcommands": [
                  {
                    "name": "create",
                    "description": "create a branch"
                  },
                  {
                    "name": "delete",
                    "description": "delete a branch"
                  },
                  {
                    "name": "list",
                    "description": "list branches"
                  },
                  {
                    "name": "switch",
                    "description": "switch the active branch"
                  }
                ]
              },
              {
                "name": "diff",
                "description": "diffs the local database for schema changes"
              },
              {
                "name": "lint",
                "description": "checks local database for typing error"
              },
              {
                "name": "push",
                "description": "push new migrations to the remote database"
              },
              {
                "name": "remote",
                "description": "manage remote databases",
                "subcommands": [
                  {
                    "name": "changes",
                    "description": "show changes on the remote database"
                  },
                  {
                    "name": "commit",
                    "description": "commit remote changes as a new migration"
                  }
                ]
              },
              {
                "name": "reset",
                "description": "resets the local database to current migrations"
              }
            ]
          },
          {
            "name": "functions",
            "description": "manage Edge functions",
            "subcommands": [
              {
                "name": "delete",
                "description": "delete a Function from Supabase"
              },
              {
                "name": "deploy",
                "description": "deploy a Function to Supabase"
              },
              {
                "name": "new",
                "description": "create a new Function locally"
              },
              {
                "name": "serve",
                "description": "serve a Function locally"
              }
            ]
          },
          {
            "name": "gen",
            "description": "run code generation tools",
            "subcommands": [
              {
                "name": "types",
                "description": "generate types from Postgres schema",
                "subcommands": [
                  {
                    "name": "typescript",
                    "description": "generate types for TypeScript"
                  }
                ]
              }
            ]
          },
          {
            "name": "init",
            "description": "initialize a local project"
          },
          {
            "name": "link",
            "description": "link to a Supabase project"
          },
          {
            "name": "login",
            "description": "authenticate using an access token"
          },
          {
            "name": "migration",
            "description": "manage database migration scripts",
            "subcommands": [
              {
                "name": "list",
                "description": "list local and remote migrations"
              },
              {
                "name": "new",
                "description": "create an empty migration script"
              }
            ]
          },
          {
            "name": "orgs",
            "description": "manage Supabase organizations",
            "subcommands": [
              {
                "name": "list",
                "description": "list all organizations"
              }
            ]
          },
          {
            "name": "projects",
            "description": "manage Supabase projects",
            "subcommands": [
              {
                "name": "create",
                "description": "create a project on Supabase"
              },
              {
                "name": "list",
                "description": "list all Supabase projects"
              }
            ]
          },
          {
            "name": "secrets",
            "description": "manage Supabase secrets",
            "subcommands": [
              {
                "name": "list",
                "description": "list all secrets on Supabase"
              },
              {
                "name": "set",
                "description": "set a secret(s) on Supabase"
              },
              {
                "name": "unset",
                "description": "unset a secret(s) on Supabase"
              }
            ]
          },
          {
            "name": "start",
            "description": "start containers for Supabase local development"
          },
          {
            "name": "status",
            "description": "show status of local Supabase containers"
          },
          {
            "name": "stop",
            "description": "stop all local Supabase containers"
          }
        ]
      }
    ],
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
