{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "lima",
    "description": "run commands in the current Lima instance",
    "options": [
      {
        "short": "h",
        "long": "help",
        "description": "show help",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "command",
          "provider": "builtin.executables",
          "index": 0,
          "repeatable": true,
          "description": "command to run",
          "required": false
        }
      ]
    },
    "providers": {
      "builtin.executables": {
        "builtin": "executables"
      }
    }
  }
}
