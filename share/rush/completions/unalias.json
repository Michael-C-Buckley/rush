{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "unalias",
    "description": "remove aliases",
    "providers": {
      "unalias.names": { "function": "__rush_complete_unalias_names" }
    },
    "options": [
      {
        "short": "a",
        "description": "remove all aliases"
      }
    ],
    "arguments": {
      "terminator": "--",
      "states": [
        {
          "name": "alias",
          "index": 0,
          "repeatable": true,
          "provider": "unalias.names",
          "description": "alias to remove"
        }
      ]
    }
  }
}
