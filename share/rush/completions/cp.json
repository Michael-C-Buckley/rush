{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "cp",
    "description": "copy files and directories",
    "options": [
      {
        "short": "a",
        "description": "preserves structure and attributes of files but not directory structure",
        "inherit": false
      },
      {
        "short": "f",
        "description": "if the destination file cannot be opened, remove it and create a new file, without prompting for confirmation",
        "inherit": false
      },
      {
        "short": "H",
        "description": "if the -R option is specified, symbolic links on the command line are followed",
        "inherit": false,
        "exclusiveGroup": "cp.symlink-traversal"
      },
      {
        "short": "i",
        "description": "cause cp to write a prompt to the standard error output before copying a file that would overwrite an exist",
        "inherit": false
      },
      {
        "short": "L",
        "description": "if the -R option is specified, all symbolic links are followed",
        "inherit": false,
        "exclusiveGroup": "cp.symlink-traversal"
      },
      {
        "short": "n",
        "description": "do not overwrite an existing file",
        "inherit": false
      },
      {
        "short": "P",
        "description": "if the -R option is specified, no symbolic links are followed",
        "inherit": false,
        "exclusiveGroup": "cp.symlink-traversal"
      },
      {
        "short": "R",
        "description": "if source designates a directory, cp copies the directory and the entire subtree connected at that point. I",
        "inherit": false
      },
      {
        "short": "v",
        "description": "cause cp to be verbose, showing files as they are copied",
        "inherit": false
      },
      {
        "short": "X",
        "description": "do not copy Extended Attributes (EAs) or resource forks",
        "inherit": false
      },
      {
        "short": "c",
        "description": "copy files using clonefile",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "source",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true,
          "description": "source file"
        },
        {
          "name": "destination",
          "provider": "builtin.files",
          "index": 1,
          "description": "destination path"
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      },
      "builtin.directories": {
        "builtin": "directories"
      }
    }
  }
}
