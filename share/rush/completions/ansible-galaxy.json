                  "name": "directory",
                  "provider": "builtin.directories"
                }
              },
              {
                "description": "use collection skeleton",
                "inherit": false,
                "long": "collection-skeleton",
                "value": {
                  "name": "directory",
                  "provider": "builtin.directories"
                }
              }
