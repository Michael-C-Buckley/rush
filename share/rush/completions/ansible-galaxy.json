        "name": "collection",
        "description": "operate on collections",
        "subcommands": [
          {
            "name": "download",
            "description": "download collections",
            "options": [
              {
                "description": "set galaxy api server",
                "inherit": false,
                "long": "server",
                "short": "s",
                "value": {
                  "name": "api-server"
                }
              },
              {
                "description": "set galaxy api key",
                "inherit": false,
                "long": "token",
                "aliases": [
                  "api-key"
                ],
                "value": {
                  "name": "api-key"
                }
              },
              {
                "description": "ignore ssl certificate errors",
                "inherit": false,
                "long": "ignore-certs",
                "short": "c"
              },
              {
                "description": "clear response cache",
                "inherit": false,
                "long": "clear-response-cache"
              },
              {
                "description": "disable response cache",
                "inherit": false,
                "long": "no-cache"
              },
              {
                "description": "skip collection dependencies",
                "inherit": false,
                "long": "no-deps",
                "short": "n"
              },
              {
                "description": "set download directory",
                "inherit": false,
                "long": "download-path",
                "short": "p",
                "value": {
                  "name": "directory",
                  "provider": "builtin.directories"
                }
              },
              {
                "description": "read requirements file",
                "inherit": false,
                "long": "requirements-file",
                "short": "r",
                "value": {
                  "name": "requirements",
                  "provider": "builtin.files"
                }
              },
              {
                "description": "include pre-release versions",
                "inherit": false,
                "long": "pre"
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "collection",
                  "index": 0,
                  "description": "collection name",
                  "provider": "ansible-galaxy.collections",
                  "repeatable": true
                }
              ]
            }
          },
          {
            "name": "init",
            "description": "initialize a collection",
            "options": [
              {
                "description": "set galaxy api server",
                "inherit": false,
                "long": "server",
                "short": "s",
                "value": {
                  "name": "api-server"
                }
              },
              {
                "description": "set galaxy api key",
                "inherit": false,
                "long": "token",
