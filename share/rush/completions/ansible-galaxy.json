{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "ansible-galaxy",
    "description": "manage ansible roles and collections",
    "providers": {
      "builtin.files": {
        "builtin": "files"
      },
      "builtin.directories": {
        "builtin": "directories"
      },
      "ansible-galaxy.collections": {
        "values": [
          "amazon.aws",
          "ansible.builtin",
          "ansible.netcommon",
          "ansible.posix",
          "ansible.utils",
          "ansible.windows",
          "awx.awx",
          "azure.azcollection",
          "cisco.ios",
          "cisco.nxos",
          "community.aws",
          "community.crypto",
          "community.docker",
          "community.general",
          "community.kubernetes",
          "community.mysql",
          "community.postgresql",
          "community.vmware",
          "containers.podman",
          "google.cloud",
          "kubernetes.core",
          "openstack.cloud",
          "vmware.vmware_rest",
          "vyos.vyos"
        ]
      },
      "ansible-galaxy.import-timeouts": {
        "values": [
          "60",
          "300",
          "600",
          "900"
        ]
      },
      "ansible-galaxy.list-formats": {
        "values": [
          "human",
          "yaml",
          "json"
        ]
      },
      "ansible-galaxy.role-types": {
        "values": [
          "container",
          "apb",
          "network"
        ]
      },
      "ansible-galaxy.branches": {
        "values": [
          "master",
          "main",
          "develop"
        ]
      }
    },
    "options": [
      {
        "long": "help",
        "short": "h",
        "description": "show help",
        "inherit": true
      },
      {
        "long": "verbose",
        "description": "enable verbose output",
        "inherit": true,
        "exclusiveGroup": "ansible-galaxy.verbosity"
      },
      {
        "short": "v",
        "description": "enable verbose output",
        "inherit": true,
        "repeatable": true,
        "exclusiveGroup": "ansible-galaxy.verbosity"
      },
      {
        "long": "version",
        "description": "show version and paths",
        "inherit": true
      }
