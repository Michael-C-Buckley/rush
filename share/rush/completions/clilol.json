        "description": "create things",
        "subcommands": [
          {
            "name": "dns",
            "description": "create a DNS record",
            "options": [
              {
                "long": "priority",
                "short": "p",
                "description": "priority of the DNS record",
                "inherit": false,
                "value": {
                  "name": "priority"
                }
              },
              {
                "long": "ttl",
                "short": "T",
                "description": "time to live of the DNS record",
                "inherit": false,
                "value": {
                  "name": "ttl"
                }
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "name",
                  "description": "name of the DNS record",
                  "index": 0
                },
                {
                  "name": "type",
                  "description": "type of the DNS record",
                  "index": 1
                },
                {
                  "name": "data",
                  "description": "data of the DNS record",
                  "index": 2
                }
              ]
            }
          },
          {
            "name": "paste",
            "description": "create or update a paste",
            "options": [
              {
                "long": "filename",
                "short": "f",
                "description": "file to read paste from (default stdin)",
                "inherit": false,
                "value": {
                  "name": "filename",
                  "provider": "builtin.files"
                }
              },
              {
                "long": "listed",
                "short": "l",
                "description": "create paste as listed (default false)",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "title",
                  "description": "title of the paste",
                  "index": 0
                }
              ]
            }
          },
          {
            "name": "picture",
            "description": "upload a picture to some.pics",
            "options": [
              {
                "long": "description",
                "short": "d",
                "description": "description of the picture (default empty/unlisted)",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "filename",
                  "description": "filename of the image file",
                  "index": 0,
                  "provider": "builtin.files"
                }
              ]
            }
          },
          {
            "name": "purl",
            "description": "create a PURL",
            "options": [
              {
                "long": "listed",
                "short": "l",
                "description": "create as listed (default false)",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "name",
                  "description": "name of the PURL",
                  "index": 0
                },
                {
                  "name": "url",
                  "description": "uRL that the PURL redirects to",
                  "index": 1
                }
              ]
