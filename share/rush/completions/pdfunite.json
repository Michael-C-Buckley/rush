{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "pdfunite",
    "description": "combine pdf files",
    "options": [
      {
        "short": "v",
        "description": "print version information",
        "inherit": false
      },
      {
        "short": "h",
        "long": "help",
        "spellings": [
          "-?"
        ],
        "description": "show help",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "pdf",
          "description": "pdf file",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
