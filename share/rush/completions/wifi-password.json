{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "wifi-password",
    "description": "print a macOS Wi-Fi password",
    "options": [
      {
        "long": "help",
        "short": "h",
        "description": "show help for wifi-password"
      },
      {
        "long": "quiet",
        "short": "q",
        "description": "only output the password"
      },
      {
        "long": "version",
        "short": "V",
        "description": "output version"
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "ssid",
          "description": "The name for a Wi-Fi network"
        }
      ]
    }
  }
}
