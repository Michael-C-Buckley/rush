{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "task",
    "description": "run Taskfile tasks or manage Taskwarrior tasks",
    "options": [
      {
        "long": "list-all",
        "description": "list all tasks",
        "inherit": false,
        "short": "a"
      },
      {
        "long": "color",
        "description": "set colored output",
        "inherit": false,
        "short": "c",
        "value": {
          "name": "color",
          "provider": {
            "values": [
              "true",
              "false"
            ]
          }
        }
      },
      {
        "long": "concurrency",
        "description": "set concurrency limit",
        "inherit": false,
        "short": "C",
        "value": {
          "name": "number"
        }
      },
      {
        "long": "dir",
        "description": "set execution directory",
        "inherit": false,
        "short": "d",
        "value": {
          "name": "directory",
          "provider": "builtin.directories"
        }
      },
      {
        "long": "dry",
        "description": "print tasks without executing",
        "inherit": false
      },
      {
        "long": "force",
        "description": "force execution",
        "inherit": false,
        "short": "f"
      },
      {
        "long": "help",
        "description": "show help",
        "inherit": false,
        "short": "h"
      },
      {
        "long": "init",
        "description": "create Taskfile.yml",
        "inherit": false,
        "short": "i"
      },
      {
        "long": "list",
        "description": "list tasks",
        "inherit": false,
        "short": "l"
      },
      {
        "long": "output",
        "description": "set output style",
        "inherit": false,
        "short": "o",
        "value": {
          "name": "style",
          "provider": {
            "values": [
              "interleaved",
              "group",
              "prefixed"
            ]
          }
        }
      },
      {
        "long": "parallel",
        "description": "run tasks in parallel",
        "inherit": false,
        "short": "p"
      },
      {
        "long": "silent",
        "description": "disable echoing",
        "inherit": false,
        "short": "s"
      },
      {
        "long": "status",
        "description": "check task status",
        "inherit": false
      },
      {
        "long": "summary",
        "description": "show task summary",
        "inherit": false
      },
      {
        "long": "taskfile",
        "description": "choose Taskfile",
        "inherit": false,
        "short": "t",
        "value": {
          "name": "taskfile",
          "provider": "builtin.files"
        }
      },
      {
        "long": "verbose",
        "description": "enable verbose mode",
        "inherit": false,
        "short": "v"
      },
      {
        "long": "version",
        "description": "show version",
        "inherit": false
      },
      {
        "long": "watch",
        "description": "watch task",
        "inherit": false,
        "short": "w"
      }
    ],
