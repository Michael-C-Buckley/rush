{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "paste",
    "description": "merge lines from files",
    "options": [
      {
        "short": "d",
        "description": "use custom delimiter characters",
        "inherit": false,
        "value": {
          "name": "list",
          "provider": {
            "values": [
              "\\t\\n",
              "\\t",
              "\\n",
              "\\\\",
              "\\0"
            ]
          }
        }
      },
      {
        "short": "s",
        "description": "paste one file at a time",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "file",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true,
          "description": "input file"
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}