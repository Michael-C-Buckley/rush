          "states": [
            {
              "name": "query",
              "description": "The SQL Query to run",
              "index": 0
            }
          ]
        },
        "options": [
          {
            "short": "v",
            "long": "version",
            "description": "show version",
            "inherit": false
          },
          {
            "short": "f",
            "long": "config",
            "description": "connection configuration file",
            "inherit": false,
            "value": {
              "name": "file",
