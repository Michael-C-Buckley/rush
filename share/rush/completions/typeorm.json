    "providers": {
      "builtin.directories": {
        "builtin": "directories"
      },
      "builtin.files": {
        "builtin": "files"
      },
      "typeorm.databases": {
        "values": [
          "mysql",
          "mariadb",
          "postgres",
          "cockroachdb",
          "sqlite",
          "mssql",
          "oracle",
          "cordova",
          "nativescript",
          "react-native",
          "expo",
          "mongodb"
        ]
      },
      "typeorm.package-managers": {
        "values": [
          "npm",
          "yarn"
        ]
      }
    },
    "options": [
      {
        "long": "help",
        "description": "show help for command",
        "inherit": false
