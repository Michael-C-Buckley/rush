          },
          {
            "long": "help",
            "description": "show help for command",
            "inherit": false
          },
          {
            "short": "n",
            "long": "name",
            "description": "name of the entity class",
            "inherit": false,
            "value": {
              "name": "entity"
            }
          },
          {
            "short": "d",
            "long": "dir",
            "description": "directory where entity should be created",
            "inherit": false,
            "value": {
              "name": "directory",
              "provider": "builtin.directories"
            }
          }
        ]
      },
      {
        "name": "subscriber:create",
