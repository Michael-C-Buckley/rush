          },
          {
            "short": "c",
            "long": "connection",
            "description": "connection name",
            "inherit": false,
            "value": {
              "name": "connection"
            }
          },
          {
            "long": "help",
            "description": "show help for command",
            "inherit": false
          }
        ]
      },
      {
        "name": "schema:drop",
        "description": "drops all tables in the database on your default connection",
