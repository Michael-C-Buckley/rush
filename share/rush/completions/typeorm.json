{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "typeorm",
    "description": "TypeORM CLI",
    "subcommands": [
      {
        "name": "schema:sync",
        "description": "synchronizes your entities with database schema",
        "options": [
          {
            "short": "v",
            "long": "version",
            "description": "show version",
            "inherit": false
          },
          {
            "short": "f",
            "long": "config",
            "description": "connection configuration file",
            "inherit": false,
            "value": {
              "name": "file",
              "provider": "builtin.files"
            }
          },
          {
            "short": "c",
            "long": "connection",
            "description": "connection name",
            "inherit": false,
            "value": {
              "name": "connection"
            }
          },
          {
            "long": "help",
            "description": "show help for command",
            "inherit": false
          }
        ]
      },
      {
        "name": "schema:log",
        "description": "shows sql to be executed by schema:sync command",
        "options": [
          {
            "short": "v",
