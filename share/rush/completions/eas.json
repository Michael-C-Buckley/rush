          {
            "long": "platform",
            "inherit": false,
            "value": {
              "name": "Platform",
              "provider": {
                "values": [
                  "all",
                  "android",
                  "ios"
                ]
              }
            }
          },
          {
            "long": "runtimeVersion",
            "inherit": false,
            "value": {
              "name": "Value"
