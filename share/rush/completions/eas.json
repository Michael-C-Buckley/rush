          {
            "long": "limit",
            "description": "the number of items to fetch each query. Defaults to 25 and is capped at 50",
            "inherit": false,
            "value": {
              "name": "Limit",
              "provider": "eas.limit.25-50"
            }
          },
          {
            "long": "non-interactive",
            "description": "run the command in non-interactive mode",
            "inherit": false
          },
          {
            "long": "offset",
            "description": "start queries from specified index. Use for paginating results. Defaults to 0",
            "inherit": false,
            "value": {
              "name": "Offset"
            }
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "Name",
              "description": "name of the branch to view",
              "index": 0
            }
          ]
        }
      },
      {
        "name": "build",
        "description": "start a build",
        "options": [
          {
            "short": "e",
            "long": "profile",
            "description": "name of the build profile from eas.json. Defaults to \"production\" if defined in eas.json",
            "inherit": false,
            "value": {
              "name": "Profile-Name"
            }
          },
          {
            "short": "m",
            "long": "message",
            "description": "a short message describing the build",
            "inherit": false,
            "value": {
              "name": "Value"
            }
          },
          {
            "short": "p",
            "long": "platform",
            "inherit": false,
            "value": {
              "name": "Platform",
              "provider": {
                "values": [
                  "android",
                  "ios",
                  "all"
                ]
              }
            }
          },
          {
            "long": "auto-submit",
            "description": "submit on build complete using the submit profile with the same name as the build profile",
            "inherit": false
          },
          {
            "long": "auto-submit-with-profile",
            "description": "submit on build complete using the submit profile with provided name",
            "inherit": false,
            "value": {
              "name": "Profile-Name"
            }
          },
          {
            "long": "clear-cache",
            "description": "clear cache before the build",
            "inherit": false
          },
          {
            "long": "json",
            "description": "enable JSON output, non-JSON messages will be printed to stderr",
            "inherit": false
          },
          {
            "long": "local",
            "description": "run build locally [experimental]",
            "inherit": false
          },
          {
            "long": "non-interactive",
            "description": "run the command in non-interactive mode",
            "inherit": false
          },
          {
            "long": "output",
            "description": "output path for local build",
            "inherit": false,
            "value": {
              "name": "Value",
              "provider": "builtin.directories"
            }
          },
          {
            "long": "no-wait",
            "description": "don't wait for build(s) to complete",
            "inherit": false
          },
          {
            "long": "wait",
            "description": "wait for build(s) to complete",
            "inherit": false
          }
        ]
      },
      {
        "name": "build:cancel",
