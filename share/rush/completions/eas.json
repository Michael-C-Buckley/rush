{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "eas",
    "description": "manage Expo Application Services",
    "subcommands": [
      {
        "name": "account:login",
        "aliases": [
          "login"
        ],
        "description": "log in with your Expo account"
      },
      {
        "name": "account:logout",
        "aliases": [
          "logout"
        ],
        "description": "log out"
      },
      {
        "name": "account:view",
        "aliases": [
          "whoami"
        ],
        "description": "show the username you are logged in as"
      },
      {
        "name": "analytics",
        "description": "display or change analytics settings",
        "arguments": {
          "states": [
            {
              "name": "Status",
              "provider": {
                "values": [
                  "on",
                  "off"
                ]
              },
              "index": 0
            }
          ]
        }
      },
      {
        "name": "autocomplete",
        "description": "display autocomplete installation instructions",
        "options": [
          {
            "short": "r",
            "long": "refresh-cache",
            "description": "refresh cache (ignores displaying instructions)",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "Shell",
              "description": "select the shell you'd like to display autocomplete information for",
              "provider": {
                "values": [
                  "zsh",
                  "bash"
                ]
              },
              "index": 0
            }
          ]
        }
      },
      {
        "name": "branch:create",
        "description": "create a branch",
        "options": [
          {
            "long": "json",
            "description": "enable JSON output, non-JSON messages will be printed to stderr",
            "inherit": false
          },
          {
            "long": "non-interactive",
            "description": "run the command in non-interactive mode",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "Name",
              "description": "name of the branch to create",
              "index": 0
            }
          ]
        }
      },
      {
        "name": "branch:delete",
        "description": "delete a branch",
        "options": [
          {
            "long": "json",
            "description": "enable JSON output, non-JSON messages will be printed to stderr",
            "inherit": false
          },
          {
            "long": "non-interactive",
            "description": "run the command in non-interactive mode",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "Name",
              "description": "name of the branch to delete",
              "index": 0
            }
          ]
        }
      },
      {
        "name": "branch:list",
        "description": "list all branches",
        "options": [
          {
            "long": "json",
            "description": "enable JSON output, non-JSON messages will be printed to stderr",
            "inherit": false
          },
          {
            "long": "limit",
            "description": "the number of items to fetch each query. Defaults to 50 and is capped at 100",
            "inherit": false,
            "value": {
              "name": "Limit",
              "provider": "eas.limit.50-100"
            }
          },
          {
            "long": "non-interactive",
            "description": "run the command in non-interactive mode",
            "inherit": false
          },
          {
            "long": "offset",
            "description": "start queries from specified index. Use for paginating results. Defaults to 0",
            "inherit": false,
            "value": {
              "name": "Offset"
            }
          }
        ]
      },
      {
        "name": "branch:rename",
        "description": "rename a branch",
        "options": [
          {
            "long": "from",
            "description": "current name of the branch",
            "inherit": false,
            "value": {
              "name": "Value"
            }
          },
          {
            "long": "json",
            "description": "enable JSON output, non-JSON messages will be printed to stderr",
            "inherit": false
          },
          {
            "long": "non-interactive",
            "description": "run the command in non-interactive mode",
            "inherit": false
          },
          {
            "long": "to",
            "description": "new name of the branch",
            "inherit": false,
            "value": {
              "name": "Value"
            }
          }
        ]
      },
      {
        "name": "branch:view",
