{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "sysctl",
    "description": "get or set kernel state",
    "options": [
      {
        "short": "A",
        "spellings": [
          "-a"
        ],
        "description": "list all available values",
        "inherit": false
      },
      {
        "short": "b",
        "description": "output raw binary values",
        "inherit": false
      },
      {
        "short": "d",
        "description": "print variable descriptions",
        "inherit": false
      },
      {
        "short": "e",
        "description": "separate names and values with =",
        "inherit": false,
        "value": {
          "name": "variable"
        }
      },
      {
        "short": "h",
        "description": "format output for humans",
        "inherit": false
      },
      {
        "short": "i",
        "description": "ignore unknown OIDs",
        "inherit": false
      },
      {
        "short": "N",
        "description": "show only variable names",
        "inherit": false
      },
      {
        "short": "n",
        "description": "show only variable values",
        "inherit": false
      },
      {
        "short": "o",
        "description": "show opaque variables",
        "inherit": false
      },
      {
        "short": "q",
        "description": "suppress warnings",
        "inherit": false
      },
      {
        "short": "X",
        "description": "equivalent to -x -a",
        "inherit": false
      },
      {
        "short": "x",
        "description": "print opaque values as hex",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "variable",
          "index": 0,
          "repeatable": true,
          "description": "variable name or assignment",
          "optional": true
        }
      ]
    }
  }
}
