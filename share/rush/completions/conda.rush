__rush_complete_conda_envs() {
  conda info --envs 2>/dev/null | awk 'NF && $1 !~ /^#/ { print $1 }' | while IFS= read -r env; do
    test -n "$env" && rush_complete candidate "$env" --kind plain --description environment
  done
}

__rush_complete_conda_packages() {
  conda list 2>/dev/null | awk 'NF && $1 !~ /^#/ { print $1 }' | while IFS= read -r package; do
    test -n "$package" && rush_complete candidate "$package" --kind plain --description package
  done
}
