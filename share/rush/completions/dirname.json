{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "dirname",
    "description": "return the directory portion of pathnames",
    "arguments": {
      "states": [
        {
          "name": "string",
          "description": "pathname to operate on",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
