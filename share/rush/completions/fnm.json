{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "fnm",
    "description": "manage Node.js versions",
    "subcommands": [
      {
        "name": "install",
        "description": "install a new Node.js version",
        "arguments": {
          "states": [
            {
              "name": "version",
              "index": 0,
              "description": "node.js version or lts/NAME"
            }
          ]
        },
        "options": [
          {
            "long": "lts",
            "description": "use the latest LTS version",
            "inherit": false
          },
          {
            "short": "h",
            "long": "help",
            "description": "print help information",
            "inherit": true
          },
          {
            "short": "V",
            "long": "version",
            "description": "print version information",
            "inherit": true
          },
          {
            "long": "arch",
            "description": "override installed Node binary architecture",
            "inherit": true,
            "value": {
              "name": "arch",
              "provider": "fnm.architectures"
            }
          },
          {
            "long": "fnm-dir",
            "description": "root directory of fnm installations",
            "inherit": true,
            "value": {
              "name": "dir",
              "provider": "builtin.directories"
            }
          },
          {
            "long": "log-level",
            "description": "set the log level",
            "inherit": true,
            "value": {
              "name": "level",
              "provider": "fnm.log-levels"
            }
          },
          {
            "long": "node-dist-mirror",
            "description": "set the Node.js distribution mirror",
            "inherit": true,
            "value": {
              "name": "url"
            }
          },
          {
            "long": "version-file-strategy",
            "description": "set how to resolve Node versions from files",
            "inherit": true,
            "value": {
              "name": "strategy",
              "provider": "fnm.version-file-strategies"
            }
          }
        ]
      },
