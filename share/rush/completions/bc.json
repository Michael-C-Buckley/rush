{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "bc",
    "description": "run an arbitrary precision calculator",
    "options": [
      {
        "long": "help",
        "short": "h",
        "description": "print the usage and exit",
        "inherit": false
      },
      {
        "long": "interactive",
        "short": "i",
        "description": "force interactive mode",
        "inherit": false
      },
      {
        "long": "mathlib",
        "short": "l",
        "description": "define the standard math library",
        "inherit": false
      },
      {
        "long": "warn",
        "short": "w",
        "description": "give warnings for extensions to POSIX bc",
        "inherit": false
      },
      {
        "long": "standard",
        "short": "s",
        "description": "process exactly the POSIX bc language",
        "inherit": false
      },
      {
        "long": "quiet",
        "short": "q",
        "description": "do not print the normal GNU bc welcome",
        "inherit": false
      },
      {
        "long": "version",
        "short": "v",
        "description": "print the version number and copyright and quit",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "file",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true,
          "description": "script file"
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
