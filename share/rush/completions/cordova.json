{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "cordova",
    "description": "build cordova applications",
    "subcommands": [
      {
        "name": "create",
        "description": "create a project",
        "options": [
          {
            "long": "template",
            "description": "use a custom template located locally, in NPM, or GitHub",
            "inherit": false
          },
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "path",
              "description": "directory which should not already exist. cordova will create this directory",
              "provider": "builtin.directories",
              "index": 0
            },
            {
              "name": "id",
              "description": "reverse domain-style identifier that maps to id attribute of widget element in config.xml. This can be chan",
              "index": 1
            },
            {
              "name": "name",
              "description": "application's display title that maps name element in config.xml file. This can be changed but there may be",
              "index": 2
            }
          ]
        }
      },
      {
        "name": "help",
        "description": "get help for a command",
        "arguments": {
          "states": [
            {
              "name": "command",
              "index": 0,
              "values": [
                "create",
                "help",
                "telemetry",
                "config",
                "info",
                "requirements",
                "platform",
                "plugin",
                "prepare",
                "compile",
                "build",
                "clean",
                "run",
                "serve"
              ]
            }
          ]
        },
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      },
      {
        "name": "telemetry",
        "description": "turn telemetry collection on or off",
        "arguments": {
          "states": [
            {
              "name": "on",
              "description": "turn telemetry collection on",
              "index": 0
            },
            {
              "name": "off",
              "description": "turn telemetry collection off",
              "index": 1
            }
          ]
        },
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      },
      {
        "name": "config",
        "description": "set, get, delete, edit, and list global cordova options",
        "subcommands": [
          {
            "name": "ls",
            "description": "lists contents of config file",
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ]
          },
          {
            "name": "edit",
            "description": "opens the config file in an editor",
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ]
          },
          {
            "name": "set",
            "description": "sets the config key to the value. If value is omitted, then it sets it to \"true\"",
            "arguments": {
              "states": [
                {
                  "name": "key",
                  "index": 0
                },
                {
                  "name": "value",
                  "index": 1
                }
              ]
            },
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ]
          },
          {
            "name": "get",
            "description": "echo the config value to stdout",
            "arguments": {
              "states": [
                {
                  "name": "key",
                  "index": 0
                }
              ]
            },
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ]
          },
          {
            "name": "delete",
            "description": "deletes the key from all configuration files",
            "arguments": {
              "states": [
                {
                  "name": "key",
                  "index": 0
                }
              ]
            },
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ]
          }
        ],
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      },
      {
        "name": "info",
        "description": "generate project information",
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      },
      {
        "name": "requirements",
        "description": "checks and print out all the installation requirements for platforms specified",
        "arguments": {
          "states": [
            {
              "name": "platform",
              "description": "platform name(s) to build. If not specified, all platforms are built",
              "index": 0,
              "provider": "cordova.platforms"
            }
          ]
        },
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      },
      {
        "name": "platform",
        "aliases": [
          "platforms"
        ],
        "description": "manage project platforms",
        "subcommands": [
          {
            "name": "add",
            "description": "add specified platforms",
            "options": [
              {
                "long": "nosave",
                "description": "do not save",
                "inherit": false
              },
              {
                "long": "link",
                "description": "when platform-spec is a local path, link the platform library directly instead of making a copy of it",
                "inherit": false,
                "value": {
                  "name": "path",
                  "provider": "builtin.directories"
                }
              },
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "platform",
                  "index": 0,
                  "repeatable": true,
                  "values": [
                    "android",
                    "ios",
                    "windows",
                    "browser",
                    "electron"
                  ],
                  "provider": "cordova.platforms"
                }
              ]
            }
          },
          {
            "name": "remove",
            "aliases": [
              "rm"
            ],
            "description": "remove specified platforms",
            "options": [
              {
                "long": "nosave",
                "description": "do not delete specified platforms from",
                "inherit": false
              },
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "platform",
                  "index": 0,
                  "repeatable": true,
                  "provider": "cordova.platforms"
                }
              ]
            }
          },
          {
            "name": "update",
            "description": "update specified platforms",
            "options": [
              {
                "long": "save",
                "description": "updates the version specified in **config.xml**",
                "inherit": false
              },
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ]
          },
          {
            "name": "list",
            "aliases": [
              "ls"
            ],
            "description": "list all installed and available platforms",
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ]
          }
        ],
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      },
      {
        "name": "plugin",
        "aliases": [
          "plugins"
        ],
        "description": "manage project plugins",
        "subcommands": [
          {
            "name": "add",
            "description": "add specified plugins",
            "options": [
              {
                "long": "searchpath",
                "description": "when looking up plugins by ID, look in this directory and each of its subdirectories before hitting the reg",
                "inherit": false,
                "value": {
                  "name": "directory",
                  "provider": "builtin.directories"
                }
              },
              {
                "long": "noregistry",
                "description": "don't search the registry for plugins",
                "inherit": false
              },
              {
                "long": "link",
                "description": "when installing from a local path, creates a symbolic link instead of copying files. The extent to which fi",
                "inherit": false
              },
              {
                "long": "nosave",
                "description": "do NOT save the <plugin-spec> as part of the plugin element into config.xml or package.json",
                "inherit": false
              },
              {
                "long": "force",
                "description": "forces copying source files from the plugin even if the same file already exists in the target directory",
                "inherit": false
              },
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "plugin",
                  "provider": "cordova.plugins",
                  "index": 0,
                  "repeatable": true
                }
              ]
            }
          },
          {
            "name": "remove",
            "description": "remove plugins with the given IDs/name",
            "options": [
              {
                "long": "nosave",
                "description": "do NOT remove the specified plugin from config.xml or package.json",
                "inherit": false
              },
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "plugin",
                  "index": 0,
                  "repeatable": true,
                  "provider": "cordova.plugins"
                }
              ]
            }
          },
          {
            "name": "list",
            "description": "list currently installed plugins",
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "show help",
                "inherit": false
              }
            ]
          }
        ],
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      },
      {
        "name": "prepare",
        "description": "copy files into platform(s) for building",
        "arguments": {
          "states": [
            {
              "name": "platform",
              "index": 0,
              "provider": "cordova.platforms"
            }
          ]
        },
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      },
      {
        "name": "compile",
        "description": "compile project for platform(s)",
        "options": [
          {
            "long": "debug",
            "description": "perform a debug build. This typically translates to debug mode for the underlying platform being built",
            "inherit": false
          },
          {
            "long": "release",
            "description": "perform a release build. This typically translates to release mode for the underlying platform being built",
            "inherit": false
          },
          {
            "long": "device",
            "description": "build it for a device",
            "inherit": false
          },
          {
            "long": "emulator",
            "description": "build it for an emulator. In particular, the platform architecture might be different for a device vs. emul",
            "inherit": false
          },
          {
            "long": "buildConfig",
            "description": "use the specified build configuration file. build.json file is used to specify parameters to customize the",
            "inherit": false,
            "value": {
              "name": "value",
              "provider": [
                "builtin.files",
                "builtin.directories"
              ]
            }
          },
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "platform",
              "description": "platform name(s) to build. If not specified, all platforms are built",
              "index": 0,
              "provider": "cordova.platforms"
            }
          ]
        }
      },
      {
        "name": "build",
        "description": "build project for platform(s) (prepare + compile)",
        "options": [
          {
            "long": "debug",
            "description": "perform a debug build. This typically translates to debug mode for the underlying platform being built",
            "inherit": false
          },
          {
            "long": "release",
            "description": "perform a release build. This typically translates to release mode for the underlying platform being built",
            "inherit": false
          },
          {
            "long": "device",
            "description": "build it for a device",
            "inherit": false
          },
          {
            "long": "emulator",
            "description": "build it for an emulator. In particular, the platform architecture might be different for a device vs. emul",
            "inherit": false
          },
          {
            "long": "buildConfig",
            "description": "use the specified build configuration file. build.json file is used to specify parameters to customize the",
            "inherit": false,
            "value": {
              "name": "value",
              "provider": [
                "builtin.files",
                "builtin.directories"
              ]
            }
          },
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "platform",
              "description": "platform name(s) to build. If not specified, all platforms are built",
              "index": 0,
              "provider": "cordova.platforms"
            }
          ]
        }
      },
      {
        "name": "clean",
        "description": "cleanup project from build artifacts",
        "arguments": {
          "states": [
            {
              "name": "platform",
              "description": "platform name(s) to build. If not specified, all platforms are built",
              "index": 0,
              "provider": "cordova.platforms"
            }
          ]
        },
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      },
      {
        "name": "run",
        "description": "run project (including prepare && compile)",
        "options": [
          {
            "long": "list",
            "description": "lists available targets. Displays both device and emulator deployment targets unless specified",
            "inherit": false
          },
          {
            "long": "debug",
            "description": "deploy a debug build. This is the default behavior unless --release is specified",
            "inherit": false
          },
          {
            "long": "release",
            "description": "deploy a release build",
            "inherit": false
          },
          {
            "long": "noprepare",
            "description": "skip preparing (available in cordova v6.2 or later)",
            "inherit": false
          },
          {
            "long": "nobuild",
            "description": "skip building",
            "inherit": false
          },
          {
            "long": "device",
            "description": "deploy to a device",
            "inherit": false
          },
          {
            "long": "emulator",
            "description": "deploy to an emulator",
            "inherit": false
          },
          {
            "long": "target",
            "description": "deploy to a specific target emulator/device. Use --list to display target options",
            "inherit": false,
            "value": {
              "name": "target"
            }
          },
          {
            "long": "buildConfig",
            "description": "use the specified build configuration file. build.json file is used to specify parameters to customize the",
            "inherit": false,
            "value": {
              "name": "configfile",
              "provider": "builtin.files"
            }
          },
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "platform",
              "description": "platform name(s) to run. If not specified, all platforms are run",
              "index": 0,
              "provider": "cordova.platforms"
            }
          ]
        }
      },
      {
        "name": "serve",
        "description": "run project with a local webserver (including prepare)",
        "arguments": {
          "states": [
            {
              "name": "port",
              "description": "port to use for local web server",
              "index": 0
            }
          ]
        },
        "options": [
          {
            "short": "h",
            "long": "help",
            "description": "show help",
            "inherit": false
          }
        ]
      }
    ],
    "providers": {
      "cordova.platforms": {
        "function": "__rush_complete_cordova_platforms"
      },
      "cordova.plugins": {
        "function": "__rush_complete_cordova_plugins"
      },
      "builtin.directories": {
        "builtin": "directories"
      }
    },
    "options": [
      {
        "short": "h",
        "long": "help",
        "description": "show help",
        "inherit": false
      },
      {
        "short": "v",
        "long": "version",
        "description": "show version",
        "inherit": false
      }
    ]
  }
}
