{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "env",
    "description": "set environment and run a command",
    "options": [
      {
        "short": "0",
        "description": "end each output line with NUL, not newline",
        "inherit": false
      },
      {
        "short": "i",
        "spellings": [
          "-"
        ],
        "description": "start with an empty environment",
        "inherit": false
      },
      {
        "short": "v",
        "description": "print verbose logs",
        "inherit": false
      },
      {
        "short": "u",
        "description": "remove variable from the environment",
        "inherit": false,
        "value": {
          "name": "name"
        }
      },
      {
        "short": "P",
        "description": "search the given directories for the utility, rather than the PATH",
        "inherit": false,
        "value": {
          "name": "altpath",
          "provider": "builtin.directories"
        }
      },
      {
        "short": "S",
        "description": "split the given string into separate arguments",
        "inherit": false,
        "value": {
          "name": "string"
        }
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "name=value",
          "description": "environment assignment",
          "index": 0,
          "repeatable": true
        },
        {
          "name": "utility",
          "description": "Utility to run",
          "provider": "builtin.executables",
          "index": 1
        }
      ]
    },
    "providers": {
      "builtin.directories": {
        "builtin": "directories"
      },
      "builtin.executables": {
        "builtin": "executables"
      }
    }
  }
}
