{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "c++",
    "description": "compile c++ programs",
    "providers": {
      "builtin.files": { "builtin": "files" },
      "builtin.directories": { "builtin": "directories" }
    },
    "options": [
      { "short": "c", "description": "compile without linking", "inherit": false },
      { "short": "g", "description": "generate debug information", "inherit": false },
      { "short": "S", "description": "compile to assembly", "inherit": false },
      { "short": "E", "description": "preprocess only", "inherit": false },
      { "short": "o", "description": "write output file", "inherit": false, "value": { "name": "file", "provider": "builtin.files" } },
      { "spellings": ["-I"], "description": "add include directory", "inherit": false, "repeatable": true, "value": { "name": "directory", "provider": "builtin.directories", "style": "adjacent" } },
      { "spellings": ["-L"], "description": "add library search directory", "inherit": false, "repeatable": true, "value": { "name": "directory", "provider": "builtin.directories", "style": "adjacent" } },
      { "spellings": ["-l"], "description": "link with library", "inherit": false, "repeatable": true, "value": { "name": "library", "style": "adjacent" } },
      { "spellings": ["-D"], "description": "define preprocessor macro", "inherit": false, "repeatable": true, "value": { "name": "macro", "style": "adjacent" } },
      { "spellings": ["-U"], "description": "undefine preprocessor macro", "inherit": false, "repeatable": true, "value": { "name": "macro", "style": "adjacent" } },
      { "long": "std", "description": "set language standard", "inherit": false, "value": { "name": "standard", "style": "equals", "values": ["c++98", "c++03", "c++11", "c++14", "c++17", "c++20", "c++23", "gnu++98", "gnu++03", "gnu++11", "gnu++14", "gnu++17", "gnu++20", "gnu++23"] } },
      { "long": "help", "description": "show help", "inherit": false },
      { "long": "version", "description": "show version", "inherit": false }
    ],
    "arguments": {
      "states": [
        { "name": "file", "index": 0, "description": "source file", "provider": "builtin.files", "repeatable": true }
      ]
    }
  }
}
