          {
            "name": "list",
            "aliases": [
              "ls"
            ],
            "description": "list managed clusters"
          },
          {
            "name": "probe",
            "description": "health probe managed cluster"
          },
          {
            "name": "rename",
            "description": "rename managed cluster"
          }
        ]
      },
      {
