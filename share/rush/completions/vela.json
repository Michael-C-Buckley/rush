                "value": {
                  "name": "path",
                  "provider": "builtin.files"
                }
              },
              {
                "long": "type",
                "short": "t",
                "description": "specify the type of the new definition. Valid types: scope, workflow-step, component, trait, policy, workload",
                "value": {
                  "name": "string"
