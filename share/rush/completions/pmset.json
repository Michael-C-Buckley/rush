        "inherit": false,
        "value": [
          {
            "name": "setting",
            "provider": "pmset.settings",
            "description": "setting name"
          },
          {
            "name": "value",
            "description": "setting value"
          }
        ]
      },
      {
        "short": "b",
        "description": "set battery settings",
        "inherit": false,
        "value": [
          {
            "name": "setting",
            "provider": "pmset.settings",
            "description": "setting name"
          },
          {
            "name": "value",
            "description": "setting value"
          }
        ]
      },
      {
        "short": "c",
        "description": "set charger settings",
        "inherit": false,
