      {
        "name": "init",
        "description": "create a new lerna repo or upgrade an existing repo to the current version of Lerna",
        "options": [
          {
            "description": "number of threads to use",
            "inherit": false,
            "long": "concurrency"
          },
          {
            "description": "log level to report",
            "inherit": false,
            "long": "loglevel",
            "value": {
              "name": "loglevel",
              "provider": {
                "values": [
                  "silent",
                  "error",
                  "warn",
                  "success",
                  "info",
                  "verbose",
                  "silly"
                ]
              }
            }
          },
          {
            "description": "maximum buffer length for each process",
            "inherit": false,
            "long": "max-buffer",
            "value": {
              "name": "bytes"
            }
          },
          {
            "description": "disable progress bars",
            "inherit": false,
            "long": "no-progress"
          },
          {
            "description": "disable package sorting",
            "inherit": false,
            "long": "no-sort"
          },
          {
            "description": "fail if a dependency cycle is found",
            "inherit": false,
            "long": "reject-cycles"
          },
          {
            "description": "show help",
            "inherit": false,
            "long": "help",
            "short": "h"
          },
          {
            "description": "show version number",
            "inherit": false,
            "long": "version",
            "short": "v"
          },
          {
            "description": "executable to run scripts with",
            "inherit": false,
            "long": "npm-client",
            "value": {
              "name": "client",
              "provider": {
                "values": [
                  "npm",
                  "yarn",
                  "pnpm"
                ]
              }
            }
          },
          {
            "short": "i",
            "long": "independent",
            "description": "use independent versioning mode",
            "inherit": false
          },
          {
            "long": "exact",
            "description": "set the exact version of lerna in the package.json file",
            "inherit": false
          }
        ]
      },
      {
        "name": "bootstrap",
        "description": "bootstrap the packages in the current Lerna repo. Installing all their dependencies and linking any cross-dependencies",
        "options": [
          {
            "description": "include packages matching a glob",
            "inherit": false,
            "long": "scope",
            "value": {
              "name": "glob"
            }
          },
          {
            "description": "exclude packages matching a glob",
            "inherit": false,
            "long": "ignore",
            "value": {
              "name": "glob"
            }
          },
          {
            "description": "exclude private packages",
            "inherit": false,
            "long": "no-private"
          },
          {
            "description": "include packages changed since a ref",
            "inherit": false,
            "long": "since",
            "value": {
              "name": "ref"
            }
          },
          {
            "description": "exclude transitive dependents",
            "inherit": false,
            "long": "exclude-dependents"
          },
          {
            "description": "include transitive dependents",
            "inherit": false,
            "long": "include-dependents"
          },
          {
            "description": "include transitive dependencies",
            "inherit": false,
            "long": "include-dependencies"
          },
          {
            "description": "include tags from merged branches",
            "inherit": false,
            "long": "include-merged-tags"
          },
          {
            "description": "executable to run scripts with",
            "inherit": false,
            "long": "npm-client",
            "value": {
              "name": "client",
              "provider": {
                "values": [
                  "npm",
                  "yarn",
                  "pnpm"
                ]
              }
            }
          },
          {
            "long": "hoist",
            "description": "install external dependencies matching glob at the repo root so they're available to all packages",
            "inherit": false,
            "value": {
              "name": "glob"
            }
          },
          {
            "long": "nohoist",
            "description": "do not install external dependencies matching glob at the repo root. This can be used to opt out of hoisting for certain dependencies",
            "inherit": false,
            "value": {
              "name": "glob"
            }
          },
          {
            "long": "strict",
            "description": "when used in conjunction with hoist will throw an error and stop bootstrapping after emitting the version warnings. Has no effect if you aren't hoisting, or if",
            "inherit": false
          },
          {
            "long": "ignore-prepublish",
            "description": "skip prepublish lifecycle scripts run by default in bootstrapped packages",
            "inherit": false
          },
          {
            "long": "ignore-scripts",
            "description": "skip any lifecycle scripts normally run (prepare, etc) in bootstrapped packages",
            "inherit": false
          },
          {
            "long": "registry",
            "description": "forwarded npm commands will use the specified registry for your package(s)",
            "inherit": false,
            "value": {
              "name": "url"
            }
          },
          {
            "long": "use-workspaces",
            "description": "enables integration with Yarn Workspaces",
            "inherit": false
          },
          {
            "long": "no-ci",
            "description": "disable usage of `npm ci` in CI environments",
            "inherit": false
          },
          {
            "long": "force-local",
            "description": "when passed, this flag causes the bootstrap command to always symlink local dependencies regardless of matching version range",
            "inherit": false
          }
        ]
