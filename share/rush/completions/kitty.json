{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "kitty",
    "options": [
      {
        "short": "T",
        "long": "title",
        "description": "set the OS window title",
        "inherit": false,
        "value": {
          "name": "title"
        }
      },
      {
        "short": "C",
        "long": "config",
        "description": "specify a path to the configuration file(s) to use",
        "inherit": false,
        "value": {
          "name": "config",
          "provider": "builtin.files"
        }
      },
      {
        "short": "o",
        "long": "override",
        "description": "override individual configuration options",
        "repeatable": true,
        "inherit": false
      },
      {
        "short": "d",
        "long": "directory",
        "aliases": [
          "working-directory"
        ],
        "description": "change to the specified directory when launching",
        "inherit": false,
        "value": {
          "name": "directory",
          "provider": "builtin.directories"
        }
      },
      {
        "long": "session",
        "description": "path to a file containing the startup session",
        "inherit": false,
        "value": {
          "name": "session",
          "provider": {
            "values": [
              {
                "value": "-",
                "description": "read from stdin"
              }
            ]
          }
        }
      },
      {
        "long": "hold",
        "description": "remain open after child process exits",
        "inherit": false
      },
      {
        "short": "1",
        "long": "single-instance",
        "description": "only a single instance of kitty will run",
        "inherit": false
      },
      {
        "long": "instance-group",
        "description": "kitty will open a new window in an existing instance and quit immediately",
        "inherit": false,
        "value": {
          "name": "instance-group"
        }
      },
      {
        "long": "wait-for-single-instance-window-close",
        "description": "the new window will not quit till the newly opened window is closed",
        "inherit": false
      },
      {
        "long": "listen-on",
        "description": "tell kitty to listen on the specified address for control messages",
        "inherit": false,
        "value": {
          "name": "listen-on"
        }
      },
      {
        "long": "start-as",
        "description": "control how the initial kitty window is created",
        "inherit": false,
        "value": {
          "name": "start-as",
          "provider": "kitty-window-modes"
        }
      },
      {
        "short": "v",
        "long": "version",
        "description": "the current kitty version",
        "inherit": false
      },
      {
        "short": "h",
        "long": "help",
        "description": "display this help message",
        "inherit": false
      }
