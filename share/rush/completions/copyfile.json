{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "copyfile",
    "description": "copy a file to the clipboard",
    "arguments": {
      "states": [
        {
          "name": "file",
          "provider": "builtin.files",
          "index": 0,
          "description": "file to copy"
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
