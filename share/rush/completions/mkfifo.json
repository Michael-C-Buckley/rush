{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "mkfifo",
    "description": "make named pipes",
    "options": [
      {
        "short": "m",
        "description": "set permission bits for created fifos",
        "inherit": false,
        "value": {
          "name": "mode",
          "provider": {
            "values": [
              "0666",
              "0644",
              "0444"
            ]
          }
        }
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "fifo",
          "description": "fifo to create",
          "index": 0,
          "repeatable": true
        }
      ]
    }
  }
}
