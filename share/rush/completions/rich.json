{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "rich",
    "description": "render rich text in the terminal",
    "options": [
      {
        "short": "p",
        "long": "print",
        "description": "print console markup. See https://rich.readthedocs.io/en/latest/markup.html",
        "inherit": false
      },
      {
        "short": "u",
        "long": "rule",
        "description": "display a horizontal rule",
        "inherit": false
      },
      {
        "short": "j",
        "long": "json",
        "description": "display as JSON",
        "inherit": false
      },
      {
        "short": "m",
        "long": "markdown",
        "description": "display as markdown",
        "inherit": false
      },
      {
        "long": "rst",
        "description": "display restructured text",
        "inherit": false
      },
      {
        "long": "csv",
        "description": "display CSV as a table",
        "inherit": false
      },
      {
        "long": "ipynb",
        "description": "display Jupyter notebook",
        "inherit": false
      },
      {
        "long": "syntax",
        "description": "syntax highlighting",
        "inherit": false
      },
      {
        "long": "inspect",
        "description": "inspect a python object",
        "inherit": false
      },
      {
        "short": "h",
        "long": "head",
        "description": "display first LINES of the file",
        "inherit": false,
        "value": {
          "name": "lines"
        }
      },
      {
        "short": "t",
        "long": "tail",
        "description": "display last LINES of the file",
        "inherit": false,
        "value": {
          "name": "lines"
        }
      },
      {
        "long": "emoji",
        "description": "enable emoji code. e.g. :sparkle:",
        "inherit": false
      },
      {
        "short": "l",
        "long": "left",
        "description": "align to left",
        "inherit": false
      },
      {
        "short": "r",
        "long": "right",
        "description": "align to right",
        "inherit": false
      },
      {
        "short": "c",
        "long": "center",
        "description": "align to center",
        "inherit": false
      },
      {
        "short": "L",
        "long": "text-left",
        "description": "justify text to left",
        "inherit": false
      },
      {
        "short": "R",
        "long": "text-right",
        "description": "justify text to right",
        "inherit": false
      },
      {
        "short": "C",
        "long": "text-center",
        "description": "justify text to center",
        "inherit": false
      },
      {
        "short": "F",
        "long": "text-full",
        "description": "justify text to both left and right edges",
        "inherit": false
      },
      {
        "long": "soft",
        "description": "enable soft wrapping of text",
        "inherit": false,
        "requires": [
          "--print"
        ]
      },
      {
        "short": "e",
        "long": "expand",
        "description": "expand to full width",
        "inherit": false,
        "requires": [
          "--panel"
        ]
      },
      {
        "short": "w",
        "long": "width",
        "description": "fit output to SIZE characters",
        "inherit": false,
        "value": {
          "name": "size"
        }
      },
      {
        "short": "W",
        "long": "max-width",
        "description": "set maximum width to SIZE characters",
        "inherit": false,
        "value": {
          "name": "size"
        }
      },
      {
        "short": "s",
        "long": "style",
        "description": "set text style to STYLE",
        "inherit": false,
        "value": {
          "name": "style"
        }
      },
      {
        "long": "rule-style",
        "description": "set rule style to STYLE",
        "inherit": false,
        "value": {
          "name": "style"
        },
        "requires": [
          "--rule"
        ]
      },
      {
        "long": "rule-char",
        "description": "use CHARACTER to generate a line with --rule",
        "inherit": false,
        "value": {
          "name": "character"
        },
        "requires": [
          "--rule"
        ]
      },
      {
        "short": "d",
        "long": "padding",
        "description": "padding around output. 1, 2 or 4 comma separated integers, e.g. 2,4",
        "inherit": false,
        "value": {
          "name": "padding"
        }
      },
      {
        "short": "a",
        "long": "panel",
        "description": "set panel type to BOX",
        "inherit": false,
        "value": {
          "name": "box",
          "provider": {
            "values": [
              "ascii",
              "ascii2",
              "double",
              "heavy",
              "none",
              "rounded",
              "square"
            ]
          }
        }
      },
      {
        "short": "S",
        "long": "panel-style",
        "description": "set the panel style to STYLE",
        "inherit": false,
        "value": {
          "name": "style"
        },
        "requires": [
          "--panel"
        ]
      },
      {
        "long": "theme",
        "description": "set syntax theme to THEME. See https://pygments.org/styles/",
        "inherit": false,
        "value": {
          "name": "theme",
          "provider": {
