{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "event",
    "description": "manage shell event hooks",
    "providers": {
      "event.names": {
        "values": [
          { "value": "directory.change", "description": "after the current directory changes" },
          { "value": "prompt.prepare", "description": "before each prompt render" },
          { "value": "prompt.async.start", "description": "when prompt async work becomes active" },
          { "value": "prompt.async.end", "description": "when prompt async work becomes inactive" },
          { "value": "completion.async.start", "description": "when completion async work starts" },
          { "value": "completion.async.end", "description": "when completion async work ends" },
          { "value": "job.start", "description": "when background jobs become active" },
          { "value": "job.end", "description": "when background jobs become inactive" },
          { "value": "timer.tick", "description": "while the editor is idle" }
        ]
      },
      "event.registrations": { "function": "__rush_complete_event_registrations" }
    },
    "subcommands": [
      {
        "name": "add",
        "description": "add or replace a hook",
        "options": [
          { "long": "priority", "value": { "name": "number" }, "description": "set hook ordering priority" },
          { "long": "every", "value": { "name": "milliseconds" }, "description": "set timer interval" }
        ],
        "arguments": {
          "states": [
            { "name": "event", "index": 0, "provider": "event.names", "description": "event to observe" },
            { "name": "name", "index": 1, "description": "registration name" },
            { "name": "function", "index": 2, "provider": "builtin.functions", "description": "function to run" }
          ]
        }
      },
      {
        "name": "remove",
        "description": "remove a hook",
        "arguments": {
          "states": [
            { "name": "event", "index": 0, "provider": "event.names", "description": "event to edit" },
            { "name": "name", "index": 1, "provider": "event.registrations", "description": "registration to remove" }
          ]
        }
      },
      {
        "name": "list",
        "description": "list registered hooks",
        "options": [
          { "long": "json", "description": "print registrations as json" }
        ],
        "arguments": {
          "states": [
            { "name": "event", "index": 0, "provider": "event.names", "description": "event to list" }
          ]
        }
      }
    ]
  }
}
