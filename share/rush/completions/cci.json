                "inherit": false
              },
              {
                "long": "help",
                "description": "help for install_playwright",
                "inherit": false
              }
            ]
          },
          {
            "name": "uninstall_playwright",
            "description": "uninstalls the robotframework-browser package and node modules",
            "options": [
              {
                "long": "help",
                "description": "help for uninstall_playwright",
                "inherit": false
              }
            ]
          }
        ]
      },
