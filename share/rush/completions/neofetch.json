        "inherit": false,
        "value": {
          "name": "https://..."
        }
      },
      {
        "long": "ip_timeout",
        "description": "Public IP timeout",
        "inherit": false,
        "value": {
          "name": "X-seconds"
        }
      },
      {
        "long": "memory_percent",
        "description": "Display memory percentage",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "memory_unit",
        "description": "Memory output unit",
        "inherit": false,
        "value": {
          "name": "unit",
          "provider": {
            "values": [
              "kib",
              "mib",
              "gib"
            ]
          }
        }
      },
      {
        "long": "colors",
        "description": "Changes the text colors",
        "inherit": false,
        "value": [
          {
            "name": "Title"
          },
          {
            "name": "@"
          },
          {
            "name": "Underline"
          },
          {
            "name": "Subtitle"
          },
          {
            "name": "Colon"
          },
          {
            "name": "Info"
          }
        ]
      },
      {
        "long": "underline",
        "description": "Enable/Disable the underline",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "underline_char",
        "description": "Character to use when underlining title",
        "inherit": false,
        "value": {
          "name": "char"
        }
      },
      {
        "long": "bold",
        "description": "Enable/Disable bold text",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
