    "arguments": {
      "states": [
        {
          "name": "info-line",
          "index": 0,
          "repeatable": true,
          "required": false,
          "provider": {
            "values": [
              "os",
              "host",
              "kernel",
              "uptime",
              "packages",
              "shell",
              "term",
              "cpu",
              "gpu",
              "memory",
              "disk",
              "battery",
              "resolution",
              "wm",
              "de",
              "theme",
              "wm_theme",
              "icons"
