{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "neofetch",
    "description": "show system information",
    "options": [
      {
        "long": "help",
        "short": "h",
        "description": "show help",
        "inherit": false
      },
      {
        "long": "disable",
        "description": "Disable information line",
        "inherit": false,
        "value": {
          "name": "info-line",
          "provider": {
            "values": [
              "os",
              "host",
              "kernel",
              "uptime",
              "packages",
              "shell",
              "term",
              "cpu",
              "gpu",
              "memory",
              "disk",
              "battery",
              "resolution",
              "wm",
              "de",
              "theme",
              "wm_theme",
              "icons"
            ]
          }
        }
      },
      {
        "long": "title_fqdn",
        "description": "Hide/Show Fully Qualified Domain Name in title",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "package_managers",
        "description": "Hide/Show Package Manager names",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off",
              "tiny"
            ]
          }
        }
      },
      {
        "long": "os_arch",
        "description": "Hide/Show OS architecture",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "speed_type",
        "description": "Change the type of cpu speed to display",
        "inherit": false,
        "value": {
          "name": "type",
          "provider": {
            "values": [
              "current",
              "min",
              "bios",
              "scaling_current",
              "scaling_min",
              "scaling_max"
            ]
          }
        }
      },
      {
        "long": "speed_shorthand",
        "description": "Whether or not to show decimals in CPU speed",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "cpu_brand",
        "description": "Enable/Disable CPU brand in output",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "cpu_cores",
        "description": "Whether or not to display the number of CPU cores",
        "inherit": false,
        "value": {
          "name": "type",
          "provider": {
            "values": [
              "logical",
              "physical",
              "off"
            ]
          }
        }
      },
      {
        "long": "cpu_speed",
        "description": "Hide/Show cpu speed",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "cpu_temp",
        "description": "Hide/Show cpu temperature",
        "inherit": false,
        "value": {
          "name": "unit/off",
          "provider": {
            "values": [
              "C",
              "F",
              "off"
            ]
          }
        }
      },
      {
        "long": "distro_shorthand",
        "description": "Shorten the output of distro",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off",
              "tiny"
            ]
          }
        }
      },
      {
        "long": "kernel_shorthand",
        "description": "Shorten the output of kernel",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off",
              "tiny"
            ]
          }
        }
      },
      {
        "long": "uptime_shorthand",
        "description": "Shorten the output of uptime",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off",
              "tiny"
            ]
          }
        }
      },
      {
        "long": "refresh_rate",
        "description": "Whether to display the refresh rate of each monitor",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "gpu_brand",
        "description": "Enable/Disable GPU brand in output",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
