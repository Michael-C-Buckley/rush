        "inherit": false,
        "value": {
          "name": "disk",
          "provider": {
            "values": [
              "/dev/sd",
              "/dev/nvme",
              "/dev/mmcblk",
              "/dev/mapper",
              "/mnt",
              "/run/media"
            ]
          }
        }
      },
      {
        "long": "disk_subtitle",
        "description": "What information to append to the Disk subtitle",
        "inherit": false,
        "value": {
          "name": "type",
          "provider": {
            "values": [
              "name",
              "mount",
              "dir",
              "none"
            ]
          }
        }
      },
      {
        "long": "disk_percent",
        "description": "Hide/Show disk percent",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "ip_host",
