        "long": "gtk_shorthand",
        "description": "Shorten output of gtk theme/icons",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off",
              "tiny"
            ]
          }
        }
      },
      {
        "long": "gtk2",
        "description": "Enable/Disable gtk2 theme/font/icons output",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "gtk3",
        "description": "Enable/Disable gtk3 theme/font/icons output",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "shell_path",
        "description": "Enable/Disable showing $SHELL path",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "shell_version",
        "description": "Enable/Disable showing $SHELL version",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
