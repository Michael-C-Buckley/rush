        "long": "gpu_type",
        "description": "Which GPU to display",
        "inherit": false,
        "value": {
          "name": "type",
          "provider": {
            "values": [
              "all",
              "dedicated",
              "integrated"
            ]
          }
        }
      },
      {
        "long": "de_version",
        "description": "Show/Hide Desktop Environment version",
        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
