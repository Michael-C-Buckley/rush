        "inherit": false
      },
      {
        "long": "pot",
        "description": "Same as --backend pot",
        "inherit": false
      },
      {
        "long": "pixterm",
        "description": "Same as --backend pixterm",
        "inherit": false
      },
      {
        "long": "sixel",
        "description": "Same as --backend sixel",
        "inherit": false
      },
      {
        "long": "termpix",
