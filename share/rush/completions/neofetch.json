        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "bar_length",
        "description": "Length in spaces to make the bars",
        "inherit": false,
        "value": {
          "name": "number"
        }
      },
      {
        "long": "bar_colors",
        "description": "Colors to make the bar",
        "inherit": false,
        "value": [
          {
            "name": "Elapsed"
          },
          {
            "name": "Total"
          }
        ]
