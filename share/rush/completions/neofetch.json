      {
        "long": "block_width",
        "description": "Width of color blocks in spaces",
        "inherit": false,
        "value": {
          "name": "number"
        }
      },
      {
        "long": "block_height",
        "description": "Height of color blocks in lines",
        "inherit": false,
        "value": {
          "name": "number"
        }
