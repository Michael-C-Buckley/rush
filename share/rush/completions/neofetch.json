        "inherit": false,
        "value": {
          "name": "on/off",
          "provider": {
            "values": [
              "on",
              "off"
            ]
          }
        }
      },
      {
        "long": "col_offset",
        "description": "Left-padding of color blocks",
        "inherit": false,
        "value": {
          "name": "number",
          "provider": {
            "values": [
              "auto"
            ]
          }
        }
