        "inherit": false,
        "value": {
          "name": "mode",
          "provider": {
            "values": [
              "bar",
              "infobar",
              "barinfo",
              "off"
            ]
          }
        }
      },
      {
        "long": "memory_display",
        "description": "Memory display mode",
        "inherit": false,
        "value": {
          "name": "mode",
          "provider": {
            "values": [
              "bar",
              "infobar",
              "barinfo",
              "off"
            ]
          }
        }
      },
      {
        "long": "battery_display",
        "description": "Battery display mode",
        "inherit": false,
        "value": {
          "name": "mode",
          "provider": {
            "values": [
              "bar",
              "infobar",
              "barinfo",
              "off"
            ]
          }
        }
      },
      {
        "long": "disk_display",
        "description": "Disk display mode",
        "inherit": false,
        "value": {
          "name": "mode",
          "provider": {
            "values": [
              "bar",
              "infobar",
              "barinfo",
              "off"
            ]
          }
        }
