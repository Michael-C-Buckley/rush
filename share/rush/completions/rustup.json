        "subcommands": [
          {
            "name": "list",
            "description": "list installed and available targets",
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "prints help information",
                "inherit": false
              },
              {
                "short": "V",
                "long": "version",
                "description": "prints version information",
                "inherit": false
              }
