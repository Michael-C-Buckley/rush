            "arguments": {
              "states": [
                {
                  "name": "target",
                  "description": "target triple",
                  "index": 0,
                  "provider": "rustup.targets"
                }
              ]
            }
          },
          {
            "name": "remove",
            "description": "remove a target from a Rust toolchain",
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "prints help information",
                "inherit": false
              },
              {
                "short": "V",
                "long": "version",
                "description": "prints version information",
                "inherit": false
              },
              {
                "long": "toolchain",
                "inherit": false,
                "value": {
                  "name": "toolchain",
                  "description": "toolchain name",
                  "provider": "rustup.toolchains"
                }
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "target",
                  "description": "target triple",
                  "index": 0,
                  "provider": "rustup.targets"
                }
              ]
            }
          },
          {
            "name": "help",
            "description": "prints this message or the help of the given subcommand(s)",
            "options": [
              {
                "short": "h",
                "long": "help",
                "description": "prints help information",
                "inherit": false
              },
              {
                "short": "V",
                "long": "version",
                "description": "prints version information",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "subcommand",
                  "index": 0
                }
              ]
            }
          }
        ]
