            "inherit": false,
            "value": {
              "name": "runtime",
              "provider": {
                "values": [
                  "dotnet8",
                  "dotnet6",
                  "go1.x",
                  "java21",
                  "java17",
                  "java11",
                  "java8.al2",
                  "nodejs20.x",
                  "nodejs18.x",
                  "nodejs16.x",
                  "provided.al2023",
                  "provided.al2",
                  "provided",
                  "python3.12",
                  "python3.11",
                  "python3.10",
                  "python3.9",
                  "python3.8",
                  "ruby3.2"
