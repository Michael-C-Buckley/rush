{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "rmdir",
    "description": "remove empty directories",
    "providers": {
      "builtin.directories": { "builtin": "directories" }
    },
    "options": [
      {
        "short": "p",
        "description": "remove parent directories if they become empty"
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "directory",
          "index": 0,
          "repeatable": true,
          "provider": "builtin.directories",
          "description": "directory to remove"
        }
      ]
    }
  }
}
