{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "premake",
    "description": "generate project files with Premake",
    "options": [
      {
        "long": "help",
        "short": "h",
        "description": "show actions",
        "inherit": false
      },
      {
        "long": "version",
        "description": "show version",
        "inherit": false
      }
    ],
    "subcommands": [
      {
        "name": "clean",
        "description": "remove all binaries and generated files",
        "options": [
          {
            "long": "file",
            "description": "set premake5.lua file",
            "inherit": false,
            "value": {
              "name": "file",
              "provider": "builtin.files"
            }
          },
          {
            "long": "debugger",
            "description": "start MobDebug debugger",
            "inherit": false
          },
          {
            "long": "fatal",
            "description": "treat script warnings as errors",
            "inherit": false
          },
          {
            "long": "insecure",
            "description": "skip SSH certificate checks",
            "inherit": false
          },
          {
            "long": "interactive",
            "description": "start interactive prompt",
            "inherit": false
          },
          {
            "long": "os",
            "description": "set target operating system",
            "inherit": false,
            "value": {
              "name": "os",
              "provider": "premake.operating-systems"
            }
          },
          {
            "long": "scripts",
            "description": "add scripts search path",
            "inherit": false,
            "value": {
              "name": "path",
              "provider": "builtin.directories"
            }
          },
          {
            "long": "systemscript",
            "description": "set system script",
            "inherit": false,
            "value": {
              "name": "script",
              "provider": "builtin.files"
            }
          },
          {
            "long": "verbose",
            "description": "show debug output",
            "inherit": false
          },
          {
            "long": "cc",
            "description": "set C/C++ compiler",
            "inherit": false,
            "value": {
              "name": "cc",
              "provider": "premake.c-compilers"
            }
          },
          {
            "long": "dc",
            "description": "set D compiler",
            "inherit": false,
            "value": {
              "name": "dc",
              "provider": "premake.d-compilers"
            }
          },
          {
            "long": "dotnet",
            "description": "set .NET compiler",
            "inherit": false,
            "value": {
              "name": "dotnet",
              "provider": "premake.dotnet-compilers"
            }
          }
        ]
      },
