{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "php",
    "description": "run the PHP interpreter",
    "arguments": {
      "states": [
        {
          "name": "script",
          "description": "PHP script or path",
          "provider": "builtin.files",
          "index": 0
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
