{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "tac",
    "description": "print files in reverse",
    "options": [
      {
        "long": "help",
        "description": "show help",
        "inherit": false
      },
      {
        "long": "before",
        "short": "b",
        "description": "attach separator before records",
        "inherit": false
      },
      {
        "long": "regex",
        "short": "r",
        "description": "treat separator as regex",
        "inherit": false
      },
      {
        "long": "separator",
        "short": "s",
        "description": "set record separator",
        "inherit": false,
        "value": {
          "name": "string"
        }
      },
      {
        "long": "version",
        "description": "show version",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "file",
          "provider": "builtin.files",
          "index": 0,
          "repeatable": true
        }
      ]
    },
    "providers": {
      "builtin.files": {
        "builtin": "files"
      }
    }
  }
}
