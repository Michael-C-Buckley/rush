# Extensive first-party Git completion slice using Rush's structured DSL.

# Global options.
complete git --option --short C --value-name path --description 'run as if git started in path'
complete git --option-value --short C --function __rush_complete_git_directories
complete git --option --long git-dir --value-name path --description 'path to the repository'
complete git --option-value --long git-dir --function __rush_complete_git_directories
complete git --option --long work-tree --value-name path --description 'path to the working tree'
complete git --option-value --long work-tree --function __rush_complete_git_directories
complete git --option --long help --description 'show help'
complete git --option --long version --description 'show version'
complete git --option --long paginate --description 'pipe output into a pager'
complete git --option --long no-pager --description 'do not pipe output into a pager'
complete git --option --long bare --description 'treat repository as bare'
complete git --option --long namespace --value-name name --description 'set the Git namespace'
complete git --option --long exec-path --value-name path --description 'path to Git core programs'
complete git --option-value --long exec-path --function __rush_complete_git_directories
complete git --option --long html-path --description 'print path to Git HTML documentation'
complete git --option --long man-path --description 'print manpath for Git man pages'
complete git --option --long info-path --description 'print path to Git info files'
complete git --option --short p --description 'page all output'
complete git --option --long no-replace-objects --description 'do not use replacement refs'
complete git --option --long literal-pathspecs --description 'treat pathspecs literally'
complete git --option --long glob-pathspecs --description 'treat pathspecs as glob patterns'
complete git --option --long noglob-pathspecs --description 'treat pathspecs literally'
complete git --option --long icase-pathspecs --description 'match pathspecs case-insensitively'
complete git --option --short c --value-name name=value --description 'pass a configuration parameter'
complete git --option --long config-env --value-name name=envvar --description 'pass config from an environment variable'

# Root subcommands. Static descriptions cover common commands; the dynamic
# provider below also exposes aliases and git-* extension commands known to Git.
complete git --subcommand add --description 'add file contents to the index'
complete git --subcommand branch --description 'list, create, or delete branches'
complete git --subcommand checkout --description 'switch branches or restore paths'
complete git --subcommand cherry-pick --description 'apply existing commits'
complete git --subcommand clone --description 'clone a repository'
complete git --subcommand commit --description 'record changes to the repository'
complete git --subcommand config --description 'get and set repository or global options'
complete git --subcommand describe --description 'name an object using refs'
complete git --subcommand diff --description 'show changes'
complete git --subcommand difftool --description 'show changes using common diff tools'
complete git --subcommand fetch --description 'download objects and refs from another repository'
complete git --subcommand format-patch --description 'prepare patches for email submission'
complete git --subcommand grep --description 'print lines matching a pattern'
complete git --subcommand init --description 'create an empty repository'
complete git --subcommand log --description 'show commit logs'
complete git --subcommand ls-files --description 'show information about files in the index and working tree'
complete git --subcommand maintenance --description 'run tasks to optimize repository data'
complete git --subcommand merge --description 'join development histories'
complete git --subcommand mergetool --description 'run merge conflict resolution tools'
complete git --subcommand mv --description 'move or rename a file'
complete git --subcommand notes --description 'add or inspect object notes'
complete git --subcommand pull --description 'fetch from and integrate with another repository'
complete git --subcommand push --description 'update remote refs'
complete git --subcommand range-diff --description 'compare two commit ranges'
complete git --subcommand rebase --description 'reapply commits on top of another base'
complete git --subcommand reflog --description 'manage reflog information'
complete git --subcommand remote --description 'manage tracked repositories'
complete git --subcommand reset --description 'reset current HEAD'
complete git --subcommand revert --description 'revert existing commits'
complete git --subcommand restore --description 'restore working tree files'
complete git --subcommand rm --description 'remove files from the working tree and index'
complete git --subcommand shortlog --description 'summarize git log output'
complete git --subcommand show --description 'show objects'
complete git --subcommand sparse-checkout --description 'reduce the working tree to a subset of files'
complete git --subcommand stash --description 'stash working tree changes'
complete git --subcommand status --description 'show the working tree status'
complete git --subcommand submodule --description 'initialize, update, or inspect submodules'
complete git --subcommand switch --description 'switch branches'
complete git --subcommand tag --description 'create, list, delete, or verify tags'
complete git --subcommands --function __rush_complete_git_commands

# add
complete 'git add' --option --long patch --short p --description 'interactively choose hunks'
complete 'git add' --option --long all --short A --description 'add changes from the whole tree'
complete 'git add' --option --long update --short u --description 'update tracked files'
complete 'git add' --option --long dry-run --short n --description 'show if files exist or are ignored without adding'
complete 'git add' --option --long verbose --short v --description 'be verbose'
complete 'git add' --option --long force --short f --description 'allow adding ignored files'
complete 'git add' --option --long interactive --short i --description 'add modified contents interactively'
complete 'git add' --option --long edit --short e --description 'edit the patch before applying'
complete 'git add' --option --long intent-to-add --short N --description 'record only that the path will be added later'
complete 'git add' --option --long refresh --description 'do not add files; refresh stat information only'
complete 'git add' --option --long ignore-errors --description 'continue adding files after errors'
complete 'git add' --option --long ignore-missing --description 'check ignored or missing files with dry-run'
complete 'git add' --option --long sparse --description 'allow updating entries outside the sparse-checkout cone'
complete 'git add' --argument --function __rush_complete_git_paths

# branch
complete 'git branch' --option --long all --short a --description 'list remote-tracking and local branches'
complete 'git branch' --option --long remotes --short r --description 'list or delete remote-tracking branches'
complete 'git branch' --option --long delete --short d --description 'delete a branch'
complete 'git branch' --option --short D --description 'delete a branch irrespective of merged status'
complete 'git branch' --option --long force --short f --description 'force creation, move, or deletion'
complete 'git branch' --option --long move --short m --description 'move or rename a branch'
complete 'git branch' --option --short M --description 'move or rename a branch even if target exists'
complete 'git branch' --option --long copy --short c --description 'copy a branch and its reflog'
complete 'git branch' --option --short C --description 'copy a branch even if target exists'
complete 'git branch' --option --long list --description 'list branches'
complete 'git branch' --option --long show-current --description 'print the current branch name'
complete 'git branch' --option --long verbose --short v --description 'show sha1 and commit subject'
complete 'git branch' --option --long quiet --short q --description 'be more quiet'
complete 'git branch' --option --long track --description 'set up upstream configuration'
complete 'git branch' --option --long no-track --description 'do not set up upstream configuration'
complete 'git branch' --option --long set-upstream-to --short u --value-name upstream --description 'change upstream information'
complete 'git branch' --option-value --long set-upstream-to --function __rush_complete_git_remote_branches
complete 'git branch' --option-value --short u --function __rush_complete_git_remote_branches
complete 'git branch' --option --long unset-upstream --description 'remove upstream information'
complete 'git branch' --option --long merged --value-name commit --description 'list branches merged into commit'
complete 'git branch' --option --long no-merged --value-name commit --description 'list branches not merged into commit'
complete 'git branch' --option --long contains --value-name commit --description 'list branches containing commit'
complete 'git branch' --option --long no-contains --value-name commit --description 'list branches not containing commit'
complete 'git branch' --option --long sort --value-name key --description 'sort branches by key'
complete 'git branch' --option --long column --value-name options --description 'list branches in columns'
complete 'git branch' --option --long no-column --description 'do not list branches in columns'
complete 'git branch' --argument --function __rush_complete_git_branches

# checkout / switch
complete 'git checkout' --option --long branch --description 'create and checkout a new branch'
complete 'git checkout' --option --short b --value-name branch --description 'create and checkout a new branch'
complete 'git checkout' --option --short B --value-name branch --description 'create/reset and checkout a branch'
complete 'git checkout' --option --long force --short f --description 'force checkout'
complete 'git checkout' --option --long detach --description 'detach HEAD'
complete 'git checkout' --option --long orphan --value-name branch --description 'create a new orphan branch'
complete 'git checkout' --option --long ours --description 'checkout our version for unmerged paths'
complete 'git checkout' --option --long theirs --description 'checkout their version for unmerged paths'
complete 'git checkout' --option --long merge --short m --description 'perform a three-way merge with the new branch'
complete 'git checkout' --option --long patch --short p --description 'select hunks interactively'
complete 'git checkout' --option --long track --description 'set up upstream configuration'
complete 'git checkout' --option --long no-track --description 'do not set up upstream configuration'
complete 'git checkout' --option --long recurse-submodules --description 'update submodules according to recorded commits'
complete 'git checkout' --option --long no-recurse-submodules --description 'do not update submodules'
complete 'git checkout' --argument --function __rush_complete_git_refs
complete 'git switch' --option --long create --short c --value-name branch --description 'create a new branch'
complete 'git switch' --option --short C --value-name branch --description 'create/reset and switch to a branch'
complete 'git switch' --option --long detach --description 'detach HEAD'
complete 'git switch' --option --long force --short f --description 'force switch'
complete 'git switch' --option --long guess --description 'guess a branch from matching remote-tracking branches'
complete 'git switch' --option --long no-guess --description 'do not guess a branch from remote-tracking branches'
complete 'git switch' --option --long discard-changes --description 'discard local changes'
complete 'git switch' --option --long merge --short m --description 'perform a three-way merge with the new branch'
complete 'git switch' --option --long track --description 'set up upstream configuration'
complete 'git switch' --option --long no-track --description 'do not set up upstream configuration'
complete 'git switch' --option --long orphan --value-name branch --description 'create a new orphan branch'
complete 'git switch' --argument --function __rush_complete_git_branches

# commit
complete 'git commit' --option --long amend --description 'amend the previous commit'
complete 'git commit' --option --long all --short a --description 'stage tracked files before committing'
complete 'git commit' --option --long message --short m --value-name message --description 'use the given commit message'
complete 'git commit' --option --long signoff --short s --description 'add a Signed-off-by trailer'
complete 'git commit' --option --long no-verify --description 'bypass pre-commit and commit-msg hooks'
complete 'git commit' --option --long verbose --short v --description 'show unified diff in commit message template'
complete 'git commit' --option --long quiet --short q --description 'suppress commit summary message'
complete 'git commit' --option --long dry-run --description 'show paths to be committed without committing'
complete 'git commit' --option --long short --description 'show dry-run output in short format'
complete 'git commit' --option --long branch --description 'show branch and tracking info in dry-run output'
complete 'git commit' --option --long porcelain --description 'show dry-run output in porcelain format'
complete 'git commit' --option --long long --description 'show dry-run output in long format'
complete 'git commit' --option --long null --short z --description 'terminate dry-run entries with NUL'
