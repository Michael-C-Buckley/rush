  completion candidate false --kind plain
  completion candidate merges --kind plain
  completion candidate interactive --kind plain
}

__rush_complete_git_signed_modes() {
  completion candidate true --kind plain
  completion candidate false --kind plain
  completion candidate if-asked --kind plain
}

__rush_complete_git_merge_strategies() {
  completion candidate ort --kind plain --description 'default single-head merge strategy'
  completion candidate recursive --kind plain --description 'historical single-head merge strategy'
  completion candidate resolve --kind plain --description 'simple two-head merge strategy'
  completion candidate octopus --kind plain --description 'multi-head merge strategy'
  completion candidate ours --kind plain --description 'resolve by keeping our tree'
  completion candidate subtree --kind plain --description 'recursive strategy adjusted for subtrees'
}

__rush_complete_git_conflict_styles() {
  completion candidate merge --kind plain
  completion candidate diff3 --kind plain
  completion candidate zdiff3 --kind plain
}

__rush_complete_git_config_types() {
  completion candidate bool --kind plain
  completion candidate int --kind plain
  completion candidate bool-or-int --kind plain
  completion candidate path --kind plain
  completion candidate expiry-date --kind plain
  completion candidate color --kind plain
}

__rush_complete_git_object_formats() {
  completion candidate sha1 --kind plain
  completion candidate sha256 --kind plain
}

__rush_complete_git_ref_formats() {
  completion candidate files --kind plain
  completion candidate reftable --kind plain
}

__rush_complete_git_untracked_modes() {
  completion candidate no --kind plain
  completion candidate normal --kind plain
  completion candidate all --kind plain
}

__rush_complete_git_ignored_modes() {
  completion candidate traditional --kind plain
  completion candidate matching --kind plain
  completion candidate no --kind plain
}

__rush_complete_git_ignore_submodules_modes() {
  completion candidate none --kind plain
  completion candidate untracked --kind plain
  completion candidate dirty --kind plain
  completion candidate all --kind plain
}

__rush_complete_git_maintenance_schedules() {
  completion candidate hourly --kind plain
  completion candidate daily --kind plain
  completion candidate weekly --kind plain
}

__rush_complete_git_maintenance_tasks() {
  completion candidate commit-graph --kind plain
  completion candidate gc --kind plain
  completion candidate loose-objects --kind plain
  completion candidate incremental-repack --kind plain
  completion candidate pack-refs --kind plain
  completion candidate prefetch --kind plain
}

# Async-friendly dynamic overlays for repository-aware path and ref completion.
complete 'git add' --argument --function __rush_complete_git_changed_paths
complete 'git commit' --argument --function __rush_complete_git_changed_paths
complete 'git diff' --argument --function __rush_complete_git_diff_args
complete 'git restore' --argument --function __rush_complete_git_changed_paths
complete 'git rm' --argument --function __rush_complete_git_tracked_paths
complete 'git reset' --argument --function __rush_complete_git_reset_args
complete 'git checkout' --argument --function __rush_complete_git_checkout_args
complete 'git switch' --argument --function __rush_complete_git_branches
complete 'git push' --argument --function __rush_complete_git_push_args
complete 'git remote set-url' --argument --function __rush_complete_git_remote_url_args
complete 'git remote get-url' --argument --function __rush_complete_git_remotes
complete 'git remote remove' --argument --function __rush_complete_git_remotes
complete 'git remote rm' --argument --function __rush_complete_git_remotes
complete 'git remote rename' --argument --function __rush_complete_git_remotes
complete 'git branch' --option-value --long sort --function __rush_complete_git_sort_keys
complete 'git log' --option-value --long author --function __rush_complete_git_authors
complete 'git log' --option-value --long committer --function __rush_complete_git_authors
complete 'git commit' --option-value --long author --function __rush_complete_git_authors

__rush_complete_git_changed_paths() {
  git status --porcelain=v1 -z 2>/dev/null | tr '\0' '\n' | sed 's/^...//' | while read path; do test -n "$path" && completion candidate "$path" --kind file; done
  completion files
}

__rush_complete_git_tracked_paths() {
  git ls-files 2>/dev/null | while read path; do test -n "$path" && completion candidate "$path" --kind file; done
  completion files
}

__rush_complete_git_untracked_paths() {
  git ls-files --others --exclude-standard 2>/dev/null | while read path; do test -n "$path" && completion candidate "$path" --kind file; done
  completion files
}

__rush_complete_git_diff_args() {
  __rush_complete_git_refs
  git diff --name-only 2>/dev/null | while read path; do test -n "$path" && completion candidate "$path" --kind file; done
  git diff --cached --name-only 2>/dev/null | while read path; do test -n "$path" && completion candidate "$path" --kind file; done
}

__rush_complete_git_reset_args() {
  __rush_complete_git_refs
  git diff --cached --name-only 2>/dev/null | while read path; do test -n "$path" && completion candidate "$path" --kind file; done
}

__rush_complete_git_checkout_args() {
  __rush_complete_git_refs
  __rush_complete_git_remote_branches
  __rush_complete_git_changed_paths
}

__rush_complete_git_push_args() {
  if test "$(completion argument-index)" = 1; then
    __rush_complete_git_remotes
  else
    __rush_complete_git_branches
    __rush_complete_git_tags
  fi
}

__rush_complete_git_remote_url_args() {
  if test "$(completion argument-index)" = 1; then
    __rush_complete_git_remotes
  else
    git remote -v 2>/dev/null | awk '{ print $2 }' | while read url; do test -n "$url" && completion candidate "$url" --kind plain; done
    completion candidate git@github.com: --kind plain
    completion candidate https://github.com/ --kind plain
  fi
}

__rush_complete_git_authors() {
  git log --format='%aN <%aE>' --all 2>/dev/null | sort -u | while read author; do test -n "$author" && completion candidate "$author" --kind plain; done
}

__rush_complete_git_sort_keys() {
  completion candidate refname --kind plain
  completion candidate -committerdate --kind plain
  completion candidate committerdate --kind plain
  completion candidate authordate --kind plain
  completion candidate -authordate --kind plain
  completion candidate upstream --kind plain
}

# Manifest-backed first-party Git providers. These use Rush's parsed completion
# context instead of re-parsing the command line in shell code.

__rush_complete_git_worktree_changed_paths() {
  tmp=$(mktemp)
  git diff --name-only > "$tmp" 2>/dev/null
  while read path; do test -n "$path" && completion candidate "$path" --kind file --description 'worktree path'; done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_staged_paths() {
  tmp=$(mktemp)
  git diff --cached --name-only > "$tmp" 2>/dev/null
  while read path; do test -n "$path" && completion candidate "$path" --kind file --description 'staged path'; done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_tree_paths() {
  tree="$1"
  tmp=$(mktemp)
  if test -n "$tree"; then
    git ls-tree -r --name-only "$tree" > "$tmp" 2>/dev/null
    while read path; do test -n "$path" && completion candidate "$path" --kind file --description 'tree path'; done < "$tmp"
  else
    git ls-files > "$tmp" 2>/dev/null
    while read path; do test -n "$path" && completion candidate "$path" --kind file --description 'tracked path'; done < "$tmp"
  fi
  rm -f "$tmp"
}

__rush_complete_git_untracked_clean_paths() {
  tmp=$(mktemp)
  git ls-files --others --exclude-standard > "$tmp" 2>/dev/null
  while read path; do test -n "$path" && completion candidate "$path" --kind file --description 'untracked path'; done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_ignored_clean_paths() {
  tmp=$(mktemp)
  git ls-files --others --ignored --exclude-standard > "$tmp" 2>/dev/null
  while read path; do test -n "$path" && completion candidate "$path" --kind file --description 'ignored path'; done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_context_diff_args() {
  if test "$(completion option-present --long no-index)" = true; then
    completion files
  else
    if test "$(completion option-present --long staged)" = true; then
      if test "$(completion options-terminated)" = true; then
        __rush_complete_git_staged_paths
      else
        if test "$(completion argument-index)" = 0; then
          __rush_complete_git_refs
          __rush_complete_git_staged_paths
        else
          __rush_complete_git_staged_paths
        fi
      fi
    else
      if test "$(completion option-present --long cached)" = true; then
        if test "$(completion options-terminated)" = true; then
          __rush_complete_git_staged_paths
        else
          if test "$(completion argument-index)" = 0; then
            __rush_complete_git_refs
            __rush_complete_git_staged_paths
          else
            __rush_complete_git_staged_paths
          fi
        fi
      else
        if test "$(completion options-terminated)" = true; then
          __rush_complete_git_worktree_changed_paths
        else
          __rush_complete_git_refs
        fi
      fi
    fi
  fi
}

__rush_complete_git_context_checkout_args() {
  if test "$(completion options-terminated)" = true; then
    tree="$(completion operand 0)"
    __rush_complete_git_tree_paths "$tree"
  else
    if test "$(completion argument-index)" = 0; then
      __rush_complete_git_branches
      __rush_complete_git_remote_branches
      __rush_complete_git_tags
    else
      __rush_complete_git_changed_paths
    fi
  fi
}

__rush_complete_git_context_switch_args() {
  __rush_complete_git_branches
  __rush_complete_git_remote_branches
}

__rush_complete_git_context_restore_paths() {
  tree=
  for value in $(completion option-values --long source); do tree="$value"; done
  if test -n "$tree"; then
    __rush_complete_git_tree_paths "$tree"
  else
    if test "$(completion option-present --long staged)" = true; then
      __rush_complete_git_staged_paths
    else
      __rush_complete_git_worktree_changed_paths
    fi
  fi
}

__rush_complete_git_reset_mode_present() {
  if test "$(completion option-present --long soft)" = true; then return 0; fi
  if test "$(completion option-present --long mixed)" = true; then return 0; fi
  if test "$(completion option-present --long hard)" = true; then return 0; fi
  if test "$(completion option-present --long merge)" = true; then return 0; fi
  if test "$(completion option-present --long keep)" = true; then return 0; fi
  return 1
}

__rush_complete_git_context_reset_args() {
  if test "$(completion options-terminated)" = true; then
    __rush_complete_git_staged_paths
  else
    if test "$(completion argument-index)" = 0; then
      if __rush_complete_git_reset_mode_present; then
        __rush_complete_git_refs
      else
        __rush_complete_git_refs
        __rush_complete_git_staged_paths
      fi
    else
      __rush_complete_git_staged_paths
    fi
  fi
}

__rush_complete_git_context_clean_paths() {
  if test "$(completion option-present --short X)" = true; then
    __rush_complete_git_ignored_clean_paths
  else
    __rush_complete_git_untracked_clean_paths
    if test "$(completion option-present --short x)" = true; then
      __rush_complete_git_ignored_clean_paths
    fi
  fi
}

__rush_complete_git_context_branch_args() {
  if test "$(completion option-present --long remotes)" = true; then
    __rush_complete_git_remote_branches
  else
    if test "$(completion option-present --short r)" = true; then
      __rush_complete_git_remote_branches
    else
      __rush_complete_git_branches
      if test "$(completion option-present --long track)" = true; then
        __rush_complete_git_remote_branches
      fi
    fi
  fi
}

__rush_complete_git_context_push_remote_refs() {
  remote="$(completion operand 0)"
  if test -n "$remote"; then
    git for-each-ref --format='%(refname:short)' "refs/remotes/$remote" 2>/dev/null | sed "s#^$remote/##" | while read ref; do test -n "$ref" && completion candidate "$ref" --kind plain --description 'remote ref'; done
  else
    __rush_complete_git_remote_branches
  fi
}

__rush_complete_git_context_push_args() {
  if test "$(completion argument-index)" = 0; then
    __rush_complete_git_remotes
  else
    if test "$(completion value-position)" = value; then
      __rush_complete_git_context_push_remote_refs
    else
      if test "$(completion option-present --long delete)" = true; then
        __rush_complete_git_context_push_remote_refs
      else
        if test "$(completion option-present --short d)" = true; then
          __rush_complete_git_context_push_remote_refs
        else
          if test "$(completion option-present --long set-upstream)" = true; then
            __rush_complete_git_branches
          else
            if test "$(completion option-present --short u)" = true; then
              __rush_complete_git_branches
            else
              __rush_complete_git_branches
              __rush_complete_git_tags
            fi
          fi
        fi
      fi
    fi
  fi
}
