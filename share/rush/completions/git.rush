__rush_complete_git_paths() {
  completion files
}

__rush_complete_git_directories() {
  completion directories --append-slash
}

__rush_complete_git_commands() {
  tmp=$(mktemp)
  git --list-cmds=list-mainporcelain,others,alias > "$tmp" 2>/dev/null
  while read command; do
    completion candidate "$command" --kind subcommand --description 'git command'
  done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_branches() {
  tmp=$(mktemp)
  git branch --format='%(refname:short)' > "$tmp" 2>/dev/null
  while read ref; do
    completion candidate "$ref" --kind plain --description branch
  done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_tags() {
  tmp=$(mktemp)
  git tag --list > "$tmp" 2>/dev/null
  while read tag; do
    completion candidate "$tag" --kind plain --description tag
  done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_remotes() {
  tmp=$(mktemp)
  git remote > "$tmp" 2>/dev/null
  while read remote; do
    completion candidate "$remote" --kind plain --description remote
  done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_remote_branches() {
  tmp=$(mktemp)
  git branch --remotes --format='%(refname:short)' > "$tmp" 2>/dev/null
  while read ref; do
    completion candidate "$ref" --kind plain --description 'remote branch'
  done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_refs() {
  __rush_complete_git_branches
  __rush_complete_git_tags
}

__rush_complete_git_stashes() {
  tmp=$(mktemp)
  git stash list --format='%gd' > "$tmp" 2>/dev/null
  while read stash; do
    completion candidate "$stash" --kind plain --description stash
  done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_worktrees() {
  tmp=$(mktemp)
  git worktree list --porcelain > "$tmp" 2>/dev/null
  while read key path; do
    if test "$key" = worktree; then
      completion candidate "$path" --kind plain --description worktree
    fi
  done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_config_keys() {
  tmp=$(mktemp)
  git config --list --name-only > "$tmp" 2>/dev/null
  while read key; do
    completion candidate "$key" --kind plain --description config
  done < "$tmp"
  rm -f "$tmp"
}

__rush_complete_git_cleanup_modes() {
  completion candidate strip --kind plain --description 'strip leading/trailing empty lines, comments, and collapse empties'
  completion candidate whitespace --kind plain --description 'strip leading/trailing empty lines'
  completion candidate verbatim --kind plain --description 'do not change message'
  completion candidate scissors --kind plain --description 'truncate message below scissors line'
  completion candidate default --kind plain --description 'use default cleanup mode'
}

__rush_complete_git_color_modes() {
  completion candidate always --kind plain
  completion candidate auto --kind plain
  completion candidate never --kind plain
}

__rush_complete_git_word_diff_modes() {
  completion candidate color --kind plain
  completion candidate plain --kind plain
  completion candidate porcelain --kind plain
  completion candidate none --kind plain
}

__rush_complete_git_pretty_formats() {
  completion candidate oneline --kind plain
  completion candidate short --kind plain
  completion candidate medium --kind plain
  completion candidate full --kind plain
  completion candidate fuller --kind plain
  completion candidate reference --kind plain
  completion candidate email --kind plain
  completion candidate raw --kind plain
  completion candidate format: --kind plain --no-space
  completion candidate tformat: --kind plain --no-space
}

__rush_complete_git_recurse_submodules_modes() {
  completion candidate yes --kind plain
  completion candidate on-demand --kind plain
  completion candidate no --kind plain
}

__rush_complete_git_pull_rebase_modes() {
