          "required": false,
          "style": "optional"
        }
      },
      {
        "description": "run action on checkpoint",
        "inherit": true,
        "long": "checkpoint-action",
        "value": {
          "name": "action"
        }
      },
      {
        "description": "process Nth occurrence",
        "inherit": true,
        "long": "occurrence",
        "value": {
          "name": "number",
          "required": false,
          "style": "optional"
        }
      },
      {
        "description": "ignore unreadable files",
        "inherit": true,
        "long": "ignore-failed-read"
      },
      {
        "description": "remove files after archiving",
        "inherit": true,
        "long": "remove-files"
