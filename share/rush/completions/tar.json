        "short": "z",
        "spellings": [
          "z"
        ]
      },
      {
        "description": "filter through compress",
        "inherit": true,
        "long": "compress",
        "short": "Z",
        "spellings": [
          "Z"
        ]
      },
      {
        "description": "filter through zstd",
        "inherit": true,
        "long": "zstd"
      },
      {
        "description": "transform file names",
        "inherit": true,
        "long": "transform",
        "value": {
          "name": "expression"
        }
      },
      {
