        "inherit": true
      },
      {
        "long": "recursion",
        "description": "recurse into directories",
        "inherit": true
      },
      {
        "long": "suffix",
        "description": "backup before removal, override usual suffix",
        "inherit": true,
        "value": {
          "name": "string"
        }
      },
      {
        "short": "T",
        "long": "files-from",
        "spellings": [
          "T"
        ],
        "description": "get names to extract or create from FILE",
        "repeatable": true,
        "inherit": true,
        "value": {
          "name": "file",
          "provider": "builtin.files"
        }
      },
      {
        "long": "unquote",
        "description": "unquote file or member names",
        "inherit": true
      },
      {
        "long": "verbatim-files-from",
        "description": "treat each line obtained from a file list as a file name, even if it starts with a dash",
        "repeatable": true,
        "inherit": true
      },
      {
        "short": "X",
        "long": "exclude-from",
        "spellings": [
          "X"
        ],
        "description": "exclude files matching patterns listed in FILE",
        "repeatable": true,
        "inherit": true,
        "value": {
          "name": "file",
          "provider": "builtin.files"
        }
      },
      {
        "long": "index-file",
        "description": "send verbose output to FILE",
        "inherit": true,
        "value": {
          "name": "file"
        }
      },
      {
        "long": "no-quote-chars",
        "description": "disable quoting for characters from STRING",
        "inherit": true,
        "value": {
          "name": "string"
        }
      },
      {
        "long": "quote-chars",
        "description": "additionally quote characters from STRING",
        "inherit": true,
        "value": {
          "name": "string"
        }
      },
