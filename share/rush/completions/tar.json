              {
                "value": "HUP"
              },
              {
                "value": "SIGQUIT"
              },
              {
                "value": "QUIT"
              },
              {
                "value": "SIGINT"
              },
              {
                "value": "INT"
              },
              {
                "value": "SIGUSR1"
              },
              {
                "value": "USR1"
              },
              {
                "value": "SIGUSR2"
              },
              {
                "value": "USR2"
              }
            ]
          }
        }
