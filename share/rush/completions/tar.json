      {
        "long": "no-recursion",
        "description": "avoid descending automatically in directories",
        "inherit": true
      },
      {
        "long": "no-unquote",
        "description": "do not unquote input file or member names",
        "inherit": true
      },
      {
        "long": "no-verbatim-files-from",
