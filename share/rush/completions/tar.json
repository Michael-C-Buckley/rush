      {
        "long": "xattrs-include",
        "description": "specify the include pattern for xattr keys",
        "inherit": true,
        "value": {
          "name": "pattern"
        }
      },
      {
        "long": "backup",
        "description": "backup before removal",
        "inherit": true,
        "value": {
          "name": "control",
          "required": false,
          "style": "optional",
          "provider": {
            "values": [
              {
                "value": "none",
                "description": "Never make backups"
              },
              {
                "value": "off",
                "description": "Never make backups"
              },
              {
                "value": "t",
                "description": "Make numbered backups"
              },
              {
                "value": "numbered",
                "description": "Make numbered backups"
              },
              {
                "value": "nil",
                "description": "Make numbered backups if numbered backups exist"
              },
              {
                "value": "existing",
                "description": "Make numbered backups if numbered backups exist"
              },
              {
                "value": "never",
                "description": "Always make simple backups"
              },
              {
                "value": "simple",
                "description": "Always make simple backups"
              }
            ]
          }
        }
      },
