{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "z",
    "description": "jump to frecent directories",
    "options": [
      { "spellings": ["-"], "priority": 20, "description": "change to previous directory" }
    ],
    "arguments": {
      "terminator": "--",
      "states": [
        {
          "name": "keyword",
          "index": 0,
          "repeatable": true,
          "provider": "z.directories",
          "description": "directory keyword or path"
        }
      ]
    },
    "providers": {
      "z.directories": { "function": "__rush_complete_z_directories" }
    }
  }
}
