{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "scp",
    "description": "copy files over SSH",
    "options": [
      {
        "short": "3",
        "inherit": false,
        "description": "copy between two remote hosts through the local host"
      },
      {
        "short": "4",
        "description": "forces scp to use IPv4 addresses only",
        "inherit": false
      },
      {
        "short": "6",
        "description": "forces scp to use IPv6 addresses only",
        "inherit": false
      },
      {
        "short": "A",
        "description": "allows forwarding of ssh-agent(1) to the remote system. The default is not to forward an authentication agent",
        "inherit": false
      },
      {
        "short": "B",
        "description": "selects batch mode (prevents asking for passwords or passphrases)",
        "inherit": false
      },
      {
        "short": "C",
        "description": "compression enable. Passes the -C flag to ssh(1) to enable compression",
        "inherit": false
      },
      {
        "short": "c",
        "description": "selects the cipher to use for encrypting the data transfer. This option is directly passed to ssh(1)",
        "inherit": false,
        "value": {
          "name": "cipher",
          "description": "the selected cipher specification"
        }
      },
      {
        "short": "F",
        "description": "specifies an alternative per-user configuration file for ssh. This option is directly passed to ssh(1)",
        "inherit": false,
        "value": {
          "name": "ssh_config",
          "description": "the selected ssh config"
        }
      },
      {
        "short": "i",
        "description": "selects the file from which the identity (private key) for public key authentication is read. This option is directly passed to ssh(1)",
        "inherit": false,
        "value": {
          "name": "identity_file",
          "description": "specified identity file"
        }
      },
      {
        "short": "J",
        "inherit": false,
        "value": {
          "name": "destination",
          "description": "scp destination",
          "provider": "builtin.files"
        },
        "description": "connect through a jump host"
      },
      {
        "short": "l",
        "description": "limits the used bandwidth, specified in Kbit/s",
        "inherit": false,
        "value": {
          "name": "limit",
          "description": "limit bandwidth in Kbit/s"
        }
      },
      {
        "short": "o",
        "inherit": false,
        "value": {
          "name": "option",
          "provider": {
            "values": [
              {
                "value": "AddressFamily"
              },
              {
                "value": "BatchMode"
              },
              {
                "value": "BindAddress"
              },
              {
                "value": "ChallengeResponseAuthentication"
              },
              {
                "value": "CheckHostIP"
              },
              {
                "value": "Cipher"
              },
              {
                "value": "Ciphers"
              },
              {
                "value": "ClearAllForwardings"
              },
              {
                "value": "Compression"
              },
              {
                "value": "CompressionLevel"
              },
              {
                "value": "ConnectionAttempts"
              },
              {
                "value": "ConnectTimeout"
              },
              {
                "value": "ControlMaster"
              },
              {
                "value": "ControlPath"
              },
              {
                "value": "ControlPersist"
              },
              {
                "value": "DynamicForward"
              },
              {
                "value": "EscapeChar"
              },
              {
                "value": "ExitOnForwardFailure"
              },
              {
                "value": "ForwardAgent"
              },
              {
                "value": "ForwardX11"
              },
              {
                "value": "ForwardX11Timeout"
              },
              {
                "value": "ForwardX11Trusted"
              },
              {
                "value": "GatewayPorts"
              },
              {
                "value": "GlobalKnownHostsFile"
              },
              {
                "value": "GSSAPIAuthentication"
              },
              {
                "value": "GSSAPIDelegateCredentials"
              },
              {
                "value": "HashKnownHosts"
              },
              {
                "value": "Host"
              },
              {
                "value": "HostbasedAuthentication"
              },
              {
                "value": "HostKeyAlgorithms"
              },
              {
                "value": "HostKeyAlias"
              },
              {
                "value": "HostName"
              },
              {
                "value": "IdentityFile"
              },
              {
                "value": "IdentitiesOnly"
              },
              {
                "value": "IPQoS"
              },
              {
                "value": "KbdInteractiveAuthentication"
              },
              {
                "value": "KbdInteractiveDevices"
              },
              {
                "value": "KexAlgorithms"
              },
              {
                "value": "LocalCommand"
              },
              {
                "value": "LocalForward"
              },
              {
                "value": "LogLevel"
              },
              {
                "value": "MACs"
              },
              {
                "value": "NoHostAuthenticationForLocalhost"
              },
              {
                "value": "NumberOfPasswordPrompts"
              },
              {
                "value": "PasswordAuthentication"
              },
              {
                "value": "PermitLocalCommand"
              },
              {
                "value": "PKCS11Provider"
              },
              {
                "value": "Port"
              },
              {
                "value": "PreferredAuthentications"
              },
              {
                "value": "Protocol"
              },
              {
                "value": "ProxyCommand"
              },
              {
                "value": "PubkeyAuthentication"
              },
              {
                "value": "RekeyLimit"
              },
              {
                "value": "RequestTTY"
              },
              {
                "value": "RhostsRSAAuthentication"
              },
              {
                "value": "RSAAuthentication"
              },
              {
                "value": "SendEnv"
              },
              {
                "value": "ServerAliveInterval"
              },
              {
                "value": "ServerAliveCountMax"
              },
              {
                "value": "StrictHostKeyChecking"
              },
              {
                "value": "TCPKeepAlive"
              },
              {
                "value": "Tunnel"
              },
              {
                "value": "TunnelDevice"
              },
              {
                "value": "UsePrivilegedPort"
              },
              {
                "value": "User"
              },
              {
                "value": "UserKnownHostsFile"
              },
              {
                "value": "VerifyHostKeyDNS"
              },
              {
                "value": "VisualHostKey"
              },
              {
                "value": "XAuthLocation"
              }
            ]
          }
        },
        "description": "pass an ssh_config option to ssh"
      },
      {
        "short": "P",
        "inherit": false,
        "value": {
          "name": "port"
        },
        "description": "set remote port"
      },
      {
        "short": "p",
        "description": "preserves modification times, access times, and modes from the original file",
        "inherit": false
      },
      {
        "short": "q",
        "description": "quiet mode: disables the progress meter as well as warning and diagnostic messages from ssh(1)",
        "inherit": false
      },
      {
        "short": "r",
        "description": "recursively copy entire directories. Note that scp follows symbolic links encountered in the tree traversal",
        "inherit": false
      },
      {
        "short": "S",
        "description": "name of program to use for the encrypted connection. The program must understand ssh(1) options",
        "inherit": false,
        "value": {
          "name": "program"
        }
      },
      {
        "short": "T",
        "inherit": false,
        "description": "disable strict filename checking"
      },
      {
        "short": "v",
        "description": "verbose mode. Causes scp and ssh(1) to print debugging messages about their progress. This is helpful in debugging connection, authentication, and configuration",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "sources",
          "description": "local path or remote host path",
          "index": 0,
          "repeatable": true,
          "provider": "scp.hosts"
        },
        {
          "name": "target",
          "description": "local path or remote host path",
          "index": 1,
          "provider": "scp.hosts"
        }
      ]
    },
    "providers": {
      "scp.hosts": {
        "function": "__rush_complete_scp_hosts"
      }
    }
  }
}
