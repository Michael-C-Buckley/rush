{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "head",
    "description": "Output the first part of files",
    "options": [
      {
        "short": "c",
        "long": "bytes",
        "description": "print the first [numBytes] bytes of each file",
        "inherit": false,
        "value": {
          "name": "numBytes"
        }
      },
      {
        "short": "n",
        "long": "lines",
        "description": "print the first [numLines] lines instead of the first 10",
        "inherit": false,
        "value": {
          "name": "numLines"
        }
      },
      {
        "short": "q",
        "long": "quiet",
        "aliases": [
          "silent"
        ],
        "description": "never print headers giving file names",
        "inherit": false
      },
      {
        "short": "v",
        "long": "verbose",
        "description": "always print headers giving file names",
        "inherit": false
      },
      {
        "long": "help",
        "description": "display this help and exit",
        "inherit": false
      },
      {
        "long": "version",
        "description": "output version information and exit",
        "inherit": false
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "file",
          "provider": "builtin.files",
          "index": 0
        }
      ]
    }
  }
}
