{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "sake",
    "description": "manage project commands with Sake",
    "options": [
      {
        "long": "help",
        "short": "h",
        "description": "show help",
        "inherit": true
      },
      {
        "long": "version",
        "description": "show version",
        "inherit": false
      }
    ],
    "subcommands": [
      {
        "name": "init",
        "description": "initialize a new SakeApp project template for defining commands",
        "options": [
          {
            "short": "c",
            "long": "config-path",
            "description": "set configuration file",
            "value": {
              "name": "path",
              "provider": "builtin.files"
            },
            "inherit": true
          },
          {
            "short": "s",
            "long": "sake-app-path",
            "description": "set SakeApp package path",
            "value": {
              "name": "directory",
              "provider": "builtin.directories"
            },
            "inherit": true
          }
        ]
      },
      {
        "name": "clean",
        "description": "remove all build artifacts generated by the SakeApp to ensure a clean state for future builds",
        "options": [
          {
            "short": "c",
            "long": "config-path",
            "description": "set configuration file",
            "value": {
              "name": "path",
              "provider": "builtin.files"
            },
            "inherit": true
          },
          {
            "short": "s",
            "long": "sake-app-path",
            "description": "set SakeApp package path",
            "value": {
              "name": "directory",
              "provider": "builtin.directories"
            },
            "inherit": true
          }
        ]
      },
      {
        "name": "edit",
        "description": "open the SakeApp in Xcode (macOS only)",
        "options": [
          {
            "short": "c",
            "long": "config-path",
            "description": "set configuration file",
            "value": {
              "name": "path",
              "provider": "builtin.files"
            },
            "inherit": true
          },
          {
            "short": "s",
            "long": "sake-app-path",
            "description": "set SakeApp package path",
            "value": {
              "name": "directory",
              "provider": "builtin.directories"
            },
            "inherit": true
          }
        ]
      },
      {
        "name": "list",
        "description": "list all available commands defined in the SakeApp",
        "options": [
          {
            "short": "c",
            "long": "config-path",
            "description": "set configuration file",
            "value": {
              "name": "path",
              "provider": "builtin.files"
            },
            "inherit": true
          },
          {
            "short": "s",
            "long": "sake-app-path",
            "description": "set SakeApp package path",
            "value": {
              "name": "directory",
              "provider": "builtin.directories"
            },
            "inherit": true
          },
          {
            "long": "json",
            "short": "j",
            "description": "Output the list of commands in JSON format",
            "inherit": false
          },
          {
            "long": "case-converting-strategy",
            "description": "set command name case conversion",
            "value": {
              "name": "strategy",
              "provider": {
                "values": [
                  {
                    "value": "keepOriginal"
                  },
                  {
                    "value": "toSnakeCase"
                  },
                  {
                    "value": "toKebabCase"
                  }
                ]
              }
            }
          },
          {
            "short": "b",
            "long": "sake-app-prebuilt-binary-path",
            "description": "set prebuilt SakeApp binary path",
            "value": {
              "name": "file",
              "provider": "builtin.files"
            }
          }
        ]
      },
      {
        "name": "build",
        "description": "manually trigger a rebuild of the SakeApp",
        "options": [
          {
            "short": "c",
            "long": "config-path",
            "description": "set configuration file",
            "value": {
              "name": "path",
              "provider": "builtin.files"
            },
            "inherit": true
          },
          {
            "short": "s",
            "long": "sake-app-path",
            "description": "set SakeApp package path",
            "value": {
              "name": "directory",
              "provider": "builtin.directories"
            },
            "inherit": true
          },
          {
            "long": "show-bin-path",
            "description": "Print the path to the built SakeApp executable",
            "inherit": false
          }
        ]
      },
      {
        "name": "run",
        "description": "run the specified command from the SakeApp",
        "arguments": {
          "states": [
            {
              "name": "command",
              "description": "command to run",
              "index": 0,
              "provider": "sake.commands"
            }
          ]
        },
        "options": [
          {
            "short": "c",
            "long": "config-path",
            "description": "set configuration file",
            "value": {
              "name": "path",
              "provider": "builtin.files"
            },
            "inherit": true
          },
          {
            "short": "s",
            "long": "sake-app-path",
            "description": "set SakeApp package path",
            "value": {
              "name": "directory",
              "provider": "builtin.directories"
            },
            "inherit": true
          },
          {
            "long": "case-converting-strategy",
            "description": "set command name case conversion",
            "value": {
              "name": "strategy",
              "provider": {
                "values": [
                  {
                    "value": "keepOriginal"
                  },
                  {
                    "value": "toSnakeCase"
                  },
                  {
                    "value": "toKebabCase"
                  }
                ]
              }
            }
          },
          {
            "short": "b",
            "long": "sake-app-prebuilt-binary-path",
            "description": "set prebuilt SakeApp binary path",
            "value": {
              "name": "file",
              "provider": "builtin.files"
            }
          }
        ]
      }
    ],
    "providers": {
      "sake.commands": {
        "function": "__rush_complete_sake_commands"
      }
    }
  }
}
