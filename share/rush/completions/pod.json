{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "pod",
    "description": "manage CocoaPods dependencies",
    "options": [
      {
        "long": "silent",
        "description": "show nothing",
        "inherit": false
      },
      {
        "long": "verbose",
        "description": "show more debugging information",
        "inherit": false
      },
      {
        "long": "no-ansi",
        "description": "show output without ANSI codes",
        "inherit": false
      },
      {
        "long": "help",
        "description": "show help banner of specified command",
        "inherit": false
      }
    ],
    "subcommands": [
      {
        "name": "deintegrate",
        "description": "deintegrate CocoaPods from your project",
        "options": [
          {
            "long": "project-directory",
            "description": "the path to the root of the project directory",
            "inherit": false,
            "value": {
              "name": "/project/dir/",
              "provider": "builtin.directories"
            }
          },
          {
            "long": "allow-root",
            "description": "allows CocoaPods to run as root",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "XCODE_PROJECT",
              "index": 0
            }
          ]
        }
      },
      {
        "name": "cache",
        "description": "manipulate the CocoaPods cache",
        "options": [
          {
            "long": "allow-root",
            "description": "allows CocoaPods to run as root",
            "inherit": false
          }
        ],
        "subcommands": [
          {
            "name": "clean",
            "description": "remove the cache for pods",
            "options": [
              {
                "long": "all",
                "description": "remove all the cached pods without asking",
                "inherit": false
              },
              {
                "long": "allow-root",
                "description": "allows CocoaPods to run as root",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "NAME",
                  "index": 0
                }
              ]
            }
          },
          {
            "name": "list",
            "description": "list the paths of pod caches for each known pod",
            "options": [
              {
                "long": "short",
                "description": "only print the path relative to the cache root",
                "inherit": false
              },
              {
                "long": "allow-root",
                "description": "allows CocoaPods to run as root",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "NAME",
                  "index": 0
                }
              ]
            }
          }
        ]
      },
      {
        "name": "list",
        "description": "list pods",
        "options": [
          {
            "long": "update",
            "description": "run `pod repo update` before listing",
            "inherit": false
          },
          {
            "long": "stats",
            "description": "show additional stats (like GitHub watchers and forks)",
            "inherit": false
          },
          {
            "long": "allow-root",
            "description": "allows CocoaPods to run as root",
            "inherit": false
          }
        ]
      },
      {
        "name": "setup",
        "description": "setup the CocoaPods environment",
        "options": [
          {
            "long": "allow-root",
            "description": "allows CocoaPods to run as root",
            "inherit": false
          }
        ]
      },
      {
        "name": "spec",
        "description": "manage pod specs",
        "options": [
          {
            "long": "allow-root",
            "description": "allows CocoaPods to run as root",
            "inherit": false
          }
        ],
        "subcommands": [
          {
            "name": "edit",
            "description": "edit a spec file",
            "options": [
              {
                "long": "regex",
                "description": "interpret the `QUERY` as a regular expression",
                "inherit": false
              },
              {
                "long": "show-all",
                "description": "pick from all versions of the given podspec",
                "inherit": false
              },
              {
                "long": "allow-root",
                "description": "allows CocoaPods to run as root",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "QUERY",
                  "index": 0
                }
              ]
            }
          },
          {
            "name": "create",
            "description": "create spec file stub",
            "options": [
              {
                "long": "allow-root",
                "description": "allows CocoaPods to run as root",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "NAME|https://github.com/USER/REPO",
                  "index": 0
                }
              ]
            }
          },
          {
            "name": "cat",
            "description": "prints a spec file",
            "options": [
              {
                "long": "regex",
                "description": "interpret the `QUERY` as a regular expression",
                "inherit": false
              },
              {
                "long": "show-all",
                "description": "pick from all versions of the given podspec",
                "inherit": false
              },
              {
                "long": "allow-root",
                "description": "allows CocoaPods to run as root",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "QUERY",
                  "index": 0
                }
              ]
            }
          },
          {
            "name": "which",
            "description": "prints the path of the given spec",
            "options": [
              {
                "long": "regex",
                "description": "interpret the `QUERY` as a regular expression",
                "inherit": false
              },
              {
                "long": "show-all",
                "description": "print all versions of the given podspec",
                "inherit": false
              },
              {
                "long": "allow-root",
                "description": "allows CocoaPods to run as root",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "QUERY",
                  "index": 0
                }
              ]
            }
          },
          {
            "name": "lint",
            "description": "validates a spec file",
            "options": [
              {
                "long": "quick",
                "description": "lint skips checks that would require to download and build the spec",
                "inherit": false
              },
              {
                "long": "allow-warnings",
                "description": "lint validates even if warnings are present",
                "inherit": false
              },
              {
                "long": "subspec",
                "description": "lint validates only the given subspec",
                "inherit": false,
                "value": {
                  "name": "NAME"
                }
              },
              {
                "long": "no-subspecs",
                "description": "lint skips validation of subspecs",
                "inherit": false
              },
              {
                "long": "no-clean",
                "description": "lint leaves the build directory intact for inspection",
                "inherit": false
              },
              {
                "long": "fail-fast",
                "description": "lint stops on the first failing platform or subspec",
                "inherit": false
              },
              {
                "long": "use-libraries",
                "description": "lint uses static libraries to install the spec",
                "inherit": false
              },
              {
                "long": "use-modular-headers",
                "description": "lint uses modular headers during installation",
                "inherit": false
              },
              {
                "long": "use-static-frameworks",
                "description": "lint uses static frameworks during installation",
                "inherit": false
              },
              {
                "long": "sources",
                "description": "the sources from which to pull dependent pods (defaults to https://cdn.cocoapods.org/)....",
                "inherit": false,
                "value": {
                  "name": "source",
                  "provider": {
                    "values": [
                      {
                        "value": "https://cdn.cocoapods.org/"
                      }
                    ]
                  }
                }
              },
              {
                "long": "platforms",
                "description": "lint against specific platforms (defaults to all platforms supported by the podspec). M...",
                "inherit": false,
                "value": {
                  "name": "platform",
                  "provider": {
                    "values": [
                      {
                        "value": "ios"
                      },
                      {
                        "value": "macos"
                      },
                      {
                        "value": "ios,macos"
                      }
                    ]
                  }
                }
              },
              {
                "long": "private",
                "description": "lint skips checks that apply only to public specs",
                "inherit": false
              },
              {
                "long": "swift-version",
                "description": "the `SWIFT_VERSION` that should be used to lint the spec. This takes precedence over th...",
                "inherit": false,
                "value": {
                  "name": "VERSION"
                }
              },
              {
                "long": "skip-import-validation",
                "description": "lint skips validating that the pod can be imported",
                "inherit": false
              },
              {
                "long": "skip-tests",
                "description": "lint skips building and running tests during validation",
                "inherit": false
              },
              {
                "long": "test-specs",
                "description": "list of test specs to run",
                "inherit": false,
                "value": {
                  "name": "test-spec"
                }
              },
              {
                "long": "analyze",
