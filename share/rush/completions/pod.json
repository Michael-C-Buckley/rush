                "inherit": false
              },
              {
                "long": "configuration",
                "description": "build using the given configuration (defaults to Release)",
                "inherit": false,
                "value": {
                  "name": "CONFIGURATION"
                }
              },
              {
                "long": "allow-root",
                "description": "allows CocoaPods to run as root",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "NAME.podspec|DIRECTORY|http://PATH/NAME.podspec",
                  "index": 0,
                  "provider": [
                    "builtin.files",
                    "builtin.directories"
                  ]
                }
              ]
            }
          }
        ]
