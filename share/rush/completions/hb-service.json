{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "hb-service",
    "description": "manage Homebridge service",
    "options": [
      {
        "long": "help",
        "short": "h",
        "description": "display help for command",
        "inherit": false
      },
      {
        "long": "version",
        "short": "v",
        "description": "output the version number",
        "inherit": false
      },
      {
        "long": "service-name",
        "short": "S",
        "description": "the name of the homebridge service to install or control",
        "inherit": true,
        "value": {
          "name": "service-name"
        }
      },
      {
        "long": "port",
        "description": "the port to set to the Homebridge UI when installing as a service",
        "inherit": true,
        "value": {
          "name": "port"
        }
      },
      {
        "long": "user",
        "description": "the user account the Homebridge service will be installed as (Linux, macOS only)",
        "inherit": true,
        "value": {
          "name": "user"
        }
      },
      {
        "long": "plugin-path",
        "short": "P",
        "inherit": true,
        "value": {
          "name": "path",
          "provider": "builtin.directories"
        },
        "description": "set plugin path"
      },
      {
        "long": "user-storage-path",
        "short": "U",
        "inherit": true,
        "value": {
          "name": "path",
          "provider": "builtin.directories"
        },
        "description": "set user storage path"
      },
      {
        "long": "no-timestamp",
        "short": "T",
        "inherit": true
      },
      {
        "long": "gid",
        "inherit": true,
        "value": {
          "name": "number"
        }
      },
      {
        "long": "uid",
        "inherit": true,
        "value": {
          "name": "number"
        }
      },
      {
        "long": "docker",
        "inherit": true
      },
      {
        "long": "allow-root",
        "inherit": true
      },
      {
        "long": "stdout",
        "inherit": true
      },
      {
        "long": "strict-plugin-resolution",
        "inherit": true
      }
    ],
    "subcommands": [
      {
        "name": "install",
        "description": "install homebridge as a service"
      },
      {
        "name": "uninstall",
        "description": "remove the homebridge service"
      },
      {
        "name": "start",
        "description": "start the homebridge service"
      },
      {
        "name": "stop",
        "description": "stop the homebridge service"
      },
      {
        "name": "restart",
        "description": "restart the homebridge service"
      },
      {
        "name": "rebuild",
        "description": "rebuild UI",
        "options": [
          {
            "long": "all",
            "description": "rebuild all npm modules (use after updating Node.js)",
            "inherit": false
          }
        ]
      },
      {
        "name": "run",
        "description": "run homebridge daemon"
      },
      {
        "name": "logs",
        "description": "tails the homebridge service logs"
      },
      {
        "name": "update-node",
        "description": "update Node.js",
        "arguments": {
          "states": [
            {
              "name": "version",
              "index": 0
            }
          ]
        }
      }
    ]
  }
}
