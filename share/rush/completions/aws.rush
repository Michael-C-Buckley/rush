__rush_complete_aws_profiles() {
  {
    test -f "$HOME/.aws/config" && sed -n 's/^\[profile \([^]]*\)\]$/\1/p; s/^\[default\]$/default/p' "$HOME/.aws/config"
    test -f "$HOME/.aws/credentials" && sed -n 's/^\[\([^]]*\)\]$/\1/p' "$HOME/.aws/credentials"
  } 2>/dev/null | sort -u | while read profile; do
    test -n "$profile" && rush_complete candidate "$profile" --kind plain --description profile
  done
}
