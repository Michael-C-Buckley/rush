            "inherit": false
          }
        ],
        "subcommands": [
          {
            "name": "fetch",
            "description": "fetch account config from an already deployed account contract",
            "options": [
              {
                "long": "rpc",
                "description": "starknet JSON-RPC endpoint",
                "inherit": false,
                "value": {
                  "name": "RPC"
                }
              },
              {
                "long": "network",
                "description": "starknet network",
                "inherit": false,
                "value": {
                  "name": "NETWORK",
                  "provider": {
                    "values": [
                      "mainnet",
                      "goerli-1",
                      "goerli-2",
                      "integration"
                    ]
                  }
                }
              },
              {
                "long": "force",
                "description": "overwrite the file if it already exists",
                "inherit": false
              },
              {
                "long": "output",
                "description": "path to save the account config file",
                "inherit": false,
                "value": {
                  "name": "OUTPUT",
                  "provider": "builtin.files"
                }
              },
              {
                "long": "log-traffic",
                "description": "log raw request/response traffic of providers",
                "inherit": false
              },
              {
                "short": "h",
                "long": "help",
                "description": "print help",
                "inherit": false
              }
            ],
            "arguments": {
              "states": [
                {
                  "name": "ADDRESS",
                  "description": "contract address",
                  "index": 0
                }
              ]
            }
          },
          {
            "name": "deploy",
            "description": "deploy account contract with a DeployAccount transaction",
