{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "tmuxinator",
    "description": "create and manage tmux sessions",
    "subcommands": [
      {
        "name": "commands",
        "description": "lists commands available in tmuxinator"
      },
      {
        "name": "completions",
        "description": "used for shell completion"
      },
      {
        "name": "copy",
        "description": "copy an existing project to a new project and open it in your editor",
        "arguments": {
          "states": [
            {
              "name": "source",
              "description": "the source project name",
              "index": 0,
              "provider": "tmuxinator.projects"
            },
            {
              "name": "target",
              "description": "the target project name",
              "index": 1,
              "provider": "tmuxinator.projects"
            }
          ]
        }
      },
      {
        "name": "debug",
        "description": "output the shell commands that are generated by tmuxinator",
        "options": [
          {
            "short": "a",
            "long": "attach",
            "description": "attach to tmux session after creation",
            "inherit": false,
            "value": {
              "name": "attach-session",
              "description": "attach to tmux session"
            }
          },
          {
            "short": "n",
            "long": "name",
            "description": "give the session a different name",
            "inherit": false,
            "value": {
              "name": "name",
              "description": "give the session a different name"
            }
          },
          {
            "short": "p",
            "long": "project-config",
            "description": "path to project config file",
            "inherit": false,
            "value": {
              "name": "project-config",
              "description": "path to project config file",
              "provider": [
                "builtin.directories",
                "builtin.files"
              ]
            }
          }
        ]
      },
      {
        "name": "delete",
        "description": "deletes given project",
        "arguments": {
          "states": [
            {
              "name": "project",
              "description": "the project name",
              "index": 0,
              "repeatable": true,
              "provider": "tmuxinator.projects"
            }
          ]
        }
      },
      {
        "name": "doctor",
        "description": "look for problems in your configuration"
      },
      {
        "name": "help",
        "description": "describe available commands or one specific command",
        "arguments": {
          "states": [
            {
              "name": "command",
              "description": "the tmuxinator commands",
              "index": 0
            }
          ]
        }
      },
      {
        "name": "implode",
        "description": "deletes all tmuxinator projects"
      },
      {
        "name": "list",
        "description": "lists all tmuxinator projects",
        "options": [
          {
            "short": "n",
            "long": "newline",
            "description": "force output to be one entry per line",
            "inherit": false
          }
        ]
      },
      {
        "name": "local",
        "description": "start a tmux session using ./.tmuxinator.y[a]ml",
        "options": [
          {
            "long": "suppress-tmux-version-warning",
            "description": "don't show a warning for unsupported tmux versions",
            "inherit": false
          }
        ]
      },
      {
        "name": "new",
        "description": "create a new project file and open it in your editor",
        "options": [
          {
            "short": "l",
            "description": "create local project file at ./.tmuxinator.y[a]ml",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "project",
              "description": "the project name",
              "index": 0,
              "provider": "tmuxinator.projects"
            },
            {
              "name": "tmux-session",
              "description": "the tmux session name",
              "index": 1,
              "provider": "tmuxinator.tmux-sessions"
            }
          ]
        }
      },
      {
        "name": "edit",
        "description": "open a project file it in your editor",
        "options": [
          {
            "short": "l",
            "description": "open local project file at ./.tmuxinator.y[a]ml",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "project",
              "description": "the project name",
              "index": 0,
              "provider": "tmuxinator.projects"
            }
          ]
        }
      },
      {
        "name": "open",
        "description": "open a project file it in your editor",
        "options": [
          {
            "short": "l",
            "description": "open local project file at ./.tmuxinator.y[a]ml",
            "inherit": false
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "project",
              "description": "the project name",
              "index": 0,
              "provider": "tmuxinator.projects"
            }
          ]
        }
      },
      {
        "name": "start",
        "description": "start a tmux session using a project's name (with an optional [ALIAS] for project reuse) or a path to a project config file (via the -p flag)",
        "arguments": {
          "states": [
            {
              "name": "project",
              "description": "the project name",
              "index": 0,
              "provider": "tmuxinator.projects"
            }
          ]
        },
        "options": [
          {
            "short": "a",
            "long": "attach",
            "description": "attach to tmux session after creation",
            "inherit": false,
            "value": {
              "name": "attach-session"
            }
          },
          {
            "short": "n",
            "long": "name",
            "description": "give the session a different name",
            "inherit": false,
            "value": {
              "name": "name"
            }
          },
          {
            "short": "p",
            "long": "project-config",
            "description": "path to project config file",
            "inherit": false,
            "value": {
              "name": "project-config",
              "provider": [
                "builtin.directories",
                "builtin.files"
              ]
            }
          },
          {
            "long": "suppress-tmux-version-warning",
            "description": "don't show a warning for unsupported tmux versions",
            "inherit": false
          }
        ]
      },
      {
        "name": "stop",
        "description": "stop a tmux session using a project's tmuxinator config",
        "arguments": {
          "states": [
            {
              "name": "project",
              "description": "the project name",
              "index": 0,
              "provider": "tmuxinator.projects"
            }
          ]
        },
        "options": [
          {
            "long": "suppress-tmux-version-warning",
            "description": "don't show a warning for unsupported tmux versions",
            "inherit": false
          }
        ]
      },
      {
        "name": "version",
        "description": "display installed tmuxinator version"
      }
    ],
    "providers": {
      "builtin.directories": {
        "builtin": "directories"
      },
      "builtin.files": {
        "builtin": "files"
      },
      "tmuxinator.projects": {
        "function": "__rush_complete_tmuxinator_projects"
      },
      "tmuxinator.tmux-sessions": {
        "function": "__rush_complete_tmuxinator_tmux_sessions"
      }
    }
  }
}
