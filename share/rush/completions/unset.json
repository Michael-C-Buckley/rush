{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "unset",
    "description": "unset variables or functions",
    "providers": {
      "unset.names": { "function": "__rush_complete_unset_names" }
    },
    "options": [
      {
        "short": "v",
        "description": "unset variables"
      },
      {
        "short": "f",
        "description": "unset functions"
      }
    ],
    "arguments": {
      "terminator": "--",
      "states": [
        {
          "name": "name",
          "index": 0,
          "repeatable": true,
          "provider": "unset.names",
          "description": "name to unset"
        }
      ]
    }
  }
}
