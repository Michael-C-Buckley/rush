{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "mkdir",
    "description": "make directories",
    "providers": {
      "builtin.directories": { "builtin": "directories" }
    },
    "options": [
      {
        "short": "m",
        "value": { "name": "mode" },
        "description": "set file permission bits for created directories"
      },
      {
        "short": "p",
        "description": "create intermediate directories as needed"
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "directory",
          "index": 0,
          "repeatable": true,
          "provider": "builtin.directories",
          "description": "directory to create"
        }
      ]
    }
  }
}
