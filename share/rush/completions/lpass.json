                  "amex",
                  "bank",
                  "credit",
                  "database",
                  "drivers_license",
                  "email",
                  "health_insurance",
                  "im",
                  "mastercard",
                  "membership",
                  "passport",
                  "server",
                  "software_license",
                  "ssh_key",
                  "ssn",
                  "visa",
                  "wifi"
