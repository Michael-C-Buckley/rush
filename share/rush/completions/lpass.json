          {
            "long": "fixed-strings",
            "short": "F",
            "description": "show sites matching this exact substring",
            "inherit": false
          },
          {
            "long": "color",
            "description": "control colored output to the terminal",
            "inherit": false,
            "value": {
              "name": "color",
              "required": false,
              "style": "optional",
              "provider": {
                "values": [
                  "auto",
                  "never",
                  "always"
