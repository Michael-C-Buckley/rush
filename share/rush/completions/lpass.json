{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "lpass",
    "description": "manage LastPass vault entries",
    "options": [
      {
        "long": "help",
        "short": "h",
        "description": "display the help for lpass",
        "inherit": false
      },
      {
        "long": "version",
        "description": "display the version of lpass",
        "inherit": false
      }
    ],
    "subcommands": [
      {
        "name": "login",
        "description": "log in to LastPass",
        "options": [
          {
            "long": "trust",
            "description": "subsequent logins will not require multifactor authentication",
            "inherit": false
          },
          {
            "long": "plaintext-key",
            "description": "save decryption key to the hard disk in plaintext",
            "inherit": false,
            "value": {
              "name": "--force",
              "description": "skip user confirmation",
              "required": false,
              "style": "optional"
            }
          },
          {
            "long": "color",
            "description": "control colored output to the terminal",
            "inherit": false,
            "value": {
              "name": "color",
              "required": false,
              "style": "optional",
              "provider": {
                "values": [
                  "auto",
                  "never",
                  "always"
                ]
              }
            }
          }
        ],
        "arguments": {
          "states": [
            {
              "name": "USERNAME",
              "description": "lastPass account username (email address)",
              "index": 0
            }
          ]
        }
      },
      {
        "name": "logout",
        "description": "log out of LastPass",
        "options": [
          {
            "long": "force",
            "description": "skip user confirmation",
            "inherit": false
          }
        ]
      },
      {
        "name": "ls",
