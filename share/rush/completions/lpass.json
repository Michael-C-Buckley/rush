            "long": "password",
            "description": "add only the password",
            "inherit": false
          },
          {
            "long": "url",
            "description": "add only the URL",
            "inherit": false
          },
          {
            "long": "notes",
            "description": "add only the notes",
            "inherit": false
          },
          {
            "long": "field",
            "description": "add only the field",
            "inherit": false,
            "value": {
              "name": "FIELD",
              "description": "add only this field"
