{
  "$schema": "https://rush.horse/completion/schema/v1.schema.json",
  "manifestVersion": 1,
  "command": {
    "name": "literalopts",
    "description": "fixture for literal option spellings",
    "providers": {
      "literal.patterns": { "values": ["needle", "haystack"] },
      "literal.iname-args": { "values": ["matched-iname"] },
      "literal.default-args": { "values": ["default-arg"] }
    },
    "optionGroups": [
      { "name": "name-test", "exclusive": true }
    ],
    "options": [
      {
        "spellings": ["-iname"],
        "exclusiveGroup": "name-test",
        "repeatable": true,
        "value": { "name": "pattern", "provider": "literal.patterns" },
        "description": "case-insensitive name predicate"
      },
      {
        "spellings": ["-name"],
        "exclusiveGroup": "name-test",
        "value": { "name": "pattern", "provider": "literal.patterns" },
        "description": "name predicate"
      },
      {
        "spellings": ["+o"],
        "description": "plus-prefixed toggle"
      },
      {
        "long": "color",
        "spellings": ["-color"],
        "description": "long spelling with a single-dash alias"
      }
    ],
    "arguments": {
      "states": [
        {
          "name": "iname-match",
          "provider": "literal.iname-args",
          "when": { "optionValue": { "-iname": "needle" } }
        },
        {
          "name": "default",
          "provider": "literal.default-args"
        }
      ]
    }
  }
}
