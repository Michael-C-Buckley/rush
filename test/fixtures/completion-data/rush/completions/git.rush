# Provider companion for the focused Git manifest fixture. These providers are
# deterministic and intentionally do not inspect the ambient repository.

__rush_complete_git_fixture_refs() {
  completion candidate main --kind plain --description "ref:$rush_completion_position:$rush_completion_option_name:$rush_completion_option_spelling:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
  completion candidate feature/demo --kind plain --description "ref:$rush_completion_position:$rush_completion_option_name:$rush_completion_option_spelling:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_branches() {
  completion candidate main --kind plain --description "branch:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
  completion candidate feature/demo --kind plain --description "branch:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_tags() {
  completion candidate v1.0 --kind plain --description "tag:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_diff_sources() {
  if completion option-present --long no-index; then
    completion files
  else
    if completion option-present --long staged; then
      if test "$rush_completion_options_terminated" = true; then
        __rush_complete_git_fixture_staged_files
      else
        if test "$rush_completion_argument_index" = 0; then
          __rush_complete_git_fixture_refs
          __rush_complete_git_fixture_staged_files
        else
          __rush_complete_git_fixture_staged_files
        fi
      fi
    else
      if completion option-present --long cached; then
        if test "$rush_completion_options_terminated" = true; then
          __rush_complete_git_fixture_staged_files
        else
          if test "$rush_completion_argument_index" = 0; then
            __rush_complete_git_fixture_refs
            __rush_complete_git_fixture_staged_files
          else
            __rush_complete_git_fixture_staged_files
          fi
        fi
      else
        if test "$rush_completion_options_terminated" = true; then
          __rush_complete_git_fixture_worktree_files
        else
          __rush_complete_git_fixture_refs
        fi
      fi
    fi
  fi
}

__rush_complete_git_fixture_tree_files() {
  completion candidate src/main.zig --kind file --description "tree-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
  completion candidate README.md --kind file --description "tree-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_staged_files() {
  completion candidate src/staged.zig --kind file --description "staged-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
  completion candidate docs/staged.md --kind file --description "staged-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_worktree_files() {
  completion candidate src/worktree.zig --kind file --description "worktree-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
  completion candidate docs/worktree.md --kind file --description "worktree-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_changed_files() {
  completion candidate src/changed.zig --kind file --description "changed-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
  completion candidate docs/changed.md --kind file --description "changed-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_untracked_files() {
  completion candidate tmp/untracked.log --kind file --description "untracked-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_ignored_files() {
  completion candidate ignored.log --kind file --description "ignored-file:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_remotes() {
  completion candidate origin --kind plain --description "remote:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
  completion candidate upstream --kind plain --description "remote:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_remote_urls() {
  completion candidate git@github.com:rockorager/rush.git --kind plain --description "url:$rush_completion_argument_state:$rush_completion_argument_index"
  completion candidate https://github.com/rockorager/rush.git --kind plain --description "url:$rush_completion_argument_state:$rush_completion_argument_index"
}

__rush_complete_git_fixture_remote_refs() {
  completion candidate main --kind plain --description "remote-ref:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
  completion candidate release --kind plain --description "remote-ref:$rush_completion_argument_state:$rush_completion_argument_index:$rush_completion_options_terminated"
}

__rush_complete_git_fixture_restore_paths() {
  if completion option-present --long source; then
    __rush_complete_git_fixture_tree_files
  else
    if completion option-present --long staged; then
      __rush_complete_git_fixture_staged_files
    else
      __rush_complete_git_fixture_worktree_files
    fi
  fi
}

__rush_complete_git_fixture_reset_mode_present() {
  if completion option-present --long soft; then return 0; fi
  if completion option-present --long mixed; then return 0; fi
  if completion option-present --long hard; then return 0; fi
  if completion option-present --long merge; then return 0; fi
  if completion option-present --long keep; then return 0; fi
  return 1
}

__rush_complete_git_fixture_reset_arguments() {
  if test "$rush_completion_options_terminated" = true; then
    __rush_complete_git_fixture_staged_files
  else
    if test "$rush_completion_argument_index" = 0; then
      if __rush_complete_git_fixture_reset_mode_present; then
        __rush_complete_git_fixture_refs
      else
        __rush_complete_git_fixture_refs
        __rush_complete_git_fixture_staged_files
      fi
    else
      __rush_complete_git_fixture_staged_files
    fi
  fi
}

__rush_complete_git_fixture_clean_paths() {
  if completion option-present --short X; then
    __rush_complete_git_fixture_ignored_files
  else
    __rush_complete_git_fixture_untracked_files
    if completion option-present --short x; then
      __rush_complete_git_fixture_ignored_files
    fi
  fi
}

__rush_complete_git_fixture_push_delete_present() {
  if completion option-present --long delete; then return 0; fi
  if completion option-present --short d; then return 0; fi
  return 1
}

__rush_complete_git_fixture_push_set_upstream_present() {
  if completion option-present --long set-upstream; then return 0; fi
  if completion option-present --short u; then return 0; fi
  return 1
}

__rush_complete_git_fixture_push_refspec_sources() {
  __rush_complete_git_fixture_branches
  if ! __rush_complete_git_fixture_push_set_upstream_present; then
    __rush_complete_git_fixture_tags
  fi
}

__rush_complete_git_fixture_push_refspecs() {
  if __rush_complete_git_fixture_push_delete_present; then
    __rush_complete_git_fixture_remote_refs
  else
    __rush_complete_git_fixture_push_refspec_sources
  fi
}

__rush_complete_git_fixture_push_arguments() {
  if test "$rush_completion_value_position" = value; then
    __rush_complete_git_fixture_remote_refs
  else
    if test "$rush_completion_argument_index" = 0; then
      if ! completion option-present --long repo; then
        __rush_complete_git_fixture_remotes
      fi
      __rush_complete_git_fixture_push_refspecs
    else
      __rush_complete_git_fixture_push_refspecs
    fi
  fi
}
