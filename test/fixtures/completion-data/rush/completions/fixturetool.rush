# Fixture for lazy-loaded structured completion tests.

complete fixturetool --subcommand static --description 'static fixture subcommand'
complete fixturetool --option --long verbose --description 'enable verbose output'
complete fixturetool --subcommand files --description 'complete file arguments'
complete 'fixturetool files' --argument --function __fixturetool_files

__fixturetool_files() {
  completion files
}
