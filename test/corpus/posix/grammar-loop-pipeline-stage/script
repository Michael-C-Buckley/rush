printf 'a\nb\n' | while read line; do echo "while-last:$line"; done
printf 'c\nd\n' | until ! read line; do echo "until-last:$line"; done
printf 'm\n' | while read line; do echo "middle:$line"; done | { read line; echo "while-middle:$line"; }
printf 'n\n' | until ! read line; do echo "middle:$line"; done | { read line; echo "until-middle:$line"; }
n=0; while [ "$n" -lt 1 ]; do n=$((n + 1)); echo while-first; done | { read line; echo "while-first:$line"; }
n=0; until [ "$n" -ge 1 ]; do n=$((n + 1)); echo until-first; done | { read line; echo "until-first:$line"; }
