set -befmuC
saved=$(set +o)
set +befmuC
eval "$saved"
case $- in *b*) echo b:on;; *) echo b:off;; esac
case $- in *e*) echo e:on;; *) echo e:off;; esac
case $- in *f*) echo f:on;; *) echo f:off;; esac
case $- in *m*) echo m:on;; *) echo m:off;; esac
case $- in *u*) echo u:on;; *) echo u:off;; esac
case $- in *C*) echo C:on;; *) echo C:off;; esac
