rm -f iffd forfd whilefd untilfd casefd fnfd brshared fnshared subshared in
if true; then /bin/sh -c 'printf if >&3'; fi 3>iffd
for x in loop; do /bin/sh -c 'printf "$1" >&3' sh "$x"; done 3>forfd
n=0
while [ $n -lt 1 ]; do n=$((n + 1)); /bin/sh -c 'printf while >&3'; done 3>whilefd
n=0
until [ $n -ge 1 ]; do n=$((n + 1)); /bin/sh -c 'printf until >&3'; done 3>untilfd
case x in x) /bin/sh -c 'printf case >&3' ;; esac 3>casefd
f(){ /bin/sh -c 'printf fn >&3'; } 3>fnfd
f
printf 'a\nb\n' >in
{ read x; printf 'brace:%s\n' "$x"; /bin/cat; } <in >brshared
f2(){ read x; printf 'function:%s\n' "$x"; /bin/cat; }
f2 <in >fnshared
( read x; printf 'subshell:%s\n' "$x"; /bin/cat ) <in >subshared
cat iffd forfd whilefd untilfd casefd fnfd
printf '\n'
cat brshared fnshared subshared
rm -f iffd forfd whilefd untilfd casefd fnfd brshared fnshared subshared in
