mkdir scripts
cat > scripts/no-shebang <<'EOF'
printf 'fallback:%s:%s:%s\n' "$0" "$1" "$RUSH_ENOEXEC_ENV"
exit "$2"
EOF
chmod 755 scripts/no-shebang
PATH=scripts RUSH_ENOEXEC_ENV=prefix no-shebang arg 7 >out
printf 'path-status:%s\n' "$?"
cat out
./scripts/no-shebang slash 9
printf 'slash-status:%s\n' "$?"
PATH=/nope RUSH_ENOEXEC_ENV=assign PATH=scripts no-shebang assign 11
printf 'assign-status:%s\n' "$?"
