test 5 -eq 5; echo eq=$?
test 5 -ne 4; echo ne=$?
test 5 -gt 4; echo gt=$?
test 5 -ge 5; echo ge=$?
test 4 -lt 5; echo lt=$?
test 5 -le 5; echo le=$?
test " 5" -eq 5; echo leading-blank=$?
test "5 " -eq 5; echo trailing-blank=$?
test "$(printf '\t5\t')" -eq 5; echo tab-blank=$?
test " -5 " -lt 0; echo negative=$?
test "010 " -eq 10; echo decimal-leading-zero=$?
