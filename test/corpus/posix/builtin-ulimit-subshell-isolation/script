old=$(ulimit -Sn)
old_hard=$(ulimit -Hn)

case $old in
  unlimited) new=64 ;;
  ''|*[!0123456789]*) new= ;;
  *)
    new=$old
    if [ "$old" -gt 64 ]; then new=64; fi
    ;;
esac

if [ -z "$new" ]; then
  echo unsupported-old
else
  subshell_result=$( ( ulimit -n "$new"; printf '%s/%s' "$(ulimit -Sn)" "$(ulimit -Hn)" ) )
  if [ "$subshell_result" = "$new/$new" ]; then echo subshell:changed; else echo subshell:mismatch; fi
  if [ "$(ulimit -Sn)" = "$old" ] && [ "$(ulimit -Hn)" = "$old_hard" ]; then echo subshell-parent:restored; else echo subshell-parent:leaked; fi

  substitution_result=$(ulimit -n "$new"; printf '%s/%s' "$(ulimit -Sn)" "$(ulimit -Hn)")
  if [ "$substitution_result" = "$new/$new" ]; then echo command-substitution:changed; else echo command-substitution:mismatch; fi
  if [ "$(ulimit -Sn)" = "$old" ] && [ "$(ulimit -Hn)" = "$old_hard" ]; then echo command-substitution-parent:restored; else echo command-substitution-parent:leaked; fi

  ulimit -n "$new" | /bin/cat >/dev/null
  if [ "$(ulimit -Sn)" = "$old" ] && [ "$(ulimit -Hn)" = "$old_hard" ]; then echo pipeline-parent:restored; else echo pipeline-parent:leaked; fi
fi
