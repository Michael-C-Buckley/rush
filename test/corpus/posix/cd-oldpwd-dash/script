start=$PWD
out=$PWD/rush-cd-old.out
mkdir -p rush-cd-old/new
cd rush-cd-old
printf 'pwd:%s\n' "${PWD##*/}"
case $OLDPWD in "$start") echo old-ok ;; *) echo old-bad ;; esac
cd new
cd - > "$out"
case $(cat "$out") in */rush-cd-old) echo dash-output-ok ;; *) echo dash-output-bad ;; esac
printf 'back:%s\n' "${PWD##*/}"
printf 'old2:%s\n' "${OLDPWD##*/}"
cd "$start"
