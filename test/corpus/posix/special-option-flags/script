printf '<%s>\n' "$-"
set -a
case $- in *a*) echo set-a ;; *) echo missing-a ;; esac
set +a
case $- in *a*) echo stale-a ;; *) echo cleared-a ;; esac
set -e
case $- in *e*) echo set-e ;; *) echo missing-e ;; esac
set +e
case $- in *e*) echo stale-e ;; *) echo cleared-e ;; esac
set -o nounset
case $- in *u*) echo set-u ;; *) echo missing-u ;; esac
set +o nounset
set -fC
case $- in *f*) echo set-f ;; *) echo missing-f ;; esac
case $- in *C*) echo set-C ;; *) echo missing-C ;; esac
set +fC
set -v
case $- in *v*) echo set-v ;; *) echo missing-v ;; esac
set +v
set -x
case $- in *x*) echo set-x ;; *) echo missing-x ;; esac
set +x
echo after-trace
