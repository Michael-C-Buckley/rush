printf builtin >/dev/full
printf 'builtin=%s\n' "$?"
f() { printf function; }
f >/dev/full
printf 'function=%s\n' "$?"
{ printf group; } >/dev/full
printf 'group=%s\n' "$?"
printf '%s\n' 'printf external || exit 37' >external-write-failure.sh
/bin/sh ./external-write-failure.sh >/dev/full 2>/dev/null
printf 'external=%s\n' "$?"
set -o pipefail
printf stage >/dev/full | :
printf 'pipefail-first-stage=%s\n' "$?"
printf pipe | printf last >/dev/full
printf 'last-stage=%s\n' "$?"
