{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rush.horse/completion/schema/v1.schema.json",
  "title": "Rush Completion Manifest v1",
  "description": "Structured completion manifest for Rush command completions. See https://rush.horse/docs/completion-manifest.html for human-readable documentation.",
  "type": "object",
  "required": ["manifestVersion", "command"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "manifestVersion": {
      "const": 1
    },
    "command": {
      "$ref": "#/$defs/command"
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/nameOrNames"
        },
        "aliases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/name"
          },
          "uniqueItems": true
        },
        "description": {
          "type": "string"
        },
        "hidden": {
          "type": "boolean"
        },
        "deprecated": {
          "$ref": "#/$defs/deprecated"
        },
        "platforms": {
          "$ref": "#/$defs/platforms"
        },
        "variantProbe": {
          "$ref": "#/$defs/variantProbe"
        },
        "variants": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/commandVariant"
          }
        },
        "providers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/provider"
          }
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/option"
          }
        },
        "optionGroups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/optionGroup"
          }
        },
        "arguments": {
          "$ref": "#/$defs/argumentModel"
        },
        "subcommands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command"
          }
        },
        "dynamicSubcommands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/providerRef"
          }
        },
        "dynamicOptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/providerRef"
          }
        }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["short"] },
        { "required": ["long"] }
      ],
      "properties": {
        "short": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1,
          "pattern": "^[^-\\s]$"
        },
        "long": {
          "$ref": "#/$defs/longOptionName"
        },
        "aliases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/longOptionName"
          },
          "uniqueItems": true
        },
        "description": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/optionValue"
        },
        "repeatable": {
          "type": "boolean"
        },
        "exclusiveGroup": {
          "$ref": "#/$defs/name"
        },
        "excludes": {
          "$ref": "#/$defs/optionExclusions"
        },
        "requires": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/optionSelector"
          },
          "uniqueItems": true
        },
        "terminatesOptions": {
          "type": "boolean"
        },
        "hidden": {
          "type": "boolean"
        },
        "deprecated": {
          "$ref": "#/$defs/deprecated"
        },
        "platforms": {
          "$ref": "#/$defs/platforms"
        }
      }
    },
    "commandVariant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platforms": { "$ref": "#/$defs/platforms" },
        "providers": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/provider" }
        },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/option" }
        },
        "optionGroups": {
          "type": "array",
          "items": { "$ref": "#/$defs/optionGroup" }
        },
        "arguments": { "$ref": "#/$defs/argumentModel" },
        "subcommands": {
          "type": "array",
          "items": { "$ref": "#/$defs/command" }
        },
        "dynamicSubcommands": {
          "type": "array",
          "items": { "$ref": "#/$defs/providerRef" }
        },
        "dynamicOptions": {
          "type": "array",
          "items": { "$ref": "#/$defs/providerRef" }
        }
      }
    },
    "variantProbe": {
      "type": "object",
      "required": ["args", "matches"],
      "additionalProperties": false,
      "properties": {
        "args": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "matches": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/platform" },
      "uniqueItems": true
    },
    "platform": {
      "enum": ["darwin", "linux", "freebsd", "openbsd", "netbsd", "dragonfly", "windows", "wasi", "haiku"]
    },
    "optionGroup": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "exclusive": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "optionValue": {
      "oneOf": [
        { "$ref": "#/$defs/value" },
        { "$ref": "#/$defs/valueSequence" }
      ]
    },
    "valueSequence": {
      "type": "array",
      "minItems": 1,
      "prefixItems": [
        { "$ref": "#/$defs/value" }
      ],
      "items": {
        "allOf": [
          { "$ref": "#/$defs/value" },
          {
            "not": {
              "required": ["style"],
              "properties": {
                "style": {
                  "enum": ["attached", "attached-or-detached", "equals", "optional"]
                }
              }
            }
          }
        ]
      }
    },
    "value": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "required": {
          "type": "boolean"
        },
        "style": {
          "enum": ["detached", "attached", "attached-or-detached", "equals", "optional"]
        },
        "provider": {
          "$ref": "#/$defs/providerRefOrArray"
        },
        "grammar": {
          "$ref": "#/$defs/valueGrammar"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "argumentModel": {
      "type": "object",
      "required": ["states"],
      "additionalProperties": false,
      "properties": {
        "terminator": {
          "type": "string"
        },
        "states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/argumentState"
          }
        }
      }
    },
    "argumentState": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "required": ["rest"] },
          "then": {
            "properties": {
              "rest": { "const": "command-line" }
            },
            "not": {
              "anyOf": [
                { "required": ["repeatable"] },
                { "required": ["provider"] },
                { "required": ["grammar"] }
              ]
            }
          }
        }
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "rest": {
          "const": "command-line"
        },
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "repeatable": {
          "type": "boolean"
        },
        "provider": {
          "$ref": "#/$defs/providerRefOrArray"
        },
        "grammar": {
          "$ref": "#/$defs/valueGrammar"
        },
        "description": {
          "type": "string"
        },
        "when": {
          "$ref": "#/$defs/condition"
        },
        "after": {
          "$ref": "#/$defs/condition"
        },
        "until": {
          "$ref": "#/$defs/condition"
        }
      }
    },
    "provider": {
      "oneOf": [
        { "$ref": "#/$defs/functionProvider" },
        { "$ref": "#/$defs/builtinProvider" },
        { "$ref": "#/$defs/staticEnumProvider" }
      ]
    },
    "functionProvider": {
      "type": "object",
      "required": ["function"],
      "additionalProperties": false,
      "properties": {
        "function": {
          "$ref": "#/$defs/functionName"
        },
        "tag": {
          "$ref": "#/$defs/name"
        },
        "description": {
          "type": "string"
        },
        "lazy": {
          "type": "boolean"
        }
      }
    },
    "builtinProvider": {
      "type": "object",
      "required": ["builtin"],
      "additionalProperties": false,
      "properties": {
        "builtin": {
          "enum": ["files", "directories", "executables", "variables"]
        },
        "tag": {
          "$ref": "#/$defs/name"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "staticEnumProvider": {
      "type": "object",
      "required": ["values"],
      "additionalProperties": false,
      "properties": {
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/enumValue"
          }
        },
        "tag": {
          "$ref": "#/$defs/name"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "providerRefOrArray": {
      "oneOf": [
        { "$ref": "#/$defs/providerRef" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/providerRef" },
          "uniqueItems": true
        }
      ]
    },
    "providerRef": {
      "oneOf": [
        { "$ref": "#/$defs/providerId" },
        { "$ref": "#/$defs/provider" }
      ]
    },
    "valueGrammar": {
      "oneOf": [
        { "$ref": "#/$defs/enumGrammar" },
        { "$ref": "#/$defs/listGrammar" },
        { "$ref": "#/$defs/keyValueGrammar" },
        { "$ref": "#/$defs/pathGrammar" },
        { "$ref": "#/$defs/stringGrammar" }
      ]
    },
    "enumGrammar": {
      "type": "object",
      "required": ["kind", "values"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "enum" },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/enumValue"
          }
        }
      }
    },
    "enumValue": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["value"],
          "additionalProperties": false,
          "properties": {
            "value": { "type": "string" },
            "description": { "type": "string" },
            "display": { "type": "string" },
            "tag": { "$ref": "#/$defs/name" },
            "suffix": { "type": "string" },
            "removableSuffix": { "type": "boolean" },
            "noSpace": { "type": "boolean" }
          }
        }
      ]
    },
    "listGrammar": {
      "type": "object",
      "required": ["kind", "separator", "item"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "list" },
        "separator": { "type": "string", "minLength": 1 },
        "item": { "$ref": "#/$defs/value" },
        "allowEmpty": { "type": "boolean" }
      }
    },
    "keyValueGrammar": {
      "type": "object",
      "required": ["kind", "separator", "key", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "keyValue" },
        "separator": { "type": "string", "minLength": 1 },
        "keyPrefix": { "type": "string", "minLength": 1 },
        "key": { "$ref": "#/$defs/value" },
        "value": { "$ref": "#/$defs/value" }
      }
    },
    "pathGrammar": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "path" },
        "directoriesOnly": { "type": "boolean" }
      }
    },
    "stringGrammar": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "string" }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "all": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" }
        },
        "any": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" }
        },
        "not": {
          "$ref": "#/$defs/condition"
        },
        "optionPresent": {
          "$ref": "#/$defs/optionSelectorOrSelectors"
        },
        "optionAbsent": {
          "$ref": "#/$defs/optionSelectorOrSelectors"
        },
        "optionValue": {
          "$ref": "#/$defs/optionValueCondition"
        },
        "terminatorSeen": {
          "type": "boolean"
        },
        "previousState": {
          "$ref": "#/$defs/name"
        },
        "argumentCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "optionSelectorOrSelectors": {
      "oneOf": [
        { "$ref": "#/$defs/optionSelector" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/optionSelector" },
          "uniqueItems": true
        }
      ]
    },
    "optionExclusions": {
      "oneOf": [
        { "$ref": "#/$defs/optionExclusionSentinel" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/optionSelector" },
              { "$ref": "#/$defs/optionExclusionSentinel" }
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      ]
    },
    "optionExclusionSentinel": {
      "enum": ["operands", "everything"]
    },
    "optionSelector": {
      "type": "string",
      "pattern": "^(--[A-Za-z0-9][A-Za-z0-9_-]*|-[^-\\s])$"
    },
    "optionValueCondition": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/optionSelector"
      },
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "uniqueItems": true
          }
        ]
      }
    },
    "nameOrNames": {
      "oneOf": [
        { "$ref": "#/$defs/name" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/name" },
          "minItems": 1,
          "uniqueItems": true
        }
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "longOptionName": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "functionName": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "deprecated": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string" }
      ]
    }
  }
}
