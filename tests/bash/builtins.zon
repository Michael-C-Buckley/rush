.{
    .name = "Bash shell builtins",
    .mode = .bash,
    .cases = .{
        .{
            .name = "wait rejects operands that are not process ids or job specs by default",
            .script =
            \\wait notapid
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "echo supports bash option clusters and escapes",
            .script =
            \\echo -ne 'a\nb\t\x21\041\u263a\U0001f600'
            \\printf '\n'
            \\echo -enE 'c\nd'
            \\echo -nex literal
            \\echo -nnneE done
            ,
            .stdout = "a\nb\t!!☺😀\nc\\nd-nex literal\ndone",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "echo escape c suppresses remaining output and newline",
            .script =
            \\echo -e 'before\cafter' ignored
            \\printf '<after>\n'
            ,
            .stdout =
            \\before<after>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "source operands initialize sourced positional parameters",
            .script =
            \\cat >file.sh <<'EOF'
            \\printf '<%s>:<%s>\n' "${1-unset}" "${2-unset}"
            \\set -- changed
            \\EOF
            \\set -- outer
            \\source ./file.sh inner more
            \\printf '<%s>:<%s>\n' "${1-unset}" "${2-unset}"
            ,
            .stdout =
            \\<inner>:<more>
            \\<changed>:<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dot operands initialize sourced positional parameters in Bash mode",
            .script =
            \\cat >file.sh <<'EOF'
            \\printf '<%s>:<%s>\n' "${1-unset}" "${2-unset}"
            \\set -- changed
            \\EOF
            \\set -- outer
            \\. ./file.sh inner more
            \\printf '<%s>:<%s>\n' "${1-unset}" "${2-unset}"
            ,
            .stdout =
            \\<inner>:<more>
            \\<changed>:<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "test integer comparisons trim operand whitespace",
            .script =
            \\test " 5" -eq " 5 "
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read -n reads up to a character count or delimiter",
            .script =
            \\printf 'abc\ndef' | {
            \\    read -r -n 2 first
            \\    printf 'first=<%s> status=<%s>\n' "$first" "$?"
            \\    read -r rest
            \\    printf 'rest=<%s> status=<%s>\n' "$rest" "$?"
            \\}
            \\printf 'a\nbc' | {
            \\    read -r -n 3 line
            \\    printf 'line=<%s> status=<%s>\n' "$line" "$?"
            \\}
            ,
            .stdout =
            \\first=<ab> status=<0>
            \\rest=<c> status=<0>
            \\line=<a> status=<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read -a assigns split fields to an indexed array",
            .script =
            \\printf 'a b  c\n' | {
            \\    read -ra arr ignored
            \\    declare -p arr
            \\    printf 'ignored=<%s>\n' "${ignored-unset}"
            \\}
            \\printf 'a::b:\n' | {
            \\    IFS=: read -ra arr
            \\    declare -p arr
            \\}
            ,
            .stdout =
            \\declare -a arr=([0]="a" [1]="b" [2]="c")
            \\ignored=<unset>
            \\declare -a arr=([0]="a" [1]="" [2]="b")
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read -n counts multibyte characters",
            .script =
            \\printf 'éx' | {
            \\    read -r -n 1 first
            \\    printf 'first=<%s> status=<%s>\n' "$first" "$?"
            \\    read -r rest
            \\    printf 'rest=<%s> status=<%s>\n' "$rest" "$?"
            \\}
            ,
            .stdout =
            \\first=<é> status=<0>
            \\rest=<x> status=<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read -N reads exact characters without delimiter splitting",
            .script =
            \\printf 'a\nbc' | {
            \\    read -r -N 3 value extra
            \\    printf 'value=<%s> extra=<%s> status=<%s>\n' "$value" "$extra" "$?"
            \\    read -r rest
            \\    printf 'rest=<%s> status=<%s>\n' "$rest" "$?"
            \\}
            \\printf ' a ' | {
            \\    read -r -N 3 value
            \\    printf 'spaces=<%s> len=<%s>\n' "$value" "${#value}"
            \\}
            ,
            .stdout =
            \\value=<a
            \\b> extra=<> status=<0>
            \\rest=<c> status=<1>
            \\spaces=< a > len=<3>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read -p suppresses prompt when stdin is not a terminal",
            .script =
            \\printf 'answer\n' | {
            \\    read -r -p 'prompt: ' value
            \\    printf '<%s>\n' "$value"
            \\}
            ,
            .stdout =
            \\<answer>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read -s accepts silent input mode",
            .script =
            \\printf 'secret\n' | {
            \\    read -r -s value
            \\    printf '<%s>:<%s>\n' "$value" "$?"
            \\}
            ,
            .stdout =
            \\<secret>:<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read -t times out and preserves partial input",
            .script =
            \\{ sleep 0.1; printf x; } | {
            \\    read -r -t 0.01 value
            \\    printf 'timeout=<%s> value=<%s>\n' "$?" "$value"
            \\}
            \\{ printf a; sleep 0.1; printf b; } | {
            \\    read -r -t 0.01 -n 2 value
            \\    printf 'partial=<%s> value=<%s>\n' "$?" "$value"
            \\}
            ,
            .stdout =
            \\timeout=<142> value=<>
            \\partial=<142> value=<a>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read -t zero probes readiness without consuming input",
            .script =
            \\printf 'x\n' >read-timeout-input
            \\{
            \\    read -r -t 0 -n 1 value
            \\    printf 'probe=<%s> value=<%s>\n' "$?" "$value"
            \\    read -r rest
            \\    printf 'rest=<%s>\n' "$rest"
            \\} <read-timeout-input
            \\{ sleep 0.1; printf x; } | {
            \\    read -r -t 0 value
            \\    printf 'not-ready=<%s> value=<%s>\n' "$?" "$value"
            \\}
            ,
            .stdout =
            \\probe=<0> value=<>
            \\rest=<x>
            \\not-ready=<1> value=<>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "local variables restore function caller bindings",
            .script =
            \\x=global
            \\f() {
            \\    local x=inner
            \\    printf 'inside=<%s>\n' "$x"
            \\    x=changed
            \\}
            \\f
            \\printf 'after=<%s>\n' "$x"
            ,
            .stdout =
            \\inside=<inner>
            \\after=<global>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "local without assignment shadows globals as unset",
            .script =
            \\x=global
            \\f() {
            \\    local x
            \\    printf 'inside=<%s>:<%s>\n' "$x" "${x-unset}"
            \\}
            \\f
            \\printf 'after=<%s>\n' "$x"
            ,
            .stdout =
            \\inside=<>:<unset>
            \\after=<global>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "local keeps function assignment-prefix values",
            .script =
            \\x=global
            \\f() {
            \\    local x
            \\    printf 'inside=<%s>:<%s>\n' "$x" "${x-unset}"
            \\}
            \\x=prefix f
            \\printf 'after=<%s>\n' "$x"
            ,
            .stdout =
            \\inside=<prefix>:<prefix>
            \\after=<global>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "local array declarations create function-local arrays",
            .script =
            \\pids=(outer)
            \\f() {
            \\    local pids=()
            \\    printf 'empty=<%s>\n' "${#pids[@]}"
            \\    local -a pids=(a b)
            \\    printf 'filled=<%s>:<%s>:<%s>\n' "${#pids[@]}" "${pids[0]}" "${pids[1]}"
            \\}
            \\f
            \\printf 'after=<%s>:<%s>\n' "${#pids[@]}" "${pids[0]}"
            ,
            .stdout =
            \\empty=<0>
            \\filled=<2>:<a>:<b>
            \\after=<1>:<outer>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "local outside functions fails",
            .script =
            \\local x=bad
            \\printf 'status=<%s>:<%s>\n' "$?" "${x-unset}"
            ,
            .stdout =
            \\status=<1>:<unset>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "declare marks readonly and exported scalar variables",
            .script =
            \\HOME=/tmp
            \\declare -rx VALUE=~:/bin
            \\case "$(declare -p VALUE)" in
            \\    'declare -rx VALUE="/tmp:/bin"') printf 'print=<ok>\n' ;;
            \\    *) printf 'print=<bad:%s>\n' "$(declare -p VALUE)" ;;
            \\esac
            \\sh -c 'test "$VALUE" = /tmp:/bin'
            \\printf 'env=<%s>\n' "$?"
            ,
            .stdout =
            \\print=<ok>
            \\env=<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "declare integer variables evaluate arithmetic assignments",
            .script =
            \\declare -i n=1+2
            \\n=4+5
            \\x=7
            \\export n=x+3
            \\declare -p n
            \\raw=1+2
            \\declare -i raw
            \\printf 'raw=<%s>\n' "$raw"
            \\declare -i empty
            \\declare -p empty
            ,
            .stdout =
            \\declare -ix n="10"
            \\raw=<1+2>
            \\declare -i empty
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "declare creates and prints indexed arrays",
            .script =
            \\declare -a arr
            \\declare -p arr
            \\arr[2]=z
            \\declare -p arr
            \\x=foo
            \\declare -a x
            \\declare -a y=bar
            \\declare -a sparse=([2]=z [4]=q)
            \\declare -p x y sparse
            ,
            .stdout =
            \\declare -a arr
            \\declare -a arr=([2]="z")
            \\declare -a x=([0]="foo")
            \\declare -a y=([0]="bar")
            \\declare -a sparse=([2]="z" [4]="q")
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "declaration builtins preserve indexed array attributes",
            .script =
            \\arr=(a)
            \\declare -rx arr
            \\declare -p arr
            \\declare -ix iarr=(1+2)
            \\iarr[1]=3+4
            \\declare -p iarr
            \\readonly -a ro=(x y)
            \\(ro[0]=z)
            \\printf 'readonly_status=<%s>\n' "$?"
            \\declare -p ro
            \\readonly -a pending
            \\export -a exported
            \\declare -p pending exported
            ,
            .stdout =
            \\declare -arx arr=([0]="a")
            \\declare -aix iarr=([0]="3" [1]="7")
            \\readonly_status=<1>
            \\declare -ar ro=([0]="x" [1]="y")
            \\declare -r pending
            \\declare -x exported
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "declare uses function local scope unless global is requested",
            .script =
            \\value=global
            \\target=old
            \\f() {
            \\    declare value=local
            \\    declare -g target=new
            \\    printf 'inside=<%s>:<%s>\n' "$value" "$target"
            \\}
            \\f
            \\printf 'after=<%s>:<%s>\n' "$value" "$target"
            ,
            .stdout =
            \\inside=<local>:<new>
            \\after=<global>:<new>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "declare array assignments use function local scope",
            .script =
            \\arr=(global)
            \\f() {
            \\    declare arr=()
            \\    printf 'empty=<%s>\n' "${#arr[@]}"
            \\    declare arr=(local value)
            \\    printf 'inside=<%s>:<%s>:<%s>\n' "${#arr[@]}" "${arr[0]}" "${arr[1]}"
            \\}
            \\f
            \\printf 'after=<%s>:<%s>\n' "${#arr[@]}" "${arr[0]}"
            ,
            .stdout =
            \\empty=<0>
            \\inside=<2>:<local>:<value>
            \\after=<1>:<global>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "typeset is an alias for scalar declaration",
            .script =
            \\typeset alias_value=ok
            \\case "$(typeset -p alias_value)" in
            \\    'declare -- alias_value="ok"') printf 'typeset=<ok>\n' ;;
            \\    *) printf 'typeset=<bad:%s>\n' "$(typeset -p alias_value)" ;;
            \\esac
            ,
            .stdout =
            \\typeset=<ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "local accepts readonly and export flags",
            .script =
            \\f() {
            \\    local -rx local_value=ok
            \\    case "$(declare -p local_value)" in
            \\        'declare -rx local_value="ok"') printf 'attrs=<ok>\n' ;;
            \\        *) printf 'attrs=<bad:%s>\n' "$(declare -p local_value)" ;;
            \\    esac
            \\    sh -c 'test "$local_value" = ok'
            \\    printf 'env=<%s>\n' "$?"
            \\}
            \\f
            \\printf 'after=<%s>\n' "${local_value-unset}"
            ,
            .stdout =
            \\attrs=<ok>
            \\env=<0>
            \\after=<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "shopt lists queries and updates expand_aliases",
            .script =
            \\shopt -q expand_aliases
            \\printf 'query-before=<%s>\n' "$?"
            \\shopt -s expand_aliases
            \\shopt -q expand_aliases
            \\printf 'query-after=<%s>\n' "$?"
            \\shopt -p expand_aliases
            ,
            .stdout =
            \\query-before=<1>
            \\query-after=<0>
            \\shopt -s expand_aliases
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "shopt without names succeeds regardless of disabled options",
            .script =
            \\shopt >/dev/null
            \\printf 'list=<%s>\n' "$?"
            \\shopt -q
            \\printf 'query=<%s>\n' "$?"
            ,
            .stdout =
            \\list=<0>
            \\query=<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "shopt option combinations follow Bash query and selection rules",
            .script =
            \\shopt -s | grep '^promptvars.*on$' >/dev/null
            \\printf 'selected-on=<%s>\n' "$?"
            \\shopt -u | grep '^expand_aliases.*off$' >/dev/null
            \\printf 'selected-off=<%s>\n' "$?"
            \\shopt -p -q promptvars
            \\printf 'print-query=<%s>\n' "$?"
            \\shopt -uq promptvars
            \\printf 'unset-query=<%s>\n' "$?"
            \\shopt -q promptvars
            \\printf 'unset-applied=<%s>\n' "$?"
            \\shopt -sq promptvars
            \\printf 'set-query=<%s>\n' "$?"
            \\shopt -s promptvars
            \\shopt -su promptvars
            \\printf 'set-unset=<%s>\n' "$?"
            \\shopt -q promptvars
            \\printf 'unchanged=<%s>\n' "$?"
            \\shopt no_such_rush_option
            \\printf 'invalid-query=<%s>\n' "$?"
            \\shopt -s no_such_rush_option
            \\printf 'invalid-set=<%s>\n' "$?"
            ,
            .stdout =
            \\selected-on=<0>
            \\selected-off=<0>
            \\print-query=<0>
            \\unset-query=<0>
            \\unset-applied=<1>
            \\set-query=<0>
            \\set-unset=<1>
            \\unchanged=<0>
            \\invalid-query=<1>
            \\invalid-set=<1>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "hash -d and alias -d share named directories",
            .script =
            \\hash -d host=/tmp/example///
            \\alias -d -- host
            \\alias -d host=/srv/replaced/
            \\hash -d host
            \\hash -d root=////
            \\alias -d root
            ,
            .stdout =
            \\host='/tmp/example'
            \\host='/srv/replaced'
            \\root='/'
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "named directories can be removed or reset",
            .script =
            \\hash -d one=/one two=/two
            \\unalias -d one
            \\hash -d one 2>/dev/null
            \\printf 'removed=<%s>\n' "$?"
            \\hash -dr
            \\alias -d two 2>/dev/null
            \\printf 'reset=<%s>\n' "$?"
            \\alias -d keep=/keep discard=/discard
            \\unalias -da
            \\hash -d keep 2>/dev/null
            \\printf 'removed-all=<%s>\n' "$?"
            ,
            .stdout =
            \\removed=<1>
            \\reset=<1>
            \\removed-all=<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "named directories require valid names and absolute paths",
            .script =
            \\hash -d relative=tmp 2>/dev/null
            \\printf 'relative=<%s>\n' "$?"
            \\alias -d 'bad/name=/tmp' 2>/dev/null
            \\printf 'name=<%s>\n' "$?"
            \\hash -d missing 2>/dev/null
            \\printf 'missing=<%s>\n' "$?"
            ,
            .stdout =
            \\relative=<1>
            \\name=<1>
            \\missing=<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "type supports path kind and all-match options",
            .script =
            \\type -t cd
            \\type -p ls >/dev/null; printf 'path=<%s>\n' "$?"
            \\type -P printf >/dev/null; printf 'force-path=<%s>\n' "$?"
            \\type -a printf | sed -n '1,2p'
            ,
            .stdout =
            \\builtin
            \\path=<0>
            \\force-path=<0>
            \\printf is a shell builtin
            \\printf is /usr/bin/printf
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
