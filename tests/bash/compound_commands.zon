.{
    .name = "Bash compound commands",
    .mode = .bash,
    .cases = .{
        .{
            .name = "case command ;;& continues by testing the next pattern",
            .script =
            \\case a in
            \\    a) printf 'one\n' ;;&
            \\    a) printf 'two\n' ;;
            \\    *) printf 'bad\n' ;;
            \\esac
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "invalid for loop variable reports failure and continues",
            .script =
            \\name=
            \\for $name in a; do printf bad; done
            \\printf 'after=<%s>\n' "$?"
            ,
            .stdout =
            \\after=<1>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "readonly for loop variable reports failure and continues by default",
            .script =
            \\readonly i
            \\for i in a b; do printf bad; done
            \\printf 'i=<%s> status=<%s>\n' "$i" "$?"
            \\printf after
            ,
            .stdout =
            \\i=<> status=<1>
            \\after
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "function keyword defines shell functions",
            .script =
            \\function one { printf 'one:%s\n' "$1"; }
            \\function two() { printf 'two:%s\n' "$1"; }
            \\one a
            \\two b
            ,
            .stdout =
            \\one:a
            \\two:b
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definitions accept periods in names",
            .script =
            \\zig_0.16.0() { printf 'traditional:%s\n' "$1"; }
            \\function tool.1.2 { printf 'keyword:%s\n' "$1"; }
            \\zig_0.16.0 a
            \\tool.1.2 b
            ,
            .stdout =
            \\traditional:a
            \\keyword:b
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic command evaluates expression status and mutations",
            .script =
            \\i=0
            \\if (( ++i )); then printf 'if:%s\n' "$i"; fi
            \\(( i - 1 ))
            \\printf 'zero-status:%s\n' "$?"
            \\(( i + 1 ))
            \\printf 'nonzero-status:%s\n' "$?"
            ,
            .stdout =
            \\if:1
            \\zero-status:1
            \\nonzero-status:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "c-style for command evaluates arithmetic clauses",
            .script =
            \\for (( i=0; i<4; ++i )); do
            \\    if (( i == 1 )); then continue; fi
            \\    if (( i == 3 )); then break; fi
            \\    printf 'loop:%s\n' "$i"
            \\done
            \\printf 'after:%s status:%s\n' "$i" "$?"
            ,
            .stdout =
            \\loop:0
            \\loop:2
            \\after:3 status:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "c-style for command permits empty clauses",
            .script =
            \\for (( ; ; )); do
            \\    printf 'once\n'
            \\    break
            \\done
            ,
            .stdout =
            \\once
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "conditional command evaluates strings and boolean operators",
            .script =
            \\x=abc
            \\empty=
            \\if [[ $x && ! $empty ]]; then printf 'truthy\n'; fi
            \\if [[ ( $empty || $x ) && $x == abc ]]; then printf 'grouped\n'; fi
            \\if [[ -n $x && -z $empty ]]; then printf 'unary\n'; fi
            \\[[ $empty ]] || printf 'empty-status:%s\n' "$?"
            ,
            .stdout =
            \\truthy
            \\grouped
            \\unary
            \\empty-status:1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "conditional command evaluates file unary primaries",
            .script =
            \\: >package.json
            \\mkdir .amp
            \\if [[ -f "package.json" && -d ".amp" ]]; then printf 'present\n'; fi
            \\if [[ ! -f missing.json ]]; then printf 'missing\n'; fi
            ,
            .stdout =
            \\present
            \\missing
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "conditional command evaluates integer comparisons",
            .script =
            \\pids=()
            \\if [[ ${#pids[@]} -eq 0 ]]; then printf 'empty\n'; fi
            \\pids+=(123)
            \\if [[ ${#pids[@]} -gt 0 && 4 -le 4 ]]; then printf 'nonempty\n'; fi
            ,
            .stdout =
            \\empty
            \\nonempty
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "conditional command compares strings and matches patterns",
            .script =
            \\x=src/main.zig
            \\if [[ $x == src/*.zig ]]; then printf 'pattern\n'; fi
            \\if [[ $x != "src/*.zig" ]]; then printf 'quoted-literal\n'; fi
            \\if [[ apple < banana && zebra > yak ]]; then printf 'ordered\n'; fi
            ,
            .stdout =
            \\pattern
            \\quoted-literal
            \\ordered
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
