.{
    .name = "Bash compound commands",
    .mode = .bash,
    .cases = .{
        .{
            .name = "case command ;;& continues by testing the next pattern",
            .script =
            \\case a in
            \\    a) printf 'one\n' ;;&
            \\    a) printf 'two\n' ;;
            \\    *) printf 'bad\n' ;;
            \\esac
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "invalid for loop variable reports failure and continues",
            .script =
            \\name=
            \\for $name in a; do printf bad; done
            \\printf 'after=<%s>\n' "$?"
            ,
            .stdout =
            \\after=<1>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "readonly for loop variable reports failure and continues by default",
            .script =
            \\readonly i
            \\for i in a b; do printf bad; done
            \\printf 'i=<%s> status=<%s>\n' "$i" "$?"
            \\printf after
            ,
            .stdout =
            \\i=<> status=<1>
            \\after
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "function keyword defines shell functions",
            .script =
            \\function one { printf 'one:%s\n' "$1"; }
            \\function two() { printf 'two:%s\n' "$1"; }
            \\one a
            \\two b
            ,
            .stdout =
            \\one:a
            \\two:b
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic command evaluates expression status and mutations",
            .script =
            \\i=0
            \\if (( ++i )); then printf 'if:%s\n' "$i"; fi
            \\(( i - 1 ))
            \\printf 'zero-status:%s\n' "$?"
            \\(( i + 1 ))
            \\printf 'nonzero-status:%s\n' "$?"
            ,
            .stdout =
            \\if:1
            \\zero-status:1
            \\nonzero-status:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "c-style for command evaluates arithmetic clauses",
            .script =
            \\for (( i=0; i<4; ++i )); do
            \\    if (( i == 1 )); then continue; fi
            \\    if (( i == 3 )); then break; fi
            \\    printf 'loop:%s\n' "$i"
            \\done
            \\printf 'after:%s status:%s\n' "$i" "$?"
            ,
            .stdout =
            \\loop:0
            \\loop:2
            \\after:3 status:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "c-style for command permits empty clauses",
            .script =
            \\for (( ; ; )); do
            \\    printf 'once\n'
            \\    break
            \\done
            ,
            .stdout =
            \\once
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
