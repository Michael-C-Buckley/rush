.{
    .name = "Bash compound commands",
    .mode = .bash,
    .cases = .{
        .{
            .name = "case command ;;& continues by testing the next pattern",
            .script =
            \\case a in
            \\    a) printf 'one\n' ;;&
            \\    a) printf 'two\n' ;;
            \\    *) printf 'bad\n' ;;
            \\esac
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "invalid for loop variable reports failure and continues",
            .script =
            \\name=
            \\for $name in a; do printf bad; done
            \\printf 'after=<%s>\n' "$?"
            ,
            .stdout =
            \\after=<1>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "readonly for loop variable reports failure and continues by default",
            .script =
            \\readonly i
            \\for i in a b; do printf bad; done
            \\printf 'i=<%s> status=<%s>\n' "$i" "$?"
            \\printf after
            ,
            .stdout =
            \\i=<> status=<1>
            \\after
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "function keyword defines shell functions",
            .script =
            \\function one { printf 'one:%s\n' "$1"; }
            \\function two() { printf 'two:%s\n' "$1"; }
            \\one a
            \\two b
            ,
            .stdout =
            \\one:a
            \\two:b
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
