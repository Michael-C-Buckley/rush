.{
    .name = "Bash redirections",
    .mode = .bash,
    .cases = .{
        .{
            .name = "self-duplicate redirection is a no-op even when the descriptor is closed",
            .script =
            \\exec 3>&1 1>&-
            \\printf '' 1>&1
            \\status=$?
            \\exec 1>&3 3>&-
            \\printf '<%s>\n' "$status"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
