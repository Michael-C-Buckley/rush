.{
    .name = "Bash redirections",
    .mode = .bash,
    .cases = .{
        .{
            .name = "ampersand output redirection redirects stdout and stderr",
            .script =
            \\{ printf 'out\n'; printf 'err\n' >&2; } &>both
            \\cat both
            ,
            .stdout =
            \\out
            \\err
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "ampersand append redirection appends stdout and stderr",
            .script =
            \\printf 'old\n' >both
            \\{ printf 'out\n'; printf 'err\n' >&2; } &>>both
            \\cat both
            ,
            .stdout =
            \\old
            \\out
            \\err
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipe ampersand redirects stderr into the pipeline",
            .script =
            \\{ printf 'out\n'; printf 'err\n' >&2; } |& sort
            ,
            .stdout =
            \\err
            \\out
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipe ampersand applies after command redirections",
            .script =
            \\{ printf 'out\n'; printf 'err\n' >&2; } >file |& cat
            \\printf 'pipe-status:<%s>\n' "$?"
            \\cat file
            ,
            .stdout =
            \\pipe-status:<0>
            \\out
            \\err
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "self-duplicate redirection is a no-op even when the descriptor is closed",
            .script =
            \\exec 3>&1 1>&-
            \\printf '' 1>&1
            \\status=$?
            \\exec 1>&3 3>&-
            \\printf '<%s>\n' "$status"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here string redirects expanded word with trailing newline",
            .script =
            \\value=hello
            \\IFS= read -r line <<< "$value world"
            \\printf '<%s>\n' "$line"
            ,
            .stdout =
            \\<hello world>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here string can target an explicit descriptor",
            .script =
            \\read -r line 3<<< data <&3
            \\printf '<%s>\n' "$line"
            ,
            .stdout =
            \\<data>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "process substitution supplies input paths",
            .script =
            \\cat <(printf 'arg\n')
            \\read -r line < <(printf 'redir\n')
            \\printf 'redir=<%s>\n' "$line"
            ,
            .stdout =
            \\arg
            \\redir=<redir>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "process substitution receives output paths",
            .script =
            \\printf 'right\n' > >(cat >out)
            \\i=0
            \\while [ ! -s out ] && [ "$i" -lt 1000 ]; do i=$((i + 1)); done
            \\cat out
            ,
            .stdout =
            \\right
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "process substitution is unquoted and not field split",
            .script =
            \\IFS=/
            \\set -- <(printf x)
            \\printf 'count=<%s>\n' "$#"
            \\case "$1" in /dev/fd/*) printf 'path=<ok>\n' ;; *) printf 'path=<bad:%s>\n' "$1" ;; esac
            \\printf 'quoted=<%s>\n' "<(printf no)"
            \\printf 'escaped=<%s>\n' \<\(printf\ no\)
            ,
            .stdout =
            \\count=<1>
            \\path=<ok>
            \\quoted=<<(printf no)>
            \\escaped=<<(printf no)>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
