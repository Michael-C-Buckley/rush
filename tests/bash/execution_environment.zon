.{
    .name = "Bash execution environment",
    .mode = .bash,
    .cases = .{
        .{
            .name = "append assignment concatenates scalar values",
            .script =
            \\unset x
            \\x+=a
            \\printf 'unset:<%s>\n' "$x"
            \\x=b x+=c
            \\printf 'current:<%s>\n' "$x"
            ,
            .stdout =
            \\unset:<a>
            \\current:<bc>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "temporary append assignment is exported and restored",
            .script =
            \\x=outer
            \\x+=-prefix sh -c 'printf "inner:<%s>\n" "$x"'
            \\printf 'outer:<%s>\n' "$x"
            ,
            .stdout =
            \\inner:<outer-prefix>
            \\outer:<outer>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "append assignments are evaluated left to right",
            .script =
            \\x=outer
            \\x=a x+=b x+=c sh -c 'printf "inner:<%s>\n" "$x"'
            \\printf 'outer:<%s>\n' "$x"
            ,
            .stdout =
            \\inner:<abc>
            \\outer:<outer>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "env builtin sees append assignment prefixes",
            .script =
            \\x=outer
            \\x+=-env env | grep '^x='
            \\printf 'outer:<%s>\n' "$x"
            ,
            .stdout =
            \\x=outer-env
            \\outer:<outer>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "indexed array assignments set and append elements",
            .script =
            \\arr=(a "b c" d)
            \\arr[1]=B
            \\arr[3]+=D
            \\i=2
            \\printf '<%s>\n' "${arr[0]}" "${arr[1]}" "${arr[$i]}" "${arr[3]}"
            ,
            .stdout =
            \\<a>
            \\<B>
            \\<d>
            \\<D>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "indexed array element assignments are sparse",
            .script =
            \\arr[3]=D
            \\printf '<%s>\n' "${arr[*]}"
            \\printf '<%s>\n' "${arr[0]}" "${arr[3]}"
            ,
            .stdout =
            \\<D>
            \\<>
            \\<D>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "indexed array compound assignments preserve sparse indices and append",
            .script =
            \\arr=([2]=two three [7]=seven)
            \\printf 'initial-i=<%s>\n' "${!arr[@]}"
            \\printf 'initial-v=<%s>\n' "${arr[@]}"
            \\arr+=(eight [10]=ten eleven)
            \\printf 'append-i=<%s>\n' "${!arr[@]}"
            \\printf 'append-v=<%s>\n' "${arr[@]}"
            \\scalar=zero
            \\scalar+=(one two)
            \\printf 'scalar=<%s>\n' "${!scalar[@]}" "${scalar[@]}"
            ,
            .stdout =
            \\initial-i=<2>
            \\initial-i=<3>
            \\initial-i=<7>
            \\initial-v=<two>
            \\initial-v=<three>
            \\initial-v=<seven>
            \\append-i=<2>
            \\append-i=<3>
            \\append-i=<7>
            \\append-i=<8>
            \\append-i=<10>
            \\append-i=<11>
            \\append-v=<two>
            \\append-v=<three>
            \\append-v=<seven>
            \\append-v=<eight>
            \\append-v=<ten>
            \\append-v=<eleven>
            \\scalar=<0>
            \\scalar=<1>
            \\scalar=<2>
            \\scalar=<zero>
            \\scalar=<one>
            \\scalar=<two>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution clears errexit by default",
            .script =
            \\set -e
            \\printf '<%s>\n' "$(false; printf survived)"
            \\printf after
            ,
            .stdout =
            \\<survived>
            \\after
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
