.{
    .name = "Bash aliases",
    .mode = .bash,
    .cases = .{
        .{
            .name = "expand_aliases shopt controls non-interactive alias expansion",
            .script =
            \\shopt -u expand_aliases
            \\alias hit='printf "%s\n" disabled'
            \\hit 2>/dev/null
            \\printf '<%s>\n' "$?"
            \\shopt -s expand_aliases
            \\alias hit='printf "%s\n" enabled'
            \\hit
            ,
            .stdout =
            \\<127>
            \\enabled
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval does not expand aliases in default non-interactive mode",
            .script =
            \\alias ll='printf "%s\n" alias'
            \\( eval 'll' ) 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval expands aliases when expand_aliases is enabled",
            .script =
            \\shopt -s expand_aliases
            \\alias ll='printf "%s\n" alias'
            \\eval 'll'
            ,
            .stdout =
            \\alias
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function bodies capture aliases when expand_aliases is enabled",
            .script =
            \\shopt -s expand_aliases
            \\alias hit='printf "%s\n" alias'
            \\f() { hit; }
            \\unalias hit
            \\f
            ,
            .stdout =
            \\alias
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
