.{
    .name = "Bash word expansions",
    .mode = .bash,
    .cases = .{
        .{
            .name = "arithmetic expansion recursively evaluates variable contents",
            .script =
            \\x='1+2'
            \\printf '%s\n' "$((x * 3))"
            ,
            .stdout =
            \\9
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion supports bash prefix increment",
            .script =
            \\i=1
            \\printf '<%s> i=<%s>\n' "$((++i))" "$i"
            \\printf '<%s> i=<%s>\n' "$((--i))" "$i"
            ,
            .stdout =
            \\<2> i=<2>
            \\<1> i=<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion error in assignment-only command does not exit",
            .script =
            \\x=$((1/0))
            \\printf 'x=<%s> status=<%s>\n' "$x" "$?"
            \\printf after
            ,
            .stdout =
            \\x=<> status=<1>
            \\after
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "arithmetic expansion error in assignment-only command skips and-or remainder",
            .script =
            \\x=$((1/0)) && printf and || printf or
            \\printf 'status=<%s> x=<%s>\n' "$?" "$x"
            ,
            .stdout =
            \\status=<1> x=<>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "arithmetic expansion error in assignment-only if condition skips the compound body",
            .script =
            \\if x=$((1/0)); then printf then; else printf else; fi
            \\printf 'status=<%s> x=<%s>\n' "$?" "$x"
            ,
            .stdout =
            \\status=<1> x=<>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "arithmetic expansion error in if condition skips the compound body",
            .script =
            \\if : $((1/0)); then printf then; else printf else; fi
            \\printf 'status=<%s>\n' "$?"
            ,
            .stdout =
            \\status=<1>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "RANDOM is a seeded dynamic parameter",
            .script =
            \\RANDOM=7
            \\first=$RANDOM
            \\second=$RANDOM
            \\RANDOM=7
            \\repeat=$RANDOM
            \\if [ "$first" -ge 0 ] && [ "$first" -le 32767 ]; then printf 'range=<ok>\n'; else printf 'range=<bad:%s>\n' "$first"; fi
            \\if [ "$first" = "$repeat" ]; then printf 'seed=<ok>\n'; else printf 'seed=<bad:%s:%s>\n' "$first" "$repeat"; fi
            \\if [ "$first" != "$second" ]; then printf 'advance=<ok>\n'; else printf 'advance=<bad:%s:%s>\n' "$first" "$second"; fi
            ,
            .stdout =
            \\range=<ok>
            \\seed=<ok>
            \\advance=<ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "SECONDS and EPOCH variables are dynamic parameters",
            .script =
            \\SECONDS=7
            \\printf 'seconds=<%s>\n' "$SECONDS"
            \\case "$EPOCHSECONDS" in ''|*[!0123456789]*) printf 'epoch-seconds=<bad:%s>\n' "$EPOCHSECONDS" ;; *) printf 'epoch-seconds=<ok>\n' ;; esac
            \\case "$EPOCHREALTIME" in *.*) printf 'epoch-real=<ok>\n' ;; *) printf 'epoch-real=<bad:%s>\n' "$EPOCHREALTIME" ;; esac
            ,
            .stdout =
            \\seconds=<7>
            \\epoch-seconds=<ok>
            \\epoch-real=<ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion error in assignment-only command returns from a function",
            .script =
            \\f() { x=$((1/0)); printf bad; }
            \\f
            \\printf 'after<%s>\n' "$?"
            ,
            .stdout =
            \\after<1>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "parameter error in assignment-only command exits by default",
            .script =
            \\unset x
            \\y=${x:?boom}
            \\printf bad
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 127,
        },
        .{
            .name = "readonly assign-default expansion fails without internal error",
            .script =
            \\x=
            \\readonly x
            \\printf '<%s>\n' "${x:=new}"
            \\printf 'x=<%s> status=<%s>\n' "$x" "$?"
            \\printf after
            ,
            .stdout =
            \\x=<> status=<1>
            \\after
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "whole positional length expansions count positional parameters",
            .script =
            \\set -- a bb ccc
            \\printf '%s:%s\n' "${#*}" "${#@}"
            ,
            .stdout =
            \\3:3
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic assignment to readonly variable fails without exiting by default",
            .script =
            \\readonly i=1
            \\: $((i=2))
            \\printf 'i=<%s> status=<%s>\n' "$i" "$?"
            \\printf after
            ,
            .stdout =
            \\i=<1> status=<1>
            \\after
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "nounset rejects unset variables in arithmetic expansion",
            .script =
            \\set -u
            \\printf '%s\n' "$((missing + 1))"
            \\printf bad
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 127,
        },
        .{
            .name = "brace expansion supports alternatives nesting and later expansions",
            .script =
            \\x=X
            \\xa=AXA
            \\xb=AXB
            \\printf '<%s>\n' pre{a,b}post {{a,b},{c,d}} {,empty} {"",quoted}
            \\printf '<%s>\n' $x{a,b} ${x}{a,b} {$(printf cmd),word}
            \\printf '<%s>\n' ${unset:-{n,o}} "{q,r}" \{e,f\}
            ,
            .stdout =
            \\<preapost>
            \\<prebpost>
            \\<a>
            \\<b>
            \\<c>
            \\<d>
            \\<empty>
            \\<>
            \\<quoted>
            \\<AXA>
            \\<AXB>
            \\<Xa>
            \\<Xb>
            \\<cmd>
            \\<word>
            \\<{n,o}>
            \\<{q,r}>
            \\<{e,f}>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace expansion supports numeric and alphabetic sequences",
            .script =
            \\printf '<%s>\n' {1..5..2} {05..1..2} {5..1..0} {a..e..2} {e..a..0} {1..5..x}
            ,
            .stdout =
            \\<1>
            \\<3>
            \\<5>
            \\<05>
            \\<03>
            \\<01>
            \\<5>
            \\<4>
            \\<3>
            \\<2>
            \\<1>
            \\<a>
            \\<c>
            \\<e>
            \\<e>
            \\<d>
            \\<c>
            \\<b>
            \\<a>
            \\<{1..5..x}>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace expansion does not apply to assignment values",
            .script =
            \\value=a{b,c}
            \\printf '<%s>\n' "$value"
            ,
            .stdout =
            \\<a{b,c}>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "indexed array star expansion joins elements with IFS",
            .script =
            \\arr=(a b c)
            \\IFS=:
            \\printf '<%s>\n' "${arr[*]}"
            ,
            .stdout =
            \\<a:b:c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted indexed array at expansion preserves fields",
            .script =
            \\arr=("a b" "" c)
            \\printf '<%s>\n' "${arr[@]}"
            \\printf '<%s>\n' "x${arr[@]}y"
            ,
            .stdout =
            \\<a b>
            \\<>
            \\<c>
            \\<xa b>
            \\<>
            \\<cy>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter substring expansion supports offsets and lengths",
            .script =
            \\value=abcdef
            \\wide=aébc
            \\printf '<%s>\n' "${value:1}" "${value:1:3}" "${value: -2}" "${value:2:-1}" "${wide:1:2}"
            ,
            .stdout =
            \\<bcdef>
            \\<bcd>
            \\<ef>
            \\<cde>
            \\<éb>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter pattern substitution supports bash operators",
            .script =
            \\value=abcabc
            \\printf '<%s>\n' "${value/a?/X}" "${value//a?/X}" "${value/#a*/X}" "${value/%*c/X}" "${value/b}"
            ,
            .stdout =
            \\<Xcabc>
            \\<XcXc>
            \\<X>
            \\<X>
            \\<acabc>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
