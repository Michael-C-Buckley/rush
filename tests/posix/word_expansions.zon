.{
    .name = "2.6 Word Expansions",
    .mode = .posix,
    .cases = .{
        .{
            .name = "parameter expansion uses default value without assigning",
            .script =
            \\unset x
            \\printf '<%s>:<%s>\n' "${x:-fallback}" "${x-unset}"
            ,
            .stdout =
            \\<fallback>:<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unquoted parameter expansion recognizes nested braced defaults",
            .script =
            \\unset outer inner
            \\printf '<%s>\n' ${outer:-${inner:-fallback}}
            ,
            .stdout =
            \\<fallback>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment words recognize nested braced parameter defaults",
            .script =
            \\unset outer inner
            \\value=${outer:-${inner:-fallback}}
            \\printf '<%s>\n' "$value"
            ,
            .stdout =
            \\<fallback>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion removes backslash newline in parameter name",
            .script = "A=ok; printf '<%s>\\n' ${A\\\n}\n",
            .stdout =
            \\<ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "empty braced parameter expansion is an error",
            .script =
            \\: ${}
            \\printf bad
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "parameter expansion removes backslash newline in default word",
            .script = "unset A; printf '<%s>\\n' ${A:-o\\\nk}\n",
            .stdout =
            \\<ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion default distinguishes unset from null",
            .script =
            \\unset missing
            \\x=
            \\printf '<%s>\n' "${x-word}" "${x:-word}" "${missing-word}" "${missing:-word}"
            ,
            .stdout =
            \\<>
            \\<word>
            \\<word>
            \\<word>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion assigns default value",
            .script =
            \\unset x
            \\printf '<%s>:<%s>\n' "${x:=fallback}" "$x"
            ,
            .stdout =
            \\<fallback>:<fallback>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion assignment distinguishes unset from null",
            .script =
            \\unset x y
            \\x=
            \\printf '<%s>:<%s>\n' "${x=word}" "$x"
            \\printf '<%s>:<%s>\n' "${x:=word}" "$x"
            \\printf '<%s>:<%s>\n' "${y=word}" "$y"
            ,
            .stdout =
            \\<>:<>
            \\<word>:<word>
            \\<word>:<word>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion uses alternate value only when set and non-null",
            .script =
            \\unset x
            \\printf '<%s>\n' "${x:+bad}"
            \\x=value
            \\printf '<%s>\n' "${x:+alt}"
            ,
            .stdout =
            \\<>
            \\<alt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion alternate distinguishes set null from unset",
            .script =
            \\unset missing
            \\x=
            \\y=value
            \\printf '<%s>\n' "${x+alt}" "${x:+alt}" "${missing+alt}" "${missing:+alt}" "${y+alt}" "${y:+alt}"
            ,
            .stdout =
            \\<alt>
            \\<>
            \\<>
            \\<>
            \\<alt>
            \\<alt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion question mark errors for unset parameters",
            .script =
            \\unset missing
            \\printf '%s\n' ${missing?'need it'}
            \\printf 'bad\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "parameter expansion diagnostics do not use trap context outside traps",
            .script =
            \\unset missing
            \\printf '%s\n' ${missing?'need it'}
            ,
            .stdout = "",
            .stderr =
            \\2: expansion error: missing: need it
            \\
            ,
            .status = 1,
        },
        .{
            .name = "parameter expansion colon question mark errors for null parameters",
            .script =
            \\x=
            \\printf '%s\n' ${x:?'need it'}
            \\printf 'bad\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "parameter expansion question mark accepts set null parameters",
            .script =
            \\x=
            \\printf '<%s>\n' ${x?'need it'}
            \\printf 'after\n'
            ,
            .stdout =
            \\<>
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion reports string length",
            .script =
            \\x=abcdef
            \\printf '%s\n' "${#x}"
            ,
            .stdout =
            \\6
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion string length counts multibyte characters",
            .script =
            \\x=åßç
            \\printf '%s\n' "${#x}"
            ,
            .stdout =
            \\3
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion removes shortest and longest suffix patterns",
            .script =
            \\x=posix/src/std
            \\printf '%s\n' "${x%/*}" "${x%%/*}"
            ,
            .stdout =
            \\posix/src
            \\posix
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion removes shortest and longest prefix patterns",
            .script =
            \\x=/one/two/three
            \\printf '%s\n' "${x#*/}" "${x##*/}"
            ,
            .stdout =
            \\one/two/three
            \\three
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion removes patterns from positional parameters",
            .script =
            \\set ' foo -> bar' foo
            \\printf '<%s>\n' "${1#" $2 -> "}"
            ,
            .stdout =
            \\<bar>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unbraced parameter expansion uses the longest valid name",
            .script =
            \\foo=abc
            \\foox=long
            \\unset foo_suffix
            \\printf '<%s>\n' "$foo_suffix" "${foo}_suffix" "$foox" "${foo}x"
            ,
            .stdout =
            \\<>
            \\<abc_suffix>
            \\<long>
            \\<abcx>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "braced positional parameter expansion supports multiple digits",
            .script =
            \\set -- one two three four five six seven eight nine ten
            \\printf '<%s>\n' $1 $10 ${10}
            ,
            .stdout =
            \\<one>
            \\<one0>
            \\<ten>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "special parameters expose count status and option flags",
            .script =
            \\set -- 'a b' '' c
            \\false
            \\st=$?
            \\set -f
            \\case "$#:$st:$-" in 3:1:*f*) printf 'special\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\special
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution preserves shell pid special parameters",
            .script =
            \\outer=$$
            \\outer_parent=$PPID
            \\sub=$(printf '%s:%s' "$$" "$PPID")
            \\case $outer:$outer_parent:$sub in
            \\    "$outer:$outer_parent:$outer:$outer_parent") printf 'pid\n' ;;
            \\    *) printf 'bad:%s\n' "$sub" ;;
            \\esac
            ,
            .stdout =
            \\pid
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted at expands positional parameters as separate fields",
            .script =
            \\set -- 'a b' '' c
            \\for x in "$@"; do printf '<%s>\n' "$x"; done
            ,
            .stdout =
            \\<a b>
            \\<>
            \\<c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted at preserves one empty positional parameter",
            .script =
            \\set -- ''
            \\printf '<%s>\n' "$#"
            \\for x in "$@"; do printf '[%s]\n' "$x"; done
            ,
            .stdout =
            \\<1>
            \\[]
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted star joins positional parameters with the first IFS character",
            .script =
            \\IFS=,
            \\set -- 'a b' '' c
            \\printf '<%s>\n' "$*"
            ,
            .stdout =
            \\<a b,,c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar and zero special parameters are non-empty",
            .script =
            \\case $$:$0 in *[!0123456789]*:*) printf 'pid0\n';; *:*[!/]*) printf 'pid0\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\pid0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang special parameter expands to the most recent background process id",
            .script =
            \\: &
            \\p=$!
            \\case $p in *[!0123456789]*|'') printf 'bad\n';; *) printf 'background\n';; esac
            ,
            .stdout =
            \\background
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion evaluates nested default words when needed",
            .script =
            \\unset x y
            \\y=inner
            \\printf '<%s>\n' "${x:-${y:-fallback}}"
            ,
            .stdout =
            \\<inner>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion does not evaluate unused default words",
            .script =
            \\x=value
            \\unset marker
            \\printf '<%s>\n' "${x:-$(printf side >marker)}"
            \\test ! -e marker && printf 'lazy\n'
            ,
            .stdout =
            \\<value>
            \\lazy
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion evaluates default words when used",
            .script =
            \\unset x
            \\printf '<%s>\n' "${x:-$(printf fallback)}"
            ,
            .stdout =
            \\<fallback>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter pattern removal supports bracket expressions",
            .script =
            \\x=abc123def
            \\printf '<%s>\n' "${x%%[0-9]*}" "${x##*[0-9]}"
            ,
            .stdout =
            \\<abc>
            \\<def>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quotes inside parameter patterns can quote pattern characters",
            .script =
            \\x='a*b'
            \\printf '<%s>\n' "${x#\"a*\"}" "${x#'a*'}" "${x#a*}"
            ,
            .stdout =
            \\<a*b>
            \\<b>
            \\<*b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter prefix removal expands tilde pattern words",
            .script =
            \\value=~/src
            \\printf '<%s>\n' "${value#~}"
            ,
            .stdout =
            \\</src>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion applies at the start of an unquoted word",
            .script =
            \\set -- ~ ~/subdir
            \\home=$1
            \\case $2 in "$home/subdir") printf 'start\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\start
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion applies in command substitution external commands",
            .script =
            \\expanded=$(echo ~)
            \\case $expanded in "$HOME") printf 'tilde\n';; *) printf 'bad:%s\n' "$expanded";; esac
            ,
            .stdout =
            \\tilde
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion is suppressed by quoting",
            .script =
            \\printf '<%s>\n' '~' "~" \~
            ,
            .stdout =
            \\<~>
            \\<~>
            \\<~>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion does not apply after other word characters",
            .script =
            \\printf '<%s>\n' x~ x~/subdir
            ,
            .stdout =
            \\<x~>
            \\<x~/subdir>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion results are not pathname expanded",
            .script =
            \\HOME='a*'
            \\: >a1
            \\: >a2
            \\printf '<%s>\n' ~
            ,
            .stdout =
            \\<a*>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion applies after equals and colon in assignment words",
            .script =
            \\home=~
            \\value=~/bin:~:/usr:~/sbin
            \\case $value in "$home/bin:$home:/usr:$home/sbin") printf 'assignment\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\assignment
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted tilde is literal in assignment words",
            .script =
            \\single='~'
            \\double="~"
            \\escaped=\~
            \\printf '<%s>\n' "$single" "$double" "$escaped"
            ,
            .stdout =
            \\<~>
            \\<~>
            \\<~>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde is literal inside assignment fields except after colon",
            .script =
            \\home=~
            \\literal=a~
            \\colon=/prefix:~
            \\printf '<%s>\n' "$literal"
            \\case $colon in "/prefix:$home") printf 'colon\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\<a~>
            \\colon
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution trims trailing newlines but preserves interior newlines",
            .script =
            \\x=$(printf 'a\n\nb\n\n')
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<a
            \\
            \\b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment command substitution does not leak captured newlines",
            .script =
            \\x="$(printf '%s\n\n' '')"
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution nests inside double quotes",
            .script =
            \\printf '<%s>\n' "$(printf '[%s]' "$(printf inner)")"
            ,
            .stdout =
            \\<[inner]>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "deep nested command substitutions preserve inner output",
            .script =
            \\s='echo ok'
            \\i=0
            \\while [ "$i" -lt 200 ]; do
            \\    s='echo $('"$s"')'
            \\    i=$((i + 1))
            \\done
            \\eval "$s"
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution removes all trailing newlines",
            .script =
            \\x=$(printf 'a\n\n\n')
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<a>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution discards null bytes from captured output",
            .script =
            \\printf '<%s>\n' "$(printf 'a\0b')"
            ,
            .stdout =
            \\<ab>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "unquoted command substitution output is field split after newline preservation",
            .script =
            \\set -- $(printf 'a\nb\n')
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unquoted empty command substitution produces no field",
            .script =
            \\set -- before $(printf '') after
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<before>
            \\<after>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted empty command substitution preserves an empty field",
            .script =
            \\set -- before "$(printf '')" after
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<before>
            \\<>
            \\<after>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution output is split when unquoted",
            .script =
            \\printf '<%s>\n' `printf 'a b'`
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution preserves spaces when quoted",
            .script =
            \\printf '<%s>\n' "`printf 'a b'`"
            ,
            .stdout =
            \\<a b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution can contain double quotes inside double quotes",
            .script =
            \\printf '<%s>\n' "`: "("`"
            ,
            .stdout =
            \\<>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution supports escaped nested backquotes",
            .script =
            \\printf '<%s>\n' "`printf '[%s]' \`printf inner\``"
            ,
            .stdout =
            \\<[inner]>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution removes escaped newline from the command text",
            .script = "printf '<%s>\n' `printf a\\\nb`\n",
            .stdout =
            \\<ab>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution can quote dollar for the inner command",
            .script = "x=outer\nprintf '<%s>\\n' \"`x=inner; printf \\\\$x`\"\n",
            .stdout =
            \\<$x>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar command substitution parses quoted closing parentheses",
            .script =
            \\printf '<%s>\n' "$(printf 'a ) b')"
            ,
            .stdout =
            \\<a ) b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar command substitution parses escaped quotes between quoted segments",
            .script =
            \\printf '<%s>\n' "$(printf \
            \\    'a'\''b')"
            ,
            .stdout =
            \\<a'b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar command substitution parses case pattern closing parentheses",
            .script =
            \\printf '<%s>\n' "$(case x in x) printf case ;; esac)"
            ,
            .stdout =
            \\<case>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution parse error exits before following commands",
            .script =
            \\echo "$(for do echo; done)"
            \\printf 'after\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "nested command substitution parse error exits before captured output is emitted",
            .script =
            \\echo "$(printf before; echo "$(for do echo; done)"; printf after)"
            \\printf 'outer-after\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "pipeline command substitution parse error exits before captured output is emitted",
            .script =
            \\echo "$(echo "$(for do echo; done)" | cat)"
            \\printf 'outer-after\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "command substitution runs in an isolated shell environment",
            .script =
            \\x=parent
            \\y=$(x=child; printf '%s' "$x")
            \\printf '<%s>:<%s>\n' "$x" "$y"
            ,
            .stdout =
            \\<parent>:<child>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion evaluates expressions after parameter expansion",
            .script =
            \\n=5
            \\printf '%s\n' "$((n * 2 + 1))"
            ,
            .stdout =
            \\11
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion expands braced parameters before evaluation",
            .script =
            \\name=target
            \\target=0
            \\printf '%s:%s\n' "$(( ${name} + 2 ))" "$((_Msh__V${name}__SP = 7))"
            \\printf '%s\n' "$_Msh__Vtarget__SP"
            \\set -- x 5
            \\printf '%s:%s\n' "$(( ${2-1} ))" "$(( ${3+${ERROR:?bad}} + 1 ))"
            ,
            .stdout =
            \\2:7
            \\7
            \\5:1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion uses arithmetic precedence and grouping",
            .script =
            \\printf '%s\n' "$((1 + 2 * 3))" "$(((1 + 2) * 3))"
            ,
            .stdout =
            \\7
            \\9
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion recognizes decimal octal and hexadecimal constants",
            .script =
            \\printf '%s:%s:%s\n' "$((10))" "$((010))" "$((0x10))"
            ,
            .stdout =
            \\10:8:16
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion reads valid integer variables with or without parameter expansion",
            .script =
            \\n=5
            \\printf '%s:%s\n' "$((n))" "$(($n))"
            ,
            .stdout =
            \\5:5
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion trims whitespace around variable values",
            .script =
            \\n=$(printf ' \t\n1')
            \\printf '<%s>\n' "$((n))"
            \\n=$(printf '1 \t\n')
            \\printf '<%s>\n' "$((n))"
            ,
            .stdout =
            \\<1>
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion treats empty variable values as zero",
            .script =
            \\n=
            \\printf '<%s>\n' "$((n))"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion honors nounset for bare variables",
            .script =
            \\( set -u
            \\  unset missing
            \\  printf 'bad:%s\n' "$((missing + 1))"
            \\  printf 'after\n' ) 2>/dev/null
