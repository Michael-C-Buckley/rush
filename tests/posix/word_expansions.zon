.{
    .name = "2.6 Word Expansions",
    .mode = .posix,
    .cases = .{
        .{
            .name = "parameter expansion uses default value without assigning",
            .script =
            \\unset x
            \\printf '<%s>:<%s>\n' "${x:-fallback}" "${x-unset}"
            ,
            .stdout =
            \\<fallback>:<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion default distinguishes unset from null",
            .script =
            \\unset missing
            \\x=
            \\printf '<%s>\n' "${x-word}" "${x:-word}" "${missing-word}" "${missing:-word}"
            ,
            .stdout =
            \\<>
            \\<word>
            \\<word>
            \\<word>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion assigns default value",
            .script =
            \\unset x
            \\printf '<%s>:<%s>\n' "${x:=fallback}" "$x"
            ,
            .stdout =
            \\<fallback>:<fallback>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion assignment distinguishes unset from null",
            .script =
            \\unset x y
            \\x=
            \\printf '<%s>:<%s>\n' "${x=word}" "$x"
            \\printf '<%s>:<%s>\n' "${x:=word}" "$x"
            \\printf '<%s>:<%s>\n' "${y=word}" "$y"
            ,
            .stdout =
            \\<>:<>
            \\<word>:<word>
            \\<word>:<word>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion uses alternate value only when set and non-null",
            .script =
            \\unset x
            \\printf '<%s>\n' "${x:+bad}"
            \\x=value
            \\printf '<%s>\n' "${x:+alt}"
            ,
            .stdout =
            \\<>
            \\<alt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion alternate distinguishes set null from unset",
            .script =
            \\unset missing
            \\x=
            \\y=value
            \\printf '<%s>\n' "${x+alt}" "${x:+alt}" "${missing+alt}" "${missing:+alt}" "${y+alt}" "${y:+alt}"
            ,
            .stdout =
            \\<alt>
            \\<>
            \\<>
            \\<>
            \\<alt>
            \\<alt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion question mark errors for unset parameters",
            .script =
            \\unset missing
            \\printf '%s\n' ${missing?'need it'}
            \\printf 'bad\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "parameter expansion diagnostics do not use trap context outside traps",
            .script =
            \\unset missing
            \\printf '%s\n' ${missing?'need it'}
            ,
            .stdout = "",
            .stderr =
            \\expansion error: missing: need it
            \\
            ,
            .status = 1,
        },
        .{
            .name = "parameter expansion colon question mark errors for null parameters",
            .script =
            \\x=
            \\printf '%s\n' ${x:?'need it'}
            \\printf 'bad\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "parameter expansion question mark accepts set null parameters",
            .script =
            \\x=
            \\printf '<%s>\n' ${x?'need it'}
            \\printf 'after\n'
            ,
            .stdout =
            \\<>
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion reports string length",
            .script =
            \\x=abcdef
            \\printf '%s\n' "${#x}"
            ,
            .stdout =
            \\6
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion string length counts multibyte characters",
            .script =
            \\x=åßç
            \\printf '%s\n' "${#x}"
            ,
            .stdout =
            \\3
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion removes shortest and longest suffix patterns",
            .script =
            \\x=posix/src/std
            \\printf '%s\n' "${x%/*}" "${x%%/*}"
            ,
            .stdout =
            \\posix/src
            \\posix
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion removes shortest and longest prefix patterns",
            .script =
            \\x=/one/two/three
            \\printf '%s\n' "${x#*/}" "${x##*/}"
            ,
            .stdout =
            \\one/two/three
            \\three
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unbraced parameter expansion uses the longest valid name",
            .script =
            \\foo=abc
            \\foox=long
            \\unset foo_suffix
            \\printf '<%s>\n' "$foo_suffix" "${foo}_suffix" "$foox" "${foo}x"
            ,
            .stdout =
            \\<>
            \\<abc_suffix>
            \\<long>
            \\<abcx>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "braced positional parameter expansion supports multiple digits",
            .script =
            \\set -- one two three four five six seven eight nine ten
            \\printf '<%s>\n' $1 $10 ${10}
            ,
            .stdout =
            \\<one>
            \\<one0>
            \\<ten>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "special parameters expose count status and option flags",
            .script =
            \\set -- 'a b' '' c
            \\false
            \\st=$?
            \\set -f
            \\case "$#:$st:$-" in 3:1:*f*) printf 'special\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\special
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted at expands positional parameters as separate fields",
            .script =
            \\set -- 'a b' '' c
            \\for x in "$@"; do printf '<%s>\n' "$x"; done
            ,
            .stdout =
            \\<a b>
            \\<>
            \\<c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted star joins positional parameters with the first IFS character",
            .script =
            \\IFS=,
            \\set -- 'a b' '' c
            \\printf '<%s>\n' "$*"
            ,
            .stdout =
            \\<a b,,c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar and zero special parameters are non-empty",
            .script =
            \\case $$:$0 in *[!0123456789]*:*) printf 'pid0\n';; *:*[!/]*) printf 'pid0\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\pid0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang special parameter expands to the most recent background process id",
            .script =
            \\: &
            \\p=$!
            \\case $p in *[!0123456789]*|'') printf 'bad\n';; *) printf 'background\n';; esac
            ,
            .stdout =
            \\background
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion evaluates nested default words when needed",
            .script =
            \\unset x y
            \\y=inner
            \\printf '<%s>\n' "${x:-${y:-fallback}}"
            ,
            .stdout =
            \\<inner>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion does not evaluate unused default words",
            .script =
            \\x=value
            \\unset marker
            \\printf '<%s>\n' "${x:-$(printf side >marker)}"
            \\test ! -e marker && printf 'lazy\n'
            ,
            .stdout =
            \\<value>
            \\lazy
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion evaluates default words when used",
            .script =
            \\unset x
            \\printf '<%s>\n' "${x:-$(printf fallback)}"
            ,
            .stdout =
            \\<fallback>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter pattern removal supports bracket expressions",
            .script =
            \\x=abc123def
            \\printf '<%s>\n' "${x%%[0-9]*}" "${x##*[0-9]}"
            ,
            .stdout =
            \\<abc>
            \\<def>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quotes inside parameter patterns can quote pattern characters",
            .script =
            \\x='a*b'
            \\printf '<%s>\n' "${x#\"a*\"}" "${x#'a*'}" "${x#a*}"
            ,
            .stdout =
            \\<a*b>
            \\<b>
            \\<*b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion applies at the start of an unquoted word",
            .script =
            \\set -- ~ ~/subdir
            \\home=$1
            \\case $2 in "$home/subdir") printf 'start\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\start
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion is suppressed by quoting",
            .script =
            \\printf '<%s>\n' '~' "~" \~
            ,
            .stdout =
            \\<~>
            \\<~>
            \\<~>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion does not apply after other word characters",
            .script =
            \\printf '<%s>\n' x~ x~/subdir
            ,
            .stdout =
            \\<x~>
            \\<x~/subdir>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion applies after equals and colon in assignment words",
            .script =
            \\home=~
            \\value=~/bin:~:/usr:~/sbin
            \\case $value in "$home/bin:$home:/usr:$home/sbin") printf 'assignment\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\assignment
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted tilde is literal in assignment words",
            .script =
            \\single='~'
            \\double="~"
            \\escaped=\~
            \\printf '<%s>\n' "$single" "$double" "$escaped"
            ,
            .stdout =
            \\<~>
            \\<~>
            \\<~>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde is literal inside assignment fields except after colon",
            .script =
            \\home=~
            \\literal=a~
            \\colon=/prefix:~
            \\printf '<%s>\n' "$literal"
            \\case $colon in "/prefix:$home") printf 'colon\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\<a~>
            \\colon
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution trims trailing newlines but preserves interior newlines",
            .script =
            \\x=$(printf 'a\n\nb\n\n')
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<a
            \\
            \\b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution nests inside double quotes",
            .script =
            \\printf '<%s>\n' "$(printf '[%s]' "$(printf inner)")"
            ,
            .stdout =
            \\<[inner]>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution removes all trailing newlines",
            .script =
            \\x=$(printf 'a\n\n\n')
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<a>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution discards null bytes from captured output",
            .script =
            \\printf '<%s>\n' "$(printf 'a\0b')"
            ,
            .stdout =
            \\<ab>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "unquoted command substitution output is field split after newline preservation",
            .script =
            \\set -- $(printf 'a\nb\n')
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unquoted empty command substitution produces no field",
            .script =
            \\set -- before $(printf '') after
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<before>
            \\<after>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted empty command substitution preserves an empty field",
            .script =
            \\set -- before "$(printf '')" after
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<before>
            \\<>
            \\<after>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution output is split when unquoted",
            .script =
            \\printf '<%s>\n' `printf 'a b'`
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution preserves spaces when quoted",
            .script =
            \\printf '<%s>\n' "`printf 'a b'`"
            ,
            .stdout =
            \\<a b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution supports escaped nested backquotes",
            .script =
            \\printf '<%s>\n' "`printf '[%s]' \`printf inner\``"
            ,
            .stdout =
            \\<[inner]>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution removes escaped newline from the command text",
            .script = "printf '<%s>\n' `printf a\\\nb`\n",
            .stdout =
            \\<ab>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backquote command substitution can quote dollar for the inner command",
            .script = "x=outer\nprintf '<%s>\\n' \"`x=inner; printf \\\\$x`\"\n",
            .stdout =
            \\<$x>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar command substitution parses quoted closing parentheses",
            .script =
            \\printf '<%s>\n' "$(printf 'a ) b')"
            ,
            .stdout =
            \\<a ) b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar command substitution parses case pattern closing parentheses",
            .script =
            \\printf '<%s>\n' "$(case x in x) printf case ;; esac)"
            ,
            .stdout =
            \\<case>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution runs in an isolated shell environment",
            .script =
            \\x=parent
            \\y=$(x=child; printf '%s' "$x")
            \\printf '<%s>:<%s>\n' "$x" "$y"
            ,
            .stdout =
            \\<parent>:<child>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion evaluates expressions after parameter expansion",
            .script =
            \\n=5
            \\printf '%s\n' "$((n * 2 + 1))"
            ,
            .stdout =
            \\11
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion uses arithmetic precedence and grouping",
            .script =
            \\printf '%s\n' "$((1 + 2 * 3))" "$(((1 + 2) * 3))"
            ,
            .stdout =
            \\7
            \\9
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion recognizes decimal octal and hexadecimal constants",
            .script =
            \\printf '%s:%s:%s\n' "$((10))" "$((010))" "$((0x10))"
            ,
            .stdout =
            \\10:8:16
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion reads valid integer variables with or without parameter expansion",
            .script =
            \\n=5
            \\printf '%s:%s\n' "$((n))" "$(($n))"
            ,
            .stdout =
            \\5:5
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion expands parameters and commands before evaluation",
            .script =
            \\x='1 + 2'
            \\printf '%s\n' "$(($x * 3))" "$(( $(printf '%s' '2 + 3') * 4 ))"
            ,
            .stdout =
            \\7
            \\14
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion variable assignments persist",
            .script =
            \\x=4
            \\printf '%s:%s\n' "$((x = x + 3))" "$x"
            \\printf '%s:%s\n' "$((x += 5))" "$x"
            ,
            .stdout =
            \\7:7
            \\12:12
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion treats double plus as unary operators",
            .script =
            \\i=1
            \\printf '<%s> i=<%s>\n' "$((++i))" "$i"
            ,
            .stdout =
            \\<1> i=<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion evaluates required operators",
            .script =
            \\printf '%s:%s:%s:%s\n' "$((7 / 2))" "$((7 % 2))" "$((3 > 2))" "$((0 || 5))"
            \\printf '%s:%s:%s:%s\n' "$((6 & 3))" "$((6 | 1))" "$((6 ^ 3))" "$((1 << 4))"
            \\printf '%s:%s\n' "$((0 ? 1 : 7))" "$((1 ? 8 : 9))"
            ,
            .stdout =
            \\3:1:1:1
            \\2:7:5:16
            \\7:8
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion short-circuits unevaluated operands",
            .script =
            \\printf '%s:%s\n' "$((0 && (1 / 0)))" "$((1 || (1 / 0)))"
            ,
            .stdout =
            \\0:1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion removes quote characters before evaluation",
            .script =
            \\printf '%s\n' "$(( "1" + 2 ))"
            ,
            .stdout =
            \\3
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "invalid arithmetic expansion fails with a diagnostic",
            .script =
            \\printf 'before\n'
            \\printf '%s\n' "$((1 + ))"
            \\printf 'after\n'
            ,
            .stdout =
            \\before
            \\
            ,
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "arithmetic assignment to readonly variable is a shell error",
            .script =
            \\readonly i=1
            \\: $((i=2))
            \\printf bad
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "arithmetic expansion fails when variable contents are not an integer constant",
            .script =
            \\printf 'before\n'
            \\x=abc
            \\printf '%s\n' "$((x))"
            \\printf 'after\n'
            ,
            .stdout =
            \\before
            \\
            ,
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "arithmetic expansion does not recursively evaluate variable contents",
            .script =
            \\printf 'before\n'
            \\x='1+2'
            \\printf '%s\n' "$((x * 3))"
            \\printf 'after\n'
            ,
            .stdout =
            \\before
            \\
            ,
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "field splitting applies to unquoted parameter expansion",
            .script =
            \\x=' a  b '
            \\set -- $x
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted positional alternate expansion preserves at fields",
            .script =
            \\set -- 'a b' c
            \\printf '[%s]\n' "${@:+$@}"
            \\printf '<%s>\n' "${@:+x}"
            \\printf '[%s]\n' "${@:-x}"
            ,
            .stdout =
            \\[a b]
            \\[c]
            \\<x>
            \\[a b]
            \\[c]
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting uses default delimiters when IFS is unset",
            .script = "unset IFS\nx='a b\tc\nd'\nset -- $x\nprintf '<%s>\\n' \"$#\" \"$@\"\n",
            .stdout =
            \\<4>
            \\<a>
            \\<b>
            \\<c>
            \\<d>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting with IFS whitespace ignores leading trailing and repeated delimiters",
            .script =
            \\IFS=' '
            \\x='  a  b  '
            \\set -- $x
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<2>
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting with non-whitespace IFS preserves empty fields between delimiters",
            .script =
            \\IFS=:
            \\x='a::b:'
            \\set -- $x
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<3>
            \\<a>
            \\<>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting treats multibyte IFS delimiters as single characters",
            .script =
            \\IFS=å
            \\x='aåb'
            \\set -- $x
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<2>
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting with non-whitespace IFS preserves leading and adjacent empty fields",
            .script =
            \\IFS=:
            \\x=':a::b:'
            \\set -- $x
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<4>
            \\<>
            \\<a>
            \\<>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting with mixed IFS trims adjacent IFS whitespace around non-whitespace delimiters",
            .script =
            \\IFS=': '
            \\x=' a : b:: c :'
            \\set -- $x
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<4>
            \\<a>
            \\<b>
            \\<>
            \\<c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "empty IFS disables splitting but removes empty unquoted expansion fields",
            .script =
            \\IFS=
            \\x='a b'
            \\empty=
            \\set -- $x $empty quoted
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<a b>
            \\<quoted>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "empty IFS disables splitting after command and arithmetic expansion",
            .script =
            \\IFS=
            \\x='a b'
            \\set -- $x $(printf 'c d') $((1 + 2))
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<3>
            \\<a b>
            \\<c d>
            \\<3>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting removes implicit nulls and preserves explicit quoted nulls",
            .script =
            \\unset IFS
            \\empty=
            \\set -- $empty "" "$empty" a${empty}b ${empty}x x${empty}
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<5>
            \\<>
            \\<>
            \\<ab>
            \\<x>
            \\<x>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting applies only to expansion results within a word",
            .script =
            \\IFS=,
            \\x='a,b'
            \\set -- pre${x}post
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<2>
            \\<prea>
            \\<bpost>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting applies after command substitution and arithmetic expansion",
            .script = "unset IFS\nset -- $(printf 'a b\\nc') $((1 + 2))x\nprintf '<%s>\\n' \"$#\" \"$@\"\n",
            .stdout =
            \\<4>
            \\<a>
            \\<b>
            \\<c>
            \\<3x>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting does not apply inside double quotes",
            .script =
            \\unset IFS
            \\x='a b'
            \\set -- "$x" "$(printf 'c d')" "$((1 + 2)) $((3 + 4))"
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<3>
            \\<a b>
            \\<c d>
            \\<3 7>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unquoted at undergoes field splitting and removes empty fields",
            .script =
            \\set -- 'a b' '' c
            \\printf '<%s>\n' $@
            ,
            .stdout =
            \\<a>
            \\<b>
            \\<c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unquoted at preserves empty fields before later fields with non-whitespace IFS",
            .script =
            \\set -- '' a '' b
            \\IFS=,
            \\printf '<%s>\n' $@
            ,
            .stdout =
            \\<>
            \\<a>
            \\<>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion expands matching fields in sorted order",
            .script =
            \\: >b.txt
            \\: >a.txt
            \\printf '%s\n' *.txt
            ,
            .stdout =
            \\a.txt
            \\b.txt
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion leaves non-matching patterns unchanged",
            .script =
            \\printf '<%s>\n' no-match-*.zzz
            ,
            .stdout =
            \\<no-match-*.zzz>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion is disabled by set minus f",
            .script =
            \\: >a.txt
            \\: >b.txt
            \\set -f
            \\printf '<%s>\n' *.txt
            ,
            .stdout =
            \\<*.txt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion applies after field splitting",
            .script =
            \\: >x.c
            \\: >y.h
            \\patterns='*.c *.h'
            \\set -- $patterns
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<2>
            \\<x.c>
            \\<y.h>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion applies to unquoted pattern characters from parameter expansion",
            .script =
            \\: >a.txt
            \\: >b.txt
            \\pattern='*.txt'
            \\printf '<%s>\n' $pattern
            ,
            .stdout =
            \\<a.txt>
            \\<b.txt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion matches question mark and bracket expressions",
            .script =
            \\: >a.txt
            \\: >b.txt
            \\: >aa.txt
            \\: >ab.txt
            \\: >ac.txt
            \\printf '<%s>\n' ?.txt a[ab].txt
            ,
            .stdout =
            \\<a.txt>
            \\<b.txt>
            \\<aa.txt>
            \\<ab.txt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion requires slash to be matched explicitly",
            .script =
            \\: >root.txt
            \\mkdir dir
            \\: >dir/file.txt
            \\printf '<%s>\n' *.txt */*.txt
            ,
            .stdout =
            \\<root.txt>
            \\<dir/file.txt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion does not match leading period implicitly",
            .script =
            \\: >a.txt
            \\: >.hidden.txt
            \\printf '<%s>\n' *.txt .*.txt
            ,
            .stdout =
            \\<a.txt>
            \\<.hidden.txt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion leaves quoted pattern characters literal",
            .script =
            \\: >a.txt
            \\printf '<%s>\n' '*' "*.txt" \*.txt
            ,
            .stdout =
            \\<*>
            \\<*.txt>
            \\<*.txt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion does not apply to assignment values",
            .script =
            \\: >a.txt
            \\value=*.txt
            \\printf '<%s>\n' "$value"
            ,
            .stdout =
            \\<*.txt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quote removal preserves quoted spaces as argument data",
            .script =
            \\printf '<%s>\n' "a b" 'c d' e\ f
            ,
            .stdout =
            \\<a b>
            \\<c d>
            \\<e f>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quote removal removes unquoted backslashes preserving escaped literals",
            .script = "printf '<%s>\\n' a\\ b c\\$d e\\`f g\\\\h\n",
            .stdout =
            \\<a b>
            \\<c$d>
            \\<e`f>
            \\<g\h>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quote removal removes single and double quote delimiters",
            .script =
            \\printf '<%s>\n' 'single quoted' "double quoted" "a'b" 'c"d'
            ,
            .stdout =
            \\<single quoted>
            \\<double quoted>
            \\<a'b>
            \\<c"d>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backslash newline is removed before tokenization",
            .script = "printf '<%s>\\n' foo\\\nbar\n",
            .stdout =
            \\<foobar>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quote removal preserves explicit null arguments",
            .script =
            \\empty=
            \\printf '<%s>\n' "" '' "$empty"
            ,
            .stdout =
            \\<>
            \\<>
            \\<>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quote characters from expansion results are not removed",
            .script =
            \\x='"a b"'
            \\printf '<%s>\n' $x "$x"
            ,
            .stdout =
            \\<"a>
            \\<b">
            \\<"a b">
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quote removal happens after field splitting and pathname expansion",
            .script =
            \\: >a.txt
            \\pattern='*.txt'
            \\printf '<%s>\n' $pattern "$pattern" \*.txt
            ,
            .stdout =
            \\<a.txt>
            \\<*.txt>
            \\<*.txt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quote removal preserves quoted expansion results as single fields",
            .script =
            \\printf '<%s>\n' "$(printf 'a b')" $(printf 'a b') "$((1 + 2)) $((3 + 4))"
            ,
            .stdout =
            \\<a b>
            \\<a>
            \\<b>
            \\<3 7>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
