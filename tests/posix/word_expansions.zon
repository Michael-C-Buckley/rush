.{
    .name = "2.6 Word Expansions",
    .mode = .posix,
    .cases = .{
        .{
            .name = "parameter expansion uses default value without assigning",
            .script =
            \\unset x
            \\printf '<%s>:<%s>\n' "${x:-fallback}" "${x-unset}"
            ,
            .stdout =
            \\<fallback>:<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion default distinguishes unset from null",
            .script =
            \\unset missing
            \\x=
            \\printf '<%s>\n' "${x-word}" "${x:-word}" "${missing-word}" "${missing:-word}"
            ,
            .stdout =
            \\<>
            \\<word>
            \\<word>
            \\<word>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion assigns default value",
            .script =
            \\unset x
            \\printf '<%s>:<%s>\n' "${x:=fallback}" "$x"
            ,
            .stdout =
            \\<fallback>:<fallback>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion assignment distinguishes unset from null",
            .script =
            \\unset x y
            \\x=
            \\printf '<%s>:<%s>\n' "${x=word}" "$x"
            \\printf '<%s>:<%s>\n' "${x:=word}" "$x"
            \\printf '<%s>:<%s>\n' "${y=word}" "$y"
            ,
            .stdout =
            \\<>:<>
            \\<word>:<word>
            \\<word>:<word>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion uses alternate value only when set and non-null",
            .script =
            \\unset x
            \\printf '<%s>\n' "${x:+bad}"
            \\x=value
            \\printf '<%s>\n' "${x:+alt}"
            ,
            .stdout =
            \\<>
            \\<alt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion alternate distinguishes set null from unset",
            .script =
            \\unset missing
            \\x=
            \\y=value
            \\printf '<%s>\n' "${x+alt}" "${x:+alt}" "${missing+alt}" "${missing:+alt}" "${y+alt}" "${y:+alt}"
            ,
            .stdout =
            \\<alt>
            \\<>
            \\<>
            \\<>
            \\<alt>
            \\<alt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion question mark errors for unset parameters",
            .script =
            \\unset missing
            \\printf '%s\n' ${missing?'need it'}
            \\printf 'bad\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "parameter expansion colon question mark errors for null parameters",
            .script =
            \\x=
            \\printf '%s\n' ${x:?'need it'}
            \\printf 'bad\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "parameter expansion question mark accepts set null parameters",
            .script =
            \\x=
            \\printf '<%s>\n' ${x?'need it'}
            \\printf 'after\n'
            ,
            .stdout =
            \\<>
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion reports string length",
            .script =
            \\x=abcdef
            \\printf '%s\n' "${#x}"
            ,
            .stdout =
            \\6
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion removes shortest and longest suffix patterns",
            .script =
            \\x=posix/src/std
            \\printf '%s\n' "${x%/*}" "${x%%/*}"
            ,
            .stdout =
            \\posix/src
            \\posix
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion removes shortest and longest prefix patterns",
            .script =
            \\x=/one/two/three
            \\printf '%s\n' "${x#*/}" "${x##*/}"
            ,
            .stdout =
            \\one/two/three
            \\three
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unbraced parameter expansion uses the longest valid name",
            .script =
            \\foo=abc
            \\foox=long
            \\unset foo_suffix
            \\printf '<%s>\n' "$foo_suffix" "${foo}_suffix" "$foox" "${foo}x"
            ,
            .stdout =
            \\<>
            \\<abc_suffix>
            \\<long>
            \\<abcx>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "braced positional parameter expansion supports multiple digits",
            .script =
            \\set -- one two three four five six seven eight nine ten
            \\printf '<%s>\n' $1 $10 ${10}
            ,
            .stdout =
            \\<one>
            \\<one0>
            \\<ten>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "special parameters expose count status and option flags",
            .script =
            \\set -- 'a b' '' c
            \\false
            \\st=$?
            \\set -f
            \\case "$#:$st:$-" in 3:1:*f*) printf 'special\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\special
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted at expands positional parameters as separate fields",
            .script =
            \\set -- 'a b' '' c
            \\for x in "$@"; do printf '<%s>\n' "$x"; done
            ,
            .stdout =
            \\<a b>
            \\<>
            \\<c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted star joins positional parameters with the first IFS character",
            .script =
            \\IFS=,
            \\set -- 'a b' '' c
            \\printf '<%s>\n' "$*"
            ,
            .stdout =
            \\<a b,,c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar and zero special parameters are non-empty",
            .script =
            \\case $$:$0 in *[!0123456789]*:*) printf 'pid0\n';; *:*[!/]*) printf 'pid0\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\pid0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang special parameter expands to the most recent background process id",
            .script =
            \\: &
            \\p=$!
            \\case $p in *[!0123456789]*|'') printf 'bad\n';; *) printf 'background\n';; esac
            ,
            .stdout =
            \\background
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion evaluates nested default words when needed",
            .script =
            \\unset x y
            \\y=inner
            \\printf '<%s>\n' "${x:-${y:-fallback}}"
            ,
            .stdout =
            \\<inner>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion does not evaluate unused default words",
            .script =
            \\x=value
            \\unset marker
            \\printf '<%s>\n' "${x:-$(printf side >marker)}"
            \\test ! -e marker && printf 'lazy\n'
            ,
            .stdout =
            \\<value>
            \\lazy
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion evaluates default words when used",
            .script =
            \\unset x
            \\printf '<%s>\n' "${x:-$(printf fallback)}"
            ,
            .stdout =
            \\<fallback>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter pattern removal supports bracket expressions",
            .script =
            \\x=abc123def
            \\printf '<%s>\n' "${x%%[0-9]*}" "${x##*[0-9]}"
            ,
            .stdout =
            \\<abc>
            \\<def>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quotes inside parameter patterns can quote pattern characters",
            .script =
            \\x='a*b'
            \\printf '<%s>\n' "${x#\"a*\"}" "${x#'a*'}" "${x#a*}"
            ,
            .stdout =
            \\<a*b>
            \\<b>
            \\<*b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion applies at the start of an unquoted word",
            .script =
            \\set -- ~ ~/subdir
            \\home=$1
            \\case $2 in "$home/subdir") printf 'start\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\start
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion is suppressed by quoting",
            .script =
            \\printf '<%s>\n' '~' "~" \~
            ,
            .stdout =
            \\<~>
            \\<~>
            \\<~>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion does not apply after other word characters",
            .script =
            \\printf '<%s>\n' x~ x~/subdir
            ,
            .stdout =
            \\<x~>
            \\<x~/subdir>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde expansion applies after equals and colon in assignment words",
            .script =
            \\home=~
            \\value=~/bin:~:/usr:~/sbin
            \\case $value in "$home/bin:$home:/usr:$home/sbin") printf 'assignment\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\assignment
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted tilde is literal in assignment words",
            .script =
            \\single='~'
            \\double="~"
            \\escaped=\~
            \\printf '<%s>\n' "$single" "$double" "$escaped"
            ,
            .stdout =
            \\<~>
            \\<~>
            \\<~>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "tilde is literal inside assignment fields except after colon",
            .script =
            \\home=~
            \\literal=a~
            \\colon=/prefix:~
            \\printf '<%s>\n' "$literal"
            \\case $colon in "/prefix:$home") printf 'colon\n';; *) printf 'bad\n';; esac
            ,
            .stdout =
            \\<a~>
            \\colon
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution trims trailing newlines but preserves interior newlines",
            .script =
            \\x=$(printf 'a\n\nb\n\n')
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<a
            \\
            \\b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution nests inside double quotes",
            .script =
            \\printf '<%s>\n' "$(printf '[%s]' "$(printf inner)")"
            ,
            .stdout =
            \\<[inner]>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "arithmetic expansion evaluates expressions after parameter expansion",
            .script =
            \\n=5
            \\printf '%s\n' "$((n * 2 + 1))"
            ,
            .stdout =
            \\11
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting applies to unquoted parameter expansion",
            .script =
            \\x=' a  b '
            \\set -- $x
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "field splitting with non-whitespace IFS preserves empty fields between delimiters",
            .script =
            \\IFS=:
            \\x='a::b:'
            \\set -- $x
            \\printf '<%s>\n' "$#" "$@"
            ,
            .stdout =
            \\<3>
            \\<a>
            \\<>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "empty IFS disables splitting but removes empty unquoted expansion fields",
            .script =
            \\IFS=
            \\x='a b'
            \\empty=
            \\set -- $x $empty quoted
            \\printf '<%s>\n' "$@"
            ,
            .stdout =
            \\<a b>
            \\<quoted>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unquoted at undergoes field splitting and removes empty fields",
            .script =
            \\set -- 'a b' '' c
            \\printf '<%s>\n' $@
            ,
            .stdout =
            \\<a>
            \\<b>
            \\<c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion expands matching fields in sorted order",
            .script =
            \\: >b.txt
            \\: >a.txt
            \\printf '%s\n' *.txt
            ,
            .stdout =
            \\a.txt
            \\b.txt
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion leaves non-matching patterns unchanged",
            .script =
            \\printf '<%s>\n' no-match-*.zzz
            ,
            .stdout =
            \\<no-match-*.zzz>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pathname expansion does not apply to assignment values",
            .script =
            \\: >a.txt
            \\value=*.txt
            \\printf '<%s>\n' "$value"
            ,
            .stdout =
            \\<*.txt>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quote removal preserves quoted spaces as argument data",
            .script =
            \\printf '<%s>\n' "a b" 'c d' e\ f
            ,
            .stdout =
            \\<a b>
            \\<c d>
            \\<e f>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
