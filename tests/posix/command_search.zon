.{
    .name = "2.9.1.4 Command Search and Execution",
    .mode = .posix,
    .cases = .{
        .{
            .name = "special built-ins are found even when PATH cannot find utilities",
            .script =
            \\PATH=/nonexistent
            \\:
            \\readonly SPECIAL_BUILTIN_FOUND=ok
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "functions are found before regular built-ins",
            .script =
            \\printf() { echo function; }
            \\printf ignored
            ,
            .stdout =
            \\function
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "functions are found before PATH utilities",
            .script =
            \\mkdir d
            \\printf '%s\n' '#!/bin/sh' 'printf "external\n"' >d/foo
            \\chmod 755 d/foo
            \\foo() { printf 'function\n'; }
            \\PATH=./d:$PATH foo
            ,
            .stdout =
            \\function
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "regular built-ins are found before PATH utilities",
            .script =
            \\mkdir d
            \\printf '%s\n' '#!/bin/sh' 'printf "external\n"' >d/printf
            \\chmod 755 d/printf
            \\PATH=./d:$PATH printf 'builtin\n'
            ,
            .stdout =
            \\builtin
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command bypasses functions to find regular built-ins",
            .script =
            \\printf() { echo function; }
            \\printf ignored
            \\command printf 'builtin\n'
            ,
            .stdout =
            \\function
            \\builtin
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command bypasses functions to find PATH utilities",
            .script =
            \\mkdir d
            \\printf '%s\n' '#!/bin/sh' 'printf "external\n"' >d/foo
            \\chmod 755 d/foo
            \\foo() { printf 'function\n'; }
            \\PATH=./d:$PATH command foo
            ,
            .stdout =
            \\external
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "PATH utility receives the command name as argv zero",
            .script =
            \\PATH=/usr/bin:/bin awk 'BEGIN { print ARGV[0] }'
            ,
            .stdout =
            \\awk
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unset -f removes functions from later command lookup",
            .script =
            \\foo() { printf 'function\n'; }
            \\foo
            \\unset -f foo
            \\foo 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\function
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command search failure sets status 127 and execution continues",
            .script =
            \\no_such_posix_command_for_rush 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "temporary assignments before command search failure do not persist",
            .script =
            \\x=outer
            \\x=temp no_such_posix_command_for_rush 2>/dev/null
            \\printf '<%s:%s>\n' "$x" "$?"
            ,
            .stdout =
            \\<outer:127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "redirections before command search failure still take effect",
            .script =
            \\no_such_posix_command_for_rush >out 2>/dev/null
            \\printf '<%s:' "$?"
            \\test -f out
            \\printf '%s>\n' "$?"
            ,
            .stdout =
            \\<127:0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "empty command names fail as not found and execution continues",
            .script =
            \\"" 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "temporary assignments before regular built-ins do not persist",
            .script =
            \\x=outer
            \\x=temp printf 'builtin\n'
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\builtin
            \\<outer>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "temporary assignments before external utilities are exported and do not persist",
            .script =
            \\x=outer
            \\x=temp sh -c 'printf "in:%s\n" "$x"'
            \\printf 'out:%s\n' "$x"
            ,
            .stdout =
            \\in:temp
            \\out:outer
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "PATH search continues past non-executable candidates",
            .script =
            \\mkdir d1 d2
            \\printf '%s\n' ignored >d1/cmd
            \\chmod 644 d1/cmd
            \\printf '%s\n' '#!/bin/sh' 'printf "found\n"' >d2/cmd
            \\chmod 755 d2/cmd
            \\PATH=./d1:./d2 cmd
            ,
            .stdout =
            \\found
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "PATH search found non-executable command sets status 126",
            .script =
            \\mkdir d
            \\printf '%s\n' ignored >d/cmd
            \\chmod 644 d/cmd
            \\PATH=./d cmd 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<126>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "PATH changes affect later command lookup",
            .script =
            \\mkdir d1 d2
            \\printf '%s\n' '#!/bin/sh' 'printf "old\n"' >d1/cmd
            \\chmod 755 d1/cmd
            \\printf '%s\n' '#!/bin/sh' 'printf "new\n"' >d2/cmd
            \\chmod 755 d2/cmd
            \\PATH=./d1 cmd
            \\PATH=./d2 cmd
            ,
            .stdout =
            \\old
            \\new
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "slash command name bypasses functions and PATH search",
            .script =
            \\printf '%s\n' '#!/bin/sh' 'printf "external\n"' >cmd
            \\chmod 755 cmd
            \\cmd() { printf '%s\n' function; }
            \\PATH=/nonexistent ./cmd
            ,
            .stdout =
            \\external
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "slash directory command fails with status 126",
            .script =
            \\mkdir dir
            \\./dir 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<126>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "slash executable text file falls back to shell execution",
            .script =
            \\printf '%s\n' 'printf "script:%s:%s\n" "$0" "$1"' >script
            \\chmod 755 script
            \\./script arg
            ,
            .stdout =
            \\script:./script:arg
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "PATH executable text file falls back to shell execution",
            .script =
            \\mkdir d
            \\printf '%s\n' 'printf "script:%s:%s\n" "$0" "$1"' >d/myscript
            \\chmod 755 d/myscript
            \\PATH=./d:$PATH myscript arg
            ,
            .stdout =
            \\script:./d/myscript:arg
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command utility preserves special built-in state effects",
            .script =
            \\command export COMMAND_EXPORT=ok
            \\printf '<%s:%s>\n' "$COMMAND_EXPORT" "$?"
            ,
            .stdout =
            \\<ok:0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command utility preserves declaration assignment expansion",
            .script =
            \\HOME=/tmp/rush-command-home
            \\command export COMMAND_EXPORT_TILDE=~
            \\printf '<%s>\n' "$COMMAND_EXPORT_TILDE"
            ,
            .stdout =
            \\</tmp/rush-command-home>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command utility preserves regular built-in state effects",
            .script =
            \\start=$PWD
            \\mkdir d
            \\command cd d
            \\case $PWD in "$start"/d) printf '<ok:%s>\n' "$?" ;; *) printf '<bad:%s>\n' "$?" ;; esac
            ,
            .stdout =
            \\<ok:0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -v reports functions and built-ins by name",
            .script =
            \\foo() { :; }
            \\command -v foo
            \\command -v :
            \\command -v command
            ,
            .stdout =
            \\foo
            \\:
            \\command
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -v and -V report reserved words",
            .script =
            \\lookup=$(command -v if)
            \\case $lookup in if) printf '<%s>\n' terse-if ;; *) printf '<%s>\n' bad ;; esac
            \\lookup=$(command -v in)
            \\case $lookup in in) printf '<%s>\n' terse-in ;; *) printf '<%s>\n' bad ;; esac
            \\lookup=$(command -v !)
            \\case $lookup in !) printf '<%s>\n' terse-bang ;; *) printf '<%s>\n' bad ;; esac
            \\lookup=$(command -v "{")
            \\case $lookup in "{") printf '<%s>\n' terse-left-brace ;; *) printf '<%s>\n' bad ;; esac
            \\lookup=$(command -v "}")
            \\case $lookup in "}") printf '<%s>\n' terse-right-brace ;; *) printf '<%s>\n' bad ;; esac
            \\lookup=$(command -V while)
            \\case $lookup in *while*keyword*|*while*reserved*) printf '<%s>\n' verbose ;;
            \\    *) printf '<%s>\n' bad ;;
            \\esac
            \\type do >/dev/null
            ,
            .stdout =
            \\<terse-if>
            \\<terse-in>
            \\<terse-bang>
            \\<terse-left-brace>
            \\<terse-right-brace>
            \\<verbose>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -V reports a function before the builtin it shadows",
            .script =
            \\cd() { :; }
            \\command -V cd
            ,
            .stdout =
            \\cd is a shell function
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -v and -V report aliases",
            .script =
            \\alias ll='ls -l'
            \\lookup=$(command -v ll)
            \\case $lookup in
            \\    *ll*'ls -l'*) printf '<%s>\n' terse ;;
            \\    *) printf '<%s>\n' bad ;;
            \\esac
            \\lookup=$(command -V ll)
            \\case $lookup in
            \\    *ll*'ls -l'*) printf '<%s>\n' verbose ;;
            \\    *) printf '<%s>\n' bad ;;
            \\esac
            ,
            .stdout =
            \\<terse>
            \\<verbose>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -v reports a found PATH utility pathname",
            .script =
            \\PATH=/bin command -v sh
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\/bin/sh
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -v reports nonzero when a name is not found",
            .script =
            \\command -v no_such_posix_command_for_rush >/dev/null 2>/dev/null
            \\case $? in 0) printf 'zero\n';; *) printf 'nonzero\n';; esac
            ,
            .stdout =
            \\nonzero
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -v reports nonzero when a pathname is not executable",
            .script =
            \\rm -f command-v-not-executable
            \\: >command-v-not-executable
            \\command -v ./command-v-not-executable >/dev/null 2>/dev/null
            \\case $? in 0) printf 'zero\n';; *) printf 'nonzero\n';; esac
            \\rm -f command-v-not-executable
            ,
            .stdout =
            \\nonzero
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -V reports zero for found names and nonzero for missing names",
            .script =
            \\command -V command >/dev/null
            \\printf '<%s>\n' "$?"
            \\command -V no_such_posix_command_for_rush >/dev/null 2>/dev/null
            \\case $? in 0) printf 'zero\n';; *) printf 'nonzero\n';; esac
            ,
            .stdout =
            \\<0>
            \\nonzero
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
