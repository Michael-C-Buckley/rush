.{
    .name = "2.2 Quoting",
    .mode = .posix,
    .cases = .{
        .{
            .name = "backslash preserves the literal value of the following character",
            .script =
            \\printf '<%s>\n' a\ b \* \$HOME
            ,
            .stdout =
            \\<a b>
            \\<*>
            \\<$HOME>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backslash-newline line continuation is removed before tokenization",
            .script =
            \\printf '<%s>\n' foo\
            \\bar
            ,
            .stdout =
            \\<foobar>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "comments are recognized after backslash-newline removal",
            .script =
            \\printf '%s\n' foo \
            \\# comment
            \\printf '%s\n' bar
            ,
            .stdout =
            \\foo
            \\bar
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "single quotes preserve literal text",
            .script =
            \\x=value
            \\printf '<%s>\n' '$x * a b'
            ,
            .stdout =
            \\<$x * a b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "double quotes preserve spaces while allowing parameter and command substitution",
            .script =
            \\x=value
            \\printf '<%s>\n' "pre $x" "$(printf cmd)"
            ,
            .stdout =
            \\<pre value>
            \\<cmd>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backslash inside double quotes only quotes dollar backquote double-quote backslash and newline",
            .script =
            \\printf '<%s>\n' "a\ b" "a\$b" "a\\b" "a\"b"
            ,
            .stdout =
            \\<a\ b>
            \\<a$b>
            \\<a\b>
            \\<a"b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "double quotes do not give dollar-single-quotes special meaning",
            .script =
            \\printf '<%s>\n' "$'a\n'"
            ,
            .stdout =
            \\<$'a\n'>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "double quotes preserve command substitution newlines as literal characters",
            .script =
            \\set -- "$(printf 'a\nb')"
            \\second=$(printf '%s\n' "$1" | sed -n '2p')
            \\printf '<%s>:<%s>\n' "$#" "$second"
            ,
            .stdout =
            \\<1>:<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution preserves stderr outside captured stdout",
            .script =
            \\x=$(printf out; printf 'err\n' >&2)
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<out>
            \\
            ,
            .stderr =
            \\err
            \\
            ,
            .status = 0,
        },
        .{
            .name = "double quotes preserve arithmetic expansion results as one field",
            .script =
            \\printf '<%s>\n' "$((1 + 2))"
            ,
            .stdout =
            \\<3>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "backslash can escape a closing brace in double-quoted parameter expansion",
            .script =
            \\x='abc}'
            \\printf '<%s>\n' "${x%\}}"
            ,
            .stdout =
            \\<abc>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted here-document delimiters prevent expansion in the body",
            .script =
            \\cat <<'EOF'
            \\$x $(printf bad) "quoted"
            \\EOF
            ,
            .stdout =
            \\$x $(printf bad) "quoted"
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar-single-quotes process common escape sequences before expansion",
            .script =
            \\second=$(printf '%s\n' $'a\nb' | sed -n '2p')
            \\printf '<%s>\n' "$second" $'\'' $'\\'
            ,
            .stdout =
            \\<b>
            \\<'>
            \\<\>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar-single-quotes process hexadecimal and octal byte escapes",
            .script =
            \\printf '<%s>\n' $'\101' $'\x41'
            ,
            .stdout =
            \\<A>
            \\<A>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar-single-quoted dollar signs do not introduce parameter expansion",
            .script =
            \\x=ok
            \\printf '<%s>\n' $'$x' $'\044x'
            ,
            .stdout =
            \\<$x>
            \\<$x>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
