.{
    .name = "2.9.1 Simple Commands",
    .mode = .posix,
    .cases = .{
        .{
            .name = "printf writes stdout",
            .script =
            \\printf '%s\n' hello
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "semantic output before and after external command preserves order",
            .script =
            \\printf a
            \\cat <<'EOF'
            \\b
            \\EOF
            \\printf c
            ,
            .stdout = "ab\nc",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment-only command affects current environment",
            .script =
            \\x=hello
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment-only command exits successfully",
            .script =
            \\x=hello
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment-only command with command substitution uses substitution status",
            .script =
            \\x=$(exit 7)
            ,
            .stdout = "",
            .stderr = "",
            .status = 7,
        },
        .{
            .name = "assignment-only command expands assignments left-to-right",
            .script =
            \\unset a b
            \\a=one b=$a
            \\printf '%s:%s\n' "$a" "$b"
            ,
            .stdout =
            \\one:one
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment-only command uses last substitution status",
            .script =
            \\a=$(exit 3) b=$(exit 7)
            ,
            .stdout = "",
            .stderr = "",
            .status = 7,
        },
        .{
            .name = "temporary assignment does not affect regular utility arguments or shell state",
            .script =
            \\x=outer
            \\x=inner printf '%s\n' "$x"
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\outer
            \\outer
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment-looking words after the command name are ordinary arguments",
            .script =
            \\printf '<%s>\n' x=inner
            \\printf '<%s>\n' "${x-unset}"
            ,
            .stdout =
            \\<x=inner>
            \\<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "temporary assignment is exported to regular utility environment",
            .script =
            \\x=outer
            \\x=inner sh -c 'printf "%s\n" "$x"'
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\inner
            \\outer
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "temporary assignment before special builtin persists",
            .script =
            \\x=outer
            \\x=inner :
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\inner
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "temporary assignment is visible during function execution",
            .script =
            \\f() { printf '%s\n' "$x"; }
            \\x=inner f
            ,
            .stdout =
            \\inner
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "temporary assignment before function is exported to child utilities",
            .script =
            \\f() { sh -c 'printf "<%s>\n" "$x"'; }
            \\x=inner f
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<inner>
            \\<>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "empty command-name expansion is skipped",
            .script =
            \\empty=
            \\$empty printf '%s\n' ok
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "expanded command word can provide arguments",
            .script =
            \\cmd='printf %s\n'
            \\$cmd ok
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "redirection can precede command word",
            .script =
            \\>out printf '%s\n' hello
            \\cat out
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "redirection-only command does not redirect later commands",
            .script =
            \\printf '%s\n' old >out
            \\>out
            \\printf '%s\n' stdout
            \\cat out
            ,
            .stdout =
            \\stdout
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "redirection-only command uses last substitution status",
            .script =
            \\>out $(exit 7)
            \\printf '<%s>\n' "$?"
            \\cat out
            ,
            .stdout =
            \\<7>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "regular utility redirection expands before assignment is applied",
            .script =
            \\x=old
            \\x=new printf '%s\n' "$x" >"$x"
            \\cat old
            \\test ! -e new || printf 'new exists\n'
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\old
            \\old
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
