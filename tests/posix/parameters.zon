.{
    .name = "2.5 Parameters and Variables",
    .mode = .posix,
    .cases = .{
        .{
            .name = "set assigns positional parameters and updates the count",
            .script =
            \\set -- a 'b c' ''
            \\printf '<%s>\n' "$#" "$1" "$2" "$3"
            ,
            .stdout =
            \\<3>
            \\<a>
            \\<b c>
            \\<>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set without operands unsets all positional parameters",
            .script =
            \\set -- a b
            \\set --
            \\printf '<%s>:<%s>\n' "$#" "${1-unset}"
            ,
            .stdout =
            \\<0>:<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "multi-digit positional parameters require braces and use decimal indices",
            .script =
            \\set -- x 2 3 4 5 6 7 eight 9 ten
            \\printf '<%s>\n' "${08}" "${008}" "${10}" "$10"
            ,
            .stdout =
            \\<eight>
            \\<eight>
            \\<ten>
            \\<x0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter expansion length accepts positional parameters",
            .script =
            \\set -- a bc def ghij
            \\printf '<%s>\n' "${#1}" "${#4}" "${#12}"
            ,
            .stdout =
            \\<1>
            \\<4>
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "double-quoted at expands positional parameters as separate fields",
            .script =
            \\set -- a 'b c' ''
            \\printf '<%s>\n' "$@"
            \\set --
            \\printf '<%s>\n' "$@" end
            ,
            .stdout =
            \\<a>
            \\<b c>
            \\<>
            \\<end>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter operators preserve quoted at fields",
            .script =
            \\set -- abc 'def ghi' jkl
            \\IFS=
            \\set ${1+"$@"}
            \\printf 'a:%s|%s|%s|%s\n' "$#" "$1" "$2" "$3"
            \\set -- abc 'def ghi' jkl
            \\set "${1+$@}"
            \\printf 'b:%s|%s|%s|%s\n' "$#" "$1" "$2" "$3"
            \\set -- abc 'def ghi' jkl
            \\unset novar
            \\set ${novar-"$@"}
            \\printf 'c:%s|%s|%s|%s\n' "$#" "$1" "$2" "$3"
            ,
            .stdout =
            \\a:3|abc|def ghi|jkl
            \\b:3|abc|def ghi|jkl
            \\c:3|abc|def ghi|jkl
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter operators preserve embedded at field boundaries",
            .script =
            \\set -- ' abc ' ' def ghi ' ' jkl '
            \\IFS=
            \\set "${1+ foo: $@ bar }"
            \\printf '<%s>\n' "$#" "$1" "$2" "$3"
            ,
            .stdout =
            \\<3>
            \\< foo:  abc >
            \\< def ghi >
            \\< jkl  bar >
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "embedded double-quoted at joins the first and last generated fields",
            .script =
            \\set -- A B
            \\printf '<%s>\n' "pre$@post"
            ,
            .stdout =
            \\<preA>
            \\<Bpost>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "repeated double-quoted at concatenates adjacent boundary fields",
            .script =
            \\set -- abc 'def ghi' jkl
            \\set "$@$@"
            \\printf '<%s>\n' "$#" "$1" "$2" "$3" "$4" "$5"
            ,
            .stdout =
            \\<5>
            \\<abc>
            \\<def ghi>
            \\<jklabc>
            \\<def ghi>
            \\<jkl>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "double-quoted star joins positional parameters with the first IFS byte",
            .script =
            \\set -- a 'b c' d
            \\IFS=:
            \\printf '<%s>\n' "$*"
            \\IFS=
            \\printf '<%s>\n' "$*"
            ,
            .stdout =
            \\<a:b c:d>
            \\<ab cd>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "parameter operators preserve quoted star field",
            .script =
            \\set -- abc 'def ghi' jkl
            \\unset var
            \\IFS=:
            \\set ${var-"$*"}
            \\printf 'a:%s|%s\n' "$#" "$1"
            \\set -- abc 'def ghi' jkl
            \\unset IFS
            \\set ${var-"$*"}
            \\printf 'b:%s|%s\n' "$#" "$1"
            \\set --
            \\IFS=:
            \\set ${var-"$*"}
            \\printf 'c:%s|%s\n' "$#" "$1"
            ,
            .stdout =
            \\a:1|abc:def ghi:jkl
            \\b:1|abc def ghi jkl
            \\c:1|
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "double-quoted star uses space as the separator when IFS is unset",
            .script =
            \\set -- a 'b c' d
            \\unset IFS
            \\printf '<%s>\n' "$*"
            ,
            .stdout =
            \\<a b c d>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "null variable values are set values and unset removes them",
            .script =
            \\x=
            \\printf '<%s>:<%s>\n' "${x+set}" "${x-unset}"
            \\unset x
            \\printf '<%s>\n' "${x-unset}"
            ,
            .stdout =
            \\<set>:<>
            \\<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "question mark expands to the most recent pipeline status",
            .script =
            \\false
            \\printf '<%s>\n' "$?"
            \\true
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "zero expands to a non-empty command name parameter",
            .script =
            \\case $0 in
            \\    '') printf '<bad>\n' ;;
            \\    *) printf '<arg0>\n' ;;
            \\esac
            ,
            .stdout =
            \\<arg0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dollar expands to the shell process id",
            .script =
            \\case $$ in
            \\    ''|*[!0123456789]*) printf 'bad\n' ;;
            \\    *) printf 'pid\n' ;;
            \\esac
            ,
            .stdout =
            \\pid
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang expands to the most recent asynchronous list process id",
            .script =
            \\sleep 0.1 &
            \\pid=$!
            \\case $pid in
            \\    ''|*[!0123456789]*) printf '<bad>\n' ;;
            \\    *) printf '<pid>\n' ;;
            \\esac
            \\wait
            ,
            .stdout =
            \\<pid>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "PPID is a numeric parent process id preserved in subshells",
            .script =
            \\case $PPID in
            \\    ''|*[!0123456789]*) printf '<bad>\n' ;;
            \\    *) printf '<ppid>\n' ;;
            \\esac
            \\outer=$PPID
            \\(printf '%s' "$PPID" >inner)
            \\inner=$(cat inner)
            \\if [ "$outer" = "$inner" ]; then printf '<same>\n'; else printf '<diff>\n'; fi
            ,
            .stdout =
            \\<ppid>
            \\<same>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "LINENO in the main script continues after dot script and eval",
            .script =
            \\cat >dot.sh <<'EOF'
            \\printf '<dot1:%s>\n' "$LINENO"
            \\printf '<dot2:%s>\n' "$LINENO"
            \\EOF
            \\printf '<before:%s>\n' "$LINENO"
            \\. ./dot.sh
            \\printf '<after-dot:%s>\n' "$LINENO"
            \\eval ':'
            \\printf '<after-eval:%s>\n' "$LINENO"
            ,
            .stdout =
            \\<before:5>
            \\<dot1:1>
            \\<dot2:2>
            \\<after-dot:7>
            \\<after-eval:9>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "LINENO reports body lines inside compound commands and command substitution",
            .script =
            \\if true
            \\then
            \\printf '<if:%s>\n' "$LINENO"
            \\fi
            \\case x in
            \\x)
            \\printf '<case:%s>\n' "$LINENO"
            \\;;
            \\esac
            \\(
            \\printf '<subshell:%s>\n' "$LINENO"
            \\)
            \\printf '<cmdsub:%s>\n' "$(printf '%s' "$LINENO")"
            ,
            .stdout =
            \\<if:3>
            \\<case:7>
            \\<subshell:11>
            \\<cmdsub:13>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "LINENO reports source lines for later multiline pipeline stages",
            .script =
            \\printf x |
            \\printf '<simple:%s>\n' "$LINENO"
            \\printf x |
            \\{
            \\printf '<brace:%s>\n' "$LINENO"
            \\}
            ,
            .stdout =
            \\<simple:2>
            \\<brace:5>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "hyphen reflects set option flags",
            .script =
            \\case $- in *u*) printf 'bad-u\n' ;; *) printf 'no-u\n' ;; esac
            \\set -u
            \\case $- in *u*) printf 'has-u\n' ;; *) printf 'bad-no-u\n' ;; esac
            \\set +u
            \\case $- in *u*) printf 'bad-still-u\n' ;; *) printf 'cleared-u\n' ;; esac
            \\set -f
            \\case $- in *f*) printf 'noglob\n' ;; *) printf 'bad-glob\n' ;; esac
            \\set +f
            \\case $- in *f*) printf 'bad-still-f\n' ;; *) printf 'glob\n' ;; esac
            ,
            .stdout =
            \\no-u
            \\has-u
            \\cleared-u
            \\noglob
            \\glob
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "shift discards leading positional parameters",
            .script =
            \\set -- one two three
            \\shift 2
            \\printf '<%s>\n' "$#" "$1"
            ,
            .stdout =
            \\<1>
            \\<three>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
