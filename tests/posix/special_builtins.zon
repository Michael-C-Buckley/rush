.{
    .name = "2.15 Special Built-In Utilities",
    .mode = .posix,
    .cases = .{
        .{
            .name = "colon ignores arguments and returns zero",
            .script =
            \\: ignored arguments
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval constructs and executes a command from its arguments",
            .script =
            \\eval 'printf "<%s>\\n" eval-ok'
            ,
            .stdout =
            \\<eval-ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval returns the status of the constructed command",
            .script =
            \\eval 'false'
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval with no arguments returns zero",
            .script =
            \\eval
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "readonly assigns a variable value",
            .script =
            \\readonly ro=value
            \\printf '<%s>\n' "$ro"
            ,
            .stdout =
            \\<value>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unset succeeds for an unset variable name",
            .script =
            \\unset missing
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "break exits the nearest enclosing loop",
            .script =
            \\for value in a b c
            \\do
            \\    printf '<%s>\n' "$value"
            \\    break
            \\done
            ,
            .stdout =
            \\<a>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "continue starts the next loop iteration",
            .script =
            \\i=0
            \\while true
            \\do
            \\    i=$((i + 1))
            \\    if [ "$i" -lt 3 ]
            \\    then
            \\        continue
            \\    fi
            \\    printf '<%s>\n' "$i"
            \\    break
            \\done
            ,
            .stdout =
            \\<3>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unset removes a shell variable",
            .script =
            \\x=set
            \\unset x
            \\printf '<%s>\n' "${x-unset}"
            ,
            .stdout =
            \\<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
