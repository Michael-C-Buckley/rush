.{
    .name = "2.15 Special Built-In Utilities",
    .mode = .posix,
    .cases = .{
        .{
            .name = "colon ignores arguments and returns zero",
            .script =
            \\: ignored arguments
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval constructs and executes a command from its arguments",
            .script =
            \\eval 'printf "<%s>\\n" eval-ok'
            ,
            .stdout =
            \\<eval-ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval returns the status of the constructed command",
            .script =
            \\eval 'false'
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval command substitution ignores quotes in comments",
            .script =
            \\eval ': || $( : # "
            \\)'
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval with no arguments returns zero",
            .script =
            \\eval
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval parse error exits a non-interactive shell",
            .script =
            \\eval "if"
            \\printf 'after\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 2,
        },
        .{
            .name = "eval sees and persists assignment prefix variables",
            .script =
            \\A=outer
            \\A=inner eval 'printf "inside=<%s>\n" "$A"; A=body; B=body'
            \\printf 'after=<%s>:<%s>\n' "$A" "$B"
            ,
            .stdout =
            \\inside=<inner>
            \\after=<body>:<body>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval preserves here-doc bodies in constructed commands",
            .script =
            \\eval "cat <<EOF
            \\hi
            \\EOF"
            ,
            .stdout =
            \\hi
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dot returns the status of the last command in the file",
            .script =
            \\printf 'false\n' >file.sh
            \\. ./file.sh
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dot returns zero when no command is executed",
            .script =
            \\: >empty.sh
            \\. ./empty.sh
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dot path search skips unreadable scripts",
            .script =
            \\mkdir p1 p2
            \\printf 'printf bad\n' >p1/script
            \\printf 'printf ok\n' >p2/script
            \\chmod 333 p1/script
            \\chmod 444 p2/script
            \\PATH=$PWD/p1:$PWD/p2:$PATH
            \\. script
            ,
            .stdout = "ok",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec with no command returns zero",
            .script =
            \\exec
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec without a command applies redirections to the current shell",
            .script =
            \\exec 3>out
            \\printf 'ok' >&3
            \\exec 3>&-
            \\cat out
            ,
            .stdout = "ok",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command exec without a command applies redirections to the current shell",
            .script =
            \\printf 'ok\n' >in
            \\command exec 8<in
            \\read line <&8
            \\printf '<%s>\n' "$line"
            \\exec 8<&-
            ,
            .stdout =
            \\<ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec redirections persist until explicitly restored",
            .script =
            \\exec 3>&1 >out
            \\printf 'file\n'
            \\printf 'fd3\n' >&3
            \\exec >&3 3>&-
            \\printf 'cat:<%s>\n' "$(cat out)"
            ,
            .stdout =
            \\fd3
            \\cat:<file>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec can close and restore standard output around builtin writes",
            .script =
            \\exec 3>&1 1>&-
            \\printf hidden 2>/dev/null
            \\exec 1>&3 3>&-
            \\printf 'after\n'
            ,
            .stdout =
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "special builtin redirection from a closed source descriptor is fatal",
            .script =
            \\exec 2>&-
            \\: >&2
            \\printf bad
            ,
            .stdout = "",
            .stderr = "",
            .status_match = .nonzero,
        },
        .{
            .name = "eval redirection failure exits the shell",
            .script =
            \\exec 2>&-
            \\eval ': >&2'
            \\printf bad
            ,
            .stdout = "",
            .stderr = "",
            .status_match = .nonzero,
        },
        .{
            .name = "exec duplicate redirection from a closed source descriptor is fatal",
            .script =
            \\exec 2>&-
            \\exec 1>&2
            \\printf bad
            ,
            .stdout = "",
            .stderr = "",
            .status_match = .nonzero,
        },
        .{
            .name = "readonly assigns a variable value",
            .script =
            \\readonly ro=value
            \\printf '<%s>\n' "$ro"
            ,
            .stdout =
            \\<value>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "readonly assigns quoted assignment operands",
            .script =
            \\readonly "ro=value"
            \\printf '<%s>\n' "$ro"
            ,
            .stdout =
            \\<value>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "export assigns expanded assignment operands",
            .script =
            \\operand=ex=value
            \\export $operand
            \\printf '<%s>\n' "$ex"
            ,
            .stdout =
            \\<value>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment to readonly variable exits nonzero",
            .script =
            \\readonly ro=value
            \\ro=other
            \\printf 'bad\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "readonly assignment error before special builtin exits the shell",
            .script =
            \\readonly ro=value
            \\ro=other :
            \\printf bad
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "export assignment to readonly variable exits the shell",
            .script =
            \\readonly ro=value
            \\export ro=other
            \\printf bad
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "export -p output can restore exported values",
            .script =
            \\export X='a b'
            \\export -p >save.sh
            \\( unset X; . ./save.sh; sh -c 'printf "<%s>\n" "$X"' )
            ,
            .stdout =
            \\<a b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "export without assignment does not set an unset variable",
            .script =
            \\unset X
            \\export X
            \\export -p | grep '^export X$'
            \\sh -c 'printf "<%s:%s>\n" "${X-unset}" "${X+set}"'
            ,
            .stdout =
            \\export X
            \\<unset:>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unset removes export attribute from unset variable",
            .script =
            \\unset X
            \\export X
            \\unset X
            \\case $(export -p) in *' X'|*' X='*) printf bad ;; *) printf ok ;; esac
            ,
            .stdout = "ok",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "readonly without assignment does not set an unset variable",
            .script =
            \\unset X
            \\readonly X
            \\readonly -p | grep '^readonly X$'
            \\printf '<%s:%s>\n' "${X-unset}" "${X+set}"
            ,
            .stdout =
            \\readonly X
            \\<unset:>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "readonly -p lists readonly variables",
            .script =
            \\readonly X='a b'
            \\readonly -p | grep '^readonly X=' >/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unset succeeds for an unset variable name",
            .script =
            \\unset missing
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "break exits the nearest enclosing loop",
            .script =
            \\for value in a b c
            \\do
            \\    printf '<%s>\n' "$value"
            \\    break
            \\done
            ,
            .stdout =
            \\<a>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "continue starts the next loop iteration",
            .script =
            \\i=0
            \\while true
            \\do
            \\    i=$((i + 1))
            \\    if [ "$i" -lt 3 ]
            \\    then
            \\        continue
            \\    fi
            \\    printf '<%s>\n' "$i"
            \\    break
            \\done
            ,
            .stdout =
            \\<3>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "continue in a function does not target the caller loop",
            .script =
            \\f() { continue 2>/dev/null; printf 'function-after\n'; }
            \\for x in once
            \\do
            \\    f
            \\    printf 'loop-after\n'
            \\done
            ,
            .stdout =
            \\function-after
            \\loop-after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return in a dot script stops the dot script with the requested status",
            .script =
            \\printf 'return 7\nprintf bad\n' >file.sh
            \\. ./file.sh
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<7>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return in a dot script accepts numeric arguments above 255",
            .script =
            \\printf 'return 256\nprintf bad\n' >file.sh
            \\. ./file.sh
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set double dash with no operands clears positional parameters",
            .script =
            \\set -- a b
            \\set --
            \\printf '<%s>\n' "$#"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set accepts option flags before double dash operands",
            .script =
            \\set -u -- a b
            \\printf '<%s:%s:%s>\n' "$#" "$1" "$2"
            \\set +u --
            \\printf '<%s>\n' "$#"
            ,
            .stdout =
            \\<2:a:b>
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set -o accepts POSIX option names",
            .script =
            \\set -o nounset -o noglob -o noclobber
            \\case $- in *u*) ;; *) printf 'bad-on:%s\n' "$-" ;; esac
            \\case $- in *f*) ;; *) printf 'bad-on:%s\n' "$-" ;; esac
            \\case $- in *C*) printf 'named-on\n' ;; *) printf 'bad-on:%s\n' "$-" ;; esac
            \\set +o nounset +o noglob +o noclobber
            \\case $- in *u*|*f*|*C*) printf 'bad-off:%s\n' "$-" ;; *) printf 'named-off\n' ;; esac
            ,
            .stdout =
            \\named-on
            \\named-off
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set accepts -o inside an option flag cluster",
            .script =
            \\set -euo pipefail
            \\case $- in *e*) printf 'errexit-on\n' ;; *) printf 'bad-e:%s\n' "$-" ;; esac
            \\case $- in *u*) printf 'nounset-on\n' ;; *) printf 'bad-u:%s\n' "$-" ;; esac
            \\set +e
            \\false | true
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\errexit-on
            \\nounset-on
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set accepts notify and hashall option flags",
            .script =
            \\set -bh
            \\case $- in *b*) printf 'notify-on\n' ;; *) printf 'bad-notify:%s\n' "$-" ;; esac
            \\case $- in *h*) printf 'hashall-on\n' ;; *) printf 'bad-hashall:%s\n' "$-" ;; esac
            \\set +bh
            \\case $- in *b*|*h*) printf 'bad-off:%s\n' "$-" ;; *) printf 'flags-off\n' ;; esac
            \\set -o hashall
            \\case $- in *h*) printf 'named-hashall-on\n' ;; *) printf 'bad-named:%s\n' "$-" ;; esac
            \\set +o hashall
            \\case $- in *h*) printf 'bad-named-off:%s\n' "$-" ;; *) printf 'named-hashall-off\n' ;; esac
            ,
            .stdout =
            \\notify-on
            \\hashall-on
            \\flags-off
            \\named-hashall-on
            \\named-hashall-off
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set -o lists option states",
            .script =
            \\set -o nounset
            \\set -o | grep '^nounset[[:space:]]*on' >/dev/null && printf 'nounset-on\n'
            \\set -o | grep '^noglob[[:space:]]*off' >/dev/null && printf 'noglob-off\n'
            \\set +o | grep '^set -o nounset$'
            ,
            .stdout =
            \\nounset-on
            \\noglob-off
            \\set -o nounset
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set without operands lists shell variables",
            .script =
            \\zeta=last
            \\alpha=first
            \\set | sed -n '/^alpha=/p;/^zeta=/p' >vars
            \\( unset alpha zeta; . ./vars; printf '<%s:%s>\n' "$alpha" "$zeta" )
            ,
            .stdout =
            \\<first:last>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set -a exports subsequent assignments",
            .script =
            \\set -fCu +ax
            \\case $- in *a*|*x*) printf 'bad-flags:%s\n' "$-" ;; *)
            \\    case $- in *C*) : ;; *) printf 'bad-flags:%s\n' "$-" ;; esac
            \\    case $- in *f*) : ;; *) printf 'bad-flags:%s\n' "$-" ;; esac
            \\    case $- in *u*) : ;; *) printf 'bad-flags:%s\n' "$-" ;; esac
            \\    printf 'flags-ok\n'
            \\esac
            \\set -a
            \\X=ok
            \\sh -c 'printf "<%s>\n" "$X"'
            \\set +a
            \\Y=no
            \\sh -c 'printf "<%s>\n" "${Y-unset}"'
            ,
            .stdout =
            \\flags-ok
            \\<ok>
            \\<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "set non-option operands replace positional parameters",
            .script =
            \\set 'a b' c
            \\printf '<%s:%s:%s>\n' "$#" "$1" "$2"
            ,
            .stdout =
            \\<2:a b:c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "xtrace uses the default PS4 prefix before PS4 is unset",
            .script =
            \\set -x
            \\echo hi
            \\set +x
            ,
            .stdout =
            \\hi
            \\
            ,
            .stderr =
            \\+ echo hi
            \\+ set +x
            \\
            ,
            .status = 0,
        },
        .{
            .name = "xtrace invocation option traces the first command",
            .shell_args = .{"-x"},
            .script =
            \\echo hi
            ,
            .stdout =
            \\hi
            \\
            ,
            .stderr =
            \\+ echo hi
            \\
            ,
            .status = 0,
        },
        .{
            .name = "xtrace uses an empty prefix after PS4 is unset",
            .script =
            \\unset PS4
            \\set -x
            \\echo hi
            \\set +x
            ,
            .stdout =
            \\hi
            \\
            ,
            .stderr =
            \\echo hi
            \\set +x
            \\
            ,
            .status = 0,
        },
        .{
            .name = "xtrace expands command substitution in PS4 prefix",
            .script =
            \\PS4='[$(printf p)] '
            \\set -x
            \\echo hi
            \\set +x
            ,
            .stdout =
            \\hi
            \\
            ,
            .stderr =
            \\[p] echo hi
            \\[p] set +x
            \\
            ,
            .status = 0,
        },
        .{
            .name = "xtrace traces external pipeline component commands",
            .script =
            \\set -x
            \\/bin/echo hi | cat
            \\set +x
            ,
            .stdout =
            \\hi
            \\
            ,
            .stderr =
            \\+ /bin/echo hi
            \\+ cat
            \\+ set +x
            \\
            ,
            .status = 0,
        },
        .{
            .name = "xtrace traces mixed pipeline external component commands",
            .script =
            \\set -x
            \\echo hi | cat
            \\set +x
            ,
            .stdout =
            \\hi
            \\
            ,
            .stderr =
            \\+ echo hi
            \\+ cat
            \\+ set +x
            \\
            ,
            .status = 0,
        },
        .{
            .name = "xtrace traces commands inside command substitutions before the expanded command",
            .script =
            \\set -x
            \\x=$(echo sub)
            \\echo x:$x
            \\set +x
            ,
            .stdout =
            \\x:sub
            \\
            ,
            .stderr =
            \\+ echo sub
            \\+ x=sub
            \\+ echo x:sub
            \\+ set +x
            \\
            ,
            .status = 0,
        },
        .{
            .name = "xtrace traces nested command substitutions before the expanded command",
            .script =
            \\set -x
            \\x=$(echo $(echo inner))
            \\echo x:$x
            \\set +x
            ,
            .stdout =
            \\x:inner
            \\
            ,
            .stderr =
            \\+ echo inner
            \\+ echo inner
            \\+ x=inner
            \\+ echo x:inner
            \\+ set +x
            \\
            ,
            .status = 0,
        },
        .{
            .name = "shift without an operand shifts by one",
            .script =
            \\set -- a b
            \\shift
            \\printf '<%s>:<%s>\n' "$#" "$1"
            ,
            .stdout =
            \\<1>:<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "shift zero leaves positional parameters unchanged",
            .script =
            \\set -- a
            \\shift 0
            \\printf '<%s>:<%s>\n' "$#" "$1"
            ,
            .stdout =
            \\<1>:<a>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "times writes shell and child process time pairs",
            .script =
            \\times | {
            \\    read shell_user shell_system
            \\    read child_user child_system
            \\    case $shell_user:$shell_system:$child_user:$child_system in
            \\        *m*s:*m*s:*m*s:*m*s) printf 'times\n' ;;
            \\        *) printf 'bad\n' ;;
            \\    esac
            \\}
            ,
            .stdout =
            \\times
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "times reports write failure when pipeline reader exits first",
            .script =
            \\exec 3>&1
            \\(
            \\    trap '' PIPE
            \\    sleep 1
            \\    command times
            \\    case $? in
            \\        0) printf 'zero\n' >&3 ;;
            \\        *) printf 'nonzero\n' >&3 ;;
            \\    esac
            \\) | true
            ,
            .stdout =
            \\nonzero
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "trap invalid signal specifications return nonzero and continue",
            .script =
            \\trap '' NOTASIG >/dev/null 2>&1
            \\printf '<%s>\n' "$?"
            \\printf 'after\n'
            ,
            .stdout =
            \\<1>
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap -p lists selected trap actions",
            .script =
            \\trap 'printf term' TERM
            \\case $(trap -p TERM 2>/dev/null) in
            \\    *TERM*) printf '<0>\n' ;;
            \\    *) printf '<1>\n' ;;
            \\esac
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unset removes a shell variable",
            .script =
            \\x=set
            \\unset x
            \\printf '<%s>\n' "${x-unset}"
            ,
            .stdout =
            \\<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unset -v removes variables without removing functions",
            .script =
            \\x=1
            \\f() { :; }
            \\unset -v x
            \\printf '<%s>\n' "${x-unset}"
            \\f
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<unset>
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unset -f ignores function names that are not defined",
            .script =
            \\f() { printf 'f\n'; }
            \\unset -f ./x
            \\printf '<%s>\n' "$?"
            \\f
            ,
            .stdout =
            \\<0>
            \\f
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
