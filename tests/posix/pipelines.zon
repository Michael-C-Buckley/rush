.{
    .name = "2.9.2 Pipelines",
    .mode = .posix,
    .cases = .{
        .{
            .name = "pipe connects stdout to next command stdin",
            .script =
            \\printf '%s\n' hello | cat
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipeline in sequence keeps only final stage stdout in parent stream",
            .script =
            \\printf a; printf b | cat; printf c
            ,
            .stdout = "abc",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipeline in command substitution captures stdout away from host",
            .script =
            \\v=$(printf x | cat); printf '<%s>\n' "$v"
            ,
            .stdout =
            \\<x>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipeline connects multiple commands left to right",
            .script =
            \\printf '%s\n' one two | sed -n '2p' | cat
            ,
            .stdout =
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipeline supplies input to exec replacement command",
            .script =
            \\printf hi | exec sh -c 'cat; exit 6'
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\histatus:6
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipeline supplies input through command utility external dispatch",
            .script =
            \\printf hi | command cat
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\histatus:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipeline stage restores physical current directory used by later redirections",
            .script =
            \\pwd >before
            \\cd / | :
            \\pwd >after
            \\cmp -s before after && printf 'restored\n'
            ,
            .stdout =
            \\restored
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipeline connects stdout but leaves stderr independent",
            .script =
            \\{ printf 'out\n'; printf 'err\n' >&2; } | cat
            ,
            .stdout =
            \\out
            \\
            ,
            .stderr =
            \\err
            \\
            ,
            .status = 0,
        },
        .{
            .name = "left command redirection overrides pipeline stdout",
            .script =
            \\printf 'left\n' >left.out | cat
            \\printf 'file='
            \\cat left.out
            ,
            .stdout =
            \\file=left
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "right command redirection overrides pipeline stdout",
            .script =
            \\printf 'right\n' | cat >right.out
            \\printf 'file='
            \\cat right.out
            ,
            .stdout =
            \\file=right
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipeline status is status of rightmost command when rightmost succeeds",
            .script =
            \\false | true
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipeline status is status of rightmost command when rightmost fails",
            .script =
            \\true | false
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "pipeline status preserves non-one rightmost status",
            .script =
            \\true | sh -c 'exit 7'
            ,
            .stdout = "",
            .stderr = "",
            .status = 7,
        },
        .{
            .name = "pipeline status observes rightmost output failure on closed stdout",
            .script =
            \\exec 3>&1 1>&-
            \\printf hi | cat
            \\status=$?
            \\exec 1>&3 3>&-
            \\if [ "$status" -ne 0 ]; then printf '<nonzero>\n'; fi
            ,
            .stdout =
            \\<nonzero>
            \\
            ,
            .stderr = "",
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "bang negates successful pipeline status",
            .script =
            \\! true
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "bang negates failing pipeline status",
            .script =
            \\! false
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang negates successful subshell pipeline with required blank",
            .script =
            \\! ( true )
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "bang negates failing subshell pipeline with required blank",
            .script =
            \\! ( false )
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang negates rightmost command status in multi-command pipeline",
            .script =
            \\! true | false
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang negates the rightmost status even when an earlier command fails",
            .script =
            \\! false | true
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "pipefail status is zero when all pipeline commands succeed",
            .script =
            \\set -o pipefail
            \\true | true
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipefail status is the rightmost nonzero command status",
            .script =
            \\set -o pipefail
            \\sh -c 'exit 3' | sh -c 'exit 7' | true
            ,
            .stdout = "",
            .stderr = "",
            .status = 7,
        },
        .{
            .name = "pipefail status observes earlier failures when the rightmost command succeeds",
            .script =
            \\set -o pipefail
            \\false | true
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "bang with pipefail succeeds when any pipeline command fails",
            .script =
            \\set -o pipefail
            \\! false | true
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang with pipefail fails when all pipeline commands succeed",
            .script =
            \\set -o pipefail
            \\! true | true
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "pipeline status uses pipefail setting from pipeline start",
            .script =
            \\set +o pipefail
            \\false | set -o pipefail
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "disabling pipefail restores rightmost command status",
            .script =
            \\set -o pipefail
            \\set +o pipefail
            \\false | true
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang is ordinary data when not at the start of a pipeline",
            .script =
            \\printf '<%s>\n' !
            ,
            .stdout =
            \\<!>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang in a command path is not pipeline negation",
            .script =
            \\printf '%s\n' '#!/bin/sh' 'printf bangcmd\\n' >'!cmd'
            \\chmod +x '!cmd'
            \\./!cmd
            ,
            .stdout =
            \\bangcmd
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
