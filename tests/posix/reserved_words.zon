.{
    .name = "2.4 Reserved Words",
    .mode = .posix,
    .cases = .{
        .{
            .name = "reserved words can be used as assignment variable names",
            .script =
            \\if=ok
            \\then=word
            \\printf '<%s>\n' "$if" "$then"
            ,
            .stdout =
            \\<ok>
            \\<word>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "reserved words are ordinary words after leading redirections in simple commands",
            .script =
            \\>out if 2>/dev/null
            \\printf '<%s:' "$?"
            \\test -f out
            \\printf '%s>\n' "$?"
            ,
            .stdout =
            \\<127:0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted reserved words are not recognized as reserved words",
            .script =
            \\\'if\' true 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "reserved words are ordinary words after a command name",
            .script =
            \\printf '<%s>\n' ! '{' '}' in then else fi do done case esac while until for if
            ,
            .stdout =
            \\<!>
            \\<{>
            \\<}>
            \\<in>
            \\<then>
            \\<else>
            \\<fi>
            \\<do>
            \\<done>
            \\<case>
            \\<esac>
            \\<while>
            \\<until>
            \\<for>
            \\<if>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unquoted reserved words are recognized in grammar positions",
            .script =
            \\if true
            \\then
            \\    printf '%s\n' yes
            \\fi
            ,
            .stdout =
            \\yes
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang is recognized as a reserved word in command position",
            .script =
            \\! false
            \\printf '<%s>\n' "$?"
            \\! true
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "braces are recognized as reserved words in grouping positions",
            .script =
            \\{ printf '<brace>\n'; }
            ,
            .stdout =
            \\<brace>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case recognizes in as the third word and ordinary text in patterns",
            .script =
            \\case in in
            \\    in) printf '<in>\n' ;;
            \\esac
            ,
            .stdout =
            \\<in>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for recognizes in as the third word",
            .script =
            \\for x in a b; do printf '<%s>\n' "$x"; done
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for recognizes do as the third word when in is omitted",
            .script =
            \\set -- a b
            \\for x do printf '<%s>\n' "$x"; done
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "reserved words are recognized after other reserved words",
            .script =
            \\if false; then :; elif true; then while false; do :; done; else :; fi
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
