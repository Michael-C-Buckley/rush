.{
    .name = "2.3 Token Recognition",
    .mode = .posix,
    .cases = .{
        .{
            .name = "unquoted number sign begins a comment at the start of a word",
            .script =
            \\printf '%s\n' before
            \\# printf '%s\n' bad
            \\printf '%s\n' after # printf '%s\n' bad
            ,
            .stdout =
            \\before
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "number sign within a word is ordinary text",
            .script =
            \\printf '<%s>\n' a#b
            ,
            .stdout =
            \\<a#b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "semicolon operator separates commands without surrounding blanks",
            .script =
            \\printf '%s\n' one;printf '%s\n' two
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "and-or operators are recognized without surrounding blanks",
            .script =
            \\printf '%s\n' one&&printf '%s\n' two||printf '%s\n' bad
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipe operator is recognized without surrounding blanks",
            .script =
            \\printf '%s\n' one|cat
            ,
            .stdout =
            \\one
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "newline separates commands",
            .script =
            \\printf '%s\n' one
            \\printf '%s\n' two
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias substitution applies to later command-name tokens",
            .script =
            \\alias hi='printf "%s\n" alias'
            \\hi
            ,
            .stdout =
            \\alias
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias substitution applies while evaluating eval text",
            .script =
            \\alias hi='printf "%s\n" alias'
            \\eval 'hi'
            ,
            .stdout =
            \\alias
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias substitution does not apply to ordinary arguments",
            .script =
            \\alias hi='printf "%s\n" alias'
            \\printf '%s\n' hi
            ,
            .stdout =
            \\hi
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias substitution applies after assignment prefixes",
            .script =
            \\alias run='printf "%s\n" assignment'
            \\name=value run
            ,
            .stdout =
            \\assignment
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias substitution applies after leading redirections",
            .script =
            \\alias run='printf "%s\n" redirection'
            \\>out run
            \\cat out
            ,
            .stdout =
            \\redirection
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias values ending in blank continue alias substitution",
            .script =
            \\alias first='second '
            \\alias second='printf "%s\n" chained'
            \\first
            ,
            .stdout =
            \\chained
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias values can produce reserved words in grammar positions",
            .script =
            \\alias cond=if
            \\cond true; then printf '%s\n' alias; fi
            ,
            .stdout =
            \\alias
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "reserved words in grammar positions are not alias candidates",
            .script =
            \\alias if='printf "%s\n" alias'
            \\if true; then printf '%s\n' reserved; fi
            ,
            .stdout =
            \\reserved
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "active aliases are not recursively reexpanded",
            .script =
            \\alias self='self'
            \\self 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function bodies capture aliases at definition time",
            .script =
            \\alias hit='printf "%s\n" alias'
            \\f() { hit; }
            \\unalias hit
            \\f
            ,
            .stdout =
            \\alias
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "aliases defined inside a compound command do not affect its remaining body",
            .script =
            \\if true; then alias late='printf "%s\n" bad'; late 2>/dev/null; printf '<%s>\n' "$?"; fi
            \\printf 'done\n'
            ,
            .stdout =
            \\<127>
            \\done
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "digits separated from redirection operators remain command arguments",
            .script =
            \\printf '%s\n' 2 >out
            \\cat out
            ,
            .stdout =
            \\2
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
