.{
    .name = "2.9.3 Lists",
    .mode = .posix,
    .cases = .{
        .{
            .name = "AND list executes next command after zero status",
            .script =
            \\true && printf '%s\n' ok
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "AND list skips next command after nonzero status",
            .script =
            \\false && printf '%s\n' bad
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "AND list status is last executed command when final command fails",
            .script =
            \\true && false
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "AND list expands commands only when they are executed",
            .script =
            \\false && : >marker
            \\test ! -e marker && printf 'not-created\n'
            ,
            .stdout =
            \\not-created
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "OR list executes next command after nonzero status",
            .script =
            \\false || printf '%s\n' ok
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "AND-OR list updates status before evaluating next pipeline",
            .script =
            \\false || case $? in
            \\    1) printf 'saw-status\n' ;;
            \\    *) printf 'bad:%s\n' "$?" ;;
            \\esac
            ,
            .stdout =
            \\saw-status
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "OR list skips next command after zero status",
            .script =
            \\true || printf '%s\n' bad
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "OR list status is last executed command when final command fails",
            .script =
            \\false || false
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "OR list expands commands only when they are executed",
            .script =
            \\true || : >marker
            \\test ! -e marker && printf 'not-created\n'
            ,
            .stdout =
            \\not-created
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "AND-OR lists are left-associative with equal precedence after false",
            .script =
            \\false && printf '%s\n' foo || printf '%s\n' bar
            ,
            .stdout =
            \\bar
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "AND-OR lists are left-associative with equal precedence after true",
            .script =
            \\true || printf '%s\n' foo && printf '%s\n' bar
            ,
            .stdout =
            \\bar
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "equal precedence lets OR result feed following AND",
            .script =
            \\false || true && printf '%s\n' ok
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "equal precedence lets AND result feed following OR",
            .script =
            \\true && false || printf '%s\n' ok
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "errexit is ignored before AND-OR control operators",
            .script =
            \\set -e
            \\false || printf '<or>\n'
            \\( false; printf '<subshell>\n' ) || printf '<fallback>\n'
            \\printf '<after>\n'
            ,
            .stdout =
            \\<or>
            \\<subshell>
            \\<after>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "errexit ignored status from skipped AND branch does not exit",
            .script =
            \\set -e
            \\false && true
            \\printf '<after:%s>\n' "$?"
            ,
            .stdout =
            \\<after:1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "errexit applies to final failing AND branch",
            .script =
            \\set -e
            \\true && false
            \\printf bad
            ,
            .stdout = "",
            .stderr = "",
            .status_match = .nonzero,
        },
        .{
            .name = "sequential list status is last executed pipeline status when last succeeds",
            .script =
            \\false; true
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "sequential list status is last executed pipeline status when last fails",
            .script =
            \\true; false
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "semicolon separator executes AND-OR lists in order",
            .script =
            \\printf '%s\n' first; printf '%s\n' second
            ,
            .stdout =
            \\first
            \\second
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "newline separator executes AND-OR lists in order",
            .script =
            \\printf '%s\n' first
            \\printf '%s\n' second
            ,
            .stdout =
            \\first
            \\second
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "newline terminator preserves preceding list status",
            .script =
            \\false
            \\
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "asynchronous list has zero status without waiting for command result",
            .script =
            \\false & printf '%s\n' "$?"
            ,
            .stdout =
            \\0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "asynchronous list records process id for wait",
            .script =
            \\false & pid=$!
            \\wait "$pid"
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "wait without operands waits all known asynchronous lists and returns zero",
            .script =
            \\false & true & wait
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "wait with multiple operands returns status of last operand",
            .script =
            \\false & first=$!
            \\true & second=$!
            \\wait "$second" "$first"
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "wait supports job id operand for asynchronous list",
            .script =
            \\false & wait %1
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "wait treats unknown process id as status 127",
            .script =
            \\wait 999999
            ,
            .stdout = "",
            .stderr = "",
            .stderr_match = .any,
            .status = 127,
        },
        .{
            .name = "asynchronous list executes in a subshell environment",
            .script =
            \\value=parent
            \\value=child & wait "$!"
            \\printf '%s\n' "$value"
            ,
            .stdout =
            \\parent
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "asynchronous list explicit stdin redirection overrides initial null input",
            .script =
            \\printf 'data\n' >input
            \\read value <input & pid=$!
            \\wait "$pid"
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "asynchronous subshell opens fifo redirections after fork",
            .script =
            \\mkfifo pipe
            \\( printf 'hello\n' >&8 ) 8>pipe &
            \\command exec 8<pipe
            \\read -r line <&8
            \\printf '<%s>\n' "$line"
            ,
            .stdout =
            \\<hello>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang pipeline status participates in AND list",
            .script =
            \\! false && printf '%s\n' ok
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "bang pipeline status participates in OR list",
            .script =
            \\! true || printf '%s\n' ok
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
