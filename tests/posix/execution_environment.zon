.{
    .name = "2.13 Shell Execution Environment",
    .mode = .posix,
    .cases = .{
        .{
            .name = "brace group commands execute in the current shell environment",
            .script =
            \\x=outer
            \\{ x=inner; printf '<%s>\n' "$x"; }
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<inner>
            \\<inner>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell commands execute in a separate shell environment",
            .script =
            \\x=outer
            \\( x=inner; printf '<%s>\n' "$x" )
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<inner>
            \\<outer>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution executes in a subshell environment",
            .script =
            \\x=outer
            \\printf '<%s>\n' "$(x=inner; printf '%s' "$x")"
            \\printf '<%s>\n' "$x"
            ,
            .stdout =
            \\<inner>
            \\<outer>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution inherits errexit in POSIX mode",
            .script =
            \\set -e
            \\printf '<%s>\n' "$(false; printf survived)"
            \\printf after
            ,
            .stdout =
            \\<>
            \\after
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution inherits aliases but isolates alias mutations",
            .script =
            \\alias parent_alias='printf alias-parent'
            \\printf '<%s>\n' "$(
            \\parent_alias
            \\unalias parent_alias
            \\)"
            \\parent_alias
            \\printf '\n'
            ,
            .stdout =
            \\<alias-parent>
            \\alias-parent
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution isolates function definitions",
            .script =
            \\printf '<%s>\n' "$(fn_inside() { printf function-inside; }; fn_inside)"
            \\fn_inside >/dev/null 2>&1 && printf 'bad\n' || printf 'missing\n'
            ,
            .stdout =
            \\<function-inside>
            \\missing
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution isolates current working directory changes",
            .script =
            \\mkdir subdir
            \\here=$(pwd)
            \\inside=$(cd subdir; pwd)
            \\after=$(pwd)
            \\case $inside in "$here/subdir") printf 'inside\n';; *) printf 'bad-inside\n';; esac
            \\case $after in "$here") printf 'outside\n';; *) printf 'bad-outside\n';; esac
            ,
            .stdout =
            \\inside
            \\outside
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution applies redirections within the substitution",
            .script =
            \\printf '<%s>\n' "$(printf hidden >cmdsub.out; printf visible)"
            \\cat cmdsub.out
            \\printf '\n'
            ,
            .stdout =
            \\<visible>
            \\hidden
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution keeps prior captured output after later redirection failure",
            .script =
            \\x=$(printf out; : 1>&- 2>&1; printf bad)
            \\status=$?
            \\case $status in 0) label=zero;; *) label=nonzero;; esac
            \\printf '<%s:%s>\n' "$label" "$x"
            ,
            .stdout =
            \\<nonzero:out>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution propagates expansion diagnostics to stderr",
            .script =
            \\set -u
            \\printf 'before\n'
            \\x=$(printf ok; echo "$unset_var"; printf after)
            \\printf 'x=<%s> s=<%s>\n' "$x" "$?"
            \\printf end
            ,
            .stdout =
            \\before
            \\x=<ok> s=<1>
            \\end
            ,
            .stderr =
            \\trap TERM: expansion error: parameter: parameter not set
            \\
            ,
            .status = 0,
        },
        .{
            .name = "exec redirections persist only within the command substitution environment",
            .script =
            \\x=$(exec 2>&-; : >&2; printf bad)
            \\status=$?
            \\case $status in 0) label=zero;; *) label=nonzero;; esac
            \\printf '<%s:%s>\n' "$label" "$x"
            \\printf err >&2
            ,
            .stdout =
            \\<nonzero:>
            \\
            ,
            .stderr = "err",
            .status = 0,
        },
        .{
            .name = "nested command substitutions isolate inner mutations from outer substitutions",
            .script =
            \\printf '<%s>\n' "$(x=outer-sub; printf '%s' "$(x=inner-sub; printf '%s' "$x")"; printf ':%s' "$x")"
            \\printf '<%s>\n' "${x-unset}"
            ,
            .stdout =
            \\<inner-sub:outer-sub>
            \\<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution isolates assignments while exporting marked variables to utilities",
            .script =
            \\unset TEMP_ONLY EXPORTED_ONLY
            \\printf '<%s>\n' "$(TEMP_ONLY=inner; export EXPORTED_ONLY=exported; sh -c 'printf "%s:%s" "$TEMP_ONLY" "$EXPORTED_ONLY"')"
            \\printf '<%s>:<%s>\n' "${TEMP_ONLY-unset}" "${EXPORTED_ONLY-unset}"
            ,
            .stdout =
            \\<:exported>
            \\<unset>:<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution runs EXIT traps in the substitution environment",
            .script =
            \\printf '<%s>\n' "$(trap 'printf "%s\n" child-exit' 0; printf body)"
            ,
            .stdout =
            \\<bodychild-exit>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution resets caught EXIT traps inherited from the parent",
            .script =
            \\trap 'printf "parent\n"' EXIT
            \\printf '<%s>\n' "$( : )"
            \\printf 'after\n'
            ,
            .stdout =
            \\<>
            \\after
            \\parent
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace group redirection does not isolate variable mutations",
            .script =
            \\x=outer
            \\{ x=inner; printf 'group\n'; } >out
            \\printf '<%s>\n' "$x"
            \\cat out
            ,
            .stdout =
            \\<inner>
            \\group
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command redirection does not isolate condition or body mutations",
            .script =
            \\condition=outer
            \\body=outer
            \\if condition=inner
            \\then
            \\    body=inner
            \\    printf 'if-body\n'
            \\fi >out
            \\printf '<%s>:<%s>\n' "$condition" "$body"
            \\cat out
            ,
            .stdout =
            \\<inner>:<inner>
            \\if-body
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command redirection does not isolate matched clause mutations",
            .script =
            \\x=outer
            \\case a in
            \\    a) x=inner; printf 'case-body\n' ;;
            \\esac >out
            \\printf '<%s>\n' "$x"
            \\cat out
            ,
            .stdout =
            \\<inner>
            \\case-body
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "loop redirection does not isolate condition or body mutations",
            .script =
            \\i=0
            \\x=outer
            \\while i=$((i + 1)); test "$i" -le 1
            \\do
            \\    x=inner
            \\    printf 'loop-body\n'
            \\done >out
            \\printf '<%s>:<%s>\n' "$i" "$x"
            \\cat out
            ,
            .stdout =
            \\<2>:<inner>
            \\loop-body
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function invocation redirection does not isolate body mutations",
            .script =
            \\x=outer
            \\fn() { x=inner; printf 'function-body\n'; }
            \\fn >out
            \\printf '<%s>\n' "$x"
            \\cat out
            ,
            .stdout =
            \\<inner>
            \\function-body
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell grouping with redirection still isolates mutations",
            .script =
            \\x=outer
            \\( x=inner; printf 'subshell-body\n' ) >out
            \\printf '<%s>\n' "$x"
            \\cat out
            ,
            .stdout =
            \\<outer>
            \\subshell-body
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "asynchronous brace group executes in a subshell environment",
            .script =
            \\x=outer
            \\{ x=inner; printf 'async-body\n' >out; } & wait "$!"
            \\printf '<%s>\n' "$x"
            \\cat out
            ,
            .stdout =
            \\<outer>
            \\async-body
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
