            .script =
            \\i=0
            \\while test "$i" -lt 2
            \\do
            \\    i=$((i + 1))
            \\    printf 'loop:%s\n' "$i"
            \\done >out
            \\cat out
            ,
            .stdout =
            \\loop:1
            \\loop:2
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command break exits the loop",
            .script =
            \\while true
            \\do
            \\    printf 'before\n'
            \\    break
            \\    printf 'bad\n'
            \\done
            \\printf 'after\n'
            ,
            .stdout =
            \\before
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command continue re-enters the condition compound-list",
            .script =
            \\i=0
            \\while test "$i" -lt 3
            \\do
            \\    i=$((i + 1))
            \\    test "$i" -eq 2 && continue
            \\    printf 'body:%s\n' "$i"
            \\done
            ,
            .stdout =
            \\body:1
            \\body:3
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command condition uses pipeline status",
            .script =
            \\i=0
            \\while test "$i" -lt 1 | true
            \\do
            \\    i=$((i + 1))
            \\    printf 'pipeline:%s\n' "$i"
            \\    break
            \\done
            ,
            .stdout =
            \\pipeline:1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command condition uses AND-OR list status",
            .script =
            \\i=0
            \\while false && printf 'bad\n' || test "$i" -lt 1
            \\do
            \\    i=1
            \\    printf 'and-or\n'
            \\done
            ,
            .stdout =
            \\and-or
            \\
            ,
            .stderr = "",
            .status = 0,
        },
