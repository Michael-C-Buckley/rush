.{
    .name = "2.9.4 Compound Commands",
    .mode = .posix,
    .cases = .{
        .{
            .name = "subshell exit status is compound-list status and assignments do not persist",
            .script =
            \\x=outer
            \\( x=inner; false )
            \\status=$?
            \\printf '%s:%s\n' "$x" "$status"
            ,
            .stdout =
            \\outer:1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell preserves current directory changes outside the group",
            .script =
            \\mkdir child
            \\before=$(pwd)
            \\( cd child; printf 'inner\n' )
            \\after=$(pwd)
            \\test "$before" = "$after" && printf 'outer-unchanged\n'
            ,
            .stdout =
            \\inner
            \\outer-unchanged
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell redirection applies to the grouped compound-list",
            .script =
            \\( printf 'one\n'; printf 'two\n' ) >out
            \\cat out
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell redirection does not affect following commands",
            .script =
            \\( printf 'group\n' ) >out
            \\printf 'after\n'
            \\cat out
            ,
            .stdout =
            \\after
            \\group
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell grouping participates in AND-OR lists by its exit status",
            .script =
            \\( false; true ) && printf 'ok\n'
            \\( true; false ) || printf 'fallback\n'
            ,
            .stdout =
            \\ok
            \\fallback
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell grouping can be a pipeline component",
            .script =
            \\( printf 'ok\n' ) | cat
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace group exit status is compound-list status and assignments persist",
            .script =
            \\x=outer
            \\{ x=inner; false; }
            \\status=$?
            \\printf '%s:%s\n' "$x" "$status"
            ,
            .stdout =
            \\inner:1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace group preserves current-shell directory changes",
            .script =
            \\mkdir child
            \\{ cd child; }
            \\test -d ../child && printf 'child\n'
            ,
            .stdout =
            \\child
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace group redirection applies to the grouped compound-list",
            .script =
            \\{ printf 'one\n'; printf 'two\n'; } >out
            \\cat out
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace group redirection does not affect following commands",
            .script =
            \\{ printf 'group\n'; } >out
            \\printf 'after\n'
            \\cat out
            ,
            .stdout =
            \\after
            \\group
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace group accepts newline separator before closing brace",
            .script =
            \\{
            \\printf 'ok\n'
            \\}
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace group accepts semicolon separator before closing brace",
            .script =
            \\{ printf 'ok\n'; }
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace group requires separator before closing brace",
            .script =
            \\{ printf 'bad\n' }
            ,
            .stdout = "",
            .stderr = "",
            .stderr_match = .nonempty,
            .status = 0,
            .status_match = .nonzero,
        },
        .{
            .name = "brace group participates in AND-OR lists by its exit status",
            .script =
            \\{ false; true; } && printf 'ok\n'
            \\{ true; false; } || printf 'fallback\n'
            ,
            .stdout =
            \\ok
            \\fallback
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace group can be a pipeline component",
            .script =
            \\{ printf 'ok\n'; } | cat
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command status is last body status when items are present",
            .script =
            \\for x in a b
            \\do
            \\    printf '%s\n' "$x"
            \\    false
            \\done
            ,
            .stdout =
            \\a
            \\b
            \\
            ,
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "for command iterates explicit in list in order",
            .script =
            \\for x in first second third
            \\do
            \\    printf '<%s>\n' "$x"
            \\done
            ,
            .stdout =
            \\<first>
            \\<second>
            \\<third>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command without in list iterates positional parameters as quoted fields",
            .script =
            \\set -- 'a b' '' c
            \\for x
            \\do
            \\    printf '<%s>\n' "$x"
            \\done
            ,
            .stdout =
            \\<a b>
            \\<>
            \\<c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command without in list runs zero times when there are no positional parameters",
            .script =
            \\set --
            \\for x
            \\do
            \\    printf 'bad\n'
            \\done
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command status is zero when there are no items",
            .script =
            \\for x in
            \\do
            \\    false
            \\done
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command empty in list does not change variable",
            .script =
            \\x=old
            \\for x in
            \\do
            \\    x=bad
            \\done
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\old
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command leaves variable set to last iterated item",
            .script =
            \\for x in a b
            \\do
            \\    :
            \\done
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\b
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command expands list before executing loop body",
            .script =
            \\value=before
            \\for x in "$value" "$value"
            \\do
            \\    printf '%s\n' "$x"
            \\    value=after
            \\done
            ,
            .stdout =
            \\before
            \\before
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command accepts semicolon separator before do",
            .script =
            \\for x in ok; do
            \\    printf '%s\n' "$x"
            \\done
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command accepts newline separator before do",
            .script =
            \\for x in ok
            \\do
            \\    printf '%s\n' "$x"
            \\done
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command break exits the loop",
            .script =
            \\for x in a b c
            \\do
            \\    test "$x" = b && break
            \\    printf '%s\n' "$x"
            \\done
            ,
            .stdout =
            \\a
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command continue proceeds to the next item",
            .script =
            \\for x in a b c
            \\do
            \\    test "$x" = b && continue
            \\    printf '%s\n' "$x"
            \\done
            ,
            .stdout =
            \\a
            \\c
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command break exits the requested enclosing loop depth",
            .script =
            \\for outer in one two
            \\do
            \\    for inner in a b
            \\    do
            \\        printf '%s:%s\n' "$outer" "$inner"
            \\        break 2
            \\    done
            \\done
            ,
            .stdout =
            \\one:a
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command break greater than enclosing depth exits outermost loop",
            .script =
            \\for x in a b
            \\do
            \\    printf '%s\n' "$x"
            \\    break 2
            \\done
            \\printf 'after\n'
            ,
            .stdout =
            \\a
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command continue proceeds at the requested enclosing loop depth",
            .script =
            \\for outer in one two
            \\do
            \\    for inner in a b
            \\    do
            \\        printf '%s:%s\n' "$outer" "$inner"
            \\        continue 2
            \\    done
            \\done
            ,
            .stdout =
            \\one:a
            \\two:a
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for command continue greater than enclosing depth continues outermost loop",
            .script =
            \\for x in a b
            \\do
            \\    printf '%s\n' "$x"
            \\    continue 2
            \\    printf 'bad\n'
            \\done
            \\printf 'after\n'
            ,
            .stdout =
            \\a
            \\b
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command status is matched clause status",
            .script =
            \\case b in
            \\    a) printf '%s\n' bad ;;
            \\    b) printf '%s\n' ok; false ;;
            \\esac
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "case command status is zero when no pattern matches",
            .script =
            \\case z in
            \\    a) false ;;
            \\esac
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command expands word before matching patterns",
            .script =
            \\x=b
            \\case $x in
            \\    a) printf 'bad\n' ;;
            \\    b) printf 'ok\n' ;;
            \\esac
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command uses the first matching clause",
            .script =
            \\case abc in
            \\    a*) printf 'first\n' ;;
            \\    ab*) printf 'second\n' ;;
            \\esac
            ,
            .stdout =
            \\first
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command does not expand patterns after the first match",
            .script =
            \\case a in
            \\    a) printf 'ok\n' ;;
            \\    ${MISSING:?bad}) printf 'bad\n' ;;
            \\esac
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command matches alternate patterns in a clause",
            .script =
            \\case c in
            \\    a|b|c) printf 'ok\n' ;;
            \\    *) printf 'bad\n' ;;
            \\esac
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command permits an empty matched clause",
            .script =
            \\case a in
            \\    a) ;;
            \\    *) false ;;
            \\esac
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command permits the last clause terminator to be omitted",
            .script =
            \\case a in
            \\    a) printf 'ok\n'
            \\esac
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command ;& continues with the next compound-list",
            .script =
            \\case a in
            \\    a) printf 'one\n' ;&
            \\    b) printf 'two\n' ;;
            \\    *) printf 'bad\n' ;;
            \\esac
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command ;& status is the final continued compound-list status",
            .script =
            \\case a in
            \\    a) true ;&
            \\    b) false ;;
            \\esac
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "case command quoted pattern characters match literally",
            .script =
            \\case x in
            \\    "*") printf 'bad\n' ;;
            \\    *) printf 'ok\n' ;;
            \\esac
            \\
            \\case '*' in
            \\    "*") printf 'literal\n' ;;
            \\    *) printf 'bad\n' ;;
            \\esac
            ,
            .stdout =
            \\ok
            \\literal
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command expands unquoted pattern variables as patterns",
            .script =
            \\pat='*'
            \\case x in
            \\    $pat) printf 'match\n' ;;
            \\    *) printf 'bad\n' ;;
            \\esac
            ,
            .stdout =
            \\match
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case command preserves quotes around expanded pattern variables",
            .script =
            \\pat='*'
            \\case x in
            \\    "$pat") printf 'bad\n' ;;
            \\    *) printf 'ok\n' ;;
            \\esac
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command status is selected then body status",
            .script =
            \\if true
            \\then
            \\    false
            \\else
            \\    true
            \\fi
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "if command status is selected else body status",
            .script =
            \\if false
            \\then
            \\    true
            \\else
            \\    false
            \\fi
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "if command status is zero when no body is selected",
            .script =
            \\if false
            \\then
            \\    false
            \\fi
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command executes the condition compound-list in the current shell",
            .script =
            \\x=before
            \\if x=condition
            \\then
            \\    printf '%s\n' "$x"
            \\fi
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\condition
            \\condition
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command uses the selected elif body status",
            .script =
            \\if false
            \\then
            \\    true
            \\elif true
            \\then
            \\    false
            \\else
            \\    true
            \\fi
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "if command tests elif clauses in order and stops after the first true condition",
            .script =
            \\if false
            \\then
            \\    printf 'bad-then\n'
            \\elif printf 'first-condition\n'; true
            \\then
            \\    printf 'first-body\n'
            \\elif printf 'bad-second-condition\n'; true
            \\then
            \\    printf 'bad-second-body\n'
            \\fi
            ,
            .stdout =
            \\first-condition
            \\first-body
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command accepts semicolon separators around reserved words",
            .script =
            \\if false; then printf 'bad\n'; elif true; then printf 'ok\n'; else printf 'bad\n'; fi
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command accepts newline separators around reserved words",
            .script =
            \\if
            \\true
            \\then
            \\printf 'then\n'
            \\else
            \\printf 'bad\n'
            \\fi
            ,
            .stdout =
            \\then
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command redirection applies to the selected body",
            .script =
            \\if true
            \\then
            \\    printf 'redirected\n'
            \\fi >out
            \\cat out
            ,
            .stdout =
            \\redirected
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command condition uses pipeline status",
            .script =
            \\if false | true
            \\then
            \\    printf 'pipeline-true\n'
            \\else
            \\    printf 'bad\n'
            \\fi
            ,
            .stdout =
            \\pipeline-true
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command condition uses pipeline negation status",
            .script =
            \\if ! true
            \\then
            \\    printf 'bad\n'
            \\else
            \\    printf 'negated-false\n'
            \\fi
            ,
            .stdout =
            \\negated-false
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command condition uses AND-OR list status",
            .script =
            \\if false && printf 'bad\n' || true
            \\then
            \\    printf 'and-or-true\n'
            \\else
            \\    printf 'bad\n'
            \\fi
            ,
            .stdout =
            \\and-or-true
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command status is zero when the body never runs",
            .script =
            \\while false
            \\do
            \\    false
            \\done
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "until command status is zero when the body never runs",
            .script =
            \\until true
            \\do
            \\    false
            \\done
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
    },
}
