            \\do
            \\    i=$((i + 1))
            \\    printf 'loop:%s\n' "$i"
            \\done >out
            \\cat out
            ,
            .stdout =
            \\loop:1
            \\loop:2
            \\
            ,
            .stderr = "",
            .status = 0,
