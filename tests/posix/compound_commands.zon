            \\do
            \\    i=1
            \\    false
            \\done
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "until command body effects persist in the current shell",
            .script =
            \\x=before
            \\until test "$x" = after
            \\do
            \\    x=after
            \\done
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "until command accepts semicolon separators around do and done",
            .script =
            \\i=0; until test "$i" -ge 1; do i=1; printf 'ok\n'; done
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "until command accepts newline separators around do and done",
