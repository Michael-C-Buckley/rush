        .{
            .name = "until command break exits the loop",
            .script =
            \\until false
            \\do
            \\    printf 'before\n'
            \\    break
            \\    printf 'bad\n'
            \\done
            \\printf 'after\n'
            ,
            .stdout =
            \\before
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "until command continue re-enters the condition compound-list",
            .script =
            \\i=0
            \\until test "$i" -ge 3
            \\do
            \\    i=$((i + 1))
            \\    test "$i" -eq 2 && continue
            \\    printf 'body:%s\n' "$i"
            \\done
            ,
            .stdout =
            \\body:1
            \\body:3
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "until command condition uses pipeline status",
            .script =
            \\i=0
            \\until true | false
            \\do
            \\    i=$((i + 1))
            \\    printf 'pipeline:%s\n' "$i"
            \\    break
            \\done
            ,
            .stdout =
            \\pipeline:1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "until command condition uses AND-OR list status",
            .script =
            \\i=0
            \\until false && printf 'bad\n' || test "$i" -ge 1
            \\do
            \\    i=1
            \\    printf 'and-or\n'
            \\done
            ,
            .stdout =
            \\and-or
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "readonly for loop variable is a shell error",
            .script =
            \\readonly i
            \\for i in a b; do printf bad; done
            \\printf bad
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
    },
