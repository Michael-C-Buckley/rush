        .{
            .name = "subshell grouping accepts deeply nested compound bodies",
            .script =
            \\s='printf "ok\n"'
            \\i=0
            \\while [ "$i" -lt 200 ]; do
            \\    s='( '"$s"' )'
            \\    i=$((i + 1))
            \\done
            \\eval "$s"
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command redirection applies to the selected body",
            .script =
            \\if true
            \\then
            \\    printf 'redirected\n'
            \\fi >out
            \\cat out
            ,
            .stdout =
            \\redirected
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command condition uses pipeline status",
            .script =
            \\if false | true
            \\then
            \\    printf 'pipeline-true\n'
            \\else
            \\    printf 'bad\n'
            \\fi
            ,
            .stdout =
            \\pipeline-true
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command output flows through a pipeline",
            .script =
            \\if printf 'a'
            \\then
            \\    printf 'b'
            \\fi | sed 's/a/X/'
            ,
            .stdout = "Xb",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command condition uses pipeline negation status",
            .script =
            \\if ! true
            \\then
            \\    printf 'bad\n'
            \\else
            \\    printf 'negated-false\n'
            \\fi
            ,
            .stdout =
            \\negated-false
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "if command condition uses AND-OR list status",
            .script =
            \\if false && printf 'bad\n' || true
            \\then
            \\    printf 'and-or-true\n'
            \\else
            \\    printf 'bad\n'
            \\fi
            ,
            .stdout =
            \\and-or-true
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command status is zero when the body never runs",
            .script =
            \\while false
            \\do
            \\    false
            \\done
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command re-evaluates the condition compound-list before each iteration",
            .script =
            \\i=0
            \\while i=$((i + 1)); test "$i" -le 3
            \\do
            \\    printf 'body:%s\n' "$i"
            \\done
            \\printf 'after:%s\n' "$i"
            ,
            .stdout =
            \\body:1
            \\body:2
            \\body:3
            \\after:4
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command preserves body output before next condition output",
            .script =
            \\exec 2>&1
            \\n=0
            \\while case y in "$(printf 'condition\n' >&2; printf y)") test "$n" -lt 1 ;; esac
            \\do
            \\    n=1
            \\    printf 'body\n'
            \\done
            ,
            .stdout =
            \\condition
            \\body
            \\condition
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command status is the last completed body status",
            .script =
            \\i=0
            \\while test "$i" -lt 1
            \\do
            \\    i=1
            \\    false
            \\done
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "while command body effects persist in the current shell",
            .script =
            \\x=before
            \\while test "$x" = before
            \\do
            \\    x=after
            \\done
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command accepts semicolon separators around do and done",
            .script =
            \\i=0; while test "$i" -lt 1; do i=1; printf 'ok\n'; done
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "while command accepts newline separators around do and done",
            .script =
            \\i=0
            \\while
            \\test "$i" -lt 1
            \\do
            \\i=1
            \\printf 'ok\n'
            \\done
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
