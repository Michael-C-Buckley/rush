.{
    .name = "2.9.5 Function Definition Command",
    .mode = .posix,
    .cases = .{
        .{
            .name = "function definition status is zero when declared successfully",
            .script =
            \\foo() { false; }
            \\printf '%s\n' "$?"
            ,
            .stdout =
            \\0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition accepts portable NAME tokens",
            .script =
            \\foo_bar_1() { printf 'portable\n'; }
            \\foo_bar_1
            ,
            .stdout =
            \\portable
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition header removes backslash-newline before parsing",
            .script =
            \\f\
            \\(){ printf 'name\n'; }
            \\f
            \\g()\
            \\{ printf 'body\n'; }
            \\g
            ,
            .stdout =
            \\name
            \\body
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition rejects special built-in names",
            .script =
            \\export() { printf 'bad\n'; }
            \\printf 'after\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 2,
        },
        .{
            .name = "function definition rejects reserved word names",
            .script =
            \\if() { printf 'bad\n'; }
            \\printf 'after\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 0,
            .status_match = .nonzero,
        },
        .{
            .name = "function invocation status is last command status",
            .script =
            \\foo() { true; false; }
            \\foo
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "deep tail-recursive function call chain exceeds one thousand calls",
            .script =
            \\f() { if [ "$1" -eq 0 ]; then printf 'ok\n'; else next=$(( $1 - 1 )); f "$next"; fi; }
            \\f 1200
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "deep non-tail-recursive function call chain masks child failure below native stack limit",
            .script =
            \\f() { if [ "$1" -eq 0 ]; then false; else next=$(( $1 - 1 )); f "$next"; :; fi; }
            \\f 600
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "deep non-tail-recursive function call chain exceeds one thousand calls",
            .script =
            \\f() { if [ "$1" -eq 0 ]; then printf 'ok\n'; else next=$(( $1 - 1 )); f "$next"; :; fi; }
            \\f 1200
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "deep mutual non-tail-recursive function call chain exceeds one thousand calls",
            .script =
            \\f() { if [ "$1" -eq 0 ]; then printf 'ok\n'; else next=$(( $1 - 1 )); g "$next"; :; fi; }
            \\g() { if [ "$1" -eq 0 ]; then printf 'ok\n'; else next=$(( $1 - 1 )); f "$next"; :; fi; }
            \\f 1200
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "non-tail recursive bare return preserves child status",
            .script =
            \\f() { if [ "$1" -eq 0 ]; then return 7; else next=$(( $1 - 1 )); f "$next"; return; fi; }
            \\f 64
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<7>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "non-tail recursive function calls restore positional parameters while unwinding",
            .script =
            \\set -- outer1 outer2
            \\f() {
            \\    if [ "$1" -eq 0 ]; then printf 'leaf:%s:%s:%s\n' "$1" "$2" "$#"; return; fi
            \\    next=$(( $1 - 1 ))
            \\    f "$next" "child-$1"
            \\    if [ "$1" -eq 3 ]; then printf 'unwind:%s:%s:%s\n' "$1" "$2" "$#"; fi
            \\    :
            \\}
            \\f 3 root
            \\printf 'outer:%s:%s:%s\n' "$1" "$2" "$#"
            ,
            .stdout =
            \\leaf:0:child-1:2
            \\unwind:3:root:2
            \\outer:outer1:outer2:2
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "non-tail recursive assignment prefixes are scoped to each function call",
            .script =
            \\v=outer
            \\f() {
            \\    if [ "$1" -eq 0 ]; then printf 'leaf:%s\n' "$v"; return; fi
            \\    next=$(( $1 - 1 ))
            \\    v="body-$1" f "$next"
            \\    printf 'unwind:%s:%s\n' "$1" "$v"
            \\    :
            \\}
            \\v=call f 2
            \\printf 'after:%s\n' "$v"
            ,
            .stdout =
            \\leaf:body-1
            \\unwind:1:body-2
            \\unwind:2:call
            \\after:outer
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "non-tail recursive call and definition redirections restore in LIFO order",
            .script =
            \\rm -f def outercall call-1 call-2
            \\f() {
            \\    if [ "$1" -eq 0 ]; then printf 'leaf\n'; return; fi
            \\    next=$(( $1 - 1 ))
            \\    f "$next" >>"call-$1"
            \\    printf 'after-%s\n' "$1"
            \\} >>def
            \\printf 'before\n'
            \\f 2 >>outercall
            \\printf 'after-stdout\n'
            \\for file in def outercall call-2 call-1; do
            \\    printf '[%s]\n' "$file"
            \\    if [ -f "$file" ]; then cat "$file"; else printf 'missing\n'; fi
            \\done
            ,
            .stdout =
            \\before
            \\after-stdout
            \\[def]
            \\leaf
            \\after-1
            \\after-2
            \\[outercall]
            \\[call-2]
            \\[call-1]
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "non-tail recursive trap checkpoints run before the next function command",
            .script =
            \\trap 'printf "trap:%s\n" "$1"' USR1
            \\f() {
            \\    if [ "$1" -eq 0 ]; then kill -s USR1 $$; printf 'leaf:%s\n' "$1"; return; fi
            \\    next=$(( $1 - 1 ))
            \\    f "$next"
            \\    printf 'after:%s\n' "$1"
            \\}
            \\f 2
            ,
            .stdout =
            \\trap:0
            \\leaf:0
            \\after:1
            \\after:2
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "non-tail recursive function child failure triggers set -e before following command",
            .script =
            \\set -e
            \\f() { if [ "$1" -eq 0 ]; then false; else next=$(( $1 - 1 )); f "$next"; :; fi; }
            \\f 3
            \\printf 'bad\n'
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "cached function compound body expands parameters when called",
            .script =
            \\f() { if true; then printf '<%s:%s>\n' "$1" "$#"; fi; }
            \\f inner extra
            ,
            .stdout =
            \\<inner:2>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function for words expand when called",
            .script =
            \\set -- definition
            \\f() { for x in "$@"; do printf '<%s>\n' "$x"; done; }
            \\f call1 call2
            ,
            .stdout =
            \\<call1>
            \\<call2>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function compound redirections expand when called",
            .script =
            \\target=definition
            \\f() { { printf 'ok\n'; } >"$target"; }
            \\target=invocation
            \\f
            \\cat invocation
            \\test ! -e definition
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function operands temporarily replace positional parameters",
            .script =
            \\set -- outer
            \\foo() { printf '%s:%s\n' "$1" "$#"; }
            \\foo inner extra
            \\printf '%s:%s\n' "$1" "$#"
            ,
            .stdout =
            \\inner:2
            \\outer:1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition redirections are applied when the function is invoked",
            .script =
            \\foo() { printf '%s\n' call; } >out
            \\printf '%s\n' before
            \\foo
            \\printf '%s\n' after
            \\cat out
            ,
            .stdout =
            \\before
            \\after
            \\call
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return completes the current function with the requested status",
            .script =
            \\foo() { return 7; printf '%s\n' bad; }
            \\foo
            ,
            .stdout = "",
            .stderr = "",
            .status = 7,
        },
        .{
            .name = "return accepts numeric arguments above 255",
            .script =
            \\foo() { return 256; printf '%s\n' bad; }
            \\foo
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return in a dot script called by a function returns from the dot script only",
            .script =
            \\printf 'return 7\nprintf bad\n' >f
            \\foo() { . ./f; printf after-source; }
            \\foo
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\after-source<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return in a function called by a dot script does not return from the dot script",
            .script =
            \\printf 'foo() { return 7; printf bad; }\nfoo\nprintf after-function\n' >f
            \\. ./f
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\after-function<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function body variable assignments affect the current shell",
            .script =
            \\x=before
            \\foo() { x=after; }
            \\foo
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function operands restore all outer positional parameters",
            .script =
            \\set -- outer1 outer2
            \\foo() { shift; printf 'inner:%s:%s\n' "$1" "$#"; }
            \\foo inner1 inner2 inner3
            \\printf 'outer:%s:%s:%s\n' "$1" "$2" "$#"
            ,
            .stdout =
            \\inner:inner2:2
            \\outer:outer1:outer2:2
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function redefinition replaces the previous body",
            .script =
            \\foo() { printf 'old\n'; }
            \\foo() { printf 'new\n'; }
            \\foo
            ,
            .stdout =
            \\new
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function body expansions occur when the function is invoked",
            .script =
            \\x=definition
            \\foo() { printf '%s\n' "$x"; }
            \\x=invocation
            \\foo
            ,
            .stdout =
            \\invocation
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function invocation redirection applies only to that invocation",
            .script =
            \\foo() { printf 'inside\n'; }
            \\foo >out
            \\printf 'outside\n'
            \\cat out
            ,
            .stdout =
            \\outside
            \\inside
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition accepts a subshell compound-command body",
            .script =
            \\x=outer
            \\foo() ( x=inner; printf 'body:%s\n' "$x" )
            \\foo
            \\printf 'after:%s\n' "$x"
            ,
            .stdout =
            \\body:inner
            \\after:outer
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return without an operand uses the previous command status",
            .script =
            \\foo() { false; return; }
            \\foo
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "guarded function definition in unselected case arm is not evaluated",
            .script =
            \\case x in
            \\    x) printf 'selected\n' ;;
            \\    *) false || foo() { printf 'unselected\n'; }; foo ;;
            \\esac
            ,
            .stdout =
            \\selected
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition in unselected if body is not defined",
            .script =
            \\if false
            \\then
            \\    foo() { printf 'bad\n'; }
            \\fi
            \\foo 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "and-if guarded function definition is not defined when skipped",
            .script =
            \\false && foo() { printf 'bad\n'; }
            \\foo 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
