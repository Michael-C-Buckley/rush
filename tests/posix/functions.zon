.{
    .name = "2.9.5 Function Definition Command",
    .mode = .posix,
    .cases = .{
        .{
            .name = "function definition status is zero when declared successfully",
            .script =
            \\foo() { false; }
            \\printf '%s\n' "$?"
            ,
            .stdout =
            \\0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition accepts portable NAME tokens",
            .script =
            \\foo_bar_1() { printf 'portable\n'; }
            \\foo_bar_1
            ,
            .stdout =
            \\portable
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition rejects special built-in names",
            .script =
            \\export() { printf 'bad\n'; }
            \\printf 'after\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 2,
        },
        .{
            .name = "function definition rejects reserved word names",
            .script =
            \\if() { printf 'bad\n'; }
            \\printf 'after\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 0,
            .status_match = .nonzero,
        },
        .{
            .name = "function invocation status is last command status",
            .script =
            \\foo() { true; false; }
            \\foo
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "function operands temporarily replace positional parameters",
            .script =
            \\set -- outer
            \\foo() { printf '%s:%s\n' "$1" "$#"; }
            \\foo inner extra
            \\printf '%s:%s\n' "$1" "$#"
            ,
            .stdout =
            \\inner:2
            \\outer:1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition redirections are applied when the function is invoked",
            .script =
            \\foo() { printf '%s\n' call; } >out
            \\printf '%s\n' before
            \\foo
            \\printf '%s\n' after
            \\cat out
            ,
            .stdout =
            \\before
            \\after
            \\call
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return completes the current function with the requested status",
            .script =
            \\foo() { return 7; printf '%s\n' bad; }
            \\foo
            ,
            .stdout = "",
            .stderr = "",
            .status = 7,
        },
        .{
            .name = "return accepts numeric arguments above 255",
            .script =
            \\foo() { return 256; printf '%s\n' bad; }
            \\foo
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return in a dot script called by a function returns from the dot script only",
            .script =
            \\printf 'return 7\nprintf bad\n' >f
            \\foo() { . ./f; printf after-source; }
            \\foo
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\after-source<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return in a function called by a dot script does not return from the dot script",
            .script =
            \\printf 'foo() { return 7; printf bad; }\nfoo\nprintf after-function\n' >f
            \\. ./f
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\after-function<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function body variable assignments affect the current shell",
            .script =
            \\x=before
            \\foo() { x=after; }
            \\foo
            \\printf '%s\n' "$x"
            ,
            .stdout =
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function operands restore all outer positional parameters",
            .script =
            \\set -- outer1 outer2
            \\foo() { shift; printf 'inner:%s:%s\n' "$1" "$#"; }
            \\foo inner1 inner2 inner3
            \\printf 'outer:%s:%s:%s\n' "$1" "$2" "$#"
            ,
            .stdout =
            \\inner:inner2:2
            \\outer:outer1:outer2:2
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function redefinition replaces the previous body",
            .script =
            \\foo() { printf 'old\n'; }
            \\foo() { printf 'new\n'; }
            \\foo
            ,
            .stdout =
            \\new
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function body expansions occur when the function is invoked",
            .script =
            \\x=definition
            \\foo() { printf '%s\n' "$x"; }
            \\x=invocation
            \\foo
            ,
            .stdout =
            \\invocation
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function invocation redirection applies only to that invocation",
            .script =
            \\foo() { printf 'inside\n'; }
            \\foo >out
            \\printf 'outside\n'
            \\cat out
            ,
            .stdout =
            \\outside
            \\inside
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition accepts a subshell compound-command body",
            .script =
            \\x=outer
            \\foo() ( x=inner; printf 'body:%s\n' "$x" )
            \\foo
            \\printf 'after:%s\n' "$x"
            ,
            .stdout =
            \\body:inner
            \\after:outer
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "return without an operand uses the previous command status",
            .script =
            \\foo() { false; return; }
            \\foo
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "guarded function definition in unselected case arm is not evaluated",
            .script =
            \\case x in
            \\    x) printf 'selected\n' ;;
            \\    *) false || foo() { printf 'unselected\n'; }; foo ;;
            \\esac
            ,
            .stdout =
            \\selected
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition in unselected if body is not defined",
            .script =
            \\if false
            \\then
            \\    foo() { printf 'bad\n'; }
            \\fi
            \\foo 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "and-if guarded function definition is not defined when skipped",
            .script =
            \\false && foo() { printf 'bad\n'; }
            \\foo 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
