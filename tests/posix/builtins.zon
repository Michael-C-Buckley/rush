.{
    .name = "Shell Built-In Utilities",
    .mode = .posix,
    .cases = .{
        .{
            .name = "cd changes the current working directory",
            .script =
            \\mkdir dir
            \\cd dir
            \\: >../marker
            \\cd ..
            \\if [ -f marker ]
            \\then
            \\    printf '%s\n' cd-ok
            \\else
            \\    printf '%s\n' bad
            \\fi
            ,
            .stdout =
            \\cd-ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "cd without operands uses HOME",
            .script =
            \\mkdir home
            \\HOME=$PWD/home
            \\cd
            \\test "$PWD" = "$HOME"
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "cd accepts physical and end-of-options operands",
            .script =
            \\mkdir dir
            \\cd -P -- dir
            \\printf '<%s>\n' "${PWD##*/}"
            ,
            .stdout =
            \\<dir>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "test evaluates POSIX string integer and file primaries",
            .script =
            \\test; printf 'empty:%s\n' "$?"
            \\test value; printf 'string:%s\n' "$?"
            \\test ""; printf 'null:%s\n' "$?"
            \\test ! ""; printf 'not-null:%s\n' "$?"
            \\test -n value; printf 'n:%s\n' "$?"
            \\test -z ""; printf 'z:%s\n' "$?"
            \\test x != y; printf 'neq:%s\n' "$?"
            \\[ 2 -gt 1 ]; printf 'gt:%s\n' "$?"
            \\[ 1 -le 1 ]; printf 'le:%s\n' "$?"
            \\: >empty
            \\printf x >nonempty
            \\mkdir dir
            \\ln -s nonempty link
            \\mkfifo pipe
            \\chmod +x nonempty
            \\test -e empty; printf 'e:%s\n' "$?"
            \\test -f empty; printf 'f:%s\n' "$?"
            \\test -d dir; printf 'd:%s\n' "$?"
            \\test -s nonempty; printf 's:%s\n' "$?"
            \\test ! -s empty; printf 'not-s:%s\n' "$?"
            \\test -h link; printf 'h:%s\n' "$?"
            \\test -L link; printf 'L:%s\n' "$?"
            \\test -p pipe; printf 'p:%s\n' "$?"
            \\test -r nonempty; printf 'r:%s\n' "$?"
            \\test -w nonempty; printf 'w:%s\n' "$?"
            \\test -x nonempty; printf 'x:%s\n' "$?"
            \\test nonempty -ef link; printf 'ef:%s\n' "$?"
            \\: >old
            \\sleep 1
            \\: >new
            \\test new -nt old; printf 'nt:%s\n' "$?"
            \\test old -ot new; printf 'ot:%s\n' "$?"
            ,
            .stdout =
            \\empty:1
            \\string:0
            \\null:1
            \\not-null:0
            \\n:0
            \\z:0
            \\neq:0
            \\gt:0
            \\le:0
            \\e:0
            \\f:0
            \\d:0
            \\s:0
            \\not-s:0
            \\h:0
            \\L:0
            \\p:0
            \\r:0
            \\w:0
            \\x:0
            \\ef:0
            \\nt:0
            \\ot:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "cd dash changes to OLDPWD and writes the new directory",
            .script =
            \\out=$PWD/cd.out
            \\mkdir a b
            \\cd a
            \\cd ../b
            \\cd - >"$out"
            \\case $(cat "$out") in */a) printed=ok ;; *) printed=bad ;; esac
            \\printf '<%s>:<%s>:<%s>\n' "$printed" "${PWD##*/}" "${OLDPWD##*/}"
            ,
            .stdout =
            \\<ok>:<a>:<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "cd uses CDPATH and writes the selected directory",
            .script =
            \\out=$PWD/cd.out
            \\mkdir -p parent/child
            \\CDPATH=parent
            \\cd child >"$out"
            \\case $(cat "$out") in */parent/child) printed=ok ;; *) printed=bad ;; esac
            \\printf '<%s>:<%s>\n' "$printed" "${PWD##*/}"
            ,
            .stdout =
            \\<ok>:<child>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "cd with readonly PWD does not abort the parent shell",
            .script =
            \\( readonly PWD; cd . 2>/dev/null )
            \\printf 'after\n'
            ,
            .stdout =
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pwd -L preserves logical paths and pwd -P resolves physical paths",
            .script =
            \\mkdir real
            \\ln -s real link 2>/dev/null || exit 0
            \\cd link
            \\logical=${PWD##*/}
            \\physical=$(pwd -P)
            \\printf '<%s>:<%s>\n' "$logical" "${physical##*/}"
            ,
            .stdout =
            \\<link>:<real>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read with -r preserves backslash characters",
            .script =
            \\printf 'a b\\c\n' | { read -r first rest; printf '<%s>:<%s>\n' "$first" "$rest"; }
            ,
            .stdout =
            \\<a>:<b\c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read without -r removes backslash escapes",
            .script =
            \\printf 'a b\\c\n' | { read first rest; printf '<%s>:<%s>\n' "$first" "$rest"; }
            ,
            .stdout =
            \\<a>:<bc>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read without -r keeps backslash-escaped separators in fields",
            .script =
            \\printf 'a\ b c\n' | { read first rest; printf '<%s>:<%s>\n' "$first" "$rest"; }
            ,
            .stdout =
            \\<a b>:<c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read without -r joins backslash-newline continuations",
            .script =
            \\read value <<EOF
            \\a\
            \\b
            \\EOF
            \\printf '<%s>\n' "$value"
            ,
            .stdout =
            \\<ab>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read assigns remaining fields to the last variable",
            .script =
            \\printf 'a b c\n' | { read first rest; printf '<%s>:<%s>\n' "$first" "$rest"; }
            ,
            .stdout =
            \\<a>:<b c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read with empty IFS assigns the whole line to the first variable",
            .script =
            \\IFS= read -r first rest <<EOF
            \\x y
            \\EOF
            \\printf '<%s>:<%s>\n' "$first" "$rest"
            ,
            .stdout =
            \\<x y>:<>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read trims trailing default separators from the last variable",
            .script =
            \\printf ' a  b   \n' | { read first rest; printf '<%s>:<%s>\n' "$first" "$rest"; }
            ,
            .stdout =
            \\<a>:<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read with one variable trims only IFS whitespace",
            .script =
            \\printf '  a b  \n' | { IFS=' ' read -r value; printf '<%s>\n' "$value"; }
            \\printf ':a:' | { IFS=: read -r value; printf '<%s>\n' "$value"; }
            ,
            .stdout =
            \\<a b>
            \\<:a:>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read preserves empty fields from non-whitespace IFS delimiters",
            .script =
            \\printf ':x::y:\n' | {
            \\    IFS=: read -r a b c d e
            \\    printf '<%s>|<%s>|<%s>|<%s>|<%s>\n' "$a" "$b" "$c" "$d" "$e"
            \\}
            ,
            .stdout =
            \\<>|<x>|<>|<y>|<>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read keeps non-whitespace IFS delimiters in the last variable remainder",
            .script =
            \\printf ':a::b:\n' | {
            \\    IFS=: read -r first second rest
            \\    printf '<%s>|<%s>|<%s>\n' "$first" "$second" "$rest"
            \\}
            ,
            .stdout =
            \\<>|<a>|<:b:>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read trims a single trailing non-whitespace IFS delimiter from the last variable",
            .script =
            \\printf 'a:b:\n' | {
            \\    IFS=: read -r first rest
            \\    printf '<%s>|<%s>\n' "$first" "$rest"
            \\}
            \\printf 'a::b:\n' | {
            \\    IFS=: read -r first second rest
            \\    printf '<%s>|<%s>|<%s>\n' "$first" "$second" "$rest"
            \\}
            \\printf 'a, b,\n' | {
            \\    IFS=", " read -r first rest
            \\    printf '<%s>|<%s>\n' "$first" "$rest"
            \\}
            ,
            .stdout =
            \\<a>|<b>
            \\<a>|<>|<b>
            \\<a>|<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read treats multibyte IFS delimiters as single characters",
            .script =
            \\printf 'aåbåc\n' | {
            \\    IFS=å read -r first second third
            \\    printf '<%s>|<%s>|<%s>\n' "$first" "$second" "$third"
            \\}
            ,
            .stdout =
            \\<a>|<b>|<c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read with mixed IFS preserves non-whitespace empty fields",
            .script =
            \\printf ' x:: y : z \n' | {
            \\    IFS=': ' read -r a b c d
            \\    printf '<%s>|<%s>|<%s>|<%s>\n' "$a" "$b" "$c" "$d"
            \\}
            ,
            .stdout =
            \\<x>|<>|<y>|<z>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read assigns a partial final line but returns nonzero",
            .script =
            \\printf abc | { read value; printf '<%s>:<%s>\n' "$?" "$value"; }
            ,
            .stdout =
            \\<1>:<abc>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read returns nonzero at end of file",
            .script =
            \\if read eof < /dev/null
            \\then
            \\    printf 'bad\n'
            \\else
            \\    printf 'eof\n'
            \\fi
            ,
            .stdout =
            \\eof
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read clears variables at end of file without bytes",
            .script =
            \\printf x >in
            \\while IFS= read -r line || [ -n "$line" ]
            \\do
            \\    printf '<%s>\n' "$line"
            \\done <in
            \\printf 'after=<%s>\n' "$line"
            ,
            .stdout =
            \\<x>
            \\after=<>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "read -d uses the first delimiter byte",
            .script =
            \\printf 'ab:cd' | { read -r -d : value; printf '<%s>:<%s>\n' "$value" "$?"; }
            ,
            .stdout =
            \\<ab>:<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pwd output can be redirected",
            .script =
            \\pwd >out
            \\test -s out
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "export marks a variable for child command environments",
            .script =
            \\export exported=value
            \\sh -c 'test "$exported" = value'
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "export assignment operands apply assignment tilde expansion",
            .script =
            \\HOME=/tmp
            \\export PATH=~:/bin
            \\printf '<%s>\n' "$PATH"
            ,
            .stdout =
            \\</tmp:/bin>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "readonly assignment operands apply assignment tilde expansion",
            .script =
            \\HOME=/tmp
            \\readonly locked=~:/bin
            \\printf '<%s>\n' "$locked"
            ,
            .stdout =
            \\</tmp:/bin>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "regular builtin assignment prefixes do not persist",
            .script =
            \\VALUE=before
            \\VALUE=after true
            \\printf '<%s>\n' "$VALUE"
            ,
            .stdout =
            \\<before>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -v writes a found utility name",
            .script =
            \\command -v cd
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\cd
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "echo and env resolve as regular builtins",
            .script =
            \\command -v echo
            \\command -v env
            ,
            .stdout =
            \\echo
            \\env
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "fc hash and ulimit are regular builtins",
            .script =
            \\command -v fc
            \\command -v hash
            \\command -v ulimit
            \\hash -r
            \\ulimit -t unlimited
            \\ulimit -c 0
            ,
            .stdout =
            \\fc
            \\hash
            \\ulimit
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "hash resolves utility operands",
            .script =
            \\hash -r
            \\hash ls
            \\hash | grep '/ls$' >/dev/null && printf 'hashed\n'
            \\hash missing-rush-command >/dev/null 2>&1
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\hashed
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "ulimit reports and updates soft file limit",
            .script =
            \\saved=$(ulimit -S -f)
            \\ulimit -S -f 0
            \\printf '<%s>\n' "$(ulimit -S -f)"
            \\ulimit -S -f "$saved"
            \\ulimit -a >/dev/null
            \\printf '<all:%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\<all:0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "getopts reports missing option arguments by mode",
            .script =
            \\set -- -xfoo -yz
            \\OPTIND=1 v=
            \\while getopts x:yz: opt 2>/dev/null; do
            \\    v="${v:+$v/}$opt,${OPTARG:-Empty}"
            \\done
            \\printf '<%s>\n' "$v"
            \\OPTIND=1 v=
            \\while getopts :x:yz: opt; do
            \\    v="${v:+$v/}$opt,${OPTARG:-Empty}"
            \\done
            \\printf '<%s>\n' "$v"
            ,
            .stdout =
            \\<x,foo/y,Empty/?,Empty>
            \\<x,foo/y,Empty/:,z>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command suppresses fatal errors from declaration builtins",
            .script =
            \\readonly v=foo
            \\if command export v=baz 2>/dev/null; then printf '<bad-export-status>\n'; fi
            \\case $v in foo) : ;; *) printf '<bad-export:%s>\n' "$v" ;; esac
            \\if command readonly v=bar 2>/dev/null; then printf '<bad-readonly-status>\n'; fi
            \\case $v in foo) : ;; *) printf '<bad-readonly:%s>\n' "$v" ;; esac
            \\printf '<after>\n'
            ,
            .stdout =
            \\<after>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command break and continue outside loops do not abort",
            .script =
            \\command break
            \\printf '<break:%s>\n' "$?"
            \\command continue
            \\printf '<continue:%s>\n' "$?"
            ,
            .stdout =
            \\<break:0>
            \\<continue:0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec exports preceding assignment variables",
            .script =
            \\case $(unset v; v=foo PATH=/bin exec sh -c 'printf "%s" "${v-U}"') in
            \\    foo) printf '<ok>\n' ;;
            \\    *) printf '<bad>\n' ;;
            \\esac
            ,
            .stdout =
            \\<ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command -p uses a default utility path",
            .script =
            \\PATH=/no/such command -p sh -c 'printf p'
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\p<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command bypasses shell functions during command search",
            .script =
            \\printf() { echo function; }
            \\printf ignored
            \\command printf 'builtin\n'
            \\command printf '<%s>\n' "$?"
            ,
            .stdout =
            \\function
            \\builtin
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "getopts reads option arguments",
            .script =
            \\set -- -b value
            \\getopts ab: opt
            \\printf '<%s>:<%s>:<%s>\n' "$opt" "$OPTARG" "$?"
            ,
            .stdout =
            \\<b>:<value>:<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "kill -s 0 probes the current shell process",
            .script =
            \\kill -s 0 $$
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "kill -l reports signal names for numbers and statuses",
            .script =
            \\kill -l 1
            \\kill -l 129
            ,
            .stdout =
            \\HUP
            \\HUP
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "jobs lists asynchronous commands",
            .script =
            \\sleep 2 &
            \\pid=$!
            \\jobs >jobs.out
            \\grep '\[1\]' jobs.out >/dev/null && grep 'sleep 2' jobs.out >/dev/null
            \\printf 'jobs:<%s>\n' "$?"
            \\kill "$pid" 2>/dev/null
            \\wait "$pid" 2>/dev/null || :
            ,
            .stdout =
            \\jobs:<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "kill accepts job operands for background jobs",
            .script =
            \\sleep 2 &
            \\pid=$!
            \\kill %1 2>/dev/null
            \\printf 'no-monitor-job:<%s>\n' "$?"
            \\wait "$pid" 2>/dev/null || :
            \\set -m
            \\sleep 2 &
            \\pid=$!
            \\jobs -l >jobs.out
            \\grep "$pid" jobs.out >/dev/null && grep 'sleep 2' jobs.out >/dev/null
            \\printf 'jobs-l:<%s>\n' "$?"
            \\kill %1
            \\printf 'kill-job:<%s>\n' "$?"
            \\wait 2>/dev/null || :
            ,
            .stdout =
            \\no-monitor-job:<0>
            \\jobs-l:<0>
            \\kill-job:<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "umask -S writes symbolic permissions",
            .script =
            \\umask 022
            \\umask -S
            ,
            .stdout =
            \\u=rwx,g=rx,o=rx
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "umask accepts symbolic permission operands",
            .script =
            \\umask 022
            \\umask u=rwx,g=,o=
            \\umask
            \\umask 022
            \\umask g+w
            \\umask
            ,
            .stdout =
            \\0077
            \\0002
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "wait with no operands succeeds when known child statuses are consumed",
            .script =
            \\wait
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "wait for an unknown process id returns 127",
            .script =
            \\wait 999999
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<127>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "wait rejects operands that are not process ids or job specs",
            .script =
            \\wait notapid
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "dot executes a file in the current environment",
            .script =
            \\printf '%s\n' 'sourced=value' >file.sh
            \\. ./file.sh
            \\printf '<%s>\n' "$sourced"
            ,
            .stdout =
            \\<value>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dot accepts extra operands and preserves caller positional parameters",
            .script =
            \\cat >file.sh <<'EOF'
            \\printf 'sourced\n'
            \\EOF
            \\set -- outer
            \\. ./file.sh inner more
            \\printf '<%s>:<%s>\n' "${1-unset}" "${2-unset}"
            ,
            .stdout =
            \\sourced
            \\<outer>:<unset>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dot searches PATH for operands without slash",
            .script =
            \\mkdir scripts
            \\printf '%s\n' 'sourced=path' >scripts/file.sh
            \\PATH=scripts
            \\. file.sh
            \\printf '<%s>:<%s>\n' "$sourced" "$?"
            ,
            .stdout =
            \\<path>:<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "dot PATH search observes assignment prefixes",
            .script =
            \\mkdir scripts
            \\printf '%s\n' 'sourced=assignment' >scripts/file.sh
            \\PATH=missing
            \\PATH=scripts . file.sh
            \\printf '<%s>:<%s>\n' "$sourced" "$PATH"
            ,
            .stdout =
            \\<assignment>:<scripts>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "true and false return their specified statuses",
            .script =
            \\true
            \\printf '<%s>\n' "$?"
            \\false
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "printf reports failure when stdout is closed",
            .script =
            \\exec 9>&1
            \\exec 1>&-
            \\printf hidden
            \\printf 'visible=<%s>\n' "$?" >&9
            ,
            .stdout =
            \\visible=<1>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "env executes utility operands with pipeline input",
            .script =
            \\printf hi | env cat
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\histatus:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "env applies assignment operands to utility environment",
            .script =
            \\FOO=outer
            \\env FOO=inner printenv FOO
            \\printf 'after:%s status:%s\n' "$FOO" "$?"
            ,
            .stdout =
            \\inner
            \\after:outer status:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "env prints assignment operands without changing shell variables",
            .script =
            \\FOO=outer
            \\env FOO=inner | grep '^FOO='
            \\printf 'after:%s status:%s\n' "$FOO" "$?"
            ,
            .stdout =
            \\FOO=inner
            \\after:outer status:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment before env is exported only to env environment",
            .script =
            \\unset FOO
            \\FOO=prefix env | grep '^FOO='
            \\printf 'after:%s status:%s\n' "${FOO-unset}" "$?"
            ,
            .stdout =
            \\FOO=prefix
            \\after:unset status:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "env assignment operands are process environment entries",
            .script =
            \\env 1BAD=x printenv 1BAD
            \\env 1BAD=x | grep '^1BAD='
            \\FOO=outer
            \\readonly FOO
            \\env FOO=inner printenv FOO
            \\printf 'after:%s\n' "$FOO"
            \\if ( export 1BAD=x ) 2>/dev/null
            \\then
            \\    printf 'export-bad\n'
            \\else
            \\    printf 'export-invalid\n'
            \\fi
            ,
            .stdout =
            \\x
            \\1BAD=x
            \\inner
            \\after:outer
            \\export-invalid
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "eval command-not-found status is not a fatal special builtin error",
            .script =
            \\PATH=/dev/null
            \\if ! eval -- ':' 2>/dev/null
            \\then
            \\    printf 'returned\n'
            \\else
            \\    printf 'parsed\n'
            \\fi
            \\printf 'after\n'
            ,
            .stdout =
            \\returned
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec redirection without command persists inside command substitution stdin",
            .script =
            \\printf x >in
            \\out=$(exec <in; cat)
            \\printf '<%s>\n' "$out"
            ,
            .stdout =
            \\<x>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec redirection without command persists inside command substitution stdout",
            .script =
            \\out=$(exec >file; printf hidden; printf visible >&2)
            \\printf 'out=<%s>\n' "$out"
            \\cat file
            ,
            .stdout =
            \\out=<>
            \\hidden
            ,
            .stderr = "visible",
            .status = 0,
        },
        .{
            .name = "exec redirection without command persists inside command substitution stderr",
            .script =
            \\out=$(exec 2>&1; printf err >&2)
            \\printf '<%s>\n' "$out"
            ,
            .stdout =
            \\<err>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec replacement keeps pipeline stage redirections",
            .script =
            \\printf data >in
            \\out=$(exec cat <in | wc -c)
            \\set -- $out
            \\printf '<%s>\n' "$1"
            ,
            .stdout =
            \\<4>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec command exits with the replacement utility status",
            .script =
            \\( exec sh -c 'exit 7'; printf 'bad\n' )
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\status:7
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "exec command replacement does not run the shell EXIT trap",
            .script =
            \\( trap 'printf trap\\n' EXIT; exec sh -c 'exit 7'; printf 'bad\n' )
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\status:7
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unalias -a removes all alias definitions",
            .script =
            \\alias a='printf a' b='printf b'
            \\alias a b
            \\unalias -a
            \\alias a >/dev/null 2>&1
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\a='printf a'
            \\b='printf b'
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias query writes the alias and unalias removes it",
            .script =
            \\alias ll='printf hi'
            \\alias ll
            \\unalias ll
            \\alias ll >/dev/null 2>&1
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\ll='printf hi'
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias query failure hints assignment syntax",
            .script =
            \\alias foo git
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 1,
        },
        .{
            .name = "alias with trailing blank expands command after negation in if condition",
            .script =
            \\alias not='! '
            \\if not { false; }; then
            \\    printf 'yes\n'
            \\fi
            ,
            .stdout =
            \\yes
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias expands first command in case item body",
            .script =
            \\alias not='! '
            \\is_false() { return 1; }
            \\case word in
            \\( word ) not is_false && printf 'yes\n' ;;
            \\esac
            ,
            .stdout =
            \\yes
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias expansion preserves here-document source positions",
            .script =
            \\alias exit=:
            \\if false; then
            \\    exit
            \\else
            \\    cat <<EOF
            \\ok
            \\EOF
            \\fi
            ,
            .stdout =
            \\ok
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "alias-aware parsing waits for complete here-document bodies",
            .script =
            \\cat > a <<EOF
            \\file
            \\EOF
            \\cat < a
            \\alias a='printf "%s\n" alive'
            \\a
            ,
            .stdout =
            \\file
            \\alive
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "echo honors bash-compatible options in POSIX mode",
            .script =
            \\echo -n no-newline
            \\printf '<after>\n'
            \\echo -e 'line\ntab\tend'
            \\echo -E 'line\ntab\tend'
            \\echo -x literal
            ,
            .stdout = "no-newline<after>\nline\ntab\tend\nline\\ntab\\tend\n-x literal\n",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "echo reports failure when stdout is closed",
            .script =
            \\echo hidden >&-
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "echo reports failure when stdout write fails",
            .script =
            \\if [ -e /dev/full ]
            \\then
            \\    echo hidden >/dev/full || printf 'write-failed\n'
            \\else
            \\    printf 'write-failed\n'
            \\fi
            ,
            .stdout =
            \\write-failed
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "buffered regular builtin reports failure when stdout is closed",
            .script =
            \\pwd >&-
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "buffered special builtin reports failure when stdout is closed",
            .script =
            \\export X=1
            \\export >&-
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "duplicated output survives later source descriptor close",
            .script =
            \\echo visible >&2 2>&-
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "visible\n",
            .status = 0,
        },
        .{
            .name = "brace group builtin duplicated output survives later source descriptor close",
            .script =
            \\{ echo visible >&2 2>&-; }
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "visible\n",
            .status = 0,
        },
        .{
            .name = "subshell builtin duplicated output survives later source descriptor close",
            .script =
            \\( echo visible >&2 2>&- )
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "visible\n",
            .status = 0,
        },
        .{
            .name = "printf duplicated output survives later source descriptor close",
            .script =
            \\{ printf visible >&2 2>&-; }
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "visible",
            .status = 0,
        },
        .{
            .name = "function builtin duplicated output survives later source descriptor close",
            .script =
            \\f() { echo visible >&2 2>&-; }
            \\f
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "visible\n",
            .status = 0,
        },
        .{
            .name = "command substitution builtin duplicated output survives later source descriptor close",
            .script =
            \\x=$(echo visible >&2 2>&-)
            \\printf 'x=<%s> status=<%s>\n' "$x" "$?"
            ,
            .stdout =
            \\x=<> status=<0>
            \\
            ,
            .stderr = "visible\n",
            .status = 0,
        },
    },
}
