.{
    .name = "2.10 Shell Grammar",
    .mode = .posix,
    .cases = .{
        .{
            .name = "newlines separate complete commands",
            .script =
            \\
            \\printf 'one\n'
            \\
            \\printf 'two\n'
            \\
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "reserved words accept linebreaks in compound commands",
            .script =
            \\if
            \\    true
            \\then
            \\    printf 'if\n'
            \\else
            \\    printf 'else\n'
            \\fi
            \\while
            \\    false
            \\do
            \\    printf 'loop\n'
            \\done
            ,
            .stdout =
            \\if
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "elif clauses select the first successful branch",
            .script =
            \\if false; then
            \\    printf 'bad\n'
            \\elif true; then
            \\    printf 'elif\n'
            \\else
            \\    printf 'else\n'
            \\fi
            ,
            .stdout =
            \\elif
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function definition permits linebreak before body",
            .script =
            \\f()
            \\{
            \\    printf 'function\n'
            \\}
            \\f
            ,
            .stdout =
            \\function
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "brace characters are ordinary within words",
            .script =
            \\printf '<%s>\n' {} x{} {}x a{b}
            ,
            .stdout =
            \\<{}>
            \\<x{}>
            \\<{}x>
            \\<a{b}>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for clause with in iterates listed words",
            .script =
            \\for name in a 'b c'
            \\do
            \\    printf '<%s>\n' "$name"
            \\done
            ,
            .stdout =
            \\<a>
            \\<b c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for clause without in iterates positional parameters",
            .script =
            \\set -- a 'b c'
            \\for name
            \\do
            \\    printf '<%s>\n' "$name"
            \\done
            ,
            .stdout =
            \\<a>
            \\<b c>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for clause rejects a non-name loop variable",
            .script =
            \\name=
            \\for $name in a; do printf bad; done
            \\printf bad
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 2,
        },
        .{
            .name = "case patterns can be separated by vertical bars",
            .script =
            \\case b in
            \\    a|b) printf 'match\n' ;;
            \\    *) printf 'bad\n' ;;
            \\esac
            ,
            .stdout =
            \\match
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case list permits final item without terminator",
            .script =
            \\case x in
            \\    y) printf 'bad\n' ;;
            \\    x) printf 'match\n'
            \\esac
            ,
            .stdout =
            \\match
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case pattern alternatives must not be empty in POSIX mode",
            .script =
            \\case x in
            \\    x|) printf 'bad\n' ;;
            \\esac
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 2,
        },
        .{
            .name = "case item cannot start with unquoted esac reserved word",
            .script =
            \\case x in esac) printf 'bad\n' ;; x) printf 'bad\n' ;; esac
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 2,
        },
        .{
            .name = "case pattern list rejects newline before closing parenthesis",
            .script =
            \\case x in x
            \\) printf 'bad\n' ;; esac
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 2,
        },
        .{
            .name = "case pattern list rejects newline after pattern separator",
            .script =
            \\case x in x|
            \\y) printf 'bad\n' ;; esac
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 2,
        },
        .{
            .name = "complete commands may end with semicolon terminators",
            .script =
            \\printf '<one>\n';
            \\printf '<two>\n';
            ,
            .stdout =
            \\<one>
            \\<two>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "asynchronous list terminator starts a waitable command",
            .script =
            \\printf '%s\n' two >out &
            \\wait
            \\printf '<%s>:<%s>\n' "$(cat out)" "$?"
            ,
            .stdout =
            \\<two>:<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "AND-OR lists accept linebreaks after control operators",
            .script =
            \\true &&
            \\printf '<and>\n'
            \\false ||
            \\printf '<or>\n'
            ,
            .stdout =
            \\<and>
            \\<or>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pipelines accept linebreaks after pipe operators",
            .script =
            \\printf 'pipe\n' |
            \\cat
            ,
            .stdout =
            \\pipe
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "AND-OR list rejects missing command before control operator",
            .script =
            \\&& printf 'bad\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "AND-OR list rejects missing command between control operators",
            .script =
            \\printf 'bad\n' && && printf 'nope\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "pipeline rejects missing command before pipe operator",
            .script =
            \\| cat
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "list rejects missing separator before subshell",
            .script =
            \\printf 'bad\n' (printf 'also-bad\n')
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "sequential list rejects missing command after separator",
            .script =
            \\printf 'bad\n' ; && printf 'nope\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "asynchronous list rejects missing command after separator",
            .script =
            \\printf 'bad\n' & & printf 'nope\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "case item terminator is rejected outside case command",
            .script =
            \\printf 'bad\n';; printf 'nope\n'
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "for clause with empty in list executes zero iterations",
            .script =
            \\var=old
            \\for var in; do printf '<bad>\n'; done
            \\printf '<%s>:<%s>\n' "$var" "$?"
            ,
            .stdout =
            \\<old>:<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for clause without in accepts semicolon before do group",
            .script =
            \\set -- a b
            \\for x; do printf '<%s>\n' "$x"; done
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for clause accepts linebreak before in and do",
            .script =
            \\for x
            \\in a b
            \\do printf '<%s>\n' "$x"; done
            ,
            .stdout =
            \\<a>
            \\<b>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "for clause rejects word list words after newline following in",
            .script =
            \\for x in
            \\a b
            \\do printf '<%s>\n' "$x"; done
            \\printf bad
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "case clause may have no case items",
            .script =
            \\case x in
            \\esac
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "case pattern list may start with a left parenthesis",
            .script =
            \\case x in
            \\    (x) printf '<match>\n' ;;
            \\esac
            ,
            .stdout =
            \\<match>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function body redirections are attached to the function definition",
            .script =
            \\f() { printf 'body\n'; } >out
            \\f
            \\printf '<%s>:<%s>\n' "$(cat out)" "$?"
            ,
            .stdout =
            \\<body>:<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "function bodies expand words when invoked rather than when parsed",
            .script =
            \\f() { printf '<%s>\n' "$later"; }
            \\later=ok
            \\f
            ,
            .stdout =
            \\<ok>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "compound commands accept trailing redirect lists",
            .script =
            \\{ printf 'brace\n'; } >brace.out
            \\( printf 'sub\n' ) >sub.out
            \\if true; then printf 'if\n'; fi >if.out
            \\while false; do :; done >while.out
            \\test -s while.out; empty=$?
            \\printf '<%s>:<%s>:<%s>:<%s>\n' "$(cat brace.out)" "$(cat sub.out)" "$(cat if.out)" "$empty"
            ,
            .stdout =
            \\<brace>:<sub>:<if>:<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "IO numbers can redirect compound command descriptors",
            .script =
            \\{ printf 'err\n' >&2; } 2>err.out
            \\printf '<%s>\n' "$(cat err.out)"
            ,
            .stdout =
            \\<err>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "reserved words are recognized after AND-OR operators",
            .script =
            \\false || if true; then printf '<if>\n'; fi
            \\true && while false; do :; done
            \\printf '<done>\n'
            ,
            .stdout =
            \\<if>
            \\<done>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "complete commands run before a later syntax error",
            .script =
            \\printf 'ran\n'
            \\)
            \\printf 'unreachable\n'
            ,
            .stdout =
            \\ran
            \\
            ,
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "syntax errors report the line and offending token",
            .script =
            \\printf 'ran\n'
            \\printf 'ok\n'
            \\)
            ,
            .stdout =
            \\ran
            \\ok
            \\
            ,
            .stderr =
            \\3: syntax error: unexpected ')'
            \\
            ,
            .status = 2,
        },
        .{
            .name = "unterminated quotes report a syntax diagnostic",
            .script = "printf 'ok\\n'\necho \"abc",
            .stdout =
            \\ok
            \\
            ,
            .stderr =
            \\2: syntax error: unterminated quoted string
            \\
            ,
            .status = 2,
        },
        .{
            .name = "unexpected end of input reports a syntax diagnostic",
            .script =
            \\if true
            \\then printf 'x\n'
            ,
            .stdout = "",
            .stderr =
            \\2: syntax error: unexpected end of input
            \\
            ,
            .status = 2,
        },
        .{
            .name = "trailing blank lines preserve the last command status",
            .script =
            \\false
            \\
            \\
            ,
            .stdout = "",
            .stderr = "",
            .status = 1,
        },
        .{
            .name = "here-document delimited by end of input has an empty body",
            .script = "cat <<EOF",
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "unalias takes effect for later complete commands",
            .script =
            \\alias greet='printf aliased\n'
            \\unalias greet
            \\greet
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status = 127,
        },
        .{
            .name = "alias value opening a compound command spans following lines",
            .script =
            \\alias begin='if true'
            \\begin
            \\then printf 'inside\n'
            \\fi
            \\printf 'after\n'
            ,
            .stdout =
            \\inside
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
