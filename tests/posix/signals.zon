.{
    .name = "2.12 Signals and Error Handling",
    .mode = .posix,
    .cases = .{
        .{
            .name = "EXIT trap runs after the script body completes",
            .script =
            \\trap 'printf "%s\n" exit-trap' 0
            \\printf '%s\n' body
            ,
            .stdout =
            \\body
            \\exit-trap
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "EXIT trap preserves semantic output around inherited external output",
            .script =
            \\trap 'printf "trap-before\n"; cat <<EOF
            \\trap-external
            \\EOF
            \\printf "trap-after\n"' 0
            \\printf 'body\n'
            ,
            .stdout =
            \\body
            \\trap-before
            \\trap-external
            \\trap-after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "EXIT trap sees the status that exits the shell",
            .script =
            \\trap 'printf "<%s>\n" "$?"' 0
            \\exit 7
            ,
            .stdout =
            \\<7>
            \\
            ,
            .stderr = "",
            .status = 7,
        },
        .{
            .name = "exit without operands in nested trap uses nested pre-trap status",
            .script =
            \\trap exit INT
            \\trap 'true; kill -s INT $$' EXIT
            \\false
            ,
            .stdout = "",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "EXIT signal name is equivalent to signal number zero",
            .script =
            \\trap 'printf "%s\n" exit-name' EXIT
            \\printf '%s\n' body
            ,
            .stdout =
            \\body
            \\exit-name
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap action expansion error exits before following commands",
            .script =
            \\trap 'echo ${missing:?need}' TERM
            \\kill -TERM $$
            \\echo after
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "trap action command substitution parse error exits before following commands",
            .script =
            \\trap 'echo "$(for do echo; done)"; echo trap-after' TERM
            \\kill -TERM $$
            \\echo after
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "pending trap preserves semantic output around inherited external output",
            .script =
            \\trap 'printf "trap-before\n"; cat <<EOF
            \\trap-external
            \\EOF
            \\printf "trap-after\n"' TERM
            \\kill -TERM $$
            \\printf 'after\n'
            ,
            .stdout =
            \\trap-before
            \\trap-external
            \\trap-after
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pending trap runs before next command inside loop body",
            .script =
            \\trap 'printf "trap\n"' TERM
            \\for word in a b
            \\do
            \\    kill -TERM $$
            \\    printf 'body:%s\n' "$word"
            \\done
            ,
            .stdout =
            \\trap
            \\body:a
            \\trap
            \\body:b
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "pending USR1 trap uses the platform signal number",
            .script =
            \\trap 'printf "trap\n"' USR1
            \\kill -USR1 $$
            \\printf 'after\n'
            ,
            .stdout =
            \\trap
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap action special builtin error exits before following commands",
            .script =
            \\trap 'set -o bad@option' INT
            \\kill -s INT $$
            \\printf 'after:%s\n' "$?"
            ,
            .stdout = "",
            .stderr_match = .nonempty,
            .status_match = .nonzero,
        },
        .{
            .name = "signal to shell pid from command substitution terminates shell",
            .script =
            \\out=$(trap 'printf trap; exit' ALRM; kill -s ALRM $$; printf bad)
            \\printf 'out=<%s> status=%s\n' "$out" "$?"
            ,
            .stdout = "",
            .stderr = "",
            .status = 142,
        },
        .{
            .name = "trap and kill accept standard symbolic signal names",
            .script =
            \\trap 'printf bad' KILL
            \\printf 'trap-kill:%s\n' "$?"
            \\trap '' PIPE
            \\printf 'trap-pipe:%s\n' "$?"
            \\sleep 10 & pid=$!
            \\kill -TSTP "$pid"
            \\printf 'kill-tstp:%s\n' "$?"
            \\kill -CONT "$pid" 2>/dev/null
            \\kill -TERM "$pid" 2>/dev/null
            \\wait "$pid" 2>/dev/null
            \\exit 0
            ,
            .stdout =
            \\trap-kill:0
            \\trap-pipe:0
            \\kill-tstp:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "kill accepts case-insensitive symbolic signal names",
            .script =
            \\sleep 10 & pid=$!
            \\kill -s term "$pid"
            \\printf 'kill-term:%s\n' "$?"
            \\wait "$pid" 2>/dev/null
            \\exit 0
            ,
            .stdout =
            \\kill-term:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap and kill list common extended signal names",
            .script =
            \\trap : VTALRM
            \\printf 'trap-vtalrm:%s\n' "$?"
            \\trap - VTALRM
            \\kill -l 26
            ,
            .stdout =
            \\trap-vtalrm:0
            \\VTALRM
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell EXIT trap registered inside trap action runs once",
            .script =
            \\trap '(trap "echo nested" EXIT; :)' EXIT
            ,
            .stdout =
            \\nested
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap registered inside loop catches later signal in same body",
            .script =
            \\for word in once
            \\do
            \\    trap 'printf "trap:%s\n" "$word"' TERM
            \\    kill -TERM $$
            \\    printf 'body:%s\n' "$word"
            \\done
            ,
            .stdout =
            \\trap:once
            \\body:once
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell EXIT trap runs before the subshell status is observed",
            .script =
            \\( trap 'printf "trap:%s\n" "$?"' EXIT; exit 3 )
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\trap:3
            \\status:3
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell EXIT trap observes subshell redirections",
            .script =
            \\( trap 'printf bad' EXIT ) >/dev/null
            \\printf 'after\n'
            ,
            .stdout =
            \\after
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshells reset caught EXIT traps inherited from the parent",
            .script =
            \\trap 'printf "parent\n"' EXIT
            \\( : )
            \\printf 'after\n'
            ,
            .stdout =
            \\after
            \\parent
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap listing in subshell reports entry traps until changed",
            .script =
            \\trap 'printf "parent\n"' EXIT
            \\(trap)
            \\(trap 'printf "child\n"' EXIT; trap)
            \\(trap)
            ,
            .stdout =
            \\trap -- 'printf "parent\n"' EXIT
            \\trap -- 'printf "child\n"' EXIT
            \\child
            \\trap -- 'printf "parent\n"' EXIT
            \\parent
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "subshell EXIT trap action mutates only the subshell environment",
            .script =
            \\x=outer
            \\( trap 'x=inner; printf "trap:%s\n" "$x"' EXIT; : )
            \\printf 'x:%s\n' "$x"
            ,
            .stdout =
            \\trap:inner
            \\x:outer
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "background subshell trap overrides inherited asynchronous signal ignore",
            .script =
            \\( trap 'printf "got INT\n"' INT
            \\  trap - QUIT
            \\  child_pid=$(sh -c 'printf "%s\n" "$PPID"')
            \\  kill -s INT "$child_pid" || exit 4
            \\  printf 'after INT\n'
            \\  kill -s QUIT "$child_pid" || exit 2
            \\  exit 0 ) &
            \\wait $!
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\got INT
            \\after INT
            \\status:131
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "background subshell dollar bang names the executing subshell process",
            .script =
            \\(
            \\    child_pid=$(PATH=/usr/bin:/bin exec sh -c 'echo $PPID')
            \\    printf '%s\n' "$child_pid" >child-pid
            \\) &
            \\background_pid=$!
            \\wait
            \\if [ "$background_pid" = "$(cat child-pid)" ]; then
            \\    printf '<same>\n'
            \\else
            \\    printf '<diff>\n'
            \\fi
            ,
            .stdout =
            \\<same>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "background subshell can reset QUIT and be signaled by dollar bang while waiting",
            .script =
            \\( trap - QUIT; printf '<sleep>\n'; sleep 10; printf '<awake>\n' ) &
            \\pid=$!
            \\sleep 1
            \\kill -QUIT "$pid"
            \\wait "$pid"
            \\status=$?
            \\if [ "$status" -ge 128 ]; then printf '<signal>\n'; else printf '<%s>\n' "$status"; fi
            ,
            .stdout =
            \\<sleep>
            \\<signal>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "command substitution EXIT trap honors scoped exec stderr merge",
            .script =
            \\v=$(exec 2>&1; trap 'printf trap >&2' EXIT; :)
            \\printf '<%s>\n' "$v"
            ,
            .stdout =
            \\<trap>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "command substitution EXIT trap preserves descriptor swap routing",
            .script =
            \\v=$(exec 3>&1 1>&2 2>&3; trap 'printf out; printf err >&2' EXIT; :)
            \\printf '<%s>\n' "$v"
            ,
            .stdout =
            \\<err>
            \\
            ,
            .stderr = "out",
            .status = 0,
        },
        .{
            .name = "subshell EXIT trap in command substitution does not leak to outer trap",
            .script =
            \\v=$( (exec 2>&1; trap 'printf sub >&2' EXIT; :); trap 'printf outer >&2' EXIT; : )
            \\printf '<%s>\n' "$v"
            ,
            .stdout =
            \\<sub>
            \\
            ,
            .stderr = "outer",
            .status = 0,
        },
        .{
            .name = "aliases defined inside an EXIT trap do not affect its remaining action",
            .script =
            \\trap 'alias late="printf late\\n"; late 2>/dev/null; printf "status:%s\n" "$?"' EXIT
            \\:
            ,
            .stdout =
            \\status:127
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap dash resets the EXIT trap to its default action",
            .script =
            \\trap 'printf "%s\n" bad' 0
            \\trap - 0
            \\printf '%s\n' body
            ,
            .stdout =
            \\body
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "a later trap action replaces an earlier EXIT trap",
            .script =
            \\trap 'printf "%s\n" first' 0
            \\trap 'printf "%s\n" second' 0
            \\printf '%s\n' body
            ,
            .stdout =
            \\body
            \\second
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap with no operands lists caught signals in reusable form",
            .script =
            \\trap 'printf term\n' TERM
            \\trap
            ,
            .stdout =
            \\trap -- 'printf term\n' TERM
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap dash resets a caught signal to its default action",
            .script =
            \\trap 'printf bad\n' TERM
            \\trap - TERM
            \\trap
            \\printf '<done>\n'
            ,
            .stdout =
            \\<done>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap returns zero for valid trap changes",
            .script =
            \\trap 'printf term\n' TERM
            \\printf '<%s>\n' "$?"
            \\trap - TERM
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<0>
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap accepts ALRM signal name",
            .script =
            \\trap 'printf alrm\n' ALRM
            \\printf '<%s>\n' "$?"
            \\trap - ALRM
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "empty trap action ignores signal for child processes",
            .script =
            \\trap '' USR1
            \\sh -c 'kill -USR1 $$; printf survived'
            \\printf ':status:%s\n' "$?"
            \\trap - USR1
            ,
            .stdout =
            \\survived:status:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap accepts numeric ALRM signal",
            .script =
            \\trap 'printf alrm\n' 14
            \\printf '<%s>\n' "$?"
            \\trap - 14
            ,
            .stdout =
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trap returns nonzero for invalid signal names",
            .script =
            \\trap : NOSUCHSIGNAL 2>/dev/null
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\<1>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trapped signals are deferred while a foreground command completes",
            .script =
            \\trap 'printf "<trap>\n"' TERM
            \\(sleep 0.1; kill -TERM $$) &
            \\sleep 0.2
            \\printf '<after>:%s\n' "$?"
            \\wait
            ,
            .stdout =
            \\<trap>
            \\<after>:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "trapped signals interrupt wait with a status greater than 128",
            .script =
            \\trap 'printf "<trap>\n"' TERM
            \\(sleep 0.1; kill -TERM $$) &
            \\wait
            \\status=$?
            \\if [ "$status" -gt 128 ]; then printf '<interrupted>\n'; else printf '<%s>\n' "$status"; fi
            ,
            .stdout =
            \\<trap>
            \\<interrupted>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "background shell commands do not run inherited PIPE traps",
            .script =
            \\tmp=$(mktemp -d "${TMPDIR:-/tmp}/rush-pipe.XXXXXX") || exit 2
            \\mkfifo "$tmp/p" || exit 2
            \\trap 'rm -rf "$tmp"; printf pipe-trap' PIPE
            \\{ while :; do printf x || exit; done >"$tmp/p"; } &
            \\pid=$!
            \\dd bs=1 count=1 <"$tmp/p" >/dev/null 2>&1
            \\wait "$pid" 2>/dev/null
            \\[ -d "$tmp" ] && printf 'exists\n' || printf 'missing\n'
            \\rm -rf "$tmp"
            \\trap - PIPE
            ,
            .stdout =
            \\exists
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "asynchronous commands inherit ignored SIGINT when job control is disabled",
            .script =
            \\sh -c 'kill -INT $$; printf "<survived>\n"' &
            \\wait
            \\printf '<wait>:%s\n' "$?"
            ,
            .stdout =
            \\<survived>
            \\<wait>:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "asynchronous commands inherit ignored SIGQUIT when job control is disabled",
            .script =
            \\sh -c 'kill -QUIT $$; printf "<survived>\n"' &
            \\wait
            \\printf '<wait>:%s\n' "$?"
            ,
            .stdout =
            \\<survived>
            \\<wait>:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "assignment-prefixed exec in background command substitution sees live subshell parent",
            .script =
            \\(
            \\    parent=$(PATH=/usr/bin:/bin exec sh -c 'echo $PPID')
            \\    if kill -0 "$parent" 2>/dev/null; then
            \\        printf '<live>\n'
            \\    else
            \\        printf '<dead>:%s\n' "$parent"
            \\    fi
            \\) &
            \\wait
            ,
            .stdout =
            \\<live>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "foreground subshell can be terminated by a descendant-reported parent pid",
            .script =
            \\{
            \\    (
            \\        parent=$(PATH=/usr/bin:/bin exec sh -c 'echo $PPID')
            \\        kill -KILL "$parent"
            \\    ) && :
            \\} 2>/dev/null
            \\status=$?
            \\printf '<%s>\n' "$(( ($status >= 128) ? ($status % 128 + 128) : $status ))"
            ,
            .stdout =
            \\<137>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
