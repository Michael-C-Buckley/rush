.{
    .name = "2.7 Redirection",
    .mode = .posix,
    .cases = .{
        .{
            .name = "output redirection creates and truncates the target file",
            .script =
            \\printf '%s\n' old >out
            \\printf '%s\n' new >out
            \\cat out
            ,
            .stdout =
            \\new
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "append redirection appends to the target file",
            .script =
            \\printf '%s\n' first >out
            \\printf '%s\n' second >>out
            \\cat out
            ,
            .stdout =
            \\first
            \\second
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "input redirection supplies standard input",
            .script =
            \\printf '%s\n' input >in
            \\cat <in
            ,
            .stdout =
            \\input
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "input-output redirection opens a file for reading and writing",
            .script =
            \\printf '%s\n' old >rw
            \\printf '%s\n' new 1<>rw
            \\cat rw
            ,
            .stdout =
            \\new
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "input-output redirection supplies standard input",
            .script =
            \\printf 'abc' >rw
            \\cat <>rw
            \\printf '\n'
            ,
            .stdout =
            \\abc
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "input-output redirection creates a missing file",
            .script =
            \\: <>rw
            \\test -f rw && printf 'created\n'
            ,
            .stdout =
            \\created
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "redirection without a command is performed in the current environment",
            .script =
            \\: >created
            \\test -f created && printf 'created\n'
            ,
            .stdout =
            \\created
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "explicit io number redirects standard error",
            .script =
            \\{ printf 'out\n'; printf 'err\n' >&2; } 2>err
            \\printf 'after\n'
            \\cat err
            ,
            .stdout =
            \\out
            \\after
            \\err
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "quoted io number is not recognized as a redirection prefix",
            .script =
            \\\2>out
            \\test -e out && printf 'created\n'
            ,
            .stdout =
            \\created
            \\
            ,
            .stderr = "",
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "quoted redirection operator is passed as an argument",
            .script =
            \\printf '%s\n' 2\>out
            \\test ! -e out && printf 'no-file\n'
            ,
            .stdout =
            \\2>out
            \\no-file
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "redirections are evaluated left to right when stdout is redirected before stderr duplication",
            .script =
            \\{ printf '%s\n' out; printf '%s\n' err >&2; } >both 2>&1
            \\cat both
            ,
            .stdout =
            \\out
            \\err
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "redirections are evaluated left to right when stderr is duplicated before stdout redirect",
            .script =
            \\{ printf '%s\n' out; printf '%s\n' err >&2; } 2>&1 >out
            \\cat out
            ,
            .stdout =
            \\err
            \\out
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "duplicate redirection from a closed source descriptor fails before command execution",
            .script =
            \\exec 3>&2 2>&-
            \\printf bad >&2
            \\status=$?
            \\exec 2>&3 3>&-
            \\if [ "$status" -ne 0 ]; then printf '<nonzero>\n'; fi
            ,
            .stdout =
            \\<nonzero>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "compound duplicate redirection fails when an earlier redirection closed the source",
            .script =
            \\{ printf out; printf err >&2; } 1>&- 2>&1
            \\status=$?
            \\if [ "$status" -ne 0 ]; then printf '<nonzero>\n'; fi
            ,
            .stdout =
            \\<nonzero>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "self-duplicate redirection from a closed descriptor is a no-op",
            .script =
            \\exec 3>&1 1>&-
            \\printf '' 1>&1
            \\status=$?
            \\exec 1>&3 3>&-
            \\if [ "$status" -eq 0 ]; then printf '<zero>\n'; fi
            ,
            .stdout =
            \\<zero>
            \\
            ,
            .stderr_match = .any,
            .status = 0,
        },
        .{
            .name = "redirection word expansion does not perform field splitting",
            .script =
            \\name='a b'
            \\printf data >$name
            \\cat 'a b'
            ,
            .stdout = "data",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "redirection word expansion does not perform pathname expansion",
            .script =
            \\touch literal other
            \\name='*'
            \\printf data >$name
            \\cat '*'
            ,
            .stdout = "data",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "redirection word expansion performs command substitution",
            .script =
            \\printf data >$(printf out)
            \\cat out
            ,
            .stdout = "data",
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "input redirection failure makes the command fail",
            .script = "cat <missing",
            .stdout = "",
            .stderr = "",
            .stderr_match = .nonempty,
            .status = 0,
            .status_match = .nonzero,
        },
        .{
            .name = "noclobber prevents output redirection from replacing an existing file",
            .script =
            \\set -C
            \\printf old >out
            \\if printf new >out; then printf 'replaced\n'; else printf 'failed\n'; fi
            \\cat out
            ,
            .stdout =
            \\failed
            \\old
            ,
            .stderr = "",
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "clobber redirection overrides noclobber",
            .script =
            \\set -C
            \\printf old >out
            \\printf new >|out
            \\printf 'status:%s\n' "$?"
            \\cat out
            ,
            .stdout =
            \\status:0
            \\new
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "input duplication reads from the duplicated descriptor",
            .script =
            \\printf 'abc' >in
            \\cat 3<in <&3
            \\printf '\n'
            ,
            .stdout =
            \\abc
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "output duplication writes to the duplicated descriptor",
            .script =
            \\printf 'via3\n' 3>&1 >&3
            ,
            .stdout =
            \\via3
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "closing an unopened output descriptor succeeds",
            .script =
            \\: 9>&-
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\status:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "external pipeline stage with closed stdout reports command failure",
            .script =
            \\printf x | cat >&-
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\status:1
            \\
            ,
            .stderr_match = .nonempty,
            .status = 0,
        },
        .{
            .name = "external pipeline stage can redirect stdout to a file",
            .script =
            \\printf x | cat >out
            \\cat out
            \\printf 'status:%s\n' "$?"
            ,
            .stdout =
            \\xstatus:0
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "external pipeline stage can redirect stderr in a longer pipeline",
            .script =
            \\printf x | cat 2>/dev/null | wc -c
            ,
            .stdout =
            \\       1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "input duplication can close standard input",
            .script = "cat <&-",
            .stdout = "",
            .stderr = "",
            .stderr_match = .nonempty,
            .status = 0,
            .status_match = .nonzero,
        },
        .{
            .name = "here document supplies input after standard input is closed",
            .script =
            \\exec 0<&-
            \\cat <<EOF
            \\hi
            \\EOF
            \\printf '<%s>\n' "$?"
            ,
            .stdout =
            \\hi
            \\<0>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document can be combined with output redirection",
            .script =
            \\cat >out <<EOF
            \\hi
            \\EOF
            \\cat out
            ,
            .stdout =
            \\hi
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document body expands when delimiter is unquoted",
            .script =
            \\x=value
            \\cat <<EOF
            \\<$x>
            \\<$(printf command)>
            \\EOF
            ,
            .stdout =
            \\<value>
            \\<command>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "multiple here documents are supplied in redirection order",
            .script =
            \\cat <<A <<B
            \\one
            \\A
            \\two
            \\B
            ,
            .stdout =
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document backslash quotes dollar backquote and backslash",
            .script = "cat <<EOF\n\\$HOME\n\\`echo bad\\`\n\\\\slash\nEOF\n",
            .stdout =
            \\$HOME
            \\`echo bad`
            \\\slash
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document dash strips leading tabs",
            .script = "cat <<-EOF\n\tone\n\t\ttwo\nEOF\n",
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document body does not expand when delimiter is quoted",
            .script =
            \\x=value
            \\cat <<'EOF'
            \\<$x>
            \\EOF
            ,
            .stdout =
            \\<$x>
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document feeds a simple pipeline stage",
            .script =
            \\cat <<EOF | cat
            \\hello
            \\EOF
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document feeds an and-or list command",
            .script =
            \\cat <<EOF && echo yes
            \\hello
            \\EOF
            ,
            .stdout =
            \\hello
            \\yes
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "multiple here documents feed separate and-or list commands",
            .script =
            \\cat <<A && cat <<B
            \\one
            \\A
            \\two
            \\B
            ,
            .stdout =
            \\one
            \\two
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document feeds a case arm command",
            .script =
            \\case x in x) cat <<EOF ;; esac
            \\hello
            \\EOF
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document feeds a subshell pipeline stage",
            .script =
            \\( cat <<EOF ) | cat
            \\hello
            \\EOF
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "compound pipeline stages keep separate here documents",
            .script =
            \\( cat <<A ) | { read x; cat <<B; printf '%s\n' "$x"; }
            \\left
            \\A
            \\right
            \\B
            ,
            .stdout =
            \\right
            \\left
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document feeds a function body command before same-line invocation",
            .script =
            \\f() { cat <<EOF; }; f
            \\hello
            \\EOF
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document feeds a loop body command",
            .script =
            \\for i in 1; do cat <<EOF; done
            \\hello
            \\EOF
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document inside loop body is not executed as source",
            .script =
            \\i=0
            \\while [ "$i" -lt 2 ]; do
            \\  cat <<EOF
            \\body-$i
            \\EOF
            \\  i=$((i+1))
            \\done
            ,
            .stdout =
            \\body-0
            \\body-1
            \\
            ,
            .stderr = "",
            .status = 0,
        },
        .{
            .name = "here document feeds a brace group body command",
            .script =
            \\{ cat <<EOF; }
            \\hello
            \\EOF
            ,
            .stdout =
            \\hello
            \\
            ,
            .stderr = "",
            .status = 0,
        },
    },
}
